<!-- Commission Payout Modal (shared across Main Agent / Affiliate / Ambassador pay actions) -->
<div class="modal fade" id="commissionPayoutModal" tabindex="-1" aria-labelledby="commissionPayoutModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content payout-modal-content">
      <div class="modal-header payout-modal-header">
        <h5 class="modal-title" id="commissionPayoutModalLabel">
          <i class="bi bi-credit-card-2-front-fill me-2"></i>
          Pay <span id="payoutModalLabel">Commission</span>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="commissionPayoutForm">
        <div class="modal-body">
          <div id="payoutModalAlert" class="alert alert-danger py-2 d-none" role="alert"></div>

          <div class="mb-3">
            <label class="form-label fw-bold">Amount</label>
            <div class="input-group">
              <span class="input-group-text">Rs.</span>
              <input type="number" step="0.01" min="0" class="form-control" id="payoutAmount" name="amount" required>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Transaction ID <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="payoutTransactionId" name="transaction_id" placeholder="e.g. TXN123456" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Payout Date</label>
            <input type="date" class="form-control" id="payoutDate" name="paid_date">
          </div>

          <div class="mb-0">
            <label class="form-label fw-bold">Notes</label>
            <textarea class="form-control" id="payoutNotes" name="notes" rows="2" placeholder="Optional remarks"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn payout-submit-btn text-white">
            <i class="bi bi-check-circle me-1"></i>Confirm Payout
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
(function() {
  var modalEl = document.getElementById('commissionPayoutModal');
  if (!modalEl || modalEl.dataset.payoutModalInitialized) return;
  modalEl.dataset.payoutModalInitialized = 'true';

  var form = document.getElementById('commissionPayoutForm');
  var labelEl = document.getElementById('payoutModalLabel');
  var amountInput = document.getElementById('payoutAmount');
  var txnInput = document.getElementById('payoutTransactionId');
  var dateInput = document.getElementById('payoutDate');
  var notesInput = document.getElementById('payoutNotes');
  var alertBox = document.getElementById('payoutModalAlert');
  var submitBtn = form.querySelector('.payout-submit-btn');
  var defaultBtnHtml = submitBtn.innerHTML;

  var currentUrl = null;
  var currentPolicyType = null;

  modalEl.addEventListener('show.bs.modal', function(event) {
    var trigger = event.relatedTarget;
    if (!trigger) return;

    currentUrl = trigger.getAttribute('data-payout-url');
    currentPolicyType = trigger.getAttribute('data-policy-type');
    var payoutType = trigger.getAttribute('data-payout-type');

    labelEl.textContent = trigger.getAttribute('data-payout-label') || 'Commission';
    amountInput.value = parseFloat(trigger.getAttribute('data-amount') || 0).toFixed(2);
    amountInput.readOnly = (payoutType === 'main_agent');
    txnInput.value = '';
    dateInput.value = new Date().toISOString().split('T')[0];
    notesInput.value = '';
    alertBox.classList.add('d-none');
    alertBox.textContent = '';
    submitBtn.disabled = false;
    submitBtn.innerHTML = defaultBtnHtml;
  });

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    if (!currentUrl) return;

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Processing...';
    alertBox.classList.add('d-none');

    var payload = {
      amount: amountInput.value,
      transaction_id: txnInput.value,
      paid_date: dateInput.value,
      notes: notesInput.value,
      policy_type: currentPolicyType
    };

    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var csrfToken = csrfMeta ? csrfMeta.content : '';

    fetch(currentUrl, {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-CSRF-Token': csrfToken
      },
      credentials: 'same-origin',
      body: JSON.stringify(payload)
    })
      .then(function(res) {
        return res.json().then(function(data) { return { ok: res.ok, data: data }; });
      })
      .then(function(result) {
        if (result.ok && result.data.success) {
          submitBtn.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Paid!';
          setTimeout(function() { window.location.reload(); }, 500);
        } else {
          alertBox.textContent = (result.data && result.data.message) || 'Payment failed. Please try again.';
          alertBox.classList.remove('d-none');
          submitBtn.disabled = false;
          submitBtn.innerHTML = defaultBtnHtml;
        }
      })
      .catch(function() {
        alertBox.textContent = 'Something went wrong. Please try again.';
        alertBox.classList.remove('d-none');
        submitBtn.disabled = false;
        submitBtn.innerHTML = defaultBtnHtml;
      });
  });
})();
</script>

<!-- Distribution Settlement Modal (Affiliate Pay cascades to Ambassador / Investor / Company) -->
<div class="modal fade" id="distributionSettleModal" tabindex="-1" aria-labelledby="distributionSettleModalLabel" aria-hidden="true" data-bs-backdrop="static">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content payout-modal-content">
      <div class="modal-header settle-modal-header">
        <h5 class="modal-title" id="distributionSettleModalLabel">
          <i class="bi bi-lightning-charge-fill me-2"></i>Settle Distribution Payouts
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" id="settleModalCloseBtn"></button>
      </div>

      <!-- Step 1: Confirmation -->
      <div id="settleConfirmStep">
        <div class="modal-body">
          <p class="settle-intro mb-3">
            Paying the <strong>Affiliate</strong> commission will also clear the remaining payouts below for this
            policy. Please review the amounts before confirming:
          </p>
          <div class="settle-item-list mb-2">
            <div class="settle-item-row">
              <span class="label"><span class="settle-icon-badge"><i class="bi bi-people-fill"></i></span>Affiliate</span>
              <span class="amount" id="settleAffAmount">Rs. 0.00</span>
            </div>
            <div class="settle-item-row">
              <span class="label"><span class="settle-icon-badge"><i class="bi bi-award-fill"></i></span>Ambassador</span>
              <span class="amount" id="settleAmbAmount">Rs. 0.00</span>
            </div>
            <div class="settle-item-row">
              <span class="label"><span class="settle-icon-badge"><i class="bi bi-graph-up-arrow"></i></span>Investor</span>
              <span class="amount" id="settleInvAmount">Rs. 0.00</span>
            </div>
            <div class="settle-item-row">
              <span class="label"><span class="settle-icon-badge"><i class="bi bi-building"></i></span>Company</span>
              <span class="amount" id="settleCompAmount">Rs. 0.00</span>
            </div>
            <div class="settle-item-row total-row">
              <span class="label">Total to Settle</span>
              <span class="amount" id="settleTotalAmount">Rs. 0.00</span>
            </div>
          </div>
          <div id="settleConfirmAlert" class="alert alert-danger py-2 mt-2 d-none" role="alert"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn settle-confirm-btn" id="settleConfirmBtn">
            <i class="bi bi-check2-circle me-1"></i>Confirm &amp; Pay All
          </button>
        </div>
      </div>

      <!-- Step 2: Progress -->
      <div id="settleProgressStep" class="d-none">
        <div class="modal-body settle-progress-wrap">
          <div class="settle-progress-circle">
            <svg viewBox="0 0 120 120">
              <defs>
                <linearGradient id="settleGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#11998e" />
                  <stop offset="100%" stop-color="#38ef7d" />
                </linearGradient>
              </defs>
              <circle class="bg-ring" cx="60" cy="60" r="52"></circle>
              <circle class="fg-ring" id="settleProgressRing" cx="60" cy="60" r="52"></circle>
            </svg>
            <div class="settle-progress-pct" id="settleProgressPct">0%</div>
          </div>
          <div class="settle-progress-status" id="settleProgressStatus">Starting settlement...</div>
        </div>
      </div>

      <!-- Step 3: Success -->
      <div id="settleSuccessStep" class="d-none">
        <div class="modal-body settle-progress-wrap">
          <div class="settle-success-check"><i class="bi bi-check-circle-fill"></i></div>
          <div class="settle-progress-status mt-2">All payouts settled successfully!</div>
          <div class="text-muted small mt-1">Refreshing the page...</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var modalEl = document.getElementById('distributionSettleModal');
  if (!modalEl || modalEl.dataset.settleModalInitialized) return;
  modalEl.dataset.settleModalInitialized = 'true';

  var confirmStep  = document.getElementById('settleConfirmStep');
  var progressStep = document.getElementById('settleProgressStep');
  var successStep  = document.getElementById('settleSuccessStep');
  var confirmBtn   = document.getElementById('settleConfirmBtn');
  var closeBtn     = document.getElementById('settleModalCloseBtn');
  var alertBox     = document.getElementById('settleConfirmAlert');

  var ring = document.getElementById('settleProgressRing');
  var pctLabel = document.getElementById('settleProgressPct');
  var statusLabel = document.getElementById('settleProgressStatus');
  var radius = 52;
  var circumference = 2 * Math.PI * radius;
  ring.style.strokeDasharray = circumference;
  ring.style.strokeDashoffset = circumference;

  var currentUrl = null;
  var currentPolicyType = null;
  var progressTimer = null;

  function formatRs(value) {
    var n = parseFloat(value || 0);
    return 'Rs. ' + n.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function setProgress(pct, label) {
    var offset = circumference - (pct / 100) * circumference;
    ring.style.strokeDashoffset = offset;
    pctLabel.textContent = pct + '%';
    if (label) statusLabel.textContent = label;
  }

  function resetModal() {
    confirmStep.classList.remove('d-none');
    progressStep.classList.add('d-none');
    successStep.classList.add('d-none');
    confirmBtn.disabled = false;
    confirmBtn.innerHTML = '<i class="bi bi-check2-circle me-1"></i>Confirm &amp; Pay All';
    alertBox.classList.add('d-none');
    alertBox.textContent = '';
    setProgress(0, 'Starting settlement...');
    if (progressTimer) { clearInterval(progressTimer); progressTimer = null; }
  }

  modalEl.addEventListener('show.bs.modal', function(event) {
    var trigger = event.relatedTarget;
    if (!trigger) return;

    currentUrl = trigger.getAttribute('data-settle-url');
    currentPolicyType = trigger.getAttribute('data-policy-type');

    document.getElementById('settleAffAmount').textContent  = formatRs(trigger.getAttribute('data-aff-amount'));
    document.getElementById('settleAmbAmount').textContent  = formatRs(trigger.getAttribute('data-amb-amount'));
    document.getElementById('settleInvAmount').textContent  = formatRs(trigger.getAttribute('data-inv-amount'));
    document.getElementById('settleCompAmount').textContent = formatRs(trigger.getAttribute('data-comp-amount'));
    document.getElementById('settleTotalAmount').textContent = formatRs(trigger.getAttribute('data-total-amount'));

    resetModal();
  });

  var settleStages = [
    { pct: 15, label: 'Clearing Affiliate payout...' },
    { pct: 40, label: 'Clearing Ambassador payout...' },
    { pct: 65, label: 'Clearing Investor payout...' },
    { pct: 90, label: 'Clearing Company payout...' }
  ];

  confirmBtn.addEventListener('click', function() {
    if (!currentUrl) return;

    confirmBtn.disabled = true;
    closeBtn.style.display = 'none';
    alertBox.classList.add('d-none');

    confirmStep.classList.add('d-none');
    progressStep.classList.remove('d-none');

    var stageIndex = 0;
    setProgress(0, 'Starting settlement...');

    progressTimer = setInterval(function() {
      if (stageIndex < settleStages.length) {
        setProgress(settleStages[stageIndex].pct, settleStages[stageIndex].label);
        stageIndex++;
      } else {
        clearInterval(progressTimer);
        progressTimer = null;
      }
    }, 450);

    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var csrfToken = csrfMeta ? csrfMeta.content : '';

    fetch(currentUrl, {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-CSRF-Token': csrfToken
      },
      credentials: 'same-origin',
      body: JSON.stringify({ policy_type: currentPolicyType })
    })
      .then(function(res) {
        return res.json().then(function(data) { return { ok: res.ok, data: data }; });
      })
      .then(function(result) {
        if (progressTimer) { clearInterval(progressTimer); progressTimer = null; }

        if (result.ok && result.data.success) {
          setProgress(100, 'Done!');
          setTimeout(function() {
            progressStep.classList.add('d-none');
            successStep.classList.remove('d-none');
            setTimeout(function() { window.location.reload(); }, 900);
          }, 350);
        } else {
          progressStep.classList.add('d-none');
          confirmStep.classList.remove('d-none');
          closeBtn.style.display = '';
          confirmBtn.disabled = false;
          alertBox.textContent = (result.data && result.data.message) || 'Settlement failed. Please try again.';
          alertBox.classList.remove('d-none');
        }
      })
      .catch(function() {
        if (progressTimer) { clearInterval(progressTimer); progressTimer = null; }
        progressStep.classList.add('d-none');
        confirmStep.classList.remove('d-none');
        closeBtn.style.display = '';
        confirmBtn.disabled = false;
        alertBox.textContent = 'Something went wrong. Please try again.';
        alertBox.classList.remove('d-none');
      });
  });
})();
</script>
