<% return unless policy.respond_to?(:drwise_policy?) && policy.drwise_policy? %>
<%
  _main_pct   = (policy.try(:main_agent_commission_percentage) || 0).to_f
  _sub_pct    = (policy.try(:sub_agent_commission_percentage)   || 0).to_f
  _amb_pct    = (policy.try(:ambassador_commission_percentage)  || 0).to_f
  _inv_pct    = (policy.try(:investor_commission_percentage)    || 0).to_f
  _exp_pct    = (policy.try(:company_expenses_percentage)       || 0).to_f
  _net        = (policy.try(:net_premium)                       || 0).to_f
  _total_dist = _sub_pct + _amb_pct + _inv_pct
  _profit_pct = _main_pct - _total_dist - _exp_pct
  _profit_amt = _net * _profit_pct / 100.0

  _policy_type = policy.class.name.underscore.gsub('_insurance', '')
  _ct_url      = admin_commission_tracking_path(policy.id, policy_type: _policy_type)

  _payouts = CommissionPayout.where(policy_type: _policy_type, policy_id: policy.id)
                             .index_by(&:payout_to)
  _main_payout = _payouts['main_agent']
  _aff_payout  = _payouts['affiliate']
  _amb_payout  = _payouts['ambassador']
  _inv_payout  = _payouts['investor']
  _comp_payout = _payouts['company_expense']

  _main_agent_paid = _main_payout&.status == 'paid'

  _aff_amount  = (policy.try(:sub_agent_after_tds_value) || 0).to_f
  _amb_amount  = (policy.try(:ambassador_after_tds_value) || policy.try(:ambassador_commission_amount) || 0).to_f
  _inv_amount  = (policy.try(:investor_after_tds_value) || policy.try(:investor_commission_amount) || 0).to_f
  _comp_amount = (policy.try(:company_expenses_amount) || 0).to_f
  _distribution_total = _aff_amount + _amb_amount + _inv_amount + _comp_amount
%>
<!-- Commission Calculation Table for View Pages -->
<div class="card mb-4 shadow-sm commission-table">
  <div class="card-header" style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h5 class="mb-0 text-dark fw-bold">
          <i class="bi bi-calculator me-2 text-primary"></i>
          Commission Calculation
        </h5>
      </div>
      <div class="text-end">
        <small class="text-muted fw-bold">Profit Formula:</small>
        <div class="badge bg-light text-dark border" style="font-size: 0.8rem;">
          Main Agent Commission - Total Distribution - Company Expenses
        </div>
      </div>
    </div>
  </div>
  <div class="card-body p-0">
    <!-- Commission Table -->
    <div class="table-responsive">
      <table class="table mb-0" style="font-size: 0.95rem;">
        <thead style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
          <tr>
            <th class="py-3 px-4 fw-bold text-dark border-0" style="width: 16%;">COMMISSION DETAILS</th>
            <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 10%;">(%)</th>
            <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 14%;">COMMISSION</th>
            <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 10%;">TDS (%)</th>
            <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 13%;">TDS AMOUNT</th>
            <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 19%; background: #f8f9fa;">ACTUAL AMOUNT</th>
            <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 18%; background: #eef2ff;">PAYOUT STATUS</th>
          </tr>
        </thead>
        <tbody>
          <!-- Main Agent -->
          <tr style="border-bottom: 1px solid #e9ecef;">
            <td class="py-3 px-4 fw-bold text-dark bg-light">Main Agent</td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center fw-bold" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= policy.try(:main_agent_commission_percentage) || 0 %>%
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= indian_currency(policy.try(:commission_amount)) || 'Rs. 0.00' %>
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= policy.try(:tds_percentage) || 0 %>%
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= indian_currency(policy.try(:tds_amount)) || 'Rs. 0.00' %>
              </div>
            </td>
            <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
              <div class="form-control border-1 text-center fw-bold fs-6" style="background: #e8f5e8; border-color: #28a745; color: #155724;">
                <%= indian_currency(policy.try(:after_tds_value)) || 'Rs. 0.00' %>
              </div>
            </td>
            <td class="py-2 px-2 text-center" style="background: #eef2ff;">
              <% if _main_payout&.status == 'paid' %>
                <%= link_to admin_payout_path(_main_payout), class: "payout-badge payout-paid" do %>
                  <i class="bi bi-check-circle-fill me-1"></i>Paid
                <% end %>
                <div class="payout-date mt-1"><%= _main_payout.payout_date&.strftime('%d %b %Y') %></div>
              <% elsif _main_payout %>
                <span class="payout-badge payout-pending">
                  <i class="bi bi-clock me-1"></i>Pending
                </span>
                <button type="button" class="btn btn-xs-pay btn-pay mt-1" data-bs-toggle="modal" data-bs-target="#commissionPayoutModal"
                        data-payout-type="main_agent" data-payout-label="Main Agent"
                        data-payout-url="<%= mark_main_agent_commission_received_admin_commission_tracking_path(policy.id) %>"
                        data-policy-type="<%= _policy_type %>"
                        data-amount="<%= (policy.try(:after_tds_value) || 0).to_f %>">
                  <i class="bi bi-credit-card me-1"></i>Pay
                </button>
              <% else %>
                <span class="payout-badge payout-none">
                  <i class="bi bi-dash-circle me-1"></i>No Payout
                </span>
                <button type="button" class="btn btn-xs-pay btn-create mt-1" data-bs-toggle="modal" data-bs-target="#commissionPayoutModal"
                        data-payout-type="main_agent" data-payout-label="Main Agent"
                        data-payout-url="<%= mark_main_agent_commission_received_admin_commission_tracking_path(policy.id) %>"
                        data-policy-type="<%= _policy_type %>"
                        data-amount="<%= (policy.try(:after_tds_value) || 0).to_f %>">
                  <i class="bi bi-plus-circle me-1"></i>Pay
                </button>
              <% end %>
            </td>
          </tr>

          <!-- Affiliate -->
          <tr style="border-bottom: 1px solid #e9ecef;">
            <td class="py-3 px-4 fw-bold text-dark">Affiliate</td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center fw-bold" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= policy.try(:sub_agent_commission_percentage) || 0 %>%
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= indian_currency(policy.try(:sub_agent_commission_amount)) || 'Rs. 0.00' %>
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= policy.try(:sub_agent_tds_percentage) || 0 %>%
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= indian_currency(policy.try(:sub_agent_tds_amount)) || 'Rs. 0.00' %>
              </div>
            </td>
            <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
              <div class="form-control border-1 text-center fw-bold fs-6" style="background: #e3f2fd; border-color: #2196f3; color: #0d47a1;">
                <%= indian_currency(policy.try(:sub_agent_after_tds_value)) || 'Rs. 0.00' %>
              </div>
            </td>
            <td class="py-2 px-2 text-center" style="background: #eef2ff;">
              <% if _aff_payout&.status == 'paid' %>
                <%= link_to admin_payout_path(_aff_payout), class: "payout-badge payout-paid" do %>
                  <i class="bi bi-check-circle-fill me-1"></i>Paid
                <% end %>
                <div class="payout-date mt-1"><%= _aff_payout.payout_date&.strftime('%d %b %Y') %></div>
              <% elsif _aff_payout %>
                <span class="payout-badge payout-pending">
                  <i class="bi bi-clock me-1"></i>Pending
                </span>
                <button type="button" class="btn btn-xs-pay btn-pay mt-1" data-bs-toggle="modal" data-bs-target="#distributionSettleModal"
                        data-settle-url="<%= settle_distribution_payouts_admin_commission_tracking_path(policy.id) %>"
                        data-policy-type="<%= _policy_type %>"
                        data-aff-amount="<%= _aff_amount %>" data-amb-amount="<%= _amb_amount %>"
                        data-inv-amount="<%= _inv_amount %>" data-comp-amount="<%= _comp_amount %>"
                        data-total-amount="<%= _distribution_total %>"
                        <%= 'disabled title="Main Agent commission must be paid first"' unless _main_agent_paid %>>
                  <i class="bi bi-credit-card me-1"></i>Pay
                </button>
              <% else %>
                <span class="payout-badge payout-none">
                  <i class="bi bi-dash-circle me-1"></i>No Payout
                </span>
                <button type="button" class="btn btn-xs-pay btn-create mt-1" data-bs-toggle="modal" data-bs-target="#distributionSettleModal"
                        data-settle-url="<%= settle_distribution_payouts_admin_commission_tracking_path(policy.id) %>"
                        data-policy-type="<%= _policy_type %>"
                        data-aff-amount="<%= _aff_amount %>" data-amb-amount="<%= _amb_amount %>"
                        data-inv-amount="<%= _inv_amount %>" data-comp-amount="<%= _comp_amount %>"
                        data-total-amount="<%= _distribution_total %>"
                        <%= 'disabled title="Main Agent commission must be paid first"' unless _main_agent_paid %>>
                  <i class="bi bi-plus-circle me-1"></i>Pay
                </button>
              <% end %>
            </td>
          </tr>

          <!-- Ambassador -->
          <tr style="border-bottom: 1px solid #e9ecef;">
            <td class="py-3 px-4 fw-bold text-dark">Ambassador</td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center fw-bold" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= policy.try(:ambassador_commission_percentage) || 0 %>%
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= indian_currency(policy.try(:ambassador_commission_amount)) || 'Rs. 0.00' %>
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= policy.try(:ambassador_tds_percentage) || '-' %>
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= indian_currency(policy.try(:ambassador_tds_amount)) || '-' %>
              </div>
            </td>
            <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
              <div class="form-control border-1 text-center fw-bold fs-6" style="background: #fff3e0; border-color: #ff9800; color: #e65100;">
                <%= indian_currency(policy.try(:ambassador_after_tds_value) || policy.try(:ambassador_commission_amount)) || 'Rs. 0.00' %>
              </div>
            </td>
            <td class="py-2 px-2 text-center" style="background: #eef2ff;">
              <% if _amb_payout&.status == 'paid' %>
                <%= link_to admin_payout_path(_amb_payout), class: "payout-badge payout-paid" do %>
                  <i class="bi bi-check-circle-fill me-1"></i>Paid
                <% end %>
                <div class="payout-date mt-1"><%= _amb_payout.payout_date&.strftime('%d %b %Y') %></div>
              <% elsif _amb_payout %>
                <span class="payout-badge payout-pending">
                  <i class="bi bi-clock me-1"></i>Pending
                </span>
                <button type="button" class="btn btn-xs-pay btn-pay mt-1" data-bs-toggle="modal" data-bs-target="#commissionPayoutModal"
                        data-payout-type="ambassador" data-payout-label="Ambassador"
                        data-payout-url="<%= transfer_to_ambassador_admin_commission_tracking_path(policy.id) %>"
                        data-policy-type="<%= _policy_type %>"
                        data-amount="<%= (policy.try(:ambassador_after_tds_value) || policy.try(:ambassador_commission_amount) || 0).to_f %>"
                        <%= 'disabled title="Main Agent commission must be paid first"' unless _main_agent_paid %>>
                  <i class="bi bi-credit-card me-1"></i>Pay
                </button>
              <% else %>
                <span class="payout-badge payout-none">
                  <i class="bi bi-dash-circle me-1"></i>No Payout
                </span>
                <button type="button" class="btn btn-xs-pay btn-create mt-1" data-bs-toggle="modal" data-bs-target="#commissionPayoutModal"
                        data-payout-type="ambassador" data-payout-label="Ambassador"
                        data-payout-url="<%= transfer_to_ambassador_admin_commission_tracking_path(policy.id) %>"
                        data-policy-type="<%= _policy_type %>"
                        data-amount="<%= (policy.try(:ambassador_after_tds_value) || policy.try(:ambassador_commission_amount) || 0).to_f %>"
                        <%= 'disabled title="Main Agent commission must be paid first"' unless _main_agent_paid %>>
                  <i class="bi bi-plus-circle me-1"></i>Pay
                </button>
              <% end %>
            </td>
          </tr>

          <!-- Investor -->
          <tr style="border-bottom: 1px solid #e9ecef;">
            <td class="py-3 px-4 fw-bold text-dark">Investor</td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center fw-bold" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= policy.try(:investor_commission_percentage) || 0 %>%
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= indian_currency(policy.try(:investor_commission_amount)) || 'Rs. 0.00' %>
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= policy.try(:investor_tds_percentage) || '-' %>
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= indian_currency(policy.try(:investor_tds_amount)) || '-' %>
              </div>
            </td>
            <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
              <div class="form-control border-1 text-center fw-bold fs-6" style="background: #e8f5e8; border-color: #4caf50; color: #2e7d32;">
                <%= indian_currency(policy.try(:investor_after_tds_value) || policy.try(:investor_commission_amount)) || 'Rs. 0.00' %>
              </div>
            </td>
            <td class="py-2 px-2 text-center" style="background: #eef2ff;">
              <span class="text-muted" style="font-size: 0.78rem;">—</span>
            </td>
          </tr>

          <!-- Company -->
          <tr style="border-bottom: 1px solid #e9ecef;">
            <td class="py-3 px-4 fw-bold text-dark">Company</td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center fw-bold" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= policy.try(:company_expenses_percentage) || 0 %>%
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                <%= indian_currency(policy.try(:company_expenses_amount)) || 'Rs. 0.00' %>
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                -
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
                -
              </div>
            </td>
            <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
              <div class="form-control border-1 text-center fw-bold fs-6" style="background: #fce4ec; border-color: #e91e63; color: #880e4f;">
                <%= indian_currency(policy.try(:company_expenses_amount)) || 'Rs. 0.00' %>
              </div>
            </td>
            <td class="py-2 px-2 text-center" style="background: #eef2ff;">
              <span class="text-muted" style="font-size: 0.78rem;">—</span>
            </td>
          </tr>

          <!-- Profit -->
          <tr style="border-bottom: 2px solid #dee2e6; background: #fffbf0;">
            <td class="py-3 px-4 fw-bold text-dark">Profit</td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center fw-bold" style="background: #fffbf0; border-color: #ffc107; color: #856404;">
                <%= number_with_precision(_profit_pct, precision: 2) %>%
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center fw-bold" style="background: #fffbf0; border-color: #ffc107; color: #856404;">
                <%= indian_currency(_profit_amt) %>
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #fffbf0; border-color: #ffc107; color: #856404;">
                -
              </div>
            </td>
            <td class="py-2 px-1 text-center">
              <div class="form-control border-1 text-center" style="background: #fffbf0; border-color: #ffc107; color: #856404;">
                -
              </div>
            </td>
            <td class="py-2 px-1 text-center" style="background: #fffbf0;">
              <div class="form-control border-1 text-center fw-bold fs-6" style="background: #fff9c4; border-color: #ffc107; color: #856404;">
                <%= indian_currency(_profit_amt) %>
              </div>
            </td>
            <td class="py-2 px-2 text-center" style="background: #fffbf0;">
              <span class="text-muted" style="font-size: 0.78rem;">—</span>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Summary Row -->
    <div class="p-3" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); border-top: 1px solid #dee2e6;">
      <div class="row">
        <div class="col-md-3">
          <small class="text-muted fw-bold">Net Premium:</small>
          <div class="h6 mb-0 text-primary">
            <%= indian_currency(policy.try(:net_premium)) || 'Rs. 0.00' %>
          </div>
        </div>
        <div class="col-md-3">
          <small class="text-muted fw-bold">Total Distribution:</small>
          <div class="h6 mb-0 text-info">
            <%= number_with_precision(_total_dist, precision: 2) %>%
          </div>
        </div>
        <div class="col-md-3">
          <small class="text-muted fw-bold">Company Expenses:</small>
          <div class="h6 mb-0 text-danger">
            <%= number_with_precision(_exp_pct, precision: 2) %>%
          </div>
        </div>
        <div class="col-md-3">
          <small class="text-muted fw-bold">Final Profit:</small>
          <div class="h6 mb-0 text-warning">
            <%= indian_currency(_profit_amt) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .commission-table {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    overflow: hidden;
  }
  .commission-table .table td,
  .commission-table .table th {
    vertical-align: middle;
    border-color: #e9ecef;
  }
  .commission-table .form-control {
    font-size: 0.9rem;
    padding: 8px 12px;
    border-radius: 6px;
    transition: all 0.2s ease;
    border: none !important;
    box-shadow: none !important;
    margin: 0;
    font-weight: 500;
    text-align: center;
  }
  .commission-table .form-control:focus {
    outline: none !important;
    box-shadow: none !important;
  }
  .commission-table tr:hover {
    background-color: rgba(102, 126, 234, 0.03);
  }
  .commission-table tr:last-child .form-control {
    font-weight: 600 !important;
    font-size: 0.95rem !important;
  }

  /* Payout status badges */
  .payout-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }
  .payout-paid {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .payout-paid:hover {
    background: #c3e6cb;
    color: #0d3d1e;
    text-decoration: none;
  }
  .payout-pending {
    background: #fff3cd;
    color: #856404;
    border: 1px solid #ffeaa7;
  }
  .payout-none {
    background: #e9ecef;
    color: #6c757d;
    border: 1px solid #ced4da;
  }
  .payout-date {
    font-size: 0.7rem;
    color: #6c757d;
  }

  /* Pay / Create buttons */
  .btn-xs-pay {
    display: inline-flex;
    align-items: center;
    font-size: 0.72rem;
