<div class="policy-documents-manager">
  <div class="card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h5 class="mb-0">
        <i class="fas fa-file-alt me-2"></i>Policy Documents Manager
      </h5>
      <small class="text-muted">Upload, organize and manage all policy-related documents with secure storage</small>
    </div>
    <div class="card-body">

      <!-- Upload Form -->
      <form id="documentUploadForm" enctype="multipart/form-data" class="mb-4">
        <div class="row g-3">

          <!-- Document Type Selection -->
          <div class="col-md-4">
            <label class="form-label fw-bold">Document Type</label>
            <select name="document_type" class="form-select" required>
              <option value="">Select Document Type</option>
              <option value="Policy Document">Policy Document</option>
              <option value="Additional Document">Additional Document</option>
              <option value="Identity Proof">Identity Proof</option>
              <option value="Medical Report">Medical Report</option>
              <option value="RC Book">RC Book</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <!-- Document Title -->
          <div class="col-md-4">
            <label class="form-label fw-bold">Document Title</label>
            <input type="text" name="title" class="form-control" placeholder="Enter document title" required>
          </div>

          <!-- File Upload -->
          <div class="col-md-4">
            <label class="form-label fw-bold">Upload File</label>
            <input type="file" name="file" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" required>
            <small class="text-muted">Supports PDF, JPEG, PNG, Word files (Max: 10MB each)</small>
          </div>

        </div>

        <!-- Description -->
        <div class="row g-3 mt-2">
          <div class="col-12">
            <label class="form-label fw-bold">Description <span class="text-muted">(Optional)</span></label>
            <textarea name="description" class="form-control" rows="2" placeholder="Add description or notes about this document"></textarea>
          </div>
        </div>

        <!-- Upload Button -->
        <div class="row mt-3">
          <div class="col-12">
            <button type="submit" class="btn btn-primary">
              <i class="fas fa-cloud-upload-alt me-2"></i>Upload Document
            </button>
            <div class="upload-progress mt-2" style="display: none;">
              <div class="progress">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%"></div>
              </div>
            </div>
          </div>
        </div>

      </form>

      <!-- Documents List -->
      <div class="documents-section">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h6 class="mb-0">
            <i class="fas fa-folder me-2"></i>Uploaded Documents
          </h6>
          <button type="button" class="btn btn-sm btn-outline-primary" id="refreshDocuments">
            <i class="fas fa-sync-alt"></i> Refresh
          </button>
        </div>

        <!-- Loading indicator -->
        <div id="documentsLoading" class="text-center p-4" style="display: none;">
          <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
          <p class="mt-2 text-muted">Loading documents...</p>
        </div>

        <!-- Documents container -->
        <div id="documentsContainer">
          <!-- Documents will be loaded here via JavaScript -->
        </div>

        <!-- No documents message -->
        <div id="noDocumentsMessage" class="text-center p-4" style="display: none;">
          <i class="fas fa-file-circle-plus fa-3x text-muted mb-3"></i>
          <p class="text-muted">No documents uploaded yet. Use the form above to upload your first document.</p>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Document Card Template (hidden) -->
<template id="documentCardTemplate">
  <div class="document-card border rounded p-3 mb-2">
    <div class="row align-items-center">
      <div class="col-md-2 text-center">
        <i class="document-icon fas fa-3x mb-2"></i>
        <small class="d-block document-size text-muted"></small>
      </div>
      <div class="col-md-6">
        <h6 class="document-title mb-1"></h6>
        <span class="badge document-type-badge mb-2"></span>
        <p class="document-description mb-1 text-muted"></p>
        <small class="text-muted">
          Uploaded by <span class="document-uploaded-by"></span> on <span class="document-date"></span>
        </small>
      </div>
      <div class="col-md-4 text-end">
        <div class="btn-group">
          <button type="button" class="btn btn-sm btn-outline-primary view-document">
            <i class="fas fa-eye"></i> View
          </button>
          <button type="button" class="btn btn-sm btn-outline-success download-document">
            <i class="fas fa-download"></i> Download
          </button>
          <button type="button" class="btn btn-sm btn-outline-danger delete-document">
            <i class="fas fa-trash"></i> Delete
          </button>
        </div>
      </div>
    </div>
  </div>
</template>

<style>
.policy-documents-manager .document-card {
  transition: all 0.2s ease;
  background: #f8f9fa;
}

.policy-documents-manager .document-card:hover {
  background: #e9ecef;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.policy-documents-manager .document-icon.fa-file-pdf { color: #dc3545; }
.policy-documents-manager .document-icon.fa-file-image { color: #28a745; }
.policy-documents-manager .document-icon.fa-file-word { color: #007bff; }
.policy-documents-manager .document-icon.fa-file { color: #6c757d; }

.policy-documents-manager .document-type-badge.policy-document { background-color: #007bff !important; }
.policy-documents-manager .document-type-badge.additional-document { background-color: #28a745 !important; }
.policy-documents-manager .document-type-badge.identity-proof { background-color: #ffc107 !important; color: #000 !important; }
.policy-documents-manager .document-type-badge.medical-report { background-color: #dc3545 !important; }
.policy-documents-manager .document-type-badge.rc-book { background-color: #6610f2 !important; }
.policy-documents-manager .document-type-badge.other { background-color: #6c757d !important; }

.upload-progress .progress {
  height: 5px;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Get policy information from the URL or data attributes
  const policyType = '<%= policy_type if defined?(policy_type) %>';
  const policyId = '<%= policy_id if defined?(policy_id) %>';

  // Initialize the document manager only if we have valid params
  if (policyType && policyId) {
    initDocumentManager(policyType, policyId);
  }
});

function initDocumentManager(policyType, policyId) {
  const uploadForm = document.getElementById('documentUploadForm');
  const documentsContainer = document.getElementById('documentsContainer');
  const refreshBtn = document.getElementById('refreshDocuments');

  // Load existing documents
  loadDocuments();

  // Handle form submission
  uploadForm.addEventListener('submit', function(e) {
    e.preventDefault();
    uploadDocument();
  });

  // Handle refresh button
  refreshBtn.addEventListener('click', loadDocuments);

  function uploadDocument() {
    const formData = new FormData(uploadForm);

    // Add policy type and ID to form data
    formData.append('policy_type', policyType);
    formData.append('policy_id', policyId);

    const progressBar = document.querySelector('.upload-progress');
    const progressBarInner = progressBar.querySelector('.progress-bar');
    const submitBtn = uploadForm.querySelector('button[type="submit"]');

    // Show progress and disable button
    progressBar.style.display = 'block';
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Uploading...';

    // Simulate progress
    let progress = 0;
    const progressInterval = setInterval(() => {
      progress += Math.random() * 20;
      if (progress > 90) progress = 90;
      progressBarInner.style.width = progress + '%';
    }, 200);

    fetch('/admin/policy_documents', {
      method: 'POST',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      },
      body: formData
    })
    .then(response => response.json())
    .then(data => {
      clearInterval(progressInterval);
      progressBarInner.style.width = '100%';

      setTimeout(() => {
        progressBar.style.display = 'none';
        progressBarInner.style.width = '0%';
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-cloud-upload-alt me-2"></i>Upload Document';

        if (data.success) {
          showAlert('Document uploaded successfully!', 'success');
          uploadForm.reset();
          loadDocuments();
        } else {
          showAlert(data.error || 'Upload failed', 'danger');
        }
      }, 500);
    })
    .catch(error => {
      clearInterval(progressInterval);
      progressBar.style.display = 'none';
      progressBarInner.style.width = '0%';
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<i class="fas fa-cloud-upload-alt me-2"></i>Upload Document';
      showAlert('Upload failed: ' + error.message, 'danger');
    });
  }

  function loadDocuments() {
    const loading = document.getElementById('documentsLoading');
    const noDocsMessage = document.getElementById('noDocumentsMessage');

    loading.style.display = 'block';
    documentsContainer.innerHTML = '';
    noDocsMessage.style.display = 'none';

    fetch(`/admin/policy_documents/for/${policyType}/${policyId}`)
      .then(response => response.json())
      .then(data => {
        loading.style.display = 'none';

        if (data.policy_documents && data.policy_documents.length > 0) {
          displayDocuments(data.policy_documents);
        } else {
          noDocsMessage.style.display = 'block';
        }
      })
      .catch(error => {
        loading.style.display = 'none';
        showAlert('Failed to load documents: ' + error.message, 'danger');
      });
  }

  function displayDocuments(documents) {
    documents.forEach(document => {
      const card = createDocumentCard(document);
      documentsContainer.appendChild(card);
    });
  }

  function createDocumentCard(doc) {
    const template = document.getElementById('documentCardTemplate');
    const card = template.content.cloneNode(true);

    // Set document icon based on file type
    const icon = card.querySelector('.document-icon');
    if (doc.r2_content_type) {
      if (doc.r2_content_type.includes('pdf')) {
        icon.className = 'document-icon fas fa-file-pdf fa-3x mb-2';
      } else if (doc.r2_content_type.includes('image')) {
        icon.className = 'document-icon fas fa-file-image fa-3x mb-2';
      } else if (doc.r2_content_type.includes('word')) {
        icon.className = 'document-icon fas fa-file-word fa-3x mb-2';
      } else {
        icon.className = 'document-icon fas fa-file fa-3x mb-2';
      }
    }

    // Set document information
    card.querySelector('.document-title').textContent = doc.title;
    card.querySelector('.document-size').textContent = doc.document_size || '0 KB';
    card.querySelector('.document-description').textContent = doc.description || 'No description';
    card.querySelector('.document-uploaded-by').textContent = doc.uploaded_by || 'System';
    card.querySelector('.document-date').textContent = doc.created_at;

    // Set type badge
    const badge = card.querySelector('.document-type-badge');
    badge.textContent = doc.document_type;
    badge.className = `badge document-type-badge ${doc.document_type.toLowerCase().replace(/\s+/g, '-')}`;

    // Add event listeners
    const viewBtn = card.querySelector('.view-document');
    const downloadBtn = card.querySelector('.download-document');
    const deleteBtn = card.querySelector('.delete-document');

    viewBtn.addEventListener('click', () => {
      if (doc.document_url) {
        window.open(doc.document_url, '_blank');
      }
    });

    downloadBtn.addEventListener('click', () => {
      if (doc.document_url) {
        window.open(doc.document_url, '_blank');
      }
    });

    deleteBtn.addEventListener('click', () => {
      if (confirm('Are you sure you want to delete this document?')) {
        deleteDocument(doc.id);
      }
    });

    return card;
  }

  function deleteDocument(documentId) {
    fetch(`/admin/policy_documents/${documentId}`, {
      method: 'DELETE',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      }
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        showAlert('Document deleted successfully!', 'success');
        loadDocuments();
      } else {
        showAlert(data.error || 'Delete failed', 'danger');
      }
    })
    .catch(error => {
      showAlert('Delete failed: ' + error.message, 'danger');
    });
  }

  function showAlert(message, type) {
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
    alertDiv.innerHTML = `
      ${message}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;

    const container = document.querySelector('.policy-documents-manager .card-body');
    container.insertBefore(alertDiv, container.firstChild);

    // Auto dismiss after 5 seconds
    setTimeout(() => {
      if (alertDiv && alertDiv.parentNode) {
        alertDiv.remove();
      }
    }, 5000);
  }
}
</script>