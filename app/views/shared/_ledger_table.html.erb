<%# locals: ledger_entries, closing_balance, entity_name %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between">
    <div class="d-flex align-items-center gap-2">
      <i class="bi bi-journal-text text-primary fs-5"></i>
      <h5 class="mb-0">Commission Ledger</h5>
    </div>
    <div class="d-flex gap-3 align-items-center">
      <span class="badge bg-success bg-opacity-15 text-success px-3 py-2" style="font-size:13px;font-weight:700;">
        <i class="bi bi-wallet2 me-1"></i>
        Closing Balance: <%= indian_currency(closing_balance.to_f.round(2)) %>
      </span>
    </div>
  </div>

  <div class="card-body p-0">
    <% if ledger_entries.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0" style="font-size:13.5px;">
          <thead style="background:#f8fafc;">
            <tr>
              <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#64748b;padding:.7rem 1rem;white-space:nowrap;">#</th>
              <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#64748b;padding:.7rem 1rem;white-space:nowrap;">Date</th>
              <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#64748b;padding:.7rem 1rem;">Description</th>
              <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#64748b;padding:.7rem 1rem;white-space:nowrap;">Policy #</th>
              <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#64748b;padding:.7rem 1rem;">Type</th>
              <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#64748b;padding:.7rem 1rem;">Customer</th>
              <th class="text-end" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#64748b;padding:.7rem 1rem;white-space:nowrap;">Credit (+)</th>
              <th class="text-end" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#64748b;padding:.7rem 1rem;white-space:nowrap;">Debit (−)</th>
              <th class="text-end" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#64748b;padding:.7rem 1rem;white-space:nowrap;">Balance</th>
            </tr>
          </thead>
          <tbody>
            <!-- Opening Balance row -->
            <tr style="background:#f0fdf4;">
              <td style="padding:.6rem 1rem;color:#94a3b8;">—</td>
              <td style="padding:.6rem 1rem;color:#64748b;font-size:12px;">—</td>
              <td style="padding:.6rem 1rem;">
                <span class="fw-semibold text-muted">Opening Balance</span>
              </td>
              <td colspan="3" style="padding:.6rem 1rem;"></td>
              <td class="text-end" style="padding:.6rem 1rem;">—</td>
              <td class="text-end" style="padding:.6rem 1rem;">—</td>
              <td class="text-end fw-bold" style="padding:.6rem 1rem;color:#15803d;">₹0.00</td>
            </tr>

            <% ledger_entries.each_with_index do |entry, idx| %>
              <% is_credit = entry[:credit].to_f > 0 %>
              <%
                policy_url = begin
                  case entry[:policy_type_raw]
                  when 'health' then admin_health_insurance_path(entry[:policy_id])
                  when 'life'   then admin_life_insurance_path(entry[:policy_id])
                  when 'motor'  then admin_motor_insurance_path(entry[:policy_id])
                  when 'other'  then admin_other_insurance_path(entry[:policy_id])
                  end
                rescue
                  nil
                end
                ct_url = begin
                  entry[:policy_id].present? ? admin_commission_tracking_path(entry[:policy_id], policy_type: entry[:policy_type_raw]) : nil
                rescue
                  nil
                end
              %>
              <tr style="<%= is_credit ? '' : 'background:#fff8f0;' %>">
                <td style="padding:.6rem 1rem;color:#94a3b8;font-size:12px;"><%= idx + 1 %></td>
                <td style="padding:.6rem 1rem;white-space:nowrap;">
                  <span style="font-size:12.5px;font-weight:600;color:#334155;"><%= entry[:date].strftime('%d %b %Y') rescue '—' %></span>
                </td>
                <td style="padding:.6rem 1rem;">
                  <% if is_credit %>
                    <% if ct_url %>
                      <%= link_to ct_url, target: '_blank', style: "text-decoration:none;" do %>
                        <span class="badge bg-success bg-opacity-15 text-success" style="font-size:11.5px;font-weight:600;cursor:pointer;">
                          <i class="bi bi-arrow-up-circle me-1"></i>Commission Earned
                          <i class="bi bi-box-arrow-up-right ms-1" style="font-size:10px;"></i>
                        </span>
                      <% end %>
                    <% else %>
                      <span class="badge bg-success bg-opacity-15 text-success" style="font-size:11.5px;font-weight:600;">
                        <i class="bi bi-arrow-up-circle me-1"></i>Commission Earned
                      </span>
                    <% end %>
                  <% else %>
                    <% if ct_url %>
                      <%= link_to ct_url, target: '_blank', style: "text-decoration:none;" do %>
                        <span class="badge bg-warning bg-opacity-15" style="font-size:11.5px;font-weight:600;color:#b45309;cursor:pointer;">
                          <i class="bi bi-arrow-down-circle me-1"></i>Payout Received
                          <i class="bi bi-box-arrow-up-right ms-1" style="font-size:10px;"></i>
                        </span>
                      <% end %>
                    <% else %>
                      <span class="badge bg-warning bg-opacity-15" style="font-size:11.5px;font-weight:600;color:#b45309;">
                        <i class="bi bi-arrow-down-circle me-1"></i>Payout Received
                      </span>
                    <% end %>
                  <% end %>
                </td>
                <td style="padding:.6rem 1rem;">
                  <% if policy_url %>
                    <%= link_to policy_url, target: '_blank', style: "font-weight:700;color:#667eea;font-size:12.5px;text-decoration:none;" do %>
                      <i class="bi bi-box-arrow-up-right me-1" style="font-size:10px;"></i><%= entry[:policy_number] %>
                    <% end %>
                  <% else %>
                    <span style="font-weight:700;color:#667eea;font-size:12.5px;"><%= entry[:policy_number] %></span>
                  <% end %>
                </td>
                <td style="padding:.6rem 1rem;">
                  <%
                    type_color = case entry[:policy_type_raw]
                                 when 'health' then 'success'
                                 when 'life'   then 'primary'
                                 when 'motor'  then 'warning'
                                 else 'secondary'
                                 end
                  %>
                  <span class="badge bg-<%= type_color %> bg-opacity-15 text-<%= type_color %>" style="font-size:11px;">
                    <%= entry[:policy_type] %>
                  </span>
                </td>
                <td style="padding:.6rem 1rem;font-size:12.5px;color:#475569;"><%= entry[:customer_name] %></td>
                <td class="text-end" style="padding:.6rem 1rem;">
                  <% if is_credit %>
                    <span style="color:#16a34a;font-weight:700;font-size:13px;"><%= indian_currency(entry[:credit]) %></span>
                  <% else %>
                    <span style="color:#94a3b8;">—</span>
                  <% end %>
                </td>
                <td class="text-end" style="padding:.6rem 1rem;">
                  <% if !is_credit && entry[:debit].to_f > 0 %>
                    <span style="color:#dc2626;font-weight:700;font-size:13px;"><%= indian_currency(entry[:debit]) %></span>
                  <% else %>
                    <span style="color:#94a3b8;">—</span>
                  <% end %>
                </td>
                <td class="text-end" style="padding:.6rem 1rem;">
                  <span style="font-weight:700;font-size:13px;color:<%= entry[:balance].to_f >= 0 ? '#15803d' : '#dc2626' %>;">
                    <%= indian_currency(entry[:balance]) %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot style="background:#f1f5f9;">
            <tr>
              <td colspan="6" style="padding:.7rem 1rem;font-weight:700;font-size:13px;">Closing Balance</td>
              <td class="text-end" style="padding:.7rem 1rem;font-weight:700;font-size:13px;color:#16a34a;">
                <%= indian_currency(ledger_entries.sum { |e| e[:credit].to_f }) %>
              </td>
              <td class="text-end" style="padding:.7rem 1rem;font-weight:700;font-size:13px;color:#dc2626;">
                <%= indian_currency(ledger_entries.sum { |e| e[:debit].to_f }) %>
              </td>
              <td class="text-end" style="padding:.7rem 1rem;font-weight:700;font-size:14px;color:<%= closing_balance.to_f >= 0 ? '#15803d' : '#dc2626' %>;">
                <%= indian_currency(closing_balance) %>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-journal-x text-muted" style="font-size:3rem;display:block;margin-bottom:12px;"></i>
        <h6 class="text-muted">No ledger entries yet</h6>
        <p class="text-muted mb-0 small">Commission entries will appear here once policies are assigned and payouts are created.</p>
      </div>
    <% end %>
  </div>
</div>
