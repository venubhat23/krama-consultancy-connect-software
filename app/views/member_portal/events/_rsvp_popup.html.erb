<div class="modal fade" id="rsvpPopupModal" tabindex="-1" aria-labelledby="rsvpPopupLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg overflow-hidden">
      <div class="modal-header border-0 text-white" style="background: linear-gradient(135deg, #4e73df, #224abe);">
        <div>
          <h5 class="modal-title mb-1" id="rsvpPopupLabel"><i class="bi bi-calendar-check me-2"></i>Are you attending?</h5>
          <p class="mb-0 small text-white-50">Let us know if you're joining these upcoming events</p>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <% events.each do |event| %>
          <div class="d-flex justify-content-between align-items-center border rounded-3 p-3 mb-3">
            <div class="me-3">
              <h6 class="mb-1"><%= event.title %></h6>
              <div class="text-muted small">
                <i class="bi bi-clock me-1"></i><%= event.starts_at.strftime("%b %d, %Y · %I:%M %p") %>
                <% if event.venue.present? %> · <i class="bi bi-geo-alt me-1"></i><%= event.venue %><% end %>
              </div>
            </div>
            <div class="d-flex gap-2 flex-shrink-0">
              <%= button_to "Yes", rsvp_member_portal_event_path(event, attending: true), method: :post, class: "btn btn-success btn-sm rounded-pill px-3" %>
              <%= button_to "No", rsvp_member_portal_event_path(event, attending: false), method: :post, class: "btn btn-outline-secondary btn-sm rounded-pill px-3" %>
            </div>
          </div>
        <% end %>
      </div>
      <div class="modal-footer border-0 justify-content-center pt-0">
        <button type="button" class="btn btn-link text-muted small" data-bs-dismiss="modal">Remind me later</button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('turbo:load', function () {
    var el = document.getElementById('rsvpPopupModal');
    if (!el || el.dataset.rsvpShown) return;
    el.dataset.rsvpShown = 'true';
    // Defer so this runs after the layout's own modal (re)initialization on the same event.
    setTimeout(function () {
      bootstrap.Modal.getOrCreateInstance(el).show();
    }, 50);
  }, { once: true });
</script>
