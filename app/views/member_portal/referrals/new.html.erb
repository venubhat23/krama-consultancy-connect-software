<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Refer a Member</h2>
    <p class="text-muted mb-0">Send a business lead to someone in your forum — same chapter or another one.</p>
  </div>
  <%= link_to member_portal_leads_path, class: "btn btn-outline-secondary" do %><i class="bi bi-inbox me-1"></i>My Leads<% end %>
</div>

<% if @referral.errors.any? %>
  <div class="alert alert-danger"><%= @referral.errors.full_messages.to_sentence %></div>
<% end %>

<div class="card border-0 shadow-sm" data-controller="member-search" data-member-search-url-value="<%= search_members_member_portal_referrals_path %>">
  <div class="card-body">
    <%= form_with scope: :referral, url: member_portal_referrals_path, method: :post, local: true do |f| %>
      <div class="mb-3 position-relative">
        <%= label_tag :member_query, "Search for a member", class: "form-label" %>
        <%= text_field_tag :member_query, @selected_user&.full_name, class: "form-control", placeholder: "Type a name, email, or company...", autocomplete: "off", data: { member_search_target: "query", action: "input->member-search#search" } %>
        <%= hidden_field_tag "referral[referred_user_id]", @selected_user&.id, data: { member_search_target: "selectedId" } %>
        <div class="list-group position-absolute w-100 shadow-sm" style="z-index: 10;" data-member-search-target="results"></div>
      </div>

      <div class="mb-3" data-member-search-target="profile"></div>

      <div class="mb-3">
        <%= f.label :business_context, "What's the opportunity?", class: "form-label" %>
        <%= f.text_area :business_context, class: "form-control", rows: 3, required: true, placeholder: "Describe the lead — what business, how you know them, what they need..." %>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-sm-6">
          <%= f.label :contact_name, "Contact name (optional)", class: "form-label" %>
          <%= f.text_field :contact_name, class: "form-control" %>
        </div>
        <div class="col-sm-6">
          <%= f.label :contact_phone, "Contact phone (optional)", class: "form-label" %>
          <%= f.text_field :contact_phone, class: "form-control" %>
        </div>
      </div>

      <%= f.submit "Send Referral", class: "btn btn-primary", data: { member_search_target: "submit" }, disabled: @selected_user.blank? %>
    <% end %>
  </div>
</div>
