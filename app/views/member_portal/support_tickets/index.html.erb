<div class="mb-4"><h2 class="mb-1">My Support Tickets</h2></div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body">
    <%= form_with url: member_portal_support_tickets_path, method: :post, local: true do |form| %>
      <div class="row g-2">
        <div class="col-md-4">
          <%= text_field_tag "support_ticket[subject]", nil, class: "form-control", placeholder: "Subject", required: true %>
        </div>
        <div class="col-md-4">
          <%= text_area_tag "support_ticket[body]", nil, class: "form-control", placeholder: "Describe the issue...", rows: 1, required: true %>
        </div>
        <div class="col-md-2">
          <%= select_tag "support_ticket[priority]", options_for_select([["Low", "low"], ["Medium", "medium"], ["High", "high"]], "medium"), class: "form-select" %>
        </div>
        <div class="col-md-2">
          <%= submit_tag "Submit", class: "btn btn-primary w-100" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if @tickets.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light"><tr><th class="border-0">Subject</th><th class="border-0">Priority</th><th class="border-0">Status</th></tr></thead>
          <tbody>
            <% @tickets.each do |t| %>
              <tr>
                <td><%= link_to t.subject, member_portal_support_ticket_path(t), class: "text-decoration-none fw-medium" %></td>
                <td><span class="badge bg-info-subtle text-info"><%= t.priority.humanize %></span></td>
                <td><span class="badge bg-<%= { 'open' => 'warning', 'in_progress' => 'primary', 'resolved' => 'success', 'closed' => 'secondary' }[t.status] %>"><%= t.status.humanize %></span></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-transparent border-0">
        <%= render "shared/pagination", records: @tickets %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-life-preserver fs-1 text-muted d-block mb-3"></i>
        <h5 class="text-muted">No tickets yet</h5>
      </div>
    <% end %>
  </div>
</div>
