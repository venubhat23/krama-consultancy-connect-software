<div class="mb-4">
  <h2 class="mb-1">My Business Profile</h2>
  <p class="text-muted mb-0">This is what other members see when they consider referring you a lead.</p>
</div>

<div class="card border-0 shadow-sm" style="max-width: 640px;">
  <div class="card-body">
    <% if @user.errors.any? %>
      <div class="alert alert-danger"><%= @user.errors.full_messages.to_sentence %></div>
    <% end %>

    <%= form_with model: @user, url: member_portal_profile_path, method: :patch, local: true do |f| %>
      <div class="mb-3">
        <%= f.label :company_name, class: "form-label" %>
        <%= f.text_field :company_name, class: "form-control" %>
      </div>
      <div class="mb-3">
        <%= f.label :designation, class: "form-label" %>
        <%= f.text_field :designation, class: "form-control" %>
      </div>
      <div class="mb-3">
        <%= f.label :business_category, class: "form-label" %>
        <%= f.text_field :business_category, class: "form-control", placeholder: "e.g. Catering, Real Estate, IT Services" %>
      </div>
      <div class="mb-3">
        <%= f.label :speciality, class: "form-label" %>
        <%= f.text_field :speciality, class: "form-control", placeholder: "What you're best known for" %>
      </div>
      <div class="mb-3">
        <%= f.label :nature_of_business, class: "form-label" %>
        <%= f.text_field :nature_of_business, class: "form-control" %>
      </div>
      <div class="mb-3">
        <%= f.label :website, class: "form-label" %>
        <%= f.text_field :website, class: "form-control", placeholder: "https://..." %>
      </div>
      <%= f.submit "Save Profile", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>
