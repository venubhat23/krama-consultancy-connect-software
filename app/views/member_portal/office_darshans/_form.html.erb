<%= form_with model: event, url: member_portal_office_darshans_path, local: true do |form| %>
  <% if event.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% event.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %></ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-8">
      <label class="form-label">Title</label>
      <%= form.text_field :title, value: event.title.presence || "Office Darshan", class: "form-control", required: true %>
    </div>
    <div class="col-md-4">
      <label class="form-label">Date &amp; Time</label>
      <%= form.datetime_field :starts_at, class: "form-control", required: true %>
    </div>
    <div class="col-md-6">
      <label class="form-label">Venue</label>
      <%= form.text_field :venue, placeholder: "e.g. Head Office, 2nd Floor", class: "form-control" %>
    </div>
    <div class="col-12">
      <label class="form-label">Description</label>
      <%= form.text_area :description, rows: 3, placeholder: "What's this visit about?", class: "form-control" %>
    </div>
  </div>

  <hr class="my-4">

  <h6 class="mb-3">Who should be invited?</h6>
  <div class="form-check mb-2">
    <%= radio_button_tag :audience, "all", true, class: "form-check-input", id: "audience_all" %>
    <%= label_tag "audience_all", "All members in the forum", class: "form-check-label" %>
  </div>
  <div class="form-check mb-3">
    <%= radio_button_tag :audience, "specific", false, class: "form-check-input", id: "audience_specific" %>
    <%= label_tag "audience_specific", "Specific members", class: "form-check-label" %>
  </div>

  <div id="specific_members_list" class="border rounded-3 p-3 mb-3" style="max-height: 260px; overflow-y: auto; display: none;">
    <% if invitable_users.any? %>
      <% invitable_users.each do |member| %>
        <div class="form-check">
          <%= check_box_tag "member_ids[]", member.id, false, class: "form-check-input", id: "member_#{member.id}" %>
          <%= label_tag "member_#{member.id}", "#{member.full_name}#{" · #{member.chapter.name}" if member.chapter}", class: "form-check-label" %>
        </div>
      <% end %>
    <% else %>
      <p class="text-muted small mb-0">No other members found.</p>
    <% end %>
  </div>

  <div class="mt-3 d-flex gap-2">
    <%= form.submit "Announce Office Darshan", class: "btn btn-primary" %>
    <%= link_to "Cancel", member_portal_office_darshans_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<script>
  document.addEventListener('turbo:load', function () {
    var specificRadio = document.getElementById('audience_specific');
    var allRadio = document.getElementById('audience_all');
    var list = document.getElementById('specific_members_list');
    if (!specificRadio || !allRadio || !list) return;
    function toggleList() { list.style.display = specificRadio.checked ? 'block' : 'none'; }
    specificRadio.addEventListener('change', toggleList);
    allRadio.addEventListener('change', toggleList);
    toggleList();
  });
</script>
