<div class="alert border-0 shadow-sm mb-4" style="background: linear-gradient(135deg, rgba(246,173,55,0.12), rgba(246,173,55,0.03)); border-left: 4px solid #f6ad37 !important;">
  <h6 class="mb-3"><i class="bi bi-building me-2 text-warning"></i>You're invited to Office Darshan</h6>
  <% events.each do |event| %>
    <% reg = event.event_registrations.find_by(user: current_user) %>
    <div class="d-flex justify-content-between align-items-center border rounded-3 p-3 mb-2 bg-body">
      <div class="me-3">
        <strong><%= event.title %></strong>
        <div class="text-muted small">
          <i class="bi bi-clock me-1"></i><%= event.starts_at.strftime("%b %d, %Y · %I:%M %p") %>
          <% if event.venue.present? %> · <i class="bi bi-geo-alt me-1"></i><%= event.venue %><% end %>
          · Invited by <%= reg&.invited_by&.full_name || event.created_by&.full_name || "a forum member" %>
        </div>
      </div>
      <div class="d-flex gap-2 flex-shrink-0">
        <%= button_to "Yes, I'll come", rsvp_member_portal_office_darshan_path(event, attending: true), method: :post, class: "btn btn-success btn-sm rounded-pill px-3" %>
        <%= button_to "Can't make it", rsvp_member_portal_office_darshan_path(event, attending: false), method: :post, class: "btn btn-outline-secondary btn-sm rounded-pill px-3" %>
      </div>
    </div>
  <% end %>
</div>
