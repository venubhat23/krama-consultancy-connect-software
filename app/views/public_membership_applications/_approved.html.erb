<div class="text-center mb-4">
  <i class="bi bi-patch-check-fill display-4" style="color: #198754;"></i>
  <h3 class="mt-3">You're approved, <%= application.name.split.first %>!</h3>
  <p class="text-muted">Complete your payment to activate your membership with <strong><%= application.forum.name %></strong>.</p>
</div>

<% if application.payment_instructions.present? %>
  <div class="info-item mb-3">
    <div class="fw-semibold mb-1">Payment Instructions</div>
    <div style="white-space: pre-line;"><%= application.payment_instructions %></div>
  </div>
<% end %>

<p class="text-muted small text-center mb-0">Once you've paid, let us know via WhatsApp and we'll confirm your membership.</p>
