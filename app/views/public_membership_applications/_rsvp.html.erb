<div class="text-center mb-4">
  <i class="bi bi-calendar-event display-4" style="color: #667eea;"></i>
  <h3 class="mt-3">Hi <%= application.name.split.first %>, you're invited!</h3>
  <p class="text-muted">
    <%= application.event&.title %>
    <% if application.event&.starts_at %><br><%= application.event.starts_at.strftime("%B %d, %Y at %I:%M %p") %><% end %>
    <% if application.event&.venue.present? %><br><%= application.event.venue %><% end %>
  </p>
</div>

<%= button_to "Yes, I'm coming!", confirm_rsvp_public_membership_application_path(application.token), method: :post, class: "btn btn-primary btn-lg w-100" %>
