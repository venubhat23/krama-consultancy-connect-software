<div class="text-center mb-4">
  <i class="bi bi-people display-4" style="color: #667eea;"></i>
  <h3 class="mt-3">Hi <%= application.name.split.first %>!</h3>
  <p class="text-muted">We'd love to have you join <strong><%= application.forum.name %></strong><% if application.chapter %> — <%= application.chapter.name %> chapter<% end %>. Interested in becoming a member?</p>
</div>

<%= button_to "Yes, I'm interested", confirm_interest_public_membership_application_path(application.token), method: :post, class: "btn btn-primary btn-lg w-100" %>
