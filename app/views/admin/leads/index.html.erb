
<!-- Leads Management Header -->
<div class="d-flex justify-content-between align-items-center mb-2">
  <div>
    <h2 class="mb-1">Leads Management</h2>
  </div>
  <div class="d-flex gap-2 align-items-center">
    <!-- View Toggle Button -->
    <div class="btn-group" role="group" aria-label="View toggle">
      <button type="button" class="btn btn-outline-secondary active" id="tableViewBtn" onclick="switchToTableView()">
        <i class="bi bi-table me-1"></i>Table
      </button>
      <button type="button" class="btn btn-outline-secondary" id="cardViewBtn" onclick="switchToCardView()">
        <i class="bi bi-grid-3x3-gap me-1"></i>Cards
      </button>
    </div>
    <!-- Kanban Board Button -->
    <%= link_to kanban_admin_leads_path, class: "btn btn-outline-primary" do %>
      <i class="bi bi-kanban me-1"></i>Kanban Board
    <% end %>
    <div class="dropdown download-dropdown">
      <button class="btn btn-success dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-download me-1"></i> Download
      </button>
      <ul class="dropdown-menu dropdown-menu-end">
        <li>
          <a class="dropdown-item" data-turbo="false" href="<%= download_admin_leads_path(request.query_parameters.merge(format_type: 'csv_individual')) %>">
            <i class="bi bi-filetype-csv text-success me-2"></i>CSV Individual
          </a>
        </li>
        <li>
          <a class="dropdown-item" data-turbo="false" href="<%= download_admin_leads_path(request.query_parameters.merge(format_type: 'excel_individual')) %>">
            <i class="bi bi-file-earmark-excel text-success me-2"></i>Excel Individual
          </a>
        </li>
        <li><hr class="dropdown-divider"></li>
        <li>
          <a class="dropdown-item" data-turbo="false" href="<%= download_admin_leads_path(request.query_parameters.merge(format_type: 'csv_corporate')) %>">
            <i class="bi bi-filetype-csv text-success me-2"></i>CSV Corporate
          </a>
        </li>
        <li>
          <a class="dropdown-item" data-turbo="false" href="<%= download_admin_leads_path(request.query_parameters.merge(format_type: 'excel_corporate')) %>">
            <i class="bi bi-file-earmark-excel text-success me-2"></i>Excel Corporate
          </a>
        </li>
      </ul>
    </div>
    <%= link_to new_admin_lead_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i>
      Add New Lead
    <% end %>
  </div>
</div>

<!-- Lead Statistics Dashboard -->
<div class="row mb-3">
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Leads</h6>
            <h3 class="mb-0 text-primary"><%= @total_leads %></h3>
          </div>
          <div class="bg-primary bg-opacity-10 rounded p-3">
            <i class="bi bi-funnel-fill text-primary fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">In Consultation</h6>
            <h3 class="mb-0 text-info"><%= @consultation_leads %></h3>
          </div>
          <div class="bg-info bg-opacity-10 rounded p-3">
            <i class="bi bi-chat-dots text-info fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Converted</h6>
            <h3 class="mb-0 text-success"><%= @converted_leads %></h3>
          </div>
          <div class="bg-success bg-opacity-10 rounded p-3">
            <i class="bi bi-check-circle text-success fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Conversion Rate</h6>
            <h3 class="mb-0 text-warning"><%= @conversion_rate %>%</h3>
          </div>
          <div class="bg-warning bg-opacity-10 rounded p-3">
            <i class="bi bi-graph-up text-warning fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Lead Status Tabs -->
<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-transparent border-0">
    <ul class="nav nav-tabs border-0" id="leadTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= params[:tab] != 'converted' ? 'active' : '' %>"
                id="active-leads-tab"
                data-bs-toggle="tab"
                data-bs-target="#active-leads"
                type="button"
                role="tab"
                aria-controls="active-leads"
                aria-selected="<%= params[:tab] != 'converted' ? 'true' : 'false' %>">
          <i class="bi bi-funnel me-2"></i>
          All Leads
          <span class="badge bg-primary ms-2"><%= @total_leads %></span>
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= params[:tab] == 'converted' ? 'active' : '' %>"
                id="converted-leads-tab"
                data-bs-toggle="tab"
                data-bs-target="#converted-leads"
                type="button"
                role="tab"
                aria-controls="converted-leads"
                aria-selected="<%= params[:tab] == 'converted' ? 'true' : 'false' %>">
          <i class="bi bi-person-check me-2"></i>
          Converted Leads
          <span class="badge bg-success ms-2"><%= @converted_leads %></span>
        </button>
      </li>
    </ul>
  </div>
</div>

<!-- Loading Spinner for Tab Switching -->
<div id="tabLoadingSpinner" class="text-center py-5" style="display: none;">
  <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
    <span class="visually-hidden">Loading...</span>
  </div>
  <div class="mt-3">
    <h5 class="text-muted">Loading leads...</h5>
    <p class="text-muted small">Please wait while we fetch the data</p>
  </div>
</div>

<div class="tab-content" id="leadTabsContent">
  <!-- Active Leads Tab -->
  <div class="tab-pane fade <%= params[:tab] != 'converted' ? 'show active' : '' %>" id="active-leads" role="tabpanel" aria-labelledby="active-leads-tab">
    <!-- Search and Filters for Active Leads -->
    <div class="card border-0 shadow-sm mb-2">
      <div class="card-header bg-transparent border-0 pb-0 pt-1">
        <h6 class="text-muted mb-0">
          <i class="bi bi-funnel me-2"></i>
          Search and Filter Active Leads
        </h6>
      </div>
      <div class="card-body pt-1 pb-1">
        <%= form_with url: admin_leads_path, method: :get, local: true, class: "filter-form" do |form| %>
          <%= form.hidden_field :tab, value: 'active' %>
          <!-- Single Row: All Filters -->
          <div class="row g-2 align-items-end">
            <div class="col-lg-2 col-md-6">
              <label class="form-label small text-muted mb-1">Search Leads</label>
              <%= form.text_field :search, placeholder: "Search by name, phone, email...", value: params[:search], class: "form-control" %>
            </div>
            <div class="col-lg-2 col-md-6">
              <label class="form-label small text-muted mb-1">Stage</label>
              <%= form.select :current_stage, options_for_select([
                ['All Stages', ''],
                ['Lead Generated', 'lead_generated'],
                ['Consultation', 'consultation_scheduled'],
                ['One-on-One', 'one_on_one'],
                ['Follow-Up', 'follow_up'],
                ['Successful', 'follow_up_successful'],
                ['Unsuccessful', 'follow_up_unsuccessful'],
                ['Not Interested', 'not_interested'],
                ['Re-Follow Up', 're_follow_up'],
                ['Lead Close - Follow-Up Unsuccessful', 'lead_closed']
              ], params[:current_stage]), {}, { class: "form-select stage-filter-dropdown" } %>
            </div>
            <div class="col-lg-2 col-md-6">
              <label class="form-label small text-muted mb-1">Category</label>
              <%= form.select :product_category, options_for_select([
                ['All Categories', ''],
                ['Insurance', 'insurance'],
                ['Investments', 'investments'],
                ['Loans', 'loans'],
                ['Taxation', 'taxation']
              ], params[:product_category]), {}, { class: "form-select" } %>
            </div>
            <div class="col-lg-2 col-md-6">
              <label class="form-label small text-muted mb-1">Source</label>
              <%= form.select :lead_source, options_for_select([
                ['All Sources', ''],
                ['Online', 'online'],
                ['Offline', 'offline'],
                ['Agent Referral', 'agent_referral'],
                ['Walk-in', 'walk_in'],
                ['Tele-calling', 'tele_calling'],
                ['Campaign', 'campaign']
              ], params[:lead_source]), {}, { class: "form-select" } %>
            </div>
            <div class="col-lg-2 col-md-12">
              <div class="d-flex gap-2">
                <%= form.submit "Apply", class: "btn btn-primary" do %>
                  <i class="bi bi-funnel me-1"></i>
                  Apply
                <% end %>
                <%= link_to admin_leads_path(tab: 'active'), class: "btn btn-outline-secondary", title: "Clear all filters" do %>
                  <i class="bi bi-arrow-clockwise"></i>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Active Leads Table -->
    <div class="card border-0 shadow-sm" id="tableView-active">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">All Leads</h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="bg-light">
              <tr>
                <th class="border-0">Lead Details</th>
                <th class="border-0">Contact Information</th>
                <th class="border-0">Product & Affiliate</th>
                <th class="border-0">Current Stage</th>
                <th class="border-0">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if params[:tab] != 'converted' && @leads.any? %>
                <% @leads.each do |lead| %>
                  <tr class="lead-row <%= 'branch-out-lead' if lead.is_branch_out? %>" data-id="<%= lead.id %>">
                    <td>
                      <div>
                        <span class="badge bg-primary mb-1"><%= lead.lead_id.presence || "LEAD-#{lead.id}" %></span>
                        <% if lead.is_branch_out? %>
                          <span class="badge bg-success mb-1">
                            <i class="bi bi-diagram-3 me-1"></i>Branch Out
                          </span>
                        <% end %>
                        <h6 class="mb-1"><%= lead.name %></h6>
                        <small class="text-muted">
                          <%= lead.created_date&.strftime('%d/%m/%Y') || lead.created_at&.strftime('%d/%m/%Y') %>
                          (<%= time_ago_in_words(lead.created_at) %> ago)
                        </small>
                      </div>
                    </td>
                    <td>
                      <div>
                        <div class="mb-1"><%= lead.contact_number&.gsub(/^\+?91|^0/, '')&.strip %></div>
                      </div>
                    </td>
                    <td>
                      <div class="d-flex flex-column gap-1">
                        <div class="d-flex flex-wrap gap-1">
                          <span class="badge bg-info text-white"><%= lead.product_category&.humanize || 'N/A' %></span>
                          <% if lead.product_subcategory.present? %>
                            <span class="badge bg-light text-dark border"><%= lead.product_subcategory %></span>
                          <% end %>
                        </div>
                        <div class="small">
                          <% if lead.is_direct %>
                            <span class="badge bg-warning text-dark">
                              <i class="bi bi-building me-1"></i>Direct
                            </span>
                          <% else %>
                            <span class="text-muted">
                              <i class="bi bi-person me-1"></i><%= truncate(lead.affiliate&.full_name || 'N/A', length: 20) %>
                            </span>
                          <% end %>
                        </div>
                      </div>
                    </td>
                    <td>
                      <%= lead.current_stage&.humanize || 'Unknown' %>
                    </td>
                    <td>
                      <div>
                        <%= link_to admin_lead_path(lead), class: "text-primary me-2", title: "View Details" do %>
                          <i class="bi bi-eye fs-5"></i>
                        <% end %>



                        <!-- Lead Stage Conversion Dropdown -->
                        <div class="dropdown d-inline-block">
                          <button class="text-success dropdown-toggle border-0 bg-transparent stage-dropdown-btn"
                                  type="button"
                                  data-bs-toggle="dropdown"
                                  aria-expanded="false"
                                  title="Change Lead Stage"
                                  style="font-size: 1.2rem;">
                            <i class="bi bi-arrow-repeat"></i>
                          </button>
                          <ul class="dropdown-menu dropdown-menu-end shadow border-0 stage-dropdown-menu" style="min-width: 280px; max-height: 400px; overflow-y: auto;">
                            <li class="dropdown-header bg-success text-white fw-bold">
                              <i class="bi bi-diagram-3 me-2"></i>Change Lead Stage
                            </li>
                            <li><hr class="dropdown-divider"></li>

                            <!-- Current Stage Display -->
                            <li class="px-3 py-2 bg-light">
                              <small class="text-muted d-block mb-1">Current:</small>
                              <span class="badge bg-primary"><%= lead.current_stage&.humanize || 'Unknown' %></span>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <!-- All Available Stages -->
                            <% stage_options = [
                                 { key: 'lead_generated', name: 'Lead Generated', icon: '🟢', desc: 'New lead created' },
                                 { key: 'consultation_scheduled', name: 'Consultation Scheduled', icon: '📅', desc: 'Meeting scheduled' },
                                 { key: 'one_on_one', name: 'One-on-One Meeting', icon: '🤝', desc: 'Personal meeting' },
                                 { key: 'follow_up', name: 'Follow-Up Successful', icon: '📞', desc: 'Following up with lead' },
                                 { key: 'follow_up_successful', name: 'Follow-Up Successful', icon: '✅', desc: 'Successful follow-up' },
                                 { key: 'follow_up_unsuccessful', name: 'Follow-Up Unsuccessful', icon: '❌', desc: 'Unsuccessful follow-up' },
                                 { key: 'converted', name: 'Converted (Client)', icon: '🎉', desc: 'Successfully converted' },
                                 { key: 'not_interested', name: 'Not Interested', icon: '🚫', desc: 'Lead not interested' },
                                 { key: 're_follow_up', name: 'Re-Follow Up', icon: '🔄', desc: 'Re-attempting follow-up' },
                                 { key: 'lead_closed', name: 'Lead Close - Follow-Up Unsuccessful', icon: '📁', desc: 'Lead closed - follow-up unsuccessful' }
                               ] %>

                            <% stage_options.each do |stage| %>
                              <% if stage[:key] == lead.current_stage %>
                                <!-- Current stage - disabled with checkmark -->
                                <li>
                                  <span class="dropdown-item disabled bg-light border-0 d-flex align-items-center">
                                    <span class="me-3" style="font-size: 1.1rem;"><%= stage[:icon] %></span>
                                    <div class="flex-grow-1">
                                      <div class="fw-semibold d-flex align-items-center">
                                        <%= stage[:name] %>
                                        <i class="bi bi-check-circle-fill text-success ms-auto"></i>
                                      </div>
                                      <small class="text-muted"><%= stage[:desc] %></small>
                                    </div>
                                  </span>
                                </li>
                              <% else %>
                                <!-- Other stages - clickable -->
                                <li>
                                  <%= form_with url: convert_stage_admin_lead_path(lead, stage: stage[:key]),
                                      method: :patch,
                                      local: true,
                                      style: "margin: 0;",
                                      onsubmit: "return confirm('Move lead to #{stage[:name]} stage?')" do |f| %>
                                    <button type="submit"
                                            class="dropdown-item border-0 d-flex align-items-center py-2 stage-option"
                                            style="background: none;">
                                      <span class="me-3" style="font-size: 1.1rem;"><%= stage[:icon] %></span>
                                      <div class="flex-grow-1 text-start">
                                        <div class="fw-medium"><%= stage[:name] %></div>
                                        <small class="text-muted d-block"><%= stage[:desc] %></small>
                                      </div>
                                      <i class="bi bi-arrow-right text-muted"></i>
                                    </button>
                                  <% end %>
                                </li>
                              <% end %>
                            <% end %>

                            <li><hr class="dropdown-divider"></li>
                            <li class="px-3 py-2">
                              <small class="text-muted">
                                <i class="bi bi-info-circle me-1"></i>
                                Click any stage to move this lead
                              </small>
                            </li>
                          </ul>
                        </div>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <% if params[:tab] != 'converted' %>
                  <tr>
                    <td colspan="7" class="text-center py-5">
                      <div class="text-muted">
                        <i class="bi bi-funnel fs-1 mb-3 d-block"></i>
                        <h5>No active leads found</h5>
                        <p>Start by creating your first lead or adjust your search filters.</p>
                        <%= link_to "Add New Lead", new_admin_lead_path, class: "btn btn-primary" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Pagination for Active Leads -->
        <% if params[:tab] != 'converted' %>
          <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
            <div class="d-flex align-items-center gap-3">
              <% if @leads.respond_to?(:total_count) %>
                <small class="text-muted">
                  Showing <strong><%= @leads.offset_value + 1 %></strong>–<strong><%= [@leads.offset_value + @leads.limit_value, @leads.total_count].min %></strong> of <strong><%= number_with_delimiter(@leads.total_count) %></strong>
                </small>
              <% end %>
              <%= render 'shared/per_page_selector' %>
            </div>
            <% if @leads.respond_to?(:total_pages) && @leads.total_pages > 1 %>
              <div class="pagination-wrapper">
                <%= paginate @leads %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Converted Leads Tab -->
  <div class="tab-pane fade <%= params[:tab] == 'converted' ? 'show active' : '' %>" id="converted-leads" role="tabpanel" aria-labelledby="converted-leads-tab">
    <!-- Search and Filters for Converted Leads -->
    <div class="card border-0 shadow-sm mb-2">
      <div class="card-header bg-transparent border-0 pb-0 pt-1">
        <h6 class="text-muted mb-0">
          <i class="bi bi-funnel me-2"></i>
          Search and Filter Converted Leads (Clients)
        </h6>
      </div>
      <div class="card-body pt-1 pb-1">
        <%= form_with url: admin_leads_path, method: :get, local: true, class: "filter-form" do |form| %>
          <%= form.hidden_field :tab, value: 'converted' %>
          <!-- Single Row: All Filters -->
          <div class="row g-2 align-items-end">
            <div class="col-lg-3 col-md-6">
              <label class="form-label small text-muted mb-1">Search Clients</label>
              <%= form.text_field :search, placeholder: "Search by name, phone, email...", value: params[:search], class: "form-control" %>
            </div>
            <div class="col-lg-3 col-md-6">
              <label class="form-label small text-muted mb-1">Category</label>
              <%= form.select :product_category, options_for_select([
                ['All Categories', ''],
                ['Insurance', 'insurance'],
                ['Investments', 'investments'],
                ['Loans', 'loans'],
                ['Taxation', 'taxation']
              ], params[:product_category]), {}, { class: "form-select" } %>
            </div>
            <div class="col-lg-3 col-md-6">
              <label class="form-label small text-muted mb-1">Source</label>
              <%= form.select :lead_source, options_for_select([
                ['All Sources', ''],
                ['Online', 'online'],
                ['Offline', 'offline'],
                ['Agent Referral', 'agent_referral'],
                ['Walk-in', 'walk_in'],
                ['Tele-calling', 'tele_calling'],
                ['Campaign', 'campaign']
              ], params[:lead_source]), {}, { class: "form-select" } %>
            </div>
            <div class="col-lg-3 col-md-12">
              <div class="d-flex gap-2">
                <%= form.submit "Apply", class: "btn btn-primary" do %>
                  <i class="bi bi-funnel me-1"></i>
                  Apply
                <% end %>
                <%= link_to admin_leads_path(tab: 'converted'), class: "btn btn-outline-secondary", title: "Clear all filters" do %>
                  <i class="bi bi-arrow-clockwise"></i>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Converted Leads Table -->
    <div class="card border-0 shadow-sm" id="tableView-converted">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Converted Leads</h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="bg-light">
              <tr>
                <th class="border-0">Client Details</th>
                <th class="border-0">Contact Information</th>
                <th class="border-0">Product & Affiliate</th>
                <th class="border-0">Last Updated</th>
                <th class="border-0">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if params[:tab] == 'converted' && @leads.any? %>
                <% @leads.each do |lead| %>
                  <%
                    # Calculate how recently this lead was updated
                    updated_time = lead.stage_updated_at || lead.updated_at
                    time_since_update = Time.current - updated_time

                    # Add visual classes based on how recent the update was
                    recently_updated_class = if time_since_update < 1.hour
                      'recently-updated-hour'
                    elsif time_since_update < 1.day
                      'recently-updated-day'
                    else
                      ''
                    end

                    row_classes = ['lead-row']
                    row_classes << 'branch-out-lead' if lead.is_branch_out?
                    row_classes << recently_updated_class if recently_updated_class.present?
                  %>
                  <tr class="<%= row_classes.join(' ') %>" data-id="<%= lead.id %>">
                    <td>
                      <div>
                        <span class="badge bg-success mb-1"><%= lead.lead_id.presence || "CLIENT-#{lead.id}" %></span>
                        <% if lead.is_branch_out? %>
                          <span class="badge bg-primary mb-1">
                            <i class="bi bi-diagram-3 me-1"></i>Branch Out
                          </span>
                        <% end %>
                        <h6 class="mb-1"><%= lead.name %></h6>
                        <small class="text-muted">
                          Lead created: <%= lead.created_date&.strftime('%d/%m/%Y') || lead.created_at&.strftime('%d/%m/%Y') %>
                        </small>
                      </div>
                    </td>
                    <td>
                      <div>
                        <div class="mb-1"><%= lead.contact_number&.gsub(/^\+?91|^0/, '')&.strip %></div>
                      </div>
                    </td>
                    <td>
                      <div class="d-flex flex-column gap-1">
                        <div class="d-flex flex-wrap gap-1">
                          <span class="badge bg-info text-white"><%= lead.product_category&.humanize || 'N/A' %></span>
                          <% if lead.product_subcategory.present? %>
                            <span class="badge bg-light text-dark border"><%= lead.product_subcategory %></span>
                          <% end %>
                        </div>
                        <div class="small">
                          <% if lead.is_direct %>
                            <span class="badge bg-warning text-dark">
                              <i class="bi bi-building me-1"></i>Direct
                            </span>
                          <% else %>
                            <span class="text-muted">
                              <i class="bi bi-person me-1"></i><%= truncate(lead.affiliate&.full_name || 'N/A', length: 20) %>
                            </span>
                          <% end %>
                        </div>
                      </div>
                    </td>
                    <td>
                      <% if lead.converted_customer.present? %>
                        <div>
                          <div class="fw-medium text-success">
                            Converted
                            <% if time_since_update < 1.hour %>
                              <span class="badge bg-danger ms-1 pulse-animation" title="Updated within the last hour">
                                <i class="bi bi-clock-fill"></i> NEW
                              </span>
                            <% elsif time_since_update < 1.day %>
                              <span class="badge bg-warning text-dark ms-1" title="Updated within the last 24 hours">
                                <i class="bi bi-clock"></i> Recent
                              </span>
                            <% end %>
                          </div>
                          <small class="text-muted">
                            <%= time_ago_in_words(lead.stage_updated_at || lead.updated_at) %> ago
                          </small>
                        </div>
                      <% else %>
                        <div>
                          <div class="fw-medium text-warning">
                            Converting...
                            <% if time_since_update < 1.hour %>
                              <span class="badge bg-danger ms-1 pulse-animation" title="Updated within the last hour">
                                <i class="bi bi-clock-fill"></i> NEW
                              </span>
                            <% elsif time_since_update < 1.day %>
                              <span class="badge bg-warning text-dark ms-1" title="Updated within the last 24 hours">
                                <i class="bi bi-clock"></i> Recent
                              </span>
                            <% end %>
                          </div>
                          <small class="text-muted">
                            <%= time_ago_in_words(lead.updated_at) %> ago
                          </small>
                        </div>
                      <% end %>
                    </td>
                    <td>
                      <div>
                        <%= link_to admin_lead_path(lead), class: "text-primary me-2", title: "View Details" do %>
                          <i class="bi bi-eye fs-5"></i>
                        <% end %>

                        <% if lead.converted_customer.present? %>
                          <%= link_to admin_customer_path(lead.converted_customer), class: "text-info me-2",
                              title: "View Customer: #{lead.converted_customer.display_name}",
                              data: { bs_toggle: "tooltip", bs_placement: "top" } do %>
                            <i class="bi bi-person-check fs-5"></i>
                          <% end %>
                        <% end %>

                        <%= link_to "#",
                            class: "text-danger delete-lead-btn",
                            data: {
                              "lead-id": lead.id,
                              "lead-name": lead.name,
                              "delete-url": admin_lead_path(lead)
                            },
                            title: "Delete Client Record" do %>
                          <i class="bi bi-trash fs-5"></i>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <% if params[:tab] == 'converted' %>
                  <tr>
                    <td colspan="7" class="text-center py-5">
                      <div class="text-muted">
                        <i class="bi bi-person-check fs-1 mb-3 d-block"></i>
                        <h5>No converted clients found</h5>
                        <p>Converted leads will appear here once you start converting leads to customers.</p>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Pagination for Converted Leads -->
        <% if params[:tab] == 'converted' %>
          <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
            <div class="d-flex align-items-center gap-3">
              <% if @leads.respond_to?(:total_count) %>
                <small class="text-muted">
                  Showing <strong><%= @leads.offset_value + 1 %></strong>–<strong><%= [@leads.offset_value + @leads.limit_value, @leads.total_count].min %></strong> of <strong><%= number_with_delimiter(@leads.total_count) %></strong>
                </small>
              <% end %>
              <%= render 'shared/per_page_selector' %>
            </div>
            <% if @leads.respond_to?(:total_pages) && @leads.total_pages > 1 %>
              <div class="pagination-wrapper">
                <%= paginate @leads %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Leads Card View -->
<div id="cardView" style="display: none;">
  <% if @leads.any? %>
    <div class="row">
      <% @leads.each do |lead| %>
        <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
          <div class="card h-100 border-0 shadow-sm lead-card <%= 'branch-out-lead-card' if lead.is_branch_out? %>">
            <div class="card-header bg-transparent border-0 pb-2">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <span class="badge bg-primary mb-1"><%= lead.lead_id.presence || "LEAD-#{lead.id}" %></span>
                  <% if lead.is_branch_out? %>
                    <span class="badge bg-success mb-1">
                      <i class="bi bi-diagram-3 me-1"></i>Branch Out
                    </span>
                  <% end %>
                </div>
                <div class="dropdown">
                  <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-three-dots"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li><%= link_to admin_lead_path(lead), class: "dropdown-item" do %>
                      <i class="bi bi-eye me-2"></i>View Details
                    <% end %></li>
                    <li><%= link_to edit_admin_lead_path(lead), class: "dropdown-item" do %>
                      <i class="bi bi-pencil me-2"></i>Edit Lead
                    <% end %></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="#" onclick="showDeleteConfirmation('<%= lead.name %>', '<%= admin_lead_path(lead) %>')">
                      <i class="bi bi-trash me-2"></i>Delete Lead
                    </a></li>
                  </ul>
                </div>
              </div>
            </div>
            <div class="card-body pt-0">
              <h6 class="card-title mb-2"><%= lead.name %></h6>
              <div class="text-muted small mb-3">
                <div class="mb-1">
                  <i class="bi bi-telephone me-1"></i>
                  <%= lead.contact_number&.gsub(/^\+?91|^0/, '')&.strip %>
                </div>
                <% if lead.email.present? %>
                  <div class="mb-1">
                    <i class="bi bi-envelope me-1"></i>
                    <%= truncate(lead.email, length: 25) %>
                  </div>
                <% end %>
                <div class="mb-1">
                  <i class="bi bi-calendar me-1"></i>
                  <%= lead.created_date&.strftime('%d/%m/%Y') || lead.created_at&.strftime('%d/%m/%Y') %>
                </div>
              </div>

              <div class="mb-3">
                <div class="d-flex flex-wrap gap-1 mb-2">
                  <span class="badge bg-info"><%= lead.product_category&.humanize || 'N/A' %></span>
                  <% if lead.product_subcategory.present? %>
                    <span class="badge bg-outline-info text-info"><%= truncate(lead.product_subcategory, length: 15) %></span>
                  <% end %>
                </div>
                <div class="small text-muted">
                  <strong>Stage:</strong> <%= lead.current_stage&.humanize || 'Unknown' %>
                </div>
                <div class="small text-muted">
                  <strong>Affiliate:</strong>
                  <% if lead.is_direct %>
                    <span class="badge bg-warning text-dark">Direct</span>
                  <% else %>
                    <%= lead.affiliate&.full_name || 'N/A' %>
                  <% end %>
                </div>
              </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
              <div class="d-flex gap-1">
                <% if lead.can_convert_to_customer? %>
                  <% if lead.is_branch_out && lead.parent_lead_id.present? %>
                    <button type="button"
                            class="btn btn-sm btn-success convert-btn branch-out-convert flex-fill"
                            title="Convert Branch Out Lead to Customer"
                            data-lead-id="<%= lead.id %>"
                            data-parent-lead-id="<%= lead.parent_lead_id %>">
                      <i class="bi bi-person-plus-fill me-1"></i>Convert
                    </button>
                  <% else %>
                    <%= link_to convert_to_customer_admin_lead_path(lead), method: :patch,
                        class: "btn btn-sm btn-success convert-btn flex-fill",
                        title: "Convert to Customer" do %>
                      <i class="bi bi-person-plus-fill me-1"></i>Convert
                    <% end %>
                  <% end %>
                <% elsif lead.converted_customer.present? %>
                  <%= link_to admin_customer_path(lead.converted_customer),
                      class: "btn btn-sm btn-info customer-link flex-fill",
                      title: "View Customer: #{lead.converted_customer.display_name}" do %>
                    <i class="bi bi-person-check-fill me-1"></i>Customer
                  <% end %>
                <% else %>
                  <button class="btn btn-sm btn-outline-secondary flex-fill disabled" disabled>
                    <i class="bi bi-person-dash me-1"></i>N/A
                  </button>
                <% end %>

                <!-- Stage Convert Button -->
                <div class="dropdown">
                  <button class="btn btn-sm btn-outline-warning dropdown-toggle" data-bs-toggle="dropdown" title="Convert Stage">
                    <i class="bi bi-arrow-repeat"></i>
                  </button>
                  <ul class="dropdown-menu stage-conversion-menu">
                    <li class="dropdown-header">
                      <i class="bi bi-funnel me-1"></i>Stage Conversion
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li class="dropdown-item-text current-stage-display bg-light px-3 py-2">
                      <small class="text-muted d-block">Current Stage:</small>
                      <span class="badge bg-primary mt-1"><%= lead.current_stage&.humanize || 'Unknown' %></span>
                    </li>
                    <li><hr class="dropdown-divider"></li>

                    <% all_stages = [
                         { key: 'lead_generated', name: 'Lead Generated', icon: '🟢', color: 'secondary' },
                         { key: 'consultation_scheduled', name: 'Consultation', icon: '📅', color: 'info' },
                         { key: 'one_on_one', name: 'One-on-One', icon: '🤝', color: 'warning' },
                         { key: 'follow_up', name: 'Follow-Up', icon: '🔁', color: 'primary' },
                         { key: 'follow_up_successful', name: 'Follow-Up Success', icon: '✅', color: 'success' },
                         { key: 'follow_up_unsuccessful', name: 'Follow-Up Failed', icon: '❌', color: 'danger' },
                         { key: 'not_interested', name: 'Not Interested', icon: '🚫', color: 'dark' },
                         { key: 're_follow_up', name: 'Re-Follow Up', icon: '🔄', color: 'warning' },
                         { key: 'lead_closed', name: 'Lead Closed', icon: '📁', color: 'secondary' }
                       ] %>

                    <% all_stages.each do |stage| %>
                      <% if stage[:key] != lead.current_stage %>
                        <li>
                          <%= form_with url: convert_stage_admin_lead_path(lead, stage: stage[:key]),
                              method: :patch, local: true, style: "margin: 0; padding: 0; display: contents;",
                              onsubmit: "return confirm('Convert lead to \"#{stage[:name]}\" stage?')" do |f| %>
                            <button type="submit" class="dropdown-item border-0 bg-transparent w-100 text-start">
                              <span style="font-size: 1rem; width: 25px; display: inline-block;"><%= stage[:icon] %></span>
                              <span style="font-size: 0.85rem;"><%= stage[:name] %></span>
                            </button>
                          <% end %>
                        </li>
                      <% end %>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Pagination for Card View -->
    <% if @leads.respond_to?(:total_pages) && @leads.total_pages > 1 %>
      <div class="d-flex justify-content-center mt-4">
        <%= paginate @leads %>
      </div>
    <% end %>
  <% else %>
    <!-- Empty State for Card View -->
    <div class="text-center py-5">
      <div class="mb-4">
        <i class="bi bi-grid-3x3-gap text-muted" style="font-size: 4rem;"></i>
      </div>
      <h5 class="text-muted mb-3">No leads found</h5>
      <p class="text-muted mb-4">Start by creating your first lead or adjust your search filters.</p>
      <%= link_to "Add New Lead", new_admin_lead_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

