<!-- Lead Details Header -->
<div class="customer-header-card">
  <div class="d-flex justify-content-between align-items-start">
    <!-- Left Section with Lead Info -->
    <div class="d-flex align-items-center gap-3">
      <!-- Avatar/Icon -->
      <div class="customer-avatar">
        <div class="avatar-placeholder">
          <%= @lead.name&.first&.upcase || 'L' %>
        </div>
      </div>

      <!-- Lead Info -->
      <div>
        <h2 class="customer-name mb-2">Lead: <%= @lead.name %></h2>
        <div class="d-flex align-items-center gap-3 mb-2">
          <span class="badge customer-type-badge individual">
            ID: <%= @lead.lead_id %>
          </span>
          <span class="badge status-badge <%= @lead.current_stage == 'converted' ? 'active' : 'inactive' %>">
            <%= @lead.current_stage&.humanize || 'Unknown Stage' %>
          </span>
        </div>
        <div class="text-muted small">
          <i class="bi bi-calendar me-1"></i>Created: <%= @lead.created_at.strftime("%B %d, %Y") %>
        </div>
      </div>
    </div>

    <!-- Right Section with Actions -->
    <div class="text-end">
      <div class="d-flex gap-2 justify-content-end">
        <%= link_to admin_leads_path, class: "btn btn-outline-secondary btn-sm" do %>
          <i class="bi bi-arrow-left me-1"></i>Back to Leads
        <% end %>

        <!-- Conversion Action Button -->
        <% if @lead.can_convert_to_customer? %>
          <%= link_to new_admin_customer_path(lead_id: @lead.id), class: "btn btn-success btn-sm", title: "Convert this lead to customer" do %>
            <i class="bi bi-person-plus-fill me-1"></i>Convert to Customer
          <% end %>
        <% elsif @lead.converted_customer.present? %>
          <%= link_to admin_customer_path(@lead.converted_customer), class: "btn btn-info btn-sm customer-link",
              title: "View Customer: #{@lead.converted_customer.display_name}" do %>
            <i class="bi bi-person-check-fill me-1"></i>View Customer
          <% end %>
        <% end %>

        <button class="btn btn-info btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#leadStagesGuideModal">
          <i class="bi bi-question-circle me-1"></i>Lead Stages Guide
        </button>

        <div class="dropdown">
          <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
            <i class="bi bi-gear me-1"></i>Actions
          </button>
          <ul class="dropdown-menu">
            <li><%= link_to "Edit Lead", edit_admin_lead_path(@lead), class: "dropdown-item" %></li>
            <li><%= link_to "Add Notes", edit_admin_lead_path(@lead), class: "dropdown-item" %></li>
            <li><hr class="dropdown-divider"></li>
            <li>
              <%= link_to "#",
                  class: "dropdown-item text-danger delete-lead-btn",
                  data: {
                    "lead-id": @lead.id,
                    "lead-name": @lead.name,
                    "delete-url": admin_lead_path(@lead)
                  } do %>
                <i class="bi bi-trash me-2"></i>Delete Lead
              <% end %>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Lead Progress Timeline Section -->
<div class="info-section-card">
  <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#timelineCollapse" aria-expanded="false">
    <div class="d-flex align-items-center">
      <div class="section-icon">
        <i class="bi bi-diagram-3"></i>
      </div>
      <h5 class="section-title">Lead Progress Timeline</h5>
    </div>
    <i class="bi bi-chevron-down collapse-icon"></i>
  </div>
  <div id="timelineCollapse" class="collapse">
    <div class="section-body">
      <!-- Flow Legend -->
      <div class="mb-4 p-3 bg-light rounded">
        <h6 class="mb-2">
          <i class="bi bi-info-circle me-1"></i>Lead Flow Guide
        </h6>
        <div class="row">
          <div class="col-md-6">
            <small class="text-success">
              <strong>✅ Success Path:</strong> Lead Generated → Consultation → Discussion → Follow-Up → Success → Converted
            </small>
          </div>
          <div class="col-md-6">
            <small class="text-danger">
              <strong>❌ Alternative Path:</strong> Follow-Up → Unsuccessful → Re-Follow-Up → Not Interested → Closed
            </small>
          </div>
        </div>
      </div>

      <div class="timeline-container">
        <%
          # Define timeline stages with their proper flow
          timeline_stages = [
            { key: 'lead_generated', title: '🟢 Lead Generated', description: 'Initial lead entry into the system' },
            { key: 'consultation_scheduled', title: '📅 Consultation Scheduled', description: 'First contact and consultation setup' },
            { key: 'one_on_one', title: '🤝 One-on-One Discussion', description: 'Detailed discussion about insurance needs' },
            { key: 'follow_up', title: '🔁 Follow-Up', description: 'Follow-up to gauge customer interest' },
            { key: 'follow_up_successful', title: '✅ Follow-Up Successful', description: 'Customer shows interest and ready to proceed' },
            { key: 'converted', title: '👤 Converted to Customer', description: 'Lead successfully converted to customer' }
          ]

          # Define alternative flow stages that branch after follow_up
          alt_timeline_stages = [
            { key: 'follow_up_unsuccessful', title: '❌ Follow-Up Unsuccessful', description: 'Customer not interested at this time', is_alt_path: true },
            { key: 're_follow_up', title: '🔄 Re-Follow-Up', description: 'Second attempt to contact customer', is_alt_path: true },
            { key: 'not_interested', title: '❌ Not Interested', description: 'Customer declined insurance', is_alt_path: true },
            { key: 'closed', title: '🚫 Lead Closed', description: 'Lead marked as closed/complete', is_alt_path: true }
          ]

          # Combine all stages for rendering
          all_stages = timeline_stages + alt_timeline_stages

          # Successful path stages
          successful_path = ['lead_generated', 'consultation_scheduled', 'one_on_one', 'follow_up', 'follow_up_successful', 'converted']

          # Check if lead is on unsuccessful path
          is_on_unsuccessful_path = ['follow_up_unsuccessful', 're_follow_up', 'not_interested', 'closed'].include?(@lead.current_stage)

          # Get stage history if available
          stage_history = @lead.respond_to?(:stage_history) ? @lead.stage_history : {}
        %>

        <% all_stages.each_with_index do |stage, index| %>
          <%
            # Determine status for this stage
            current_stage_index = timeline_stages.map { |s| s[:key] }.index(@lead.current_stage) || -1
            this_stage_index = timeline_stages.map { |s| s[:key] }.index(stage[:key]) || -1

            # Status logic
            if stage[:key] == @lead.current_stage
              status = 'active'
              status_class = 'text-primary fw-bold'
              date_text = 'Currently at this stage'
            elsif (this_stage_index >= 0 && current_stage_index >= 0 && this_stage_index < current_stage_index) ||
                 (stage[:is_alt_path] && is_on_unsuccessful_path &&
                  ['follow_up_unsuccessful', 're_follow_up', 'not_interested'].include?(stage[:key]) &&
                  (['follow_up_unsuccessful', 're_follow_up', 'not_interested', 'closed'].index(@lead.current_stage) || 0) >=
                  (['follow_up_unsuccessful', 're_follow_up', 'not_interested', 'closed'].index(stage[:key]) || 0))
              status = 'completed'
              status_class = 'text-success'
              # Try to get actual date from stage history
              if stage_history[stage[:key]].present?
                date_text = Time.parse(stage_history[stage[:key]]).strftime("%b %d, %Y at %I:%M %p")
              else
                date_text = 'Completed'
              end
            else
              status = 'pending'
              status_class = 'text-muted'
              date_text = 'Not yet reached'
            end
          %>

          <!-- Timeline Stage -->
          <div class="timeline-item <%= status %> <%= 'alternative-path' if stage[:is_alt_path] %> <%= 'inaccessible' if is_on_unsuccessful_path && successful_path.include?(stage[:key]) && successful_path.index(stage[:key]) > successful_path.index('follow_up') %> <%= 'branching-point' if stage[:key] == 'follow_up' && is_on_unsuccessful_path %>">
            <div class="timeline-marker"></div>
            <div class="timeline-content">
              <h6><%= stage[:title] %></h6>
              <p class="text-muted mb-1"><%= stage[:description] %></p>
              <small class="<%= status_class %>"><%= date_text %></small>

              <!-- Show current path indicator -->
              <% if stage[:key] == @lead.current_stage %>
                <div class="mt-1">
                  <span class="badge bg-warning text-dark">
                    <i class="bi bi-geo-alt-fill me-1"></i>Current Stage
                  </span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

