<!-- Lead Stages Guide Modal -->
<div class="modal fade" id="leadStagesGuideModal" tabindex="-1" aria-labelledby="leadStagesGuideModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="leadStagesGuideModalLabel">
          <i class="bi bi-diagram-3 me-2"></i>Lead Stages Flow Guide
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="row">
