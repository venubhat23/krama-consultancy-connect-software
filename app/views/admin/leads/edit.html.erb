<!-- Form Validation Script -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.querySelector('form');
  const nameField = form.querySelector('[name="lead[name]"]');
  const phoneField = form.querySelector('[name="lead[contact_number]"]');
  const customerTypeField = document.getElementById('customer_type');
  const productCategoryField = document.getElementById('product_category');
  const productSubcategoryField = document.getElementById('product_subcategory');

  // Customer type conditional fields
  const individualFields = document.getElementById('individual_fields');
  const corporateFields = document.getElementById('corporate_fields');
  const generalFields = document.getElementById('general_fields');

  // Contact number validation — accepts +91 format, validates without overwriting user input
  function validateContactNumber(input) {
    const mobilePattern = /^[6-9]\d{9}$/;
    let rawValue = input.value.trim();
    let digits = rawValue.replace(/\D/g, '');

    // Strip country code prefix if present
    if (digits.length === 13 && digits.startsWith('91')) digits = digits.slice(2);
    else if (digits.length === 12 && digits.startsWith('91')) digits = digits.slice(2);
    else if (digits.length === 11 && digits.startsWith('0')) digits = digits.slice(1);

    // Remove previous custom feedback (preserve user's formatted input — do NOT change input.value)
    input.classList.remove('is-valid', 'is-invalid');
    const prev = input.parentNode.querySelector('.contact-feedback');
    if (prev) prev.remove();

    if (rawValue.length === 0) return;

    if (digits.length !== 10) {
      input.classList.add('is-invalid');
      const err = document.createElement('div');
      err.className = 'invalid-feedback contact-feedback';
      err.textContent = 'Mobile number must be exactly 10 digits';
      input.parentNode.appendChild(err);
    } else if (!mobilePattern.test(digits)) {
      input.classList.add('is-invalid');
      const err = document.createElement('div');
      err.className = 'invalid-feedback contact-feedback';
      err.textContent = 'Mobile number must start with 6, 7, 8, or 9';
      input.parentNode.appendChild(err);
    } else {
      input.classList.add('is-valid');
    }
  }

  phoneField.addEventListener('input', function() { validateContactNumber(this); });
  phoneField.addEventListener('blur', function() { validateContactNumber(this); });
  if (phoneField.value) validateContactNumber(phoneField);

  // Handle direct lead checkbox
  const directLeadCheckbox = document.getElementById('direct_lead_checkbox');
  const referredByField = document.getElementById('referred_by_field');
  const affiliateSelection = document.getElementById('affiliate_selection');

  if (directLeadCheckbox && referredByField && affiliateSelection) {
    directLeadCheckbox.addEventListener('change', function() {
      if (this.checked) {
        // Direct lead - hide both affiliate and referred by fields
        affiliateSelection.style.display = 'none';
        referredByField.style.display = 'none';

        // Clear values
        const affiliateDropdown = document.getElementById('affiliate_dropdown_edit');
        const referredByInput = referredByField.querySelector('input');
        if (affiliateDropdown) affiliateDropdown.value = '';
        if (referredByInput) referredByInput.value = '';
      } else {
        // Referred lead - show both affiliate and referred by fields
        affiliateSelection.style.display = 'block';
        referredByField.style.display = 'block';
      }
    });
  }

  // Handle customer type change
  if (customerTypeField) {
    customerTypeField.addEventListener('change', function() {
      const selectedType = this.value;

      // Hide all customer type specific fields
      if (individualFields) individualFields.style.display = 'none';
      if (corporateFields) corporateFields.style.display = 'none';
      if (generalFields) generalFields.style.display = 'none';

      // Clear required attributes from all fields
      const allInputs = form.querySelectorAll('#individual_fields input, #individual_fields select, #corporate_fields input, #corporate_fields select');
      allInputs.forEach(input => {
        input.removeAttribute('required');
      });

      if (selectedType === 'individual') {
        if (individualFields) individualFields.style.display = 'block';
        if (generalFields) generalFields.style.display = 'block';

        // Set required fields for individual
        const firstNameField = form.querySelector('[name="lead[first_name]"]');
        const lastNameField = form.querySelector('[name="lead[last_name]"]');
        if (firstNameField) firstNameField.setAttribute('required', 'required');
        if (lastNameField) lastNameField.setAttribute('required', 'required');
      } else if (selectedType === 'corporate') {
        if (corporateFields) corporateFields.style.display = 'block';
        if (generalFields) generalFields.style.display = 'block';

        // Set required fields for corporate
        const companyNameField = form.querySelector('[name="lead[company_name]"]');
        const emailField = form.querySelector('#corporate_fields [name="lead[email]"]');
        if (companyNameField) companyNameField.setAttribute('required', 'required');
        if (emailField) emailField.setAttribute('required', 'required');
      }
    });
  }

  // Product category handling
  const subcategoryOptions = {
    'insurance': [
      ['Life Insurance', 'life'],
      ['Health Insurance', 'health'],
      ['Motor Insurance', 'motor'],
      ['General Insurance', 'general'],
      ['Travel Insurance', 'travel'],
      ['General Insurance', 'other']
    ],
    'investments': [
      ['Mutual Fund', 'mutual_fund'],
      ['Gold', 'gold'],
      ['NPS', 'nps'],
      ['Bonds', 'bonds'],
      ['Other', 'other']
    ],
    'loans': [
      ['Personal Loan', 'personal'],
      ['Home Loan', 'home'],
      ['Business Loan', 'business'],
      ['Other', 'other']
    ],
    'taxation': [
      ['ITR', 'itr'],
      ['Other', 'other']
    ]
  };

  if (productCategoryField && productSubcategoryField) {
    // Load subcategories on page load if category is already selected
    const currentCategory = productCategoryField.value;
    if (currentCategory && subcategoryOptions[currentCategory]) {
      productSubcategoryField.innerHTML = '<option value="">Select Product Type</option>';
      subcategoryOptions[currentCategory].forEach(function(option) {
        const optionElement = document.createElement('option');
        optionElement.value = option[1];
        optionElement.textContent = option[0];
        if (optionElement.value === productSubcategoryField.dataset.selected) {
          optionElement.selected = true;
        }
        productSubcategoryField.appendChild(optionElement);
      });
      productSubcategoryField.disabled = false;
    }

    // Handle both native change and Select2 change events
    productCategoryField.addEventListener('change', function() {
      const selectedCategory = this.value;
      handleCategoryChange(selectedCategory);
    });

    // Also handle Select2 change event
    $('#product_category').on('select2:select', function (e) {
      const selectedValue = e.params.data.id;
      handleCategoryChange(selectedValue);
    });

    function handleCategoryChange(selectedCategory) {
      // First destroy Select2 on subcategory if it exists
      const $subcategorySelect = $(productSubcategoryField);
      if ($subcategorySelect.hasClass('select2-hidden-accessible')) {
        $subcategorySelect.select2('destroy');
      }

      productSubcategoryField.innerHTML = '<option value="">Select Product Type</option>';

      if (selectedCategory && subcategoryOptions[selectedCategory]) {
        productSubcategoryField.disabled = false;
        subcategoryOptions[selectedCategory].forEach(function(option) {
          const optionElement = document.createElement('option');
          optionElement.value = option[1];
          optionElement.textContent = option[0];
          productSubcategoryField.appendChild(optionElement);
        });

        // Reinitialize Select2 for the subcategory dropdown
        setTimeout(() => {
          $subcategorySelect.select2({
            theme: 'bootstrap-5',
            placeholder: 'Search and select product type...',
            allowClear: true,
            width: '100%',
            minimumResultsForSearch: 0,
            dropdownParent: $('body')
          });
        }, 50);
      } else {
        productSubcategoryField.disabled = true;
      }
    }
  }

  // Native HTML5 date picker is now used - no additional formatting needed

  // Form validation
  form.addEventListener('submit', function(e) {
    // Ensure Select2 values are properly synced to underlying select elements
    if (typeof $ !== 'undefined' && $.fn.select2) {
      // Sync city value from Select2
      const $citySelect = $('#lead_city');
      if ($citySelect.hasClass('select2-hidden-accessible')) {
        const cityValue = $citySelect.val();
        if (cityValue) {
          leadCitySelect.value = cityValue;
          console.log('City value synced:', cityValue);
        }
      }

      // Sync state value from Select2
      const $stateSelect = $('#lead_state');
      if ($stateSelect.hasClass('select2-hidden-accessible')) {
        const stateValue = $stateSelect.val();
        if (stateValue) {
          leadStateSelect.value = stateValue;
          console.log('State value synced:', stateValue);
        }
      }
    }

    let isValid = true;
    const errors = [];

    // Validate name
    if (nameField.value.trim().length < 2) {
      errors.push('Lead name must be at least 2 characters long');
      isValid = false;
    }

    // Validate phone — strip +91/91/0 prefix before validating and submitting
    let cleanPhone = phoneField.value.replace(/\D/g, '');
    if (cleanPhone.length === 12 && cleanPhone.startsWith('91')) cleanPhone = cleanPhone.slice(2);
    else if (cleanPhone.length === 13 && cleanPhone.startsWith('91')) cleanPhone = cleanPhone.slice(2);
    else if (cleanPhone.length === 11 && cleanPhone.startsWith('0')) cleanPhone = cleanPhone.slice(1);
    phoneField.value = cleanPhone; // update field so server receives clean 10-digit number

    const phoneRegex = /^[6-9]\d{9}$/;
    if (!phoneRegex.test(cleanPhone)) {
      errors.push('Please enter a valid Indian mobile number (10 digits starting with 6-9)');
      isValid = false;
    }

    // Validate product category and subcategory selection
    if (!productCategoryField || !productCategoryField.value) {
      errors.push('Please select a product category');
      isValid = false;
    }

    if (!productSubcategoryField || !productSubcategoryField.value) {
      errors.push('Please select a product type');
      isValid = false;
    }

    // Debug logging for city and state values
    console.log('Final form submission (edit) - City value:', leadCitySelect ? leadCitySelect.value : 'N/A');
    console.log('Final form submission (edit) - State value:', leadStateSelect ? leadStateSelect.value : 'N/A');

    // HTML5 date field handles date validation automatically

    if (!isValid) {
      e.preventDefault();
      alert('Please fix the following errors:\n' + errors.join('\n'));
    }
  });

  // Simple State-City Dropdown for Lead Edit Form
  const leadStateSelect = document.getElementById('lead_state');
  const leadCitySelect = document.getElementById('lead_city');

  // Use global location data or API fallback
  let leadCitiesData = {};

  if (window.LocationData && window.LocationData.states) {
    leadCitiesData = Object.keys(window.LocationData.states).reduce((acc, key) => {
      acc[key] = window.LocationData.states[key].cities;
      return acc;
    }, {});
  }

  function loadLeadCitiesForState(stateValue, selectedCityValue = null) {
    console.log('Loading cities for lead edit form:', stateValue);
    console.log('Selected city to set:', selectedCityValue);

    if (!stateValue) {
      leadCitySelect.innerHTML = '<option value="">Select State First</option>';
      leadCitySelect.disabled = true;
      return;
    }

    let cities = [];

    // Try to get cities from location data using multiple methods
    if (window.LocationData && window.LocationData.states) {
      // Method 1: Direct key match
      cities = leadCitiesData[stateValue] || [];
      console.log('Direct key match cities:', cities.length);

      // Method 2: Match by state name if direct key fails
      if (cities.length === 0) {
        Object.keys(window.LocationData.states).forEach(key => {
          const stateData = window.LocationData.states[key];
          if (stateData.name === stateValue || key === stateValue) {
            cities = stateData.cities || [];
            console.log('Found by state name match:', cities.length);
          }
        });
      }

      // Method 3: Case-insensitive search
      if (cities.length === 0) {
        const stateLower = stateValue.toLowerCase();
        Object.keys(window.LocationData.states).forEach(key => {
          const stateData = window.LocationData.states[key];
          if (stateData.name.toLowerCase() === stateLower || key.toLowerCase() === stateLower) {
            cities = stateData.cities || [];
            console.log('Found by case-insensitive match:', cities.length);
          }
        });
      }
    }

    if (cities.length > 0) {
      populateCityDropdownWithSelection(cities, selectedCityValue);
    } else {
      console.warn('No cities found for state:', stateValue, 'using fallback');
      // Fallback: populate with empty and try to preserve selected city
      populateCityDropdownWithSelection([], selectedCityValue);
    }
  }

  function populateCityDropdown(cities, selectedCityValue = null) {
    // First destroy Select2 if it exists
    const $leadCitySelect = $(leadCitySelect);
    if ($leadCitySelect.hasClass('select2-hidden-accessible')) {
      $leadCitySelect.select2('destroy');
    }

    // Get the saved city from either parameter or data attribute
    const savedCity = selectedCityValue || leadCitySelect.dataset.savedCity || '<%= @lead&.city || "" %>';

    // Clear dropdown and add cities
    leadCitySelect.innerHTML = '<option value="">Select City</option>';

    // Track if saved city is found in the list
    let savedCityFound = false;

    // If cities are available, populate them
    if (cities && cities.length > 0) {
      cities.forEach(city => {
        const option = document.createElement('option');
        option.value = city;
        option.textContent = city;
        if (savedCity && city === savedCity) {
          option.selected = true;
          savedCityFound = true;
        }
        leadCitySelect.appendChild(option);
      });
      leadCitySelect.disabled = false;
    }

    // If saved city wasn't in the list but exists, add it as an option
    if (savedCity && !savedCityFound) {
      const option = document.createElement('option');
      option.value = savedCity;
      option.textContent = savedCity;
      option.selected = true;
      leadCitySelect.appendChild(option);
      leadCitySelect.disabled = false;
      console.log('Added saved city as additional option:', savedCity);
    }

    // Ensure city is disabled only if no state is selected and no saved city
    if (!cities.length && !savedCity) {
      leadCitySelect.disabled = true;
    }

    console.log(`Loaded ${cities.length} cities for leads edit form, selected: ${savedCity}`);

    // Reinitialize Select2
    setTimeout(() => {
      $leadCitySelect.select2({
        theme: 'bootstrap-5',
        placeholder: 'Search and select city...',
        allowClear: false, // Changed to prevent clearing
        width: '100%',
        minimumResultsForSearch: 0
      });

      // Add change event handler to ensure value is properly set
      $leadCitySelect.on('select2:select', function(e) {
        const selectedCity = e.params.data.id;
        leadCitySelect.value = selectedCity;
        console.log('City selected via Select2:', selectedCity);
      });

      // Ensure the saved city is selected in Select2
      if (savedCity && leadCitySelect.value === savedCity) {
        $leadCitySelect.val(savedCity).trigger('change.select2');
      }
    }, 50);
  }

  function populateCityDropdownWithSelection(cities, selectedCityValue = null) {
    // First destroy Select2 if it exists
    const $leadCitySelect = $(leadCitySelect);
    if ($leadCitySelect.hasClass('select2-hidden-accessible')) {
      $leadCitySelect.select2('destroy');
    }

    // Get the saved city from parameter or lead data
    const savedCity = selectedCityValue || '<%= @lead&.city || "" %>';
    console.log('Populating cities with selection:', savedCity);

    // Clear dropdown and add cities
    leadCitySelect.innerHTML = '<option value="">Select City</option>';

    // Track if saved city is found in the list
    let savedCityFound = false;

    // If cities are available, populate them
    if (cities && cities.length > 0) {
      cities.forEach(city => {
        const option = document.createElement('option');
        option.value = city;
        option.textContent = city;
        if (savedCity && city === savedCity) {
          option.selected = true;
          savedCityFound = true;
          console.log('Found and selected saved city:', city);
        }
        leadCitySelect.appendChild(option);
      });
      leadCitySelect.disabled = false;
    }

    // If saved city wasn't in the list but exists, add it as an option
    if (savedCity && !savedCityFound) {
      const option = document.createElement('option');
      option.value = savedCity;
      option.textContent = savedCity;
      option.selected = true;
      leadCitySelect.appendChild(option);
      leadCitySelect.disabled = false;
      console.log('Added saved city as additional option:', savedCity);
      savedCityFound = true;
    }

    // Ensure city is disabled only if no state is selected and no saved city
    if (!cities.length && !savedCity) {
      leadCitySelect.disabled = true;
    }

    console.log(`Loaded ${cities.length} cities for leads edit form, selected: ${savedCity}, found: ${savedCityFound}`);

    // Reinitialize Select2
    setTimeout(() => {
      $leadCitySelect.select2({
        theme: 'bootstrap-5',
        placeholder: 'Search and select city...',
        allowClear: false,
        width: '100%',
        minimumResultsForSearch: 0
      });

      // Add change event handler to ensure value is properly set
      $leadCitySelect.on('select2:select', function(e) {
        const selectedCity = e.params.data.id;
        leadCitySelect.value = selectedCity;
        console.log('City selected via Select2:', selectedCity);
      });

      // Force set the saved city value in Select2
      if (savedCity && savedCityFound) {
        $leadCitySelect.val(savedCity);
        $leadCitySelect.trigger('change.select2');
        console.log('Forced Select2 to show saved city:', savedCity);
      }
    }, 100);
  }

  // Setup lead edit form state-city functionality
  if (leadStateSelect && leadCitySelect) {
    // Initialize state dropdown with Select2
    if (typeof $ !== 'undefined' && $.fn.select2) {
      $(leadStateSelect).select2({
        theme: 'bootstrap-5',
        placeholder: 'Search and select state...',
        allowClear: false, // Changed to prevent clearing
        width: '100%',
        minimumResultsForSearch: 0
      });

      $(leadCitySelect).select2({
        theme: 'bootstrap-5',
        placeholder: 'Search and select city...',
        allowClear: false, // Changed to prevent clearing
        width: '100%',
        minimumResultsForSearch: 0
      });

      // Add change event handler to ensure state value is properly set
      $(leadStateSelect).on('select2:select', function(e) {
        const selectedState = e.params.data.id;
        leadStateSelect.value = selectedState;
        console.log('State selected via Select2:', selectedState);
        loadLeadCitiesForState(selectedState);
      });

      // Add change event handler for city to ensure value is properly set
      $(leadCitySelect).on('select2:select', function(e) {
        const selectedCity = e.params.data.id;
        leadCitySelect.value = selectedCity;
        console.log('City selected via Select2:', selectedCity);
      });
    }

    leadStateSelect.addEventListener('change', function() {
      loadLeadCitiesForState(this.value);
    });

    // Load cities if state is pre-selected (improved initialization)
    const savedState = '<%= @lead&.state || "" %>';
    const savedCity = '<%= @lead&.city || "" %>';

    console.log('Initializing lead edit form with saved state:', savedState, 'and city:', savedCity);

    // Initialize Select2 first, then check state value
    setTimeout(() => {
      console.log('Starting edit form initialization...');
      console.log('Saved state:', savedState);
      console.log('Saved city:', savedCity);
      console.log('Lead state select value:', leadStateSelect.value);

      // Check if state is present (either from saved value or dropdown)
      const currentState = savedState || leadStateSelect.value;

      if (currentState && currentState !== '') {
        console.log('Processing state:', currentState);

        // Try to find the state in dropdown options
        const stateOption = Array.from(leadStateSelect.options).find(option =>
          option.value === currentState || option.text === currentState
        );

        if (stateOption) {
          // Set the state value
          leadStateSelect.value = stateOption.value;
          $('#lead_state').val(stateOption.value).trigger('change.select2');
          console.log('Set state dropdown to:', stateOption.value);

          // Load cities for this state after a small delay to ensure Select2 is ready
          setTimeout(() => {
            loadLeadCitiesForState(stateOption.value, savedCity);
          }, 100);
        } else {
          // State not in dropdown, but still try to load cities
          loadLeadCitiesForState(currentState, savedCity);
        }
      } else {
        console.log('No state found, checking if city exists');
        // If there's a saved city but no state, still show it
        if (savedCity && savedCity !== '') {
          console.log('Saved city exists without state, adding it manually');
          const $leadCitySelect = $(leadCitySelect);
          leadCitySelect.disabled = false;

          // Clear and add the saved city option
          leadCitySelect.innerHTML = '<option value="">Select City</option>';
          const option = document.createElement('option');
          option.value = savedCity;
          option.textContent = savedCity;
          option.selected = true;
          leadCitySelect.appendChild(option);
          console.log('Added saved city option:', savedCity);

          // Initialize Select2 and set the value
          setTimeout(() => {
            if (!$leadCitySelect.hasClass('select2-hidden-accessible')) {
              $leadCitySelect.select2({
                theme: 'bootstrap-5',
                placeholder: 'Search and select city...',
                allowClear: false,
                width: '100%',
                minimumResultsForSearch: 0
              });
            }
            $leadCitySelect.val(savedCity).trigger('change.select2');
            console.log('Forced city selection:', savedCity);
          }, 150);
        }
      }
    }, 500); // Increased delay to ensure all scripts are loaded
  }

  // Initialize affiliate dropdown with Select2 for edit form
  const affiliateDropdownEdit = document.getElementById('affiliate_dropdown_edit');
  if (affiliateDropdownEdit && typeof $ !== 'undefined' && $.fn.select2) {
    $(affiliateDropdownEdit).select2({
      theme: 'bootstrap-5',
      placeholder: 'Search and select affiliate...',
      allowClear: true,
      width: '100%',
      dropdownParent: $('body'),
      minimumInputLength: 0, // Allow opening without typing
      ajax: {
        url: '/admin/leads/search_sub_agents',
        dataType: 'json',
        delay: 250,
        data: function (params) {
          return {
            q: params.term || '', // Send empty query to get default results
            limit: params.term ? 20 : 10 // Show fewer results when no search term
          };
        },
        processResults: function (data) {
          return {
            results: data.results || []
          };
        },
        cache: true
      },
      templateResult: function(option) {
        if (option.loading) return option.text;
        if (!option.id || option.id === '') {
          return option.text;
        }

        // Enhanced template with avatar
        var initials = option.text.split(' ').map(function(name) {
          return name.charAt(0).toUpperCase();
        }).join('').substring(0, 2);

        var $option = $(
          '<div class="affiliate-option d-flex align-items-center">' +
            '<div class="affiliate-avatar bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 12px; font-weight: bold;">' +
              initials +
            '</div>' +
            '<div class="affiliate-details">' +
              '<div class="affiliate-name" style="font-weight: 500;">' + option.text + '</div>' +
              '<small class="text-muted">ID: #' + option.id + '</small>' +
            '</div>' +
          '</div>'
        );
        return $option;
      },
      templateSelection: function(option) {
        return option.text || 'Search and select affiliate...';
      },
      escapeMarkup: function(markup) {
        return markup;
      }
    });
  }

  // Initialize all searchable dropdowns with Select2
  function initializeSearchableDropdowns() {
    if (typeof $ !== 'undefined' && $.fn.select2) {
      // Initialize all dropdowns with searchable-select class
      $('.searchable-select').each(function() {
        const $element = $(this);
        const placeholder = $element.data('placeholder') || 'Search and select...';

        // Skip if already initialized
        if ($element.hasClass('select2-hidden-accessible')) {
          return;
        }

        $element.select2({
          theme: 'bootstrap-5',
          placeholder: placeholder,
          allowClear: true,
          width: '100%',
          minimumResultsForSearch: 0,
          dropdownParent: $('body')
        });
      });
    }
  }

  // Initialize searchable dropdowns after DOM is ready
  setTimeout(() => {
    initializeSearchableDropdowns();

    // Explicitly initialize Product Category with Select2 if not already initialized
    if (typeof $ !== 'undefined' && $.fn.select2) {
      const $productCategory = $('#product_category');
      if (!$productCategory.hasClass('select2-hidden-accessible')) {
        $productCategory.select2({
          theme: 'bootstrap-5',
          placeholder: 'Search and select category...',
          allowClear: true,
          width: '100%',
          minimumResultsForSearch: 0,
          dropdownParent: $('body')
        });
      }
    }
  }, 100);

  // Reinitialize product subcategory when options are updated
  if (productCategoryField && productSubcategoryField) {
    const originalProductCategoryHandler = productCategoryField.onchange;
    productCategoryField.addEventListener('change', function() {
      // Call original handler first
      if (originalProductCategoryHandler) {
        originalProductCategoryHandler.call(this);
      }

      // Destroy and reinitialize Select2 for product subcategory
      const $subcategorySelect = $(productSubcategoryField);
      if ($subcategorySelect.hasClass('select2-hidden-accessible')) {
        $subcategorySelect.select2('destroy');
      }

      setTimeout(() => {
        $subcategorySelect.select2({
          theme: 'bootstrap-5',
          placeholder: 'Search and select product type...',
          allowClear: true,
          width: '100%',
          minimumResultsForSearch: 0,
          dropdownParent: $('body')
        });
      }, 50);
    });
  }

});
</script>