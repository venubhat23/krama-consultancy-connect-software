<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-1"><%= @announcement.title %></h2>
  <%= link_to edit_admin_platform_announcement_path(@announcement), class: "btn btn-outline-primary" do %><i class="bi bi-pencil me-1"></i>Edit<% end %>
</div>
<div class="card border-0 shadow-sm"><div class="card-body">
  <p><%= simple_format @announcement.body %></p>
  <hr>
  <p class="text-muted mb-0">
    Audience: <%= @announcement.audience.humanize %><br>
    Posted <%= @announcement.published_at&.strftime("%b %d, %Y %I:%M %p") || "not yet published" %> by <%= @announcement.created_by.full_name %>
  </p>
</div></div>
