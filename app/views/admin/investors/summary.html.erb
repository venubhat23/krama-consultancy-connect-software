<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Investor Summary — <%= @investor.display_name %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <style>
    :root {
      --primary: #2c3e7a;
      --accent:  #e8a020;
      --green:   #27ae60;
      --orange:  #e67e22;
      --blue:    #2980b9;
      --purple:  #8e44ad;
      --red:     #e74c3c;
    }
    body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; }

    /* ── Header ── */
    .inv-header {
      background: linear-gradient(135deg, #1a2550 0%, #2c3e7a 60%, #3a5298 100%);
      color: #fff;
      padding: 2rem 2.5rem;
    }
    .inv-header .badge-status {
      background: rgba(255,255,255,.15);
      border: 1px solid rgba(255,255,255,.3);
      padding: .35em .8em;
      border-radius: 20px;
      font-size: .8rem;
      letter-spacing: .5px;
    }
    .inv-header .badge-status.active  { background: rgba(39,174,96,.3); border-color: #27ae60; }
    .inv-header .badge-status.inactive{ background: rgba(231,76,60,.3);  border-color: #e74c3c; }

    /* ── KPI strip ── */
    .kpi-strip { display: flex; gap: .75rem; flex-wrap: nowrap; padding: 1.5rem 2.5rem; }
    .kpi-card {
      flex: 1 1 0; min-width: 0;
      background: #fff;
      border-radius: 12px;
      padding: 1.1rem 1.2rem;
      box-shadow: 0 2px 12px rgba(0,0,0,.07);
      border-top: 4px solid var(--c, #2c3e7a);
    }
    .kpi-card .kpi-val { font-size: 1.45rem; font-weight: 700; color: var(--c, #2c3e7a); }
    .kpi-card .kpi-lbl { font-size: .72rem; color: #6c757d; text-transform: uppercase; letter-spacing: .6px; margin-top: .15rem; }

    /* ── Section heading ── */
    .sec-title {
      font-size: 1rem; font-weight: 700; letter-spacing: .4px;
      color: #fff; background: var(--c, var(--primary));
      padding: .6rem 1.2rem; border-radius: 8px 8px 0 0; margin: 0;
    }

    /* ── Ambassador card ── */
    .amb-card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 14px rgba(0,0,0,.07);
      overflow: hidden;
      margin-bottom: 1.5rem;
    }
    .amb-header {
      background: linear-gradient(90deg, #f8f9ff 0%, #eef1ff 100%);
      padding: .9rem 1.3rem;
      border-bottom: 1px solid #e4e8ff;
      display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    }
    .amb-avatar {
      width: 46px; height: 46px; border-radius: 50%;
      background: linear-gradient(135deg, var(--primary), #3a5298);
      color: #fff; display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 1.1rem; flex-shrink: 0;
    }
    .amb-meta .name { font-size: 1rem; font-weight: 700; color: #2c3e7a; }
    .amb-meta .sub  { font-size: .78rem; color: #6c757d; }
    .amb-pills { margin-left: auto; display: flex; gap: .5rem; flex-wrap: wrap; }
    .pill {
      padding: .3em .85em; border-radius: 20px; font-size: .75rem; font-weight: 600;
      display: flex; align-items: center; gap: .3rem;
    }
    .pill-green  { background: #eafaf1; color: #27ae60; border: 1px solid #a9dfbf; }
    .pill-orange { background: #fef9ec; color: #e67e22; border: 1px solid #f9d8a0; }
    .pill-blue   { background: #eaf4fb; color: #2980b9; border: 1px solid #aed6f1; }
    .pill-purple { background: #f5eef8; color: #8e44ad; border: 1px solid #d7bde2; }

    /* ── Affiliate accordion ── */
    .aff-section { padding: 1rem 1.3rem; border-top: 1px solid #f0f0f0; }
    .aff-toggle {
      background: none; border: none; padding: .35rem .75rem;
      font-size: .85rem; font-weight: 600; color: var(--primary); cursor: pointer;
      display: flex; align-items: center; gap: .4rem;
      border: 1px solid #c5ceff; border-radius: 6px;
      background: #f5f7ff;
      transition: background .15s, color .15s;
    }
    .aff-toggle:hover { background: #e8eeff; color: var(--accent); }
    .aff-toggle .chev {
      font-size: .72rem;
      transition: transform .25s ease;
      display: inline-block;
    }
    .aff-toggle[aria-expanded="true"] .chev { transform: rotate(180deg); }
    .aff-toggle[aria-expanded="false"] .chev { transform: rotate(0deg); }

    /* ── Tables ── */
    .data-table { font-size: .82rem; }
    .data-table th { background: #f8f9fa; font-weight: 600; color: #495057; border: none; padding: .6rem .8rem; }
    .data-table td { border-color: #f0f0f0; padding: .55rem .8rem; vertical-align: middle; }
    .data-table tbody tr:hover { background: #f8f9ff; }
    .amount-cell { font-weight: 600; }
    .paid-amt    { color: #27ae60; }
    .pending-amt { color: #e67e22; }
    .zero-amt    { color: #adb5bd; }

    /* ── Policy table section ── */
    .policy-section {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 14px rgba(0,0,0,.07);
      overflow: hidden;
      margin-bottom: 1.5rem;
    }
    .policy-section .sec-body { padding: 1.2rem; }

    /* ── No data ── */
    .empty-state { text-align: center; padding: 2.5rem 1rem; color: #adb5bd; }
    .empty-state i { font-size: 2.5rem; display: block; margin-bottom: .5rem; }

    /* ── Print ── */
    .print-btn {
      position: fixed; bottom: 1.5rem; right: 1.5rem;
      background: var(--primary); color: #fff; border: none;
      border-radius: 50px; padding: .65rem 1.3rem;
      font-size: .85rem; font-weight: 600; box-shadow: 0 4px 16px rgba(44,62,122,.35);
      cursor: pointer; z-index: 999;
    }
    .print-btn:hover { background: #1a2550; }
    @media print {
      .print-btn { display: none; }
      body { background: #fff; }
      .kpi-strip { flex-wrap: wrap; }
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .kpi-strip { flex-wrap: wrap; }
      .kpi-card  { flex: 1 1 45%; }
      .inv-header { padding: 1.2rem 1rem; }
    }
  </style>
</head>
<body>

<!-- ═══════════════════════════════ HEADER ═══════════════════════════════ -->
<div class="inv-header">
  <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
    <div>
      <div class="d-flex align-items-center gap-2 mb-1">
        <span style="font-size:.8rem; opacity:.7; letter-spacing:.5px; text-transform:uppercase;">Investor Summary</span>
        <span class="badge-status <%= @investor.status %>"><%= @investor.status&.capitalize %></span>
      </div>
      <h1 style="font-size:1.8rem; font-weight:800; margin:0 0 .3rem;">
        <%= @investor.display_name %>
      </h1>
      <div style="opacity:.75; font-size:.85rem; display:flex; gap:1.2rem; flex-wrap:wrap;">
        <% if @investor.email.present? %>
          <span><i class="bi bi-envelope me-1"></i><%= @investor.email %></span>
        <% end %>
        <% if @investor.mobile.present? %>
          <span><i class="bi bi-telephone me-1"></i><%= @investor.mobile %></span>
        <% end %>
        <span><i class="bi bi-calendar me-1"></i>Joined <%= @investor.created_at.strftime('%d %b %Y') %></span>
      </div>
    </div>
    <div class="text-end">
      <% if @investor.invested_amount.present? && @investor.invested_amount > 0 %>
        <div style="font-size:.75rem; opacity:.65; text-transform:uppercase; letter-spacing:.5px;">Total Invested</div>
        <div style="font-size:1.6rem; font-weight:800;"><%= indian_currency(@investor.invested_amount.to_f.round(0)) %></div>
      <% end %>
      <% if @investor.investment_percentage.present? && @investor.investment_percentage > 0 %>
        <div style="margin-top:.2rem; font-size:.85rem; opacity:.8;"><i class="bi bi-pie-chart me-1"></i><%= @investor.investment_percentage %>% Profit Share</div>
      <% end %>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════ KPI STRIP ══════════════════════════════ -->
<div class="kpi-strip">
  <div class="kpi-card" style="--c:#2c3e7a">
    <div class="kpi-val"><%= @total_ambassadors %></div>
    <div class="kpi-lbl"><i class="bi bi-person-badge me-1"></i>Ambassadors</div>
  </div>
  <div class="kpi-card" style="--c:#e67e22">
    <div class="kpi-val"><%= @total_affiliates %></div>
    <div class="kpi-lbl"><i class="bi bi-people me-1"></i>Affiliates</div>
  </div>
  <div class="kpi-card" style="--c:#27ae60">
    <div class="kpi-val"><%= @total_direct_policies %></div>
    <div class="kpi-lbl"><i class="bi bi-file-earmark-check me-1"></i>Direct Policies</div>
  </div>
  <div class="kpi-card" style="--c:#2980b9">
    <div class="kpi-val" style="font-size:1.2rem;"><%= indian_currency((@investor_commission_paid + @investor_commission_pending).round(2)) %></div>
    <div class="kpi-lbl"><i class="bi bi-cash-coin me-1"></i>Your Commission</div>
  </div>
  <div class="kpi-card" style="--c:#8e44ad">
    <div class="kpi-val" style="font-size:1.2rem;"><%= indian_currency((@total_ambassador_comm + @total_affiliate_comm).round(0)) %></div>
    <div class="kpi-lbl"><i class="bi bi-diagram-3 me-1"></i>Network Commission</div>
  </div>
  <div class="kpi-card" style="--c:#16a085">
    <div class="kpi-val" style="font-size:1.2rem;"><%= indian_currency((@total_network_premium + @total_direct_premium).round(0)) %></div>
    <div class="kpi-lbl"><i class="bi bi-currency-rupee me-1"></i>Total Premium</div>
  </div>
</div>

<div class="container-fluid px-4 pb-5">

  <!-- ══════════════════ YOUR COMMISSION BREAKDOWN ══════════════════ -->
  <div class="policy-section mb-4">
    <div class="sec-title d-flex align-items-center gap-2" style="--c:#2c3e7a">
      <i class="bi bi-cash-coin"></i> Your Commission Breakdown
      <small style="font-size:.72rem; font-weight:400; opacity:.8;">Click a card for policy details</small>
    </div>
    <div class="sec-body">
      <div class="row g-3">
        <div class="col-md-4">
          <div class="p-3 rounded comm-breakdown-card" data-filter="paid"
               style="background:#eafaf1; border:1px solid #a9dfbf; cursor:pointer; transition:box-shadow .15s;"
               data-bs-toggle="modal" data-bs-target="#commissionModal">
            <div style="font-size:.75rem; color:#27ae60; text-transform:uppercase; font-weight:600; letter-spacing:.5px;">
              <i class="bi bi-check-circle me-1"></i>Commission Paid
            </div>
            <div style="font-size:1.6rem; font-weight:800; color:#27ae60;"><%= indian_currency(@investor_commission_paid.round(2)) %></div>
            <div style="font-size:.72rem; color:#27ae60; margin-top:.2rem; opacity:.7;"><i class="bi bi-eye me-1"></i>View policies</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-3 rounded comm-breakdown-card" data-filter="pending"
               style="background:#fef9ec; border:1px solid #f9d8a0; cursor:pointer; transition:box-shadow .15s;"
               data-bs-toggle="modal" data-bs-target="#commissionModal">
            <div style="font-size:.75rem; color:#e67e22; text-transform:uppercase; font-weight:600; letter-spacing:.5px;">
              <i class="bi bi-hourglass-split me-1"></i>Commission Pending
            </div>
            <div style="font-size:1.6rem; font-weight:800; color:#e67e22;"><%= indian_currency(@investor_commission_pending.round(2)) %></div>
            <div style="font-size:.72rem; color:#e67e22; margin-top:.2rem; opacity:.7;"><i class="bi bi-eye me-1"></i>View policies</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-3 rounded comm-breakdown-card" data-filter="all"
               style="background:#eaf4fb; border:1px solid #aed6f1; cursor:pointer; transition:box-shadow .15s;"
               data-bs-toggle="modal" data-bs-target="#commissionModal">
            <div style="font-size:.75rem; color:#2980b9; text-transform:uppercase; font-weight:600; letter-spacing:.5px;">
              <i class="bi bi-bar-chart-line me-1"></i>Total Commission
            </div>
            <div style="font-size:1.6rem; font-weight:800; color:#2980b9;"><%= indian_currency((@investor_commission_paid + @investor_commission_pending).round(2)) %></div>
            <div style="font-size:.72rem; color:#2980b9; margin-top:.2rem; opacity:.7;"><i class="bi bi-eye me-1"></i>View all policies</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════ COMMISSION DETAIL MODAL ══════════════════ -->
  <div class="modal fade" id="commissionModal" tabindex="-1" aria-labelledby="commissionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" style="max-width:min(1400px,96vw);">
      <div class="modal-content">
        <div class="modal-header" style="background:linear-gradient(135deg,#1a2550,#2c3e7a); color:#fff;">
          <h5 class="modal-title" id="commissionModalLabel">
            <i class="bi bi-cash-coin me-2"></i><span id="modalTitleText">Your Commission — Policy Breakdown</span>
          </h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-0">
          <!-- Summary bar -->
          <div id="modalSummaryBar" class="d-flex gap-3 flex-wrap px-3 py-2" style="background:#f8f9fa; border-bottom:1px solid #e9ecef; font-size:.82rem;">
          </div>
          <!-- Table -->
          <div class="table-responsive">
            <table class="table data-table mb-0" id="commissionDetailTable">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Policy No.</th>
                  <th>Type</th>
                  <th>Customer</th>
                  <th>Source (Ambassador → Affiliate)</th>
                  <th class="text-end">Premium</th>
                  <th class="text-end">Inv. %</th>
                  <th class="text-end">Gross Comm.</th>
                  <th class="text-end">TDS %</th>
                  <th class="text-end">TDS Amt.</th>
                  <th class="text-end">After TDS</th>
                  <th class="text-end">Net Payout</th>
                  <th class="text-center">Status</th>
                  <th>Payout Date</th>
                </tr>
              </thead>
              <tbody id="commissionDetailBody">
              </tbody>
              <tfoot>
                <tr style="background:#eaf4fb;">
                  <td colspan="11" class="fw-bold text-end" style="color:#2980b9;">Total Net Payout</td>
                  <td class="text-end fw-bold" id="modalTotalNet" style="color:#2980b9; font-size:1rem;"></td>
                  <td colspan="2"></td>
                </tr>
              </tfoot>
            </table>
          </div>
          <div id="modalEmpty" class="text-center py-5 text-muted" style="display:none;">
            <i class="bi bi-inbox" style="font-size:2rem; display:block; margin-bottom:.5rem;"></i>
            No policies found for this filter.
          </div>
        </div>
        <div class="modal-footer" style="background:#f8f9fa;">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

  <script>
  (function() {
    // Embed all investor commission rows from Rails
    const allRows = <%= @investor_commission_rows.to_json.html_safe %>;

    const fmt = (n) => {
      if (n == null || n === 0) return '<span style="color:#adb5bd;">—</span>';
      const abs = Math.abs(n);
      const sign = n < 0 ? '-' : '';
      // Indian number format
      const s = abs.toFixed(2);
      const [int, dec] = s.split('.');
      const lastThree = int.slice(-3);
      const rest = int.slice(0, -3);
      const formatted = rest.replace(/\B(?=(\d{2})+(?!\d))/g, ',') + (rest ? ',' : '') + lastThree;
      return sign + 'Rs. ' + formatted + '.' + dec;
    };

    const statusBadge = (status) => {
      if (status === 'paid')
        return '<span class="badge" style="background:#eafaf1;color:#27ae60;border:1px solid #a9dfbf;">Paid</span>';
      if (status === 'pending')
        return '<span class="badge" style="background:#fef9ec;color:#e67e22;border:1px solid #f9d8a0;">Pending</span>';
      return '<span class="badge" style="background:#f8f9fa;color:#adb5bd;border:1px solid #dee2e6;">No Payout</span>';
    };

    const typeBadge = (type) => {
      const map = {
        Health: ['#eafaf1','#27ae60','#a9dfbf'],
        Motor:  ['#eaf4fb','#2980b9','#aed6f1'],
        Life:   ['#f5eef8','#8e44ad','#d7bde2']
      };
      const [bg, fg, br] = map[type] || ['#f8f9fa','#6c757d','#dee2e6'];
      return `<span class="badge" style="background:${bg};color:${fg};border:1px solid ${br};">${type}</span>`;
    };

    function renderModal(filter) {
      const rows = filter === 'all' ? allRows : allRows.filter(r => r.inv_status === filter);
      const tbody = document.getElementById('commissionDetailBody');
      const empty = document.getElementById('modalEmpty');
      const table = document.getElementById('commissionDetailTable');
      const summaryBar = document.getElementById('modalSummaryBar');
      const titleEl = document.getElementById('modalTitleText');
      const totalEl = document.getElementById('modalTotalNet');

      // Title
      const titles = { paid: 'Commission Paid — Policy Breakdown', pending: 'Commission Pending — Policy Breakdown', all: 'Total Commission — All Policies' };
      titleEl.textContent = titles[filter] || 'Your Commission — Policy Breakdown';

      if (rows.length === 0) {
        tbody.innerHTML = '';
        table.style.display = 'none';
        empty.style.display = '';
        totalEl.textContent = '—';
        summaryBar.innerHTML = '';
        return;
      }

      table.style.display = '';
      empty.style.display = 'none';

      const policyUrl = (r) => {
        if (!r.policy_id || !r.policy_slug) return null;
        return `/admin/insurance/${r.policy_slug}/${r.policy_id}`;
      };

      let html = '';
      let totalNet = 0;
      rows.forEach((r, i) => {
        totalNet += r.inv_net || 0;
        const url = policyUrl(r);
        const policyCell = url
          ? `<a href="${url}" target="_blank" style="font-weight:600;color:#2c3e7a;font-family:monospace;text-decoration:none;" title="Open policy">${r.policy_number} <i class="bi bi-box-arrow-up-right" style="font-size:.7rem;opacity:.6;"></i></a>`
          : `<span style="font-weight:600;color:#2c3e7a;font-family:monospace;">${r.policy_number}</span>`;
        html += `<tr>
          <td style="color:#6c757d;">${i+1}</td>
          <td>${policyCell}</td>
          <td>${typeBadge(r.type)}</td>
          <td>${r.customer_name}</td>
          <td style="font-size:.78rem;color:#6c757d;">${r.source}</td>
          <td class="text-end" style="color:#16a085;font-weight:600;">${fmt(r.premium)}</td>
          <td class="text-end">${r.inv_comm_pct > 0 ? r.inv_comm_pct + '%' : '<span style="color:#adb5bd;">—</span>'}</td>
          <td class="text-end">${fmt(r.inv_gross)}</td>
          <td class="text-end">${r.inv_tds_pct > 0 ? r.inv_tds_pct + '%' : '<span style="color:#adb5bd;">—</span>'}</td>
          <td class="text-end" style="color:#e74c3c;">${fmt(r.inv_tds)}</td>
          <td class="text-end">${fmt(r.inv_after_tds)}</td>
          <td class="text-end amount-cell ${r.inv_status === 'paid' ? 'paid-amt' : (r.inv_status === 'pending' ? 'pending-amt' : 'zero-amt')}">${fmt(r.inv_net)}</td>
          <td class="text-center">${statusBadge(r.inv_status)}</td>
          <td style="font-size:.78rem;color:#6c757d;">${r.payout_date || '—'}</td>
        </tr>`;
      });
      tbody.innerHTML = html;
      totalEl.innerHTML = fmt(totalNet);

      // Summary bar
      const paidCount    = rows.filter(r => r.inv_status === 'paid').length;
      const pendingCount = rows.filter(r => r.inv_status === 'pending').length;
      const paidTotal    = rows.filter(r => r.inv_status === 'paid').reduce((s,r) => s + r.inv_net, 0);
      const pendingTotal = rows.filter(r => r.inv_status === 'pending').reduce((s,r) => s + r.inv_net, 0);
      summaryBar.innerHTML = `
        <span><strong>${rows.length}</strong> policies</span>
        <span style="color:#27ae60;"><i class="bi bi-check-circle me-1"></i><strong>${paidCount}</strong> paid &nbsp;(${fmt(paidTotal)})</span>
        <span style="color:#e67e22;"><i class="bi bi-hourglass-split me-1"></i><strong>${pendingCount}</strong> pending &nbsp;(${fmt(pendingTotal)})</span>
      `;
    }

    document.querySelectorAll('.comm-breakdown-card').forEach(card => {
      card.addEventListener('mouseenter', () => card.style.boxShadow = '0 4px 18px rgba(0,0,0,.13)');
      card.addEventListener('mouseleave', () => card.style.boxShadow = '');
      card.addEventListener('click', () => renderModal(card.dataset.filter));
    });
  })();
  </script>

  <!-- ══════════════════ AMBASSADOR SECTION ══════════════════ -->
  <% if @ambassador_rows.any? %>
    <div class="d-flex align-items-center gap-2 mb-3"
         style="cursor:pointer; user-select:none;"
         data-bs-toggle="modal" data-bs-target="#networkModal"
         onmouseenter="this.style.opacity='.8'" onmouseleave="this.style.opacity='1'">
      <h5 class="mb-0 fw-bold" style="color:#2c3e7a;">
        <i class="bi bi-person-badge me-1"></i>Ambassadors & Their Network
      </h5>
      <span class="badge rounded-pill" style="background:#2c3e7a; font-size:.78rem;"><%= @total_ambassadors %> Total</span>
      <small style="font-size:.75rem; color:#8e44ad; font-weight:600;">
        <i class="bi bi-eye me-1"></i>View full commission breakdown
      </small>
    </div>

    <% @ambassador_rows.each_with_index do |row, idx| %>
      <div class="amb-card">
        <!-- Ambassador header -->
        <div class="amb-header">
          <div class="amb-avatar"><%= row[:name][0]&.upcase || '?' %></div>
          <div class="amb-meta">
            <div class="name"><%= row[:name] %></div>
            <div class="sub">
              <% if row[:ambassador].email.present? %><i class="bi bi-envelope me-1"></i><%= row[:ambassador].email %>&ensp;<% end %>
              <% if row[:ambassador].mobile.present? %><i class="bi bi-telephone me-1"></i><%= row[:ambassador].mobile %><% end %>
            </div>
          </div>
          <div class="amb-pills ms-auto">
            <span class="pill pill-blue"><i class="bi bi-file-earmark-check"></i><%= row[:policies] %> Policies</span>
            <span class="pill pill-purple"><i class="bi bi-people"></i><%= row[:affiliates_count] %> Affiliates</span>
            <span class="pill" style="background:#e8f8f5; color:#16a085; border:1px solid #a2d9ce;"><i class="bi bi-currency-rupee"></i><%= indian_currency(row[:premium].to_f.round(0)) %> Premium</span>
            <span class="pill pill-green"><i class="bi bi-check-circle"></i>Paid <%= indian_currency(row[:commission_paid].round(0)) %></span>
            <span class="pill pill-orange"><i class="bi bi-hourglass-split"></i>Pending <%= indian_currency(row[:commission_pending].round(0)) %></span>
          </div>
        </div>

        <!-- Ambassador commission mini-bar -->
        <% total = row[:commission_paid] + row[:commission_pending] %>
        <% if total > 0 %>
          <div style="background:#f8f9fa; padding:.5rem 1.3rem; border-bottom:1px solid #f0f0f0;">
            <div style="font-size:.72rem; color:#6c757d; margin-bottom:.3rem;">Commission Progress</div>
            <div style="background:#e9ecef; border-radius:20px; height:8px; overflow:hidden;">
              <% pct = total > 0 ? (row[:commission_paid] / total * 100).round(1) : 0 %>
              <div style="width:<%= pct %>%; background:#27ae60; height:100%; border-radius:20px; transition:width .4s;"></div>
            </div>
            <div style="font-size:.7rem; color:#6c757d; margin-top:.2rem;"><%= pct %>% paid of <%= indian_currency(total.round(0)) %> total</div>
          </div>
        <% end %>

        <!-- Ambassador direct policies -->
        <% if row[:policy_rows].any? %>
          <div class="aff-section" style="border-top:1px solid #f0f0f0;">
            <button class="aff-toggle" type="button" data-bs-toggle="collapse"
                    data-bs-target="#amb-pol-<%= idx %>"
                    aria-expanded="false" aria-controls="amb-pol-<%= idx %>">
              <i class="bi bi-file-earmark-text me-1"></i>
              Ambassador Policies (<%= row[:policies] %>)
              <i class="bi bi-chevron-down chev ms-1"></i>
            </button>
            <div class="collapse" id="amb-pol-<%= idx %>">
              <%= render partial: 'admin/investors/policy_commission_table',
                    locals: { rows: row[:policy_rows], collapse_id: "amb-pol-#{idx}",
                              section_label: 'Ambassador Commission',
                              show_ambassador: false, show_investor: true } %>
            </div>
          </div>
        <% end %>

        <!-- Affiliates section -->
        <% if row[:affiliates].any? %>
          <div class="aff-section" style="border-top:1px solid #f0f0f0;">
            <button class="aff-toggle" type="button" data-bs-toggle="collapse"
                    data-bs-target="#aff-<%= idx %>"
                    aria-expanded="false" aria-controls="aff-<%= idx %>"
                    style="border-color:#f9d8a0; background:#fef9ec; color:#b7650c;">
              <i class="bi bi-people me-1"></i>
              Affiliates (<%= row[:affiliates_count] %>)
              <i class="bi bi-chevron-down chev ms-1"></i>
            </button>
            <div class="collapse" id="aff-<%= idx %>">
              <% row[:affiliates].each_with_index do |af, aidx| %>
                <!-- Affiliate header bar -->
                <div style="background:#f8f9ff; border-radius:8px; padding:.65rem 1rem; margin:.5rem 0; display:flex; align-items:center; gap:.8rem; flex-wrap:wrap; border:1px solid #e4e8ff;">
                  <div style="font-weight:700; color:#2c3e7a; min-width:160px;"><%= af[:name] %></div>
                  <div style="font-size:.78rem; color:#6c757d;"><i class="bi bi-telephone me-1"></i><%= af[:affiliate].mobile.presence || '—' %></div>
                  <span class="pill pill-blue" style="font-size:.72rem;"><i class="bi bi-file-earmark-check"></i><%= af[:policies] %> Policies</span>
                  <span style="font-size:.8rem; color:#16a085; font-weight:600;"><i class="bi bi-currency-rupee"></i><%= indian_currency(af[:premium].to_f.round(0)) %> Premium</span>
                  <span class="<%= af[:commission_paid] > 0 ? 'paid-amt' : 'zero-amt' %>" style="font-size:.8rem; font-weight:600;">Paid: <%= indian_currency(af[:commission_paid].round(2)) %></span>
                  <span class="<%= af[:commission_pending] > 0 ? 'pending-amt' : 'zero-amt' %>" style="font-size:.8rem; font-weight:600;">Pending: <%= indian_currency(af[:commission_pending].round(2)) %></span>
                  <% if af[:policy_rows].any? %>
                    <button class="aff-toggle ms-auto" type="button" data-bs-toggle="collapse"
                            data-bs-target="#af-pol-<%= idx %>-<%= aidx %>"
                            aria-expanded="false" aria-controls="af-pol-<%= idx %>-<%= aidx %>"
                            style="border-color:#a9dfbf; background:#eafaf1; color:#1a7a45;">
                      <i class="bi bi-list-ul me-1"></i> Policy Breakdown
                      <i class="bi bi-chevron-down chev ms-1"></i>
                    </button>
                  <% end %>
                </div>

                <!-- Affiliate policy-wise commission table -->
                <% if af[:policy_rows].any? %>
                  <div class="collapse" id="af-pol-<%= idx %>-<%= aidx %>">
                    <%= render partial: 'admin/investors/policy_commission_table',
                          locals: { rows: af[:policy_rows], collapse_id: "af-pol-#{idx}-#{aidx}",
                                    section_label: 'Affiliate Commission',
                                    show_ambassador: true, show_investor: true } %>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="aff-section">
            <span style="font-size:.82rem; color:#adb5bd;"><i class="bi bi-info-circle me-1"></i>No affiliates under this ambassador.</span>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Ambassador totals summary -->
    <div class="policy-section mb-4">
      <div class="sec-title d-flex align-items-center gap-2" style="--c:#8e44ad">
        <i class="bi bi-calculator"></i> Network Commission Summary
      </div>
      <div class="sec-body">
        <table class="table data-table mb-0">
          <thead>
            <tr>
              <th>Category</th>
              <th class="text-end">Commission Pending</th>
              <th class="text-end">Commission Paid</th>
              <th class="text-end">Total</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><i class="bi bi-person-badge me-1" style="color:#2c3e7a;"></i><strong>All Ambassadors</strong></td>
              <td class="text-end pending-amt fw-bold"><%= indian_currency(@ambassador_rows.sum { |r| r[:commission_pending] }.round(2)) %></td>
              <td class="text-end paid-amt fw-bold"><%= indian_currency(@ambassador_rows.sum { |r| r[:commission_paid] }.round(2)) %></td>
              <td class="text-end fw-bold" style="color:#2c3e7a;"><%= indian_currency(@total_ambassador_comm.round(2)) %></td>
            </tr>
            <tr>
              <td><i class="bi bi-people me-1" style="color:#e67e22;"></i><strong>All Affiliates</strong></td>
              <td class="text-end pending-amt fw-bold"><%= indian_currency(@ambassador_rows.sum { |r| r[:affiliates].sum { |a| a[:commission_pending] } }.round(2)) %></td>
              <td class="text-end paid-amt fw-bold"><%= indian_currency(@ambassador_rows.sum { |r| r[:affiliates].sum { |a| a[:commission_paid] } }.round(2)) %></td>
              <td class="text-end fw-bold" style="color:#e67e22;"><%= indian_currency(@total_affiliate_comm.round(2)) %></td>
            </tr>
            <tr style="background:#f8f9ff;">
              <td><i class="bi bi-diagram-3 me-1" style="color:#8e44ad;"></i><strong>Total Network</strong></td>
              <td class="text-end pending-amt fw-bold"><%= indian_currency((@ambassador_rows.sum { |r| r[:commission_pending] } + @ambassador_rows.sum { |r| r[:affiliates].sum { |a| a[:commission_pending] } }).round(2)) %></td>
              <td class="text-end paid-amt fw-bold"><%= indian_currency((@ambassador_rows.sum { |r| r[:commission_paid] } + @ambassador_rows.sum { |r| r[:affiliates].sum { |a| a[:commission_paid] } }).round(2)) %></td>
              <td class="text-end fw-bold" style="color:#8e44ad; font-size:1rem;"><%= indian_currency((@total_ambassador_comm + @total_affiliate_comm).round(2)) %></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  <% end %>

  <!-- ══════════════════ DIRECT POLICIES ══════════════════ -->
  <div class="policy-section">
    <div class="sec-title d-flex align-items-center gap-2" style="--c:#16a085">
      <i class="bi bi-file-earmark-check"></i> Direct Policies
      <span class="badge rounded-pill ms-1" style="background:rgba(255,255,255,.25); font-size:.78rem;"><%= @total_direct_policies %></span>
    </div>
    <div class="sec-body p-0">
      <% if @direct_policies.any? %>
        <table class="table data-table mb-0">
          <thead>
            <tr>
              <th>#</th>
              <th>Policy Number</th>
              <th>Type</th>
              <th>Customer</th>
              <th>Insurance Company</th>
              <th class="text-end">Premium (Rs.)</th>
              <th>Booking Date</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% @direct_policies.each_with_index do |row, i| %>
              <% p = row[:policy] %>
              <tr>
                <td style="color:#6c757d;"><%= i + 1 %></td>
                <td style="font-weight:600; color:#2c3e7a; font-family:monospace;"><%= p.policy_number.presence || '—' %></td>
                <td>
                  <span class="badge"
                    style="background:<%= row[:type] == 'Health' ? '#eafaf1' : '#eaf4fb' %>;
                           color:<%= row[:type] == 'Health' ? '#27ae60' : '#2980b9' %>;
                           border:1px solid <%= row[:type] == 'Health' ? '#a9dfbf' : '#aed6f1' %>;">
                    <%= row[:type] %>
                  </span>
                </td>
                <td>
                  <% cname = p.customer&.display_name.presence || 'N/A' %>
                  <%= cname %>
                </td>
                <td style="color:#6c757d;"><%= p.insurance_company_name.presence || '—' %></td>
                <td class="text-end amount-cell" style="color:#16a085;"><%= indian_currency(row[:premium].round(2)) %></td>
                <td style="color:#6c757d;"><%= p.policy_booking_date&.strftime('%d %b %Y') || '—' %></td>
                <td>
                  <% active = p.respond_to?(:active) ? p.active : (p.respond_to?(:status) ? p.status == 'active' : true) %>
                  <span class="badge" style="background:<%= active ? '#eafaf1' : '#fef9ec' %>; color:<%= active ? '#27ae60' : '#e67e22' %>; border:1px solid <%= active ? '#a9dfbf' : '#f9d8a0' %>;">
                    <%= active ? 'Active' : 'Inactive' %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot style="background:#f8f9ff;">
            <tr>
              <td colspan="5" class="fw-bold" style="color:#16a085;">Total</td>
              <td class="text-end fw-bold" style="color:#16a085; font-size:1rem;"><%= indian_currency(@total_direct_premium.round(2)) %></td>
              <td colspan="2"></td>
            </tr>
          </tfoot>
        </table>
      <% else %>
        <div class="empty-state">
          <i class="bi bi-file-earmark-x"></i>
          No direct policies linked to this investor.
        </div>
      <% end %>
    </div>
  </div>

  <!-- ══════════════════ NETWORK FAMILY TREE ══════════════════ -->
  <% if @ambassador_rows.any? %>
  <div class="policy-section mb-4">
    <div class="sec-title d-flex align-items-center gap-2" style="--c:#1a2550;">
      <i class="bi bi-diagram-3-fill"></i> Network Family Tree
      <small style="font-size:.75rem; font-weight:400; opacity:.8;">Click any node to expand / collapse</small>
    </div>
    <div class="sec-body" style="padding:1.2rem 0;">

      <!-- Legend -->
      <div class="d-flex gap-3 flex-wrap px-3 mb-3" style="font-size:.78rem;">
        <span><span style="display:inline-block;width:12px;height:12px;border-radius:50%;background:#2c3e7a;margin-right:5px;"></span>Investor</span>
        <span><span style="display:inline-block;width:12px;height:12px;border-radius:50%;background:#8e44ad;margin-right:5px;"></span>Ambassador</span>
        <span><span style="display:inline-block;width:12px;height:12px;border-radius:50%;background:#e67e22;margin-right:5px;"></span>Affiliate</span>
        <span><span style="display:inline-block;width:12px;height:12px;border-radius:50%;background:#27ae60;margin-right:5px;"></span>Customer</span>
        <button onclick="expandAll()" class="btn btn-sm btn-outline-secondary ms-auto" style="font-size:.75rem; padding:.2rem .7rem;">Expand All</button>
        <button onclick="collapseAll()" class="btn btn-sm btn-outline-secondary" style="font-size:.75rem; padding:.2rem .7rem;">Collapse All</button>
      </div>

      <div id="family-tree" style="overflow-x:auto; overflow-y:visible; padding-bottom:8px; -webkit-overflow-scrolling:touch; cursor:grab;"></div>
    </div>
  </div>

</div><!-- /container -->

<!-- ══════════════════ NETWORK COMMISSION MODAL ══════════════════ -->
<div class="modal fade" id="networkModal" tabindex="-1" aria-labelledby="networkModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable" style="max-width:min(1400px,96vw);">
    <div class="modal-content">
      <div class="modal-header" style="background:linear-gradient(135deg,#1a2550,#2c3e7a); color:#fff;">
        <h5 class="modal-title" id="networkModalLabel">
          <i class="bi bi-diagram-3 me-2"></i>Full Network Commission Breakdown
          <small style="font-size:.75rem; font-weight:400; opacity:.8; margin-left:.5rem;">
            <%= @total_ambassadors %> Ambassador<%= @total_ambassadors == 1 ? '' : 's' %> · <%= @total_affiliates %> Affiliate<%= @total_affiliates == 1 ? '' : 's' %>
          </small>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">
        <!-- Summary strip -->
        <div class="d-flex flex-wrap gap-3 px-3 py-2" style="background:#f8f9fa; border-bottom:1px solid #e9ecef; font-size:.82rem;">
          <% net_total_rows = @ambassador_rows.flat_map { |r| r[:policy_rows] } +
                              @ambassador_rows.flat_map { |r| r[:affiliates].flat_map { |a| a[:policy_rows] } } %>
          <span><strong><%= net_total_rows.size %></strong> total policies</span>
          <span style="color:#27ae60;">
            <i class="bi bi-check-circle me-1"></i>
            Investor Paid: <strong><%= indian_currency(@investor_commission_paid.round(2)) %></strong>
          </span>
          <span style="color:#e67e22;">
            <i class="bi bi-hourglass-split me-1"></i>
            Investor Pending: <strong><%= indian_currency(@investor_commission_pending.round(2)) %></strong>
          </span>
          <span style="color:#8e44ad;">
            Network Commission: <strong><%= indian_currency((@total_ambassador_comm + @total_affiliate_comm).round(2)) %></strong>
          </span>
        </div>

        <% row_index = 0 %>
        <% type_colors = {'Health'=>['#eafaf1','#27ae60','#a9dfbf'],'Motor'=>['#eaf4fb','#2980b9','#aed6f1'],'Life'=>['#f5eef8','#8e44ad','#d7bde2']} %>
        <% @ambassador_rows.each do |amb_row| %>
          <!-- Ambassador block header -->
          <div class="px-3 py-2 d-flex align-items-center gap-2 flex-wrap"
               style="background:linear-gradient(90deg,#eef1ff,#f5f7ff); border-bottom:1px solid #dde1ff;">
            <span class="badge rounded-pill" style="background:#2c3e7a; font-size:.78rem;">
              <i class="bi bi-person-badge me-1"></i>Ambassador
            </span>
            <strong style="color:#2c3e7a;"><%= amb_row[:name] %></strong>
            <span class="text-muted" style="font-size:.78rem;">
              <%= amb_row[:policies] %> direct polic<%= amb_row[:policies] == 1 ? 'y' : 'ies' %> ·
              <%= amb_row[:affiliates_count] %> affiliate<%= amb_row[:affiliates_count] == 1 ? '' : 's' %>
            </span>
            <span class="ms-auto" style="font-size:.8rem; color:#27ae60; font-weight:600;">
              Paid: <%= indian_currency(amb_row[:commission_paid].round(2)) %>
            </span>
            <span style="font-size:.8rem; color:#e67e22; font-weight:600;">
              Pending: <%= indian_currency(amb_row[:commission_pending].round(2)) %>
            </span>
          </div>

          <% if amb_row[:policy_rows].any? %>
            <div class="table-responsive">
              <table class="table data-table mb-0" style="font-size:.8rem;">
                <thead>
                  <tr style="background:#f0f2ff;">
                    <th style="width:2rem;">#</th>
                    <th>Policy</th>
                    <th>Type</th>
                    <th>Customer</th>
                    <th>Affiliate</th>
                    <th class="text-end">Premium</th>
                    <th class="text-end">Amb. Comm.</th>
                    <th class="text-end" style="color:#8e44ad;">Inv. %</th>
                    <th class="text-end" style="color:#8e44ad;">Inv. Comm.</th>
                    <th class="text-end" style="color:#8e44ad;">Inv. After TDS</th>
                    <th class="text-center">Inv. Status</th>
                    <th class="text-end" style="color:#16a085;">Total Comm.</th>
                  </tr>
                </thead>
                <tbody>
                  <% amb_row[:policy_rows].each do |pr| %>
                    <% row_index += 1 %>
                    <% total_comm = pr[:net_commission].to_f + pr[:inv_after_tds].to_f %>
                    <tr>
                      <td class="text-muted"><%= row_index %></td>
                      <td style="font-weight:600; color:#2c3e7a; font-family:monospace;"><%= pr[:policy_number] %></td>
                      <td>
                        <% bg, fg, br = type_colors[pr[:type]] || ['#f8f9fa','#6c757d','#dee2e6'] %>
                        <span class="badge" style="background:<%= bg %>;color:<%= fg %>;border:1px solid <%= br %>;"><%= pr[:type] %></span>
                      </td>
                      <td><%= pr[:customer_name] %></td>
                      <td class="text-muted" style="font-size:.75rem;">Direct</td>
                      <td class="text-end" style="color:#16a085; font-weight:600;"><%= indian_currency(pr[:premium].to_f.round(2)) %></td>
                      <td class="text-end <%= pr[:net_commission].to_f > 0 ? (pr[:status] == 'paid' ? 'paid-amt' : 'pending-amt') : 'zero-amt' %> fw-bold">
                        <%= pr[:net_commission].to_f > 0 ? indian_currency(pr[:net_commission].to_f.round(2)) : '—' %>
                      </td>
                      <td class="text-end" style="color:#8e44ad;">
                        <%= pr[:inv_comm_pct].to_f > 0 ? "#{pr[:inv_comm_pct]}%" : '—' %>
                      </td>
                      <td class="text-end" style="color:#8e44ad; font-weight:600;">
                        <%= pr[:inv_gross].to_f > 0 ? indian_currency(pr[:inv_gross].to_f.round(2)) : '—' %>
                      </td>
                      <td class="text-end" style="color:#8e44ad; font-weight:600;">
                        <%= pr[:inv_after_tds].to_f > 0 ? indian_currency(pr[:inv_after_tds].to_f.round(2)) : '—' %>
                      </td>
                      <td class="text-center">
                        <% inv_s = pr[:inv_status] %>
                        <% if inv_s == 'paid' %>
                          <span class="badge" style="background:#eafaf1;color:#27ae60;border:1px solid #a9dfbf;">Paid</span>
                        <% elsif inv_s == 'pending' %>
                          <span class="badge" style="background:#fef9ec;color:#e67e22;border:1px solid #f9d8a0;">Pending</span>
                        <% else %>
                          <span class="badge" style="background:#f8f9fa;color:#adb5bd;border:1px solid #dee2e6;">—</span>
                        <% end %>
                      </td>
                      <td class="text-end fw-bold" style="color:#16a085;">
                        <%= total_comm > 0 ? indian_currency(total_comm.round(2)) : '—' %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
                <tfoot>
                  <tr style="background:#eef1ff; font-size:.8rem;">
                    <td colspan="5" class="fw-bold" style="color:#2c3e7a;">Ambassador Subtotal</td>
                    <td class="text-end fw-bold" style="color:#16a085;"><%= indian_currency(amb_row[:policy_rows].sum { |r| r[:premium].to_f }.round(2)) %></td>
                    <td class="text-end fw-bold" style="color:#27ae60;"><%= indian_currency(amb_row[:policy_rows].sum { |r| r[:net_commission].to_f }.round(2)) %></td>
                    <td></td>
                    <td class="text-end fw-bold" style="color:#8e44ad;"><%= indian_currency(amb_row[:policy_rows].sum { |r| r[:inv_gross].to_f }.round(2)) %></td>
                    <td class="text-end fw-bold" style="color:#8e44ad;"><%= indian_currency(amb_row[:policy_rows].sum { |r| r[:inv_after_tds].to_f }.round(2)) %></td>
                    <td></td>
                    <td class="text-end fw-bold" style="color:#16a085;"><%= indian_currency(amb_row[:policy_rows].sum { |r| r[:net_commission].to_f + r[:inv_after_tds].to_f }.round(2)) %></td>
                  </tr>
                </tfoot>
              </table>
            </div>
          <% end %>

          <!-- Affiliates under this ambassador -->
          <% amb_row[:affiliates].each do |af| %>
            <% next unless af[:policy_rows].any? %>
            <div class="px-3 py-2 d-flex align-items-center gap-2 flex-wrap"
                 style="background:#fffbf3; border-top:1px solid #f9d8a0; border-bottom:1px solid #f9d8a0;">
              <span class="badge rounded-pill" style="background:#e67e22; font-size:.75rem;">
                <i class="bi bi-people me-1"></i>Affiliate
              </span>
              <strong style="color:#b7650c;"><%= af[:name] %></strong>
              <span class="text-muted" style="font-size:.78rem;">
                via <%= amb_row[:name] %> · <%= af[:policies] %> polic<%= af[:policies] == 1 ? 'y' : 'ies' %>
              </span>
              <span class="ms-auto" style="font-size:.8rem; color:#27ae60; font-weight:600;">Paid: <%= indian_currency(af[:commission_paid].round(2)) %></span>
              <span style="font-size:.8rem; color:#e67e22; font-weight:600;">Pending: <%= indian_currency(af[:commission_pending].round(2)) %></span>
            </div>
            <div class="table-responsive">
              <table class="table data-table mb-0" style="font-size:.8rem;">
                <thead>
                  <tr style="background:#fffbf3;">
                    <th style="width:2rem;">#</th>
                    <th>Policy</th>
                    <th>Type</th>
                    <th>Customer</th>
                    <th>Ambassador</th>
                    <th class="text-end">Premium</th>
                    <th class="text-end">Aff. Comm.</th>
                    <th class="text-end" style="color:#8e44ad;">Inv. %</th>
                    <th class="text-end" style="color:#8e44ad;">Inv. Comm.</th>
                    <th class="text-end" style="color:#8e44ad;">Inv. After TDS</th>
                    <th class="text-center">Inv. Status</th>
                    <th class="text-end" style="color:#16a085;">Total Comm.</th>
                  </tr>
                </thead>
                <tbody>
                  <% af[:policy_rows].each do |pr| %>
                    <% row_index += 1 %>
                    <% total_comm = pr[:net_commission].to_f + pr[:amb_after_tds].to_f + pr[:inv_after_tds].to_f %>
                    <tr>
                      <td class="text-muted"><%= row_index %></td>
                      <td style="font-weight:600; color:#2c3e7a; font-family:monospace;"><%= pr[:policy_number] %></td>
                      <td>
                        <% bg, fg, br = type_colors[pr[:type]] || ['#f8f9fa','#6c757d','#dee2e6'] %>
                        <span class="badge" style="background:<%= bg %>;color:<%= fg %>;border:1px solid <%= br %>;"><%= pr[:type] %></span>
                      </td>
                      <td><%= pr[:customer_name] %></td>
                      <td style="font-size:.75rem; color:#6c757d;"><%= amb_row[:name] %></td>
                      <td class="text-end" style="color:#16a085; font-weight:600;"><%= indian_currency(pr[:premium].to_f.round(2)) %></td>
                      <td class="text-end <%= pr[:net_commission].to_f > 0 ? (pr[:status] == 'paid' ? 'paid-amt' : 'pending-amt') : 'zero-amt' %> fw-bold">
                        <%= pr[:net_commission].to_f > 0 ? indian_currency(pr[:net_commission].to_f.round(2)) : '—' %>
                      </td>
                      <td class="text-end" style="color:#8e44ad;">
                        <%= pr[:inv_comm_pct].to_f > 0 ? "#{pr[:inv_comm_pct]}%" : '—' %>
                      </td>
                      <td class="text-end" style="color:#8e44ad; font-weight:600;">
                        <%= pr[:inv_gross].to_f > 0 ? indian_currency(pr[:inv_gross].to_f.round(2)) : '—' %>
                      </td>
                      <td class="text-end" style="color:#8e44ad; font-weight:600;">
                        <%= pr[:inv_after_tds].to_f > 0 ? indian_currency(pr[:inv_after_tds].to_f.round(2)) : '—' %>
                      </td>
                      <td class="text-center">
                        <% inv_s = pr[:inv_status] %>
                        <% if inv_s == 'paid' %>
                          <span class="badge" style="background:#eafaf1;color:#27ae60;border:1px solid #a9dfbf;">Paid</span>
                        <% elsif inv_s == 'pending' %>
                          <span class="badge" style="background:#fef9ec;color:#e67e22;border:1px solid #f9d8a0;">Pending</span>
                        <% else %>
                          <span class="badge" style="background:#f8f9fa;color:#adb5bd;border:1px solid #dee2e6;">—</span>
                        <% end %>
                      </td>
                      <td class="text-end fw-bold" style="color:#16a085;">
                        <%= total_comm > 0 ? indian_currency(total_comm.round(2)) : '—' %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
                <tfoot>
                  <tr style="background:#fffbf3; font-size:.8rem;">
                    <td colspan="5" class="fw-bold" style="color:#b7650c;">Affiliate Subtotal</td>
                    <td class="text-end fw-bold" style="color:#16a085;"><%= indian_currency(af[:policy_rows].sum { |r| r[:premium].to_f }.round(2)) %></td>
                    <td class="text-end fw-bold" style="color:#e67e22;"><%= indian_currency(af[:policy_rows].sum { |r| r[:net_commission].to_f }.round(2)) %></td>
                    <td></td>
                    <td class="text-end fw-bold" style="color:#8e44ad;"><%= indian_currency(af[:policy_rows].sum { |r| r[:inv_gross].to_f }.round(2)) %></td>
                    <td class="text-end fw-bold" style="color:#8e44ad;"><%= indian_currency(af[:policy_rows].sum { |r| r[:inv_after_tds].to_f }.round(2)) %></td>
                    <td></td>
                    <td class="text-end fw-bold" style="color:#16a085;"><%= indian_currency(af[:policy_rows].sum { |r| r[:net_commission].to_f + r[:amb_after_tds].to_f + r[:inv_after_tds].to_f }.round(2)) %></td>
                  </tr>
                </tfoot>
              </table>
            </div>
          <% end %>
        <% end %>

        <!-- Grand Total row -->
        <% all_amb_pols  = @ambassador_rows.flat_map { |r| r[:policy_rows] } %>
        <% all_aff_pols  = @ambassador_rows.flat_map { |r| r[:affiliates].flat_map { |a| a[:policy_rows] } } %>
        <% grand_premium = all_amb_pols.sum { |r| r[:premium].to_f } + all_aff_pols.sum { |r| r[:premium].to_f } %>
        <% grand_net_amb = all_amb_pols.sum { |r| r[:net_commission].to_f } %>
        <% grand_net_aff = all_aff_pols.sum { |r| r[:net_commission].to_f } %>
        <% grand_inv     = (all_amb_pols + all_aff_pols).sum { |r| r[:inv_after_tds].to_f } %>
        <% grand_total   = grand_net_amb + grand_net_aff + grand_inv %>
        <div class="px-3 py-3 d-flex align-items-center flex-wrap gap-3"
             style="background:linear-gradient(90deg,#f0f2ff,#f8f9ff); border-top:2px solid #c5ceff; font-size:.85rem;">
          <strong style="color:#1a2550; font-size:.95rem;">Grand Total</strong>
          <span class="ms-2" style="color:#16a085;">Premium: <strong><%= indian_currency(grand_premium.round(2)) %></strong></span>
          <span style="color:#2c3e7a;">Amb. Comm.: <strong><%= indian_currency(grand_net_amb.round(2)) %></strong></span>
          <span style="color:#e67e22;">Aff. Comm.: <strong><%= indian_currency(grand_net_aff.round(2)) %></strong></span>
          <span style="color:#8e44ad;">Investor Comm.: <strong><%= indian_currency(grand_inv.round(2)) %></strong></span>
          <span class="ms-auto" style="color:#16a085; font-size:1rem;">
            Total All Comm.: <strong><%= indian_currency(grand_total.round(2)) %></strong>
          </span>
        </div>
      </div>
      <div class="modal-footer" style="background:#f8f9fa;">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<button class="print-btn" onclick="window.print()">
  <i class="bi bi-printer me-1"></i> Print Report
</button>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/d3@7"></script>
<script>
(function() {
  // ── Build tree data from Rails ──────────────────────────────────────────
  const rawData = {
    name: <%= @investor.display_name.to_json.html_safe %>,
    type: "investor",
    sub: "<%= @total_ambassadors %> Ambassador<%= @total_ambassadors == 1 ? '' : 's' %> · <%= @total_affiliates %> Affiliate<%= @total_affiliates == 1 ? '' : 's' %>",
    children: [
      <% @ambassador_rows.each do |row| %>
      {
        name: <%= row[:name].to_json.html_safe %>,
        type: "ambassador",
        sub: "<%= row[:affiliates_count] %> affiliate<%= row[:affiliates_count] == 1 ? '' : 's' %> · <%= row[:policies] %> polic<%= row[:policies] == 1 ? 'y' : 'ies' %>",
        children: [
          <% row[:affiliates].each do |af| %>
          {
            name: <%= af[:name].to_json.html_safe %>,
            type: "affiliate",
            sub: "<%= af[:policies] %> polic<%= af[:policies] == 1 ? 'y' : 'ies' %>",
            children: [
              <% af[:policy_rows].map { |pr| pr[:customer_name] }.uniq.compact.reject { |c| c.blank? || c == 'N/A' || c == 'Unknown' }.each do |cust| %>
              { name: <%= cust.to_json.html_safe %>, type: "customer", sub: "", children: [] },
              <% end %>
            ]
          },
          <% end %>
        ]
      },
      <% end %>
    ]
  };

  // ── Config ───────────────────────────────────────────────────────────────
  const COLOR   = { investor:'#2c3e7a', ambassador:'#8e44ad', affiliate:'#e67e22', customer:'#27ae60' };
  const BGFILL  = { investor:'#eaf0fb', ambassador:'#f5eef8', affiliate:'#fef6ec', customer:'#eafaf1' };
  const NODE_W  = 160;
  const NODE_H  = 48;
  const COL_GAP = 220;
  const ROW_GAP = 64;
  const MARGIN  = { top:30, right: NODE_W/2 + 20, bottom:30, left: NODE_W/2 + 20 };

  // ── SVG setup ────────────────────────────────────────────────────────────
  const container = document.getElementById('family-tree');
  const contW = Math.max(container.offsetWidth || 1100, 900);

  const svg = d3.select('#family-tree').append('svg')
      .attr('id', 'tree-svg')
      .style('font-family', "'Segoe UI', sans-serif");

  const g = svg.append('g').attr('transform', `translate(${MARGIN.left},${MARGIN.top})`);

  // Defs: arrow marker
  svg.append('defs').append('marker')
      .attr('id','arrow').attr('viewBox','0 -5 10 10')
      .attr('refX',8).attr('refY',0)
      .attr('markerWidth',6).attr('markerHeight',6)
      .attr('orient','auto')
    .append('path').attr('d','M0,-5L10,0L0,5').attr('fill','#b0bec5');

  let nodeIdCounter = 0;
  let root;

  function buildHierarchy(data) {
    root = d3.hierarchy(data, d => d.children && d.children.length ? d.children : null);
    root.x0 = 0; root.y0 = 0;
    root.each(d => { d.id = ++nodeIdCounter; });
    // Start with customers collapsed
    root.children && root.children.forEach(d => {
      d.children && d.children.forEach(af => {
        if (af.children && af.children.length > 6) {
          af._children = af.children;
          af.children = null;
        }
      });
    });
    return root;
  }

  function toggle(d) {
    if (d.children) { d._children = d.children; d.children = null; }
    else             { d.children = d._children; d._children = null; }
  }

  window.expandAll = function() {
    root.each(d => { if (d._children) { d.children = d._children; d._children = null; } });
    update();
  };
  window.collapseAll = function() {
    root.each(d => { if (d.children && d.depth > 0) { d._children = d.children; d.children = null; } });
    update();
  };

  function update() {
    // Compute tree layout
    const treeLayout = d3.tree().nodeSize([ROW_GAP, COL_GAP]);
    treeLayout(root);

    const nodes = root.descendants();
    const links = root.links();

    // Resize SVG to fit
    const xs = nodes.map(d => d.x);
    const ys = nodes.map(d => d.y);
    const minX = Math.min(...xs) - NODE_H;
    const maxX = Math.max(...xs) + NODE_H + 20;
    const minY = Math.min(...ys) - NODE_W / 2;
    const maxY = Math.max(...ys) + NODE_W / 2 + 20;
    const svgH = maxX - minX + MARGIN.top + MARGIN.bottom;
    const svgW = maxY - minY + MARGIN.left + MARGIN.right;

    svg.attr('width', svgW).attr('height', svgH);
    g.attr('transform', `translate(${MARGIN.left - minY},${MARGIN.top - minX})`);

    // ── Links ──────────────────────────────────────────────────────────────
    const link = g.selectAll('path.link').data(links, d => d.target.id);

    link.enter().append('path')
        .attr('class','link')
        .attr('fill','none')
        .attr('stroke','#b0bec5')
        .attr('stroke-width', 1.5)
        .attr('marker-end','url(#arrow)')
        .attr('d', d => stepPath(d.source, d.target))
      .merge(link)
        .transition().duration(300)
        .attr('d', d => stepPath(d.source, d.target));

    link.exit().transition().duration(300)
        .attr('opacity',0).remove();

    // ── Nodes ──────────────────────────────────────────────────────────────
    const node = g.selectAll('g.node').data(nodes, d => d.id);

    const nodeEnter = node.enter().append('g')
        .attr('class','node')
        .attr('transform', d => `translate(${d.y},${d.x})`);

    // Card rect
    nodeEnter.append('rect')
        .attr('x', -NODE_W/2).attr('y', -NODE_H/2)
        .attr('width', NODE_W).attr('height', NODE_H)
        .attr('rx', 8).attr('ry', 8)
        .attr('fill', d => BGFILL[d.data.type])
        .attr('stroke', d => COLOR[d.data.type])
        .attr('stroke-width', 2);

    // Left accent bar
    nodeEnter.append('rect')
        .attr('x', -NODE_W/2).attr('y', -NODE_H/2)
        .attr('width', 4).attr('height', NODE_H)
        .attr('rx', 2).attr('fill', d => COLOR[d.data.type]);

    // Collapse indicator
    nodeEnter.append('text')
        .attr('class','collapse-dot')
        .attr('x', NODE_W/2 - 10).attr('y', 4)
        .attr('text-anchor','middle')
        .style('font-size','14px')
        .style('font-weight','bold');

    // Name text
    nodeEnter.append('text')
        .attr('class','node-name')
        .attr('x', -NODE_W/2 + 14).attr('y', -8)
        .style('font-size','11px').style('font-weight','700')
        .attr('dominant-baseline','middle');

    // Sub text
    nodeEnter.append('text')
        .attr('class','node-sub')
        .attr('x', -NODE_W/2 + 14).attr('y', 10)
        .style('font-size','9.5px')
        .attr('dominant-baseline','middle');

    const nodeUpdate = nodeEnter.merge(node);

    // Update cursor on every render
    nodeUpdate.style('cursor', d => (d.children || d._children) ? 'pointer' : 'default');

    nodeUpdate.transition().duration(300)
        .attr('transform', d => `translate(${d.y},${d.x})`);

    nodeUpdate.select('rect:first-of-type')
        .attr('fill', d => BGFILL[d.data.type])
        .attr('stroke', d => COLOR[d.data.type]);

    nodeUpdate.select('.collapse-dot')
        .style('fill', d => COLOR[d.data.type])
        .text(d => d._children ? '▸' : (d.children && d.children.length ? '▾' : ''));

    nodeUpdate.select('.node-name')
        .attr('fill', d => COLOR[d.data.type])
        .text(d => {
          const max = 18;
          return d.data.name.length > max ? d.data.name.slice(0, max) + '…' : d.data.name;
        });

    nodeUpdate.select('.node-sub')
        .attr('fill','#6c757d')
        .text(d => d.data.sub || '');

    node.exit().transition().duration(300)
        .attr('opacity',0).remove();
  }

  // Elbow / step connector
  function stepPath(s, t) {
    const mx = (s.y + NODE_W/2 + t.y - NODE_W/2) / 2;
    return `M${s.y + NODE_W/2},${s.x}
            C${mx},${s.x} ${mx},${t.x} ${t.y - NODE_W/2 - 6},${t.x}`;
  }

  // ── Init ─────────────────────────────────────────────────────────────────
  buildHierarchy(rawData);
  update();

  // ── Single delegated click handler (works for both expand AND collapse) ──
  // Using event delegation on the SVG ensures the handler always reads the
  // freshest datum bound to the node, regardless of D3 update cycles.
  document.getElementById('tree-svg').addEventListener('click', function(e) {
    const nodeEl = e.target.closest('g.node');
    if (!nodeEl) return;
    e.stopPropagation();
    const d = d3.select(nodeEl).datum();
    if (!d || (!d.children && !d._children)) return;
    toggle(d);
    update();
  });

  // ── Drag-to-scroll ───────────────────────────────────────────────────────
  const el = document.getElementById('family-tree');
  let isDown = false, startX, scrollLeft;
  el.addEventListener('mousedown', e => {
    if (e.target.closest('g.node')) return; // let node clicks through
    isDown = true; startX = e.pageX - el.offsetLeft; scrollLeft = el.scrollLeft;
    el.style.cursor = 'grabbing';
  });
  el.addEventListener('mouseleave', () => { isDown = false; el.style.cursor = 'grab'; });
  el.addEventListener('mouseup',    () => { isDown = false; el.style.cursor = 'grab'; });
  el.addEventListener('mousemove',  e => {
    if (!isDown) return;
    e.preventDefault();
    el.scrollLeft = scrollLeft - (e.pageX - el.offsetLeft - startX);
  });
})();
</script>
  <% end %>
</body>
</html>
