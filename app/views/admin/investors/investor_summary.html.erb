<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Investor Summary - Drwise</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-light">

<div class="container-fluid py-4">
  <!-- Page Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center">
      <%= link_to admin_investors_path, class: "btn btn-outline-secondary me-3", title: "Back to Investors" do %>
        <i class="bi bi-arrow-left me-1"></i>
        Back
      <% end %>
      <div>
        <h1 class="h3 mb-1">
          <i class="bi bi-bar-chart-line text-primary me-2"></i>
          Investor Summary Report
        </h1>
        <p class="text-muted mb-0">Comprehensive overview of investor data and performance</p>
      </div>
    </div>
    <div>
      <small class="text-muted">Generated: <%= Time.current.strftime("%d %B, %Y at %I:%M %p") %></small>
    </div>
  </div>

  <!-- Statistics Cards -->
  <div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h6 class="text-muted mb-2">Commission Pool</h6>
              <h4 class="mb-0 text-success"><%= indian_currency(@total_commission_pool) %></h4>
            </div>
            <div class="bg-success bg-opacity-10 rounded p-3">
              <i class="bi bi-currency-rupee text-success fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h6 class="text-muted mb-2">Total Shares</h6>
              <h4 class="mb-0 text-primary"><%= number_with_delimiter(@total_shares) %></h4>
            </div>
            <div class="bg-primary bg-opacity-10 rounded p-3">
              <i class="bi bi-pie-chart text-primary fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h6 class="text-muted mb-2">Profit Per Share</h6>
              <h4 class="mb-0 text-info"><%= indian_currency(@profit_per_share) %></h4>
            </div>
            <div class="bg-info bg-opacity-10 rounded p-3">
              <i class="bi bi-graph-up text-info fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h6 class="text-muted mb-2">Total Investment</h6>
              <h4 class="mb-0 text-warning"><%= indian_currency(@system_investment_amount) %></h4>
            </div>
            <div class="bg-warning bg-opacity-10 rounded p-3">
              <i class="bi bi-piggy-bank text-warning fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Detailed Profit Sharing Table -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-0">Investor Profit Sharing Summary</h5>
              <small class="text-muted">Detailed calculation of profit distribution based on shares</small>
            </div>
            <div>
              <small class="text-muted">Calculation: <%= indian_currency(@total_commission_pool) %> ÷ <%= indian_number(@total_shares) %> shares = <%= indian_currency(@profit_per_share) %> per share</small>
            </div>
          </div>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Sl No</th>
                  <th>Investor Name</th>
                  <th>No. of Shares</th>
                  <th>Invested Amount</th>
                  <th>Sharing %</th>
                  <th data-bs-toggle="tooltip" data-bs-placement="top" title="Formula: Shares × Profit Per Share" style="cursor: help;">
                    Profit Amt
                    <i class="bi bi-info-circle text-muted ms-1"></i>
                  </th>
                  <th data-bs-toggle="tooltip" data-bs-placement="top" title="Formula: Profit Amount × Sharing %" style="cursor: help;">
                    Actual Profit Shared
                    <i class="bi bi-calculator text-muted ms-1"></i>
                  </th>
                  <th data-bs-toggle="tooltip" data-bs-placement="top" title="Formula: (Actual Profit Shared ÷ Invested Amount) × 100" style="cursor: help;">
                    Return on Investment
                    <i class="bi bi-graph-up-arrow text-muted ms-1"></i>
                  </th>
                </tr>
              </thead>
              <tbody>
                <% @profit_sharing_data.each do |data| %>
                  <tr>
                    <td><strong><%= data[:sl_no] %></strong></td>
                    <td>
                      <div>
                        <strong><%= data[:investor].full_name.upcase %></strong>
                        <br>
                        <small class="text-muted"><%= data[:investor].email %></small>
                      </div>
                    </td>
                    <td class="text-center">
                      <span class="badge bg-primary fs-6"><%= indian_number(data[:shares]) %></span>
                    </td>
                    <td>
                      <strong class="text-success"><%= indian_currency(data[:invested_amount]) %></strong>
                    </td>
                    <td>
                      <span class="text-info"><%= number_with_precision(data[:sharing_percentage], precision: 2) %>%</span>
                    </td>
                    <td>
                      <strong class="text-primary"><%= indian_currency(data[:profit_amount]) %></strong>
                    </td>
                    <td>
                      <div>
                        <span class="badge bg-success"><%= data[:actual_profit_shared_percentage] %>%</span>
                        <br>
                        <strong class="text-success"><%= indian_currency(data[:actual_profit_shared]) %></strong>
                      </div>
                    </td>
                    <td>
                      <strong class="text-warning"><%= number_with_precision(data[:roi], precision: 2) %>%</strong>
                    </td>
                  </tr>
                <% end %>
                <!-- Summary Row -->
                <tr class="table-secondary">
                  <td><strong></strong></td>
                  <td><strong>TOTAL</strong></td>
                  <td class="text-center">
                    <span class="badge bg-dark fs-6"><%= indian_number(@total_shares) %></span>
                  </td>
                  <td>
                    <strong class="text-success"><%= indian_currency(@total_invested_amount) %></strong>
                  </td>
                  <td><strong>-</strong></td>
                  <td>
                    <strong class="text-primary"><%= indian_currency(@total_commission_pool) %></strong>
                  </td>
                  <td>
                    <strong class="text-success"><%= indian_currency(@profit_sharing_data.sum { |d| d[:actual_profit_shared] }) %></strong>
                  </td>
                  <td><strong>-</strong></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Top Investors Tables Row -->
  <div class="row mb-4">
    <div class="col-xl-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0">
          <h5 class="mb-0">Top Investors by Amount</h5>
          <small class="text-muted">Highest investment amounts</small>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Rank</th>
                  <th>Investor</th>
                  <th>Investment</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% @top_investors_by_amount.each_with_index do |investor, index| %>
                  <tr>
                    <td>
                      <span class="badge bg-<%= index < 3 ? ['warning', 'secondary', 'info'][index] : 'light' %> text-dark">
                        #<%= index + 1 %>
                      </span>
                    </td>
                    <td>
                      <div>
                        <strong><%= investor.full_name %></strong>
                        <br>
                        <small class="text-muted"><%= investor.email %></small>
                      </div>
                    </td>
                    <td>
                      <strong class="text-success"><%= indian_currency(investor.invested_amount) %></strong>
                    </td>
                    <td>
                      <span class="badge bg-<%= investor.active? ? 'success' : 'danger' %>">
                        <%= investor.status&.humanize || 'Active' %>
                      </span>
                    </td>
                  </tr>
                <% end %>
                <% if @top_investors_by_amount.empty? %>
                  <tr>
                    <td colspan="4" class="text-center text-muted py-3">
                      No investment data available
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>


</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Initialize Bootstrap tooltips
  var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
  var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
    return new bootstrap.Tooltip(tooltipTriggerEl);
  });
  // Monthly Chart
  const monthlyData = <%= raw @monthly_data.to_json %>;
  const monthlyCtx = document.getElementById('monthlyChart').getContext('2d');

  new Chart(monthlyCtx, {
    type: 'bar',
    data: {
      labels: monthlyData.map(d => d.month),
      datasets: [
        {
          label: 'New Investors',
          data: monthlyData.map(d => d.investors_count),
          backgroundColor: 'rgba(54, 162, 235, 0.6)',
          borderColor: 'rgba(54, 162, 235, 1)',
          borderWidth: 1,
          yAxisID: 'y'
        },
        {
          label: 'Investment Amount (Rs.)',
          data: monthlyData.map(d => d.investment_amount),
          backgroundColor: 'rgba(75, 192, 192, 0.6)',
          borderColor: 'rgba(75, 192, 192, 1)',
          borderWidth: 1,
          yAxisID: 'y1',
          type: 'line'
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: {
        mode: 'index',
        intersect: false,
      },
      scales: {
        x: {
          display: true,
          title: {
            display: true,
            text: 'Month'
          }
        },
        y: {
          type: 'linear',
          display: true,
          position: 'left',
          title: {
            display: true,
            text: 'Number of Investors'
          },
        },
        y1: {
          type: 'linear',
          display: true,
          position: 'right',
          title: {
            display: true,
            text: 'Investment Amount (Rs.)'
          },
          grid: {
            drawOnChartArea: false,
          },
        }
      }
    }
  });

  // Status Chart
  const statusCtx = document.getElementById('statusChart').getContext('2d');

  new Chart(statusCtx, {
    type: 'doughnut',
    data: {
      labels: ['Active', 'Inactive'],
      datasets: [{
        data: [<%= @active_investors %>, <%= @inactive_investors %>],
        backgroundColor: [
          'rgba(40, 167, 69, 0.8)',
          'rgba(220, 53, 69, 0.8)'
        ],
        borderColor: [
          'rgba(40, 167, 69, 1)',
          'rgba(220, 53, 69, 1)'
        ],
        borderWidth: 2
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom'
        }
      }
    }
  });
});
</script>

<style>
.card {
  transition: transform 0.2s ease-in-out;
}

.card:hover {
  transform: translateY(-2px);
}

.table-responsive {
  border-radius: 0.375rem;
}

.badge {
  font-size: 0.75rem;
}

@media print {
  .no-print {
    display: none;
  }

  .container-fluid {
    padding: 0;
  }

  .card {
    border: 1px solid #dee2e6 !important;
    box-shadow: none !important;
  }
}
</style>

</body>
</html>