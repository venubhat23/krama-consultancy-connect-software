<% content_for :page_title, "Edit General Insurance" %>
<% content_for :page_subtitle, "Update general insurance policy details" %>

<!-- Action Buttons -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <%= link_to admin_other_insurances_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-2"></i>
      Back to List
    <% end %>
  </div>

  <div class="d-flex gap-2">
    <%= link_to admin_other_insurance_path(@other_insurance), class: "btn btn-outline-info" do %>
      <i class="bi bi-eye me-2"></i>
      View Policy
    <% end %>
    <div class="trust-seal">
      <i class="bi bi-shield-check seal-icon"></i>
      <span>Update Policy</span>
    </div>
  </div>
</div>

<%= render 'form' %>

<style>
.trust-seal {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 0.75rem 1.5rem;
  border-radius: 25px;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.9rem;
  font-weight: 600;
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
}

.seal-icon {
  font-size: 1.1rem;
  filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.3));
}
</style>

