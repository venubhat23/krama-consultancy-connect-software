          </div>
          <div class="col-md-3 mb-3">
            <label class="form-label required">Relationship</label>
            <select name="other_insurance[other_insurance_nominees_attributes][${nomineeIndex}][relationship]"
                    class="form-select" required>
              <option value="">Select Relationship</option>
              <option value="father" ${nominee.relationship === 'father' ? 'selected' : ''}>Father</option>
              <option value="mother" ${nominee.relationship === 'mother' ? 'selected' : ''}>Mother</option>
              <option value="spouse" ${nominee.relationship === 'spouse' ? 'selected' : ''}>Spouse</option>
              <option value="son" ${nominee.relationship === 'son' ? 'selected' : ''}>Son</option>
              <option value="daughter" ${nominee.relationship === 'daughter' ? 'selected' : ''}>Daughter</option>
              <option value="brother" ${nominee.relationship === 'brother' ? 'selected' : ''}>Brother</option>
              <option value="sister" ${nominee.relationship === 'sister' ? 'selected' : ''}>Sister</option>
              <option value="other" ${nominee.relationship === 'other' ? 'selected' : ''}>Other</option>
            </select>
          </div>
          <div class="col-md-2 mb-3">
            <label class="form-label required">Age</label>
            <input type="number" name="other_insurance[other_insurance_nominees_attributes][${nomineeIndex}][age]"
                   class="form-control" value="${nominee.age}" min="1" max="120" required>
          </div>
          <div class="col-md-2 mb-3">
            <label class="form-label">Share %</label>
            <input type="number" name="other_insurance[other_insurance_nominees_attributes][${nomineeIndex}][share_percentage]"
                   class="form-control" min="0" max="100" step="0.01" placeholder="100"
                   value="${nominee.share_percentage !== undefined ? nominee.share_percentage : ''}">
          </div>
          <div class="col-md-1 d-flex align-items-end mb-3">
            <button type="button" class="btn btn-outline-danger remove-nominee-btn">
              <i class="bi bi-trash"></i>
            </button>
          </div>
        </div>
      </div>
    `;
    document.getElementById('nominees').insertAdjacentHTML('beforeend', nomineeHtml);
    nomineeIndex++;
  };
});

