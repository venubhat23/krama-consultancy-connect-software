  window.loadCustomerNominees = function(customerId) {
    if (!customerId) return;

    $.ajax({
      url: '/admin/insurance/other/load_customer_nominees',
      method: 'GET',
      data: { customer_id: customerId },
      success: function(response) {
        if (response.success && response.nominees && response.nominees.length > 0) {
          $('.nominee-row').remove();

          const count = response.nominees.length;
          const equalShare = parseFloat((100 / count).toFixed(2));
          response.nominees.forEach(function(nominee, index) {
            const share = (index === count - 1) ? (100 - equalShare * (count - 1)).toFixed(2) : equalShare;
            addNomineeFromFamilyMember(Object.assign({}, nominee, { share_percentage: share }));
          });

          toggleNoNomineesMessage();
          console.log(`Auto-loaded ${response.nominees.length} nominee(s) from ${response.customer_name}`);
        } else {
          console.log('No nominee data found for auto-loading');
        }
      },
      error: function(xhr, status, error) {
        console.error('Error auto-loading customer nominees:', error);
      }
    });
  };

  // Clear nominees when customer changes
  window.clearNominees = function() {
    $('.nominee-row').remove();
    toggleNoNomineesMessage();
  };

  // Function to add nominee from family member data (like Motor Insurance)
  window.addNomineeFromFamilyMember = function(nominee) {
    const nomineeHtml = `
      <div class="nominee-row border rounded p-3 mb-3 bg-light">
