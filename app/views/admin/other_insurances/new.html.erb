    <div class="nominee-row border rounded p-3 mb-3" style="background-color: #f8f9fa;">
      <input type="hidden" name="other_insurance[other_insurance_nominees_attributes][${index}][id]" id="other_insurance_other_insurance_nominees_attributes_${index}_id">
      <div class="row">
        <div class="col-md-4 mb-3">
          <label class="form-label">Nominee Name <span class="text-danger">*</span></label>
          <input class="form-control" placeholder="Enter nominee name" required="required" type="text" name="other_insurance[other_insurance_nominees_attributes][${index}][nominee_name]" id="other_insurance_other_insurance_nominees_attributes_${index}_nominee_name">
        </div>
        <div class="col-md-3 mb-3">
          <label class="form-label">Relationship <span class="text-danger">*</span></label>
          <select class="form-control" required="required" name="other_insurance[other_insurance_nominees_attributes][${index}][relationship]" id="other_insurance_other_insurance_nominees_attributes_${index}_relationship">
            <option value="">Select Relationship</option>
            <option value="spouse">Spouse</option>
            <option value="son">Son</option>
            <option value="daughter">Daughter</option>
            <option value="father">Father</option>
            <option value="mother">Mother</option>
            <option value="brother">Brother</option>
            <option value="sister">Sister</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="col-md-2 mb-3">
          <label class="form-label">Age <span class="text-danger">*</span></label>
          <input class="form-control" placeholder="Age" required="required" min="0" max="120" type="number" name="other_insurance[other_insurance_nominees_attributes][${index}][age]" id="other_insurance_other_insurance_nominees_attributes_${index}_age">
        </div>
        <div class="col-md-2 mb-3">
          <label class="form-label">Share (%)</label>
          <input class="form-control" placeholder="100" min="0" max="100" step="0.01" type="number" name="other_insurance[other_insurance_nominees_attributes][${index}][share_percentage]" id="other_insurance_other_insurance_nominees_attributes_${index}_share_percentage">
        </div>
        <div class="col-md-1 mb-3 d-flex align-items-end">
          <button type="button" class="btn btn-danger btn-sm" onclick="removeNominee(this)" title="Remove nominee">
            <i class="bi bi-trash"></i>
          </button>
        </div>
      </div>
      <input value="false" class="destroy-flag" type="hidden" name="other_insurance[other_insurance_nominees_attributes][${index}][_destroy]" id="other_insurance_other_insurance_nominees_attributes_${index}__destroy">
    </div>
  `;

  document.getElementById('nominees').insertAdjacentHTML('beforeend', nomineeHtml);
  toggleNoNomineesMessage();
}

function removeNominee(button) {
  const nomineeRow = button.closest('.nominee-row');
  const destroyField = nomineeRow.querySelector('.destroy-flag');

  if (destroyField.value === 'false') {
    destroyField.value = 'true';
    nomineeRow.style.display = 'none';
  } else {
    nomineeRow.remove();
  }

  toggleNoNomineesMessage();
}

function toggleNoNomineesMessage() {
  const nomineeRows = document.querySelectorAll('.nominee-row');
  const noNomineesMsg = document.getElementById('no_nominees_message');

  const visibleRows = Array.from(nomineeRows).filter(row => row.style.display !== 'none');

  if (visibleRows.length === 0) {
    noNomineesMsg.style.display = 'block';
  } else {
    noNomineesMsg.style.display = 'none';
  }
}

