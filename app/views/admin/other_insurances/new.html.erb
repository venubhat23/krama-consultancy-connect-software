<script>
document.addEventListener('DOMContentLoaded', function() {
  // Initialize Select2 for searchable dropdowns
  $('#customer_select').select2({
    theme: 'bootstrap-5',
    placeholder: 'Search and select client...',
    allowClear: true,
    width: '100%',
    dropdownParent: $('body'),
    dropdownCssClass: 'select2-dropdown-large',
    minimumResultsForSearch: 0,
    closeOnSelect: true,
    templateResult: function(option) {
      if (!option.id || option.id === '') {
        return $('<span style="color: #6c757d; font-style: italic;">' + option.text + '</span>');
      }
      return $('<span>' + option.text + '</span>');
    }
  });

  // Initialize Select2 for Broker Code dropdown
  $('#other_insurance_broker_code_type').select2({
    theme: 'bootstrap-5',
    placeholder: 'Select Broker Code...',
    allowClear: true,
    width: '100%',
    dropdownParent: $('body'),
    minimumResultsForSearch: -1 // Disable search for small lists
  });

  $('#policy_holder_select').select2({
    theme: 'bootstrap-5',
    placeholder: 'Select policy holder...',
    allowClear: false,
    width: '100%',
    dropdownParent: $('body'),
    minimumResultsForSearch: 0
  });

  $('#affiliate_select').select2({
    theme: 'bootstrap-5',
    placeholder: 'Search and select affiliate...',
    allowClear: true,
    width: '100%',
    dropdownParent: $('body'),
    minimumResultsForSearch: 0,
    ajax: {
      url: '/api/v1/public/search_sub_agents',
      dataType: 'json',
      delay: 250,
      data: function (params) {
        var selectedCustomerId = $('#customer_select').val();

        return {
          q: params.term || '',
          customer_id: selectedCustomerId,
          limit: params.term ? 20 : 10
        };
      },
      processResults: function (data) {
        return {
          results: data.results || []
        };
      },
      cache: true
    },
    templateResult: function(affiliate) {
      if (affiliate.loading) return affiliate.text;
      if (!affiliate.id || affiliate.id === '') {
        return $('<span style="color: #6c757d; font-style: italic;">' + affiliate.text + '</span>');
      }

      var initials = affiliate.text.split(' ').map(n => n[0]).join('').toUpperCase();
      var $container = $(`
        <div class="affiliate-option">
          <div class="affiliate-option-avatar">${initials}</div>
          <div class="affiliate-option-details">
            <div class="affiliate-option-name">${affiliate.text}</div>
            <div class="affiliate-option-id">ID: ${affiliate.id}</div>
          </div>
        </div>
      `);

      return $container;
    },
    templateSelection: function(affiliate) {
      return affiliate.text || affiliate.id;
    }
  });

  $('#other_insurance_agency_code_id').select2({
    theme: 'bootstrap-5',
    placeholder: 'Search and select agency code...',
    allowClear: true,
    width: '100%',
    dropdownParent: $('body'),
    minimumResultsForSearch: 0
  });

  $('#other_insurance_insurance_company_name').select2({
    theme: 'bootstrap-5',
    placeholder: 'Search and select company...',
    allowClear: true,
    width: '100%',
    dropdownParent: $('body'),
    minimumResultsForSearch: 0
  });

  // Handle customer selection change using Select2 events
  $('#customer_select').on('select2:select', function(e) {
    const customerId = $(this).val();
    console.log('Customer selected:', customerId);

    if (customerId) {
      // Fetch customer family members and update policy holder options
      fetch('/admin/customers/' + customerId + '/family_members')
        .then(response => response.json())
        .then(data => {
          const policyHolderSelect = $('#policy_holder_select');

          // Destroy existing Select2 instance
          if (policyHolderSelect.data('select2')) {
            policyHolderSelect.select2('destroy');
          }

          // Clear and rebuild options
          policyHolderSelect.empty();
          policyHolderSelect.append('<option value="Self" selected>Self</option>');

          if (data.family_members && data.family_members.length > 0) {
            data.family_members.forEach(member => {
              policyHolderSelect.append(`<option value="${member.name}">${member.name} (${member.relationship})</option>`);
            });
          }

          // Reinitialize Select2 with new options
          policyHolderSelect.select2({
            theme: 'bootstrap-5',
            placeholder: 'Select policy holder...',
            allowClear: false,
            width: '100%',
            dropdownParent: $('body'),
            minimumResultsForSearch: 0
          });

          // Set value to Self
          policyHolderSelect.val('Self').trigger('change');
        })
        .catch(error => {
          console.error('Error fetching family members:', error);
          const policyHolderSelect = $('#policy_holder_select');

          // Reset to Self only on error
          if (policyHolderSelect.data('select2')) {
            policyHolderSelect.select2('destroy');
          }

          policyHolderSelect.empty();
          policyHolderSelect.append('<option value="Self" selected>Self</option>');

          policyHolderSelect.select2({
            theme: 'bootstrap-5',
            placeholder: 'Select policy holder...',
            allowClear: false,
            width: '100%',
            dropdownParent: $('body'),
            minimumResultsForSearch: 0
          });
        });

      // Refresh affiliate dropdown to filter by customer
      $('#affiliate_select').val(null).trigger('change');
      console.log('Customer selected, affiliate dropdown will now filter for customer ID:', customerId);

      // Auto-load customer nominees (like Motor Insurance)
      loadCustomerNominees(customerId);
    }
  });

  // Handle customer clearing
  $('#customer_select').on('select2:clear', function(e) {
    console.log('Customer cleared');

    // Reset policy holder to Self only
    const policyHolderSelect = $('#policy_holder_select');

    if (policyHolderSelect.data('select2')) {
      policyHolderSelect.select2('destroy');
    }

    policyHolderSelect.empty();
    policyHolderSelect.append('<option value="Self" selected>Self</option>');

    policyHolderSelect.select2({
      theme: 'bootstrap-5',
      placeholder: 'Select policy holder...',
      allowClear: false,
      width: '100%',
      dropdownParent: $('body'),
      minimumResultsForSearch: 0
    });

    // Clear affiliate selection and refresh dropdown
    $('#affiliate_select').val(null).trigger('change');
    console.log('Customer cleared, affiliate dropdown will now show all affiliates');

    // Clear nominees when customer is cleared (like Motor Insurance)
    clearNominees();
  });

  // Handle broker code type change - matches Health Insurance functionality
  $('#other_insurance_broker_code_type').on('click', function() {
    const insuranceCompanySelect = $('#other_insurance_insurance_company_name');
    if (insuranceCompanySelect.length && insuranceCompanySelect.prop('disabled')) {
      insuranceCompanySelect.prop('disabled', false);
      console.log('✅ Other Insurance Company Name dropdown enabled');

      // Also enable it for native element if needed
      const nativeSelect = document.getElementById('other_insurance_insurance_company_name');
      if (nativeSelect && nativeSelect.disabled) {
        nativeSelect.disabled = false;
      }
