  // Auto-calculate functions
  function calculateTotalPremium() {
    const netPremium = parseFloat(document.getElementById('net_premium_field').value) || 0;
    const gstPercentage = parseFloat(document.getElementById('gst_percentage_field').value) || 0;

    const gstAmount = (netPremium * gstPercentage) / 100;
    const totalPremium = netPremium + gstAmount;

    document.getElementById('total_premium_field').value = totalPremium.toFixed(2);
  }

  function calculateCommissions() {
    const netPremium = parseFloat(document.getElementById('net_premium_field').value) || 0;

    // Main Agent Commission
    const mainCommissionPct = parseFloat(document.getElementById('commission_percentage').value) || 0;
    const mainCommissionAmt = (netPremium * mainCommissionPct) / 100;
    document.getElementById('commission_amount').value = mainCommissionAmt.toFixed(2);

    const mainTdsPct = parseFloat(document.getElementById('tds_percentage').value) || 0;
    const mainTdsAmt = (mainCommissionAmt * mainTdsPct) / 100;
    document.getElementById('tds_amount').value = mainTdsAmt.toFixed(2);
    document.getElementById('after_tds_value').value = (mainCommissionAmt - mainTdsAmt).toFixed(2);

    // Affiliate Commission
    const subAgentPct = parseFloat(document.querySelector('.sub-agent-commission-percentage').value) || 0;
    const subAgentAmt = (netPremium * subAgentPct) / 100;
    document.querySelector('.sub-agent-commission-amount').value = subAgentAmt.toFixed(2);

    const subAgentTdsPct = parseFloat(document.querySelector('.sub-agent-tds-percentage').value) || 0;
    const subAgentTdsAmt = (subAgentAmt * subAgentTdsPct) / 100;
    document.querySelector('.sub-agent-tds-amount').value = subAgentTdsAmt.toFixed(2);
    document.querySelector('.sub-agent-after-tds-value').value = (subAgentAmt - subAgentTdsAmt).toFixed(2);

    // Investor Commission (no TDS for investors)
    const investorPct = parseFloat(document.querySelector('.investor-commission-percentage').value) || 0;
    const investorAmt = (netPremium * investorPct) / 100;
    document.querySelector('.investor-commission-amount').value = investorAmt.toFixed(2);
    // Update investor display field (since they don't have TDS)
    document.querySelector('.investor-commission-amount-display').value = investorAmt.toFixed(2);

    // Ambassador Commission
    const ambassadorPct = parseFloat(document.querySelector('.ambassador-commission-percentage').value) || 0;
    const ambassadorAmt = (netPremium * ambassadorPct) / 100;
    document.querySelector('.ambassador-commission-amount').value = ambassadorAmt.toFixed(2);

    const ambassadorTdsPct = parseFloat(document.querySelector('.ambassador-tds-percentage').value) || 0;
    const ambassadorTdsAmt = (ambassadorAmt * ambassadorTdsPct) / 100;
    document.querySelector('.ambassador-tds-amount').value = ambassadorTdsAmt.toFixed(2);
    document.querySelector('.ambassador-after-tds-value').value = (ambassadorAmt - ambassadorTdsAmt).toFixed(2);

    // Company Expenses
    const companyExpensesPct = parseFloat(document.querySelector('.company-expenses-percentage').value) || 0;
    const companyExpensesAmt = (netPremium * companyExpensesPct) / 100;
    document.querySelector('.company-expenses-amount').value = companyExpensesAmt.toFixed(2);
    document.querySelector('.company-expenses-amount-display').value = companyExpensesAmt.toFixed(2);

    // Calculate total distribution and profit
    const totalDistribution = subAgentPct + investorPct + ambassadorPct;
    document.querySelector('.total-distribution-percentage').value = totalDistribution.toFixed(2);

    const profitPct = mainCommissionPct - totalDistribution - companyExpensesPct;
    document.querySelector('.profit-percentage-display').value = profitPct.toFixed(2);

    const profitAmt = (netPremium * profitPct) / 100;
    document.querySelector('.profit-amount-display').value = profitAmt.toFixed(2);
    document.querySelector('.profit-amount-display-final').value = profitAmt.toFixed(2);
  }

  // Enhanced Policy End Date calculation based on start date and payment mode
  function calculatePolicyEndDate() {
    const startDateField = document.getElementById('start_date');
    const endDateField = document.getElementById('end_date');
    const paymentModeField = document.getElementById('payment_mode_select');

    if (!startDateField || !endDateField || !paymentModeField) {
      return;
    }

    const startDate = new Date(startDateField.value);
    const paymentMode = paymentModeField.value;

    if (!startDateField.value || !paymentMode) {
      return;
    }

    let endDate = new Date(startDate);

    switch(paymentMode) {
      case 'Yearly':
        endDate.setFullYear(endDate.getFullYear() + 1);
        endDate.setDate(endDate.getDate() - 1); // End date is one day before renewal
        break;
      case 'Half Yearly':
        endDate.setMonth(endDate.getMonth() + 6);
        endDate.setDate(endDate.getDate() - 1);
        break;
      case 'Quarterly':
        endDate.setMonth(endDate.getMonth() + 3);
        endDate.setDate(endDate.getDate() - 1);
        break;
      case 'Monthly':
        endDate.setMonth(endDate.getMonth() + 1);
        endDate.setDate(endDate.getDate() - 1);
        break;
      default:
        endDate.setFullYear(endDate.getFullYear() + 1);
        endDate.setDate(endDate.getDate() - 1);
    }

    endDateField.value = endDate.toISOString().split('T')[0];
    console.log('📅 Policy End Date calculated:', endDate.toISOString().split('T')[0]);
  }

  // Auto-calculate Installment Autopay End Date
  function calculateAutopayEndDate() {
    const paymentMode = document.getElementById('payment_mode_select').value;
    const startDate = document.getElementById('autopay_start_date').value;

    if (startDate && paymentMode) {
      const start = new Date(startDate);
      let end = new Date(start);

      switch (paymentMode) {
        case 'Yearly':
          end.setFullYear(end.getFullYear() + 1);
          end.setDate(end.getDate() - 1); // Subtract 1 day for proper end date
          break;
        case 'Half Yearly':
          end.setMonth(end.getMonth() + 6);
          end.setDate(end.getDate() - 1);
          break;
        case 'Quarterly':
          end.setMonth(end.getMonth() + 3);
          end.setDate(end.getDate() - 1);
          break;
        case 'Monthly':
          end.setMonth(end.getMonth() + 1);
          end.setDate(end.getDate() - 1);
          break;
        default:
          // Default to yearly if unknown payment mode
          end.setFullYear(end.getFullYear() + 1);
          end.setDate(end.getDate() - 1);
          break;
      }

      document.getElementById('autopay_end_date').value = end.toISOString().split('T')[0];
      console.log('💳 Autopay End Date calculated:', end.toISOString().split('T')[0]);
    }
  }

