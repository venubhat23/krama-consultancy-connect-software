<!-- Custom styles for renewal button animation -->
<style>
  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(220, 53, 69, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
    }
  }

  .pulse-animation {
    animation: pulse 1.5s infinite;
  }

  .btn-danger.pulse-animation:hover {
    animation: none;
    transform: scale(1.05);
    transition: transform 0.2s;
  }

  /* Enhanced button styles */
  .btn-success:hover {
    transform: scale(1.05);
    transition: transform 0.2s;
  }

  .btn-primary:hover {
    transform: scale(1.05);
    transition: transform 0.2s;
  }

  .btn-warning:hover {
    transform: scale(1.05);
    transition: transform 0.2s;
  }
</style>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">General Insurance Policies</h2>
  </div>
  <div class="d-flex gap-2">
    <div class="dropdown download-dropdown">
      <button class="btn btn-success dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-download me-1"></i> Download
      </button>
      <ul class="dropdown-menu dropdown-menu-end">
        <li>
          <a class="dropdown-item" data-turbo="false" href="<%= download_admin_other_insurances_path(request.query_parameters.merge(format_type: 'csv')) %>">
            <i class="bi bi-filetype-csv text-success me-2"></i>CSV
          </a>
        </li>
        <li>
          <a class="dropdown-item" data-turbo="false" href="<%= download_admin_other_insurances_path(request.query_parameters.merge(format_type: 'excel')) %>">
            <i class="bi bi-file-earmark-excel text-success me-2"></i>Excel
          </a>
        </li>
      </ul>
    </div>
    <%= link_to new_admin_other_insurance_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i>
      Add New Policy
    <% end %>
  </div>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Policies</h6>
            <h3 class="mb-0 text-primary"><%= number_with_delimiter((@drwise_count || 0) + (@non_drwise_count || 0)) %></h3>
            <div class="d-flex gap-2 mt-2">
              <small class="text-success">
                <i class="bi bi-check-circle me-1"></i>DrWise: <%= @drwise_count %>
              </small>
              <small class="text-warning">
                <i class="bi bi-x-circle me-1"></i>Non-DrWise: <%= @non_drwise_count %>
              </small>
            </div>
          </div>
          <div class="bg-primary bg-opacity-10 rounded p-3">
            <i class="bi bi-shield text-primary fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Premium</h6>
            <h3 class="mb-0 text-success"><%= indian_currency((@drwise_premium || 0) + (@non_drwise_premium || 0)) %></h3>
            <div class="mt-2">
              <small class="text-muted d-block">DrWise: <%= indian_currency(@drwise_premium || 0) %></small>
              <small class="text-muted d-block">Non-DrWise: <%= indian_currency(@non_drwise_premium || 0) %></small>
            </div>
          </div>
          <div class="bg-success bg-opacity-10 rounded p-3">
            <i class="bi bi-currency-rupee text-success fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Coverage</h6>
            <h3 class="mb-0 text-info"><%= indian_currency((@drwise_coverage || 0) + (@non_drwise_coverage || 0)) %></h3>
            <div class="mt-2">
              <small class="text-muted d-block">DrWise: <%= indian_currency(@drwise_coverage || 0) %></small>
              <small class="text-muted d-block">Non-DrWise: <%= indian_currency(@non_drwise_coverage || 0) %></small>
            </div>
          </div>
          <div class="bg-info bg-opacity-10 rounded p-3">
            <i class="bi bi-shield-check text-info fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Active Policies</h6>
            <%
              drwise_active = OtherInsurance.where(
                is_admin_added: true, is_customer_added: false, is_agent_added: false
              ).where('policy_end_date IS NULL OR policy_end_date >= ?', Date.current).count

              non_drwise_active = OtherInsurance.where(
                '(is_customer_added = ? AND is_admin_added = ? AND is_agent_added = ?) OR (is_agent_added = ? AND is_customer_added = ? AND is_admin_added = ?)',
                true, false, false, true, false, false
              ).where('policy_end_date IS NULL OR policy_end_date >= ?', Date.current).count
            %>
            <h3 class="mb-0 text-warning"><%= number_with_delimiter(drwise_active + non_drwise_active) %></h3>
            <div class="d-flex gap-2 mt-2">
              <small class="text-success">
                <i class="bi bi-check-circle me-1"></i>DrWise: <%= drwise_active %>
              </small>
              <small class="text-warning">
                <i class="bi bi-x-circle me-1"></i>Non-DrWise: <%= non_drwise_active %>
              </small>
            </div>
          </div>
          <div class="bg-warning bg-opacity-10 rounded p-3">
            <i class="bi bi-check-circle text-warning fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Tabs for DrWise vs Non-DrWise -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body p-0">
    <ul class="nav nav-tabs border-0" role="tablist">
      <li class="nav-item" role="presentation">
        <%= link_to admin_other_insurances_path(tab: 'drwise', search: params[:search], insurance_type: params[:insurance_type], payment_mode: params[:payment_mode]),
            class: "nav-link #{'active' if @current_tab == 'drwise'}",
            role: "tab" do %>
          <i class="bi bi-check-circle me-2"></i>
          DrWise Policies
          <span class="badge bg-success ms-2"><%= @drwise_count %></span>
        <% end %>
      </li>
      <li class="nav-item" role="presentation">
        <%= link_to admin_other_insurances_path(tab: 'non_drwise', search: params[:search], insurance_type: params[:insurance_type], payment_mode: params[:payment_mode]),
            class: "nav-link #{'active' if @current_tab == 'non_drwise'}",
            role: "tab" do %>
          <i class="bi bi-x-circle me-2"></i>
          Non-DrWise Policies
          <span class="badge bg-warning ms-2"><%= @non_drwise_count %></span>
        <% end %>
      </li>
    </ul>
  </div>
</div>

<!-- Search and Filters -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet"/>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: admin_other_insurances_path, method: :get, local: true, id: "other-filter-form" do |form| %>
      <%= form.hidden_field :tab, value: @current_tab %>

      <!-- Basic filter row -->
      <div class="row g-2 align-items-end mb-2">
        <div class="col-md-4">
          <%= form.text_field :search, placeholder: "Search by policy no., customer, company…", value: params[:search], class: "form-control" %>
        </div>
        <div class="col-md-2">
          <%= form.select :status, options_for_select([
            ['All Statuses', ''],
            ['Active', 'active'],
            ['Expiring Soon', 'expiring_soon'],
            ['Expired', 'expired']
          ], params[:status]), {}, { class: "form-select" } %>
        </div>
        <div class="col-md-2">
          <%= form.submit "Search", class: "btn btn-primary w-100" %>
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-outline-secondary w-100" id="toggle-oi-adv-filter">
            <i class="bi bi-funnel me-1"></i>Advanced
            <% oi_adv_active = [params[:company], params[:sub_agent_id], params[:insurance_type], params[:payment_mode], params[:from_date], params[:to_date]].any?(&:present?) %>
            <% if oi_adv_active %>
              <span class="badge bg-primary ms-1" id="oi-adv-dot">●</span>
            <% else %>
              <span class="badge bg-secondary ms-1 d-none" id="oi-adv-dot">●</span>
            <% end %>
          </button>
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-outline-secondary w-100" id="oi-col-config-btn"
                  title="Configure visible columns">
            <i class="bi bi-layout-three-columns me-1"></i>Columns
            <span class="badge bg-secondary ms-1" id="oi-col-count-badge">7</span>
          </button>
        </div>
      </div>

      <!-- Advanced filter panel -->
      <div id="oi-adv-panel" class="border rounded p-3 mt-2 bg-light" style="display: <%= oi_adv_active ? 'block' : 'none' %>;">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label fw-semibold small text-muted">Company Name</label>
            <select name="company" class="form-select oi-adv-select2">
              <option value="">All Companies</option>
              <% @filter_companies.each do |co| %>
                <option value="<%= co %>" <%= 'selected' if params[:company] == co %>><%= co %></option>
              <% end %>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold small text-muted">Affiliate</label>
            <select name="sub_agent_id" class="form-select oi-adv-select2">
              <option value="">All Affiliates</option>
              <% @filter_sub_agents.each do |sa| %>
                <option value="<%= sa.id %>" <%= 'selected' if params[:sub_agent_id].to_s == sa.id.to_s %>><%= sa.display_name %></option>
              <% end %>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold small text-muted">Insurance Type</label>
            <select name="insurance_type" class="form-select oi-adv-select2">
              <option value="">All Types</option>
              <% @filter_insurance_types.each do |it| %>
                <option value="<%= it %>" <%= 'selected' if params[:insurance_type] == it %>><%= it %></option>
              <% end %>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold small text-muted">Start Date — From</label>
            <div class="input-group">
              <span class="input-group-text bg-primary text-white border-0"><i class="bi bi-calendar3"></i></span>
              <%= form.date_field :from_date, value: params[:from_date], class: "form-control" %>
            </div>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold small text-muted">Start Date — To</label>
            <div class="input-group">
              <span class="input-group-text bg-primary text-white border-0"><i class="bi bi-calendar3"></i></span>
              <%= form.date_field :to_date, value: params[:to_date], class: "form-control" %>
            </div>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold small text-muted">Payment Mode</label>
            <select name="payment_mode" class="form-select oi-adv-select2">
              <option value="">All Modes</option>
              <% @filter_payment_modes.each do |pm| %>
                <option value="<%= pm %>" <%= 'selected' if params[:payment_mode] == pm %>><%= pm %></option>
              <% end %>
            </select>
          </div>
          <div class="col-md-3 d-flex align-items-end gap-2">
            <%= form.submit "Apply Filter", class: "btn btn-primary flex-fill" %>
            <%= link_to "Reset", admin_other_insurances_path(tab: params[:tab]), class: "btn btn-outline-secondary flex-fill" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- General Insurance Policies List -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">
      <% if @current_tab == 'drwise' %>
        <i class="bi bi-check-circle text-success me-2"></i>DrWise General Insurance Policies
      <% else %>
        <i class="bi bi-x-circle text-warning me-2"></i>Non-DrWise General Insurance Policies
      <% end %>
    </h5>
  </div>
  <div class="card-body p-0">
    <% if @other_insurances.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0" id="oi-table">
          <thead class="bg-light">
            <tr>
              <th class="border-0" data-col="oi-policy">Policy</th>
              <th class="border-0" data-col="oi-customer">Customer</th>
              <th class="border-0" data-col="oi-company">Company</th>
              <th class="border-0" data-col="oi-source">Source &amp; Type</th>
              <th class="border-0" data-col="oi-coverage">Coverage</th>
              <th class="border-0" data-col="oi-premium">Premium</th>
              <th class="border-0" data-col="oi-status">Status</th>
              <!-- Optional columns -->
              <th class="border-0" data-col="oi-start-date">Start Date</th>
              <th class="border-0" data-col="oi-end-date">End Date</th>
              <th class="border-0" data-col="oi-net-premium">Net Premium</th>
              <th class="border-0" data-col="oi-payment-mode">Payment Mode</th>
              <th class="border-0" data-col="oi-policy-type">Policy Type</th>
              <th class="border-0" data-col="oi-agent">Agent</th>
              <th class="border-0" data-col="oi-booking-date">Booking Date</th>
              <!-- Actions always visible -->
              <th class="border-0">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @other_insurances.each do |policy| %>
              <tr>
                <td data-col="oi-policy">
                  <div>
                    <h6 class="mb-1"><%= policy.policy_number %></h6>
                    <small class="text-muted"><%= policy.policy_type&.humanize %></small>
                    <br>
                    <% doc_count = policy.total_documents_count %>
                    <small class="<%= doc_count > 0 ? 'text-success' : 'text-danger' %>">
                      <i class="bi bi-file-earmark-<%= doc_count > 0 ? 'check' : 'x' %> me-1"></i>
                      <%= doc_count %> doc<%= doc_count == 1 ? '' : 's' %>
                    </small>
                  </div>
                </td>
                <td data-col="oi-customer">
                  <div>
                    <h6 class="mb-1"><%= policy.customer&.display_name %></h6>
                    <small class="text-muted"><%= policy.customer&.mobile %></small>
                  </div>
                </td>
                <td data-col="oi-company">
                  <div>
                    <h6 class="mb-1"><%= policy.insurance_company_code || policy.insurance_company_name %></h6>
                  </div>
                </td>
                <td data-col="oi-source">
                  <div class="d-flex flex-column gap-1">
                    <div>
                      <% if policy.is_customer_added? %>
                        <span class="badge bg-info-subtle text-info"><i class="bi bi-person-check me-1"></i>Customer</span>
                      <% elsif policy.is_agent_added? %>
                        <span class="badge bg-success-subtle text-success"><i class="bi bi-person-badge me-1"></i>Agent</span>
                      <% elsif policy.is_admin_added? %>
                        <span class="badge bg-primary-subtle text-primary"><i class="bi bi-shield-check me-1"></i>Admin</span>
                      <% else %>
                        <span class="badge bg-secondary-subtle text-secondary"><i class="bi bi-question-circle me-1"></i>Unknown</span>
                      <% end %>
                    </div>
                    <div>
                      <span class="badge bg-light text-dark border"><i class="bi bi-shield me-1"></i><%= policy.insurance_type %></span>
                    </div>
                  </div>
                </td>
                <td data-col="oi-coverage">
                  <div>
                    <small class="text-muted d-block" style="font-size:0.75rem;">Sum Insured</small>
                    <div class="fw-bold text-primary" style="font-size:1rem;"><%= policy.sum_insured ? indian_currency(policy.sum_insured) : '—' %></div>
                  </div>
                </td>
                <td data-col="oi-premium">
                  <div>
                    <small class="text-muted d-block" style="font-size:0.75rem;"><%= policy.payment_mode&.humanize || 'Yearly' %></small>
                    <div class="fw-bold text-success" style="font-size:1rem;"><%= indian_currency(policy.total_premium) %></div>
                  </div>
                </td>
                <td data-col="oi-status">
                  <% if policy.has_been_renewed? && policy.expired? %>
                    <span class="badge" style="background-color:#6f42c1;">Renewed</span>
                  <% elsif policy.policy_end_date && policy.policy_end_date < Date.current %>
                    <span class="badge bg-danger">Expired</span>
                  <% elsif policy.policy_end_date && policy.policy_end_date <= 30.days.from_now %>
                    <span class="badge bg-warning">Expiring Soon</span>
                  <% else %>
                    <span class="badge bg-success">Active</span>
                  <% end %>
                </td>
                <!-- Optional columns -->
                <td data-col="oi-start-date"><span class="text-muted"><%= policy.policy_start_date&.strftime('%d %b %Y') || '—' %></span></td>
                <td data-col="oi-end-date"><span class="text-muted"><%= policy.policy_end_date&.strftime('%d %b %Y') || '—' %></span></td>
                <td data-col="oi-net-premium"><span class="fw-semibold text-secondary"><%= policy.net_premium.present? ? indian_currency(policy.net_premium) : '—' %></span></td>
                <td data-col="oi-payment-mode"><span class="text-muted"><%= policy.payment_mode&.humanize || '—' %></span></td>
                <td data-col="oi-policy-type"><span class="text-muted"><%= policy.policy_type.presence || '—' %></span></td>
                <td data-col="oi-agent"><span class="text-muted"><%= policy.sub_agent&.display_name || '—' %></span></td>
                <td data-col="oi-booking-date"><span class="text-muted"><%= policy.policy_booking_date&.strftime('%d %b %Y') || '—' %></span></td>
                <td>
                  <div class="d-flex gap-1">
                    <% if can_view?('other_insurances') %>
                      <%= link_to admin_other_insurance_path(policy), class: "btn btn-sm btn-outline-primary", title: "View" do %>
                        <i class="bi bi-eye"></i>
                      <% end %>
                    <% end %>
                    <% if can_edit?('other_insurances') %>
                      <%= link_to edit_admin_other_insurance_path(policy), class: "btn btn-sm btn-outline-warning", title: "Edit" do %>
                        <i class="bi bi-pencil"></i>
                      <% end %>
                    <% end %>

                    <!-- Renewal Button -->
                    <% if policy.can_be_renewed? && can_create?('other_insurances') %>
                      <%
                        # Determine button color and animation based on urgency
                        days_until_expiry = policy.days_until_expiry
                        button_class = if days_until_expiry <= 7
                                        "btn btn-sm btn-danger pulse-animation"
                                      elsif days_until_expiry <= 30
                                        "btn btn-sm btn-warning"
                                      else
                                        "btn btn-sm btn-success"
                                      end
                      %>
                      <%= link_to renew_admin_other_insurance_path(policy),
                          class: button_class,
                          title: "Renew Policy (Expires in #{days_until_expiry} days)" do %>
                        <i class="bi bi-arrow-clockwise"></i> Renew
                      <% end %>
                    <% elsif policy.has_been_renewed? %>
                      <button class="btn btn-sm btn-secondary" disabled title="Already Renewed">
                        <i class="bi bi-check-circle"></i>
                      </button>
                    <% elsif policy.is_renewal? %>
                      <span class="badge bg-info">Renewal</span>
                    <% end %>

                    <% if can_delete?('other_insurances') %>
                      <%= link_to admin_other_insurance_path(policy),
                          class: "btn btn-sm btn-outline-danger delete-policy-btn",
                          title: "Delete Policy & All Data",
                          method: :delete,
                          data: {
                            policy_number: policy.policy_number,
                            customer_name: policy.customer&.display_name,
                            insurance_type: policy.insurance_type,
                            company_name: policy.insurance_company_name,
                            premium_amount: number_to_currency(policy.net_premium, unit: 'Rs. ', precision: 0),
                            turbo_method: :delete,
                            turbo_confirm: false
                          },
                          onclick: "return confirmOtherPolicyDeletion(this, event);" do %>
                        <i class="bi bi-trash"></i>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @other_insurances.respond_to?(:current_page) %>
        <div class="card-footer bg-transparent border-0">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="d-flex align-items-center gap-3">
              <% if @other_insurances.respond_to?(:total_count) %>
                <small class="text-muted">
                  Showing <strong><%= @other_insurances.offset_value + 1 %></strong>–<strong><%= [@other_insurances.offset_value + @other_insurances.limit_value, @other_insurances.total_count].min %></strong> of <strong><%= number_with_delimiter(@other_insurances.total_count) %></strong>
                </small>
              <% end %>
              <%= render 'shared/per_page_selector' %>
            </div>
            <% if @other_insurances.respond_to?(:total_pages) && @other_insurances.total_pages > 1 %>
              <%= paginate @other_insurances %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-shield fs-1 text-muted d-block mb-3"></i>
        <h5 class="text-muted">No general insurance policies found</h5>
        <p class="text-muted mb-3">
          <% if params[:search].present? || params[:insurance_type].present? || params[:payment_mode].present? %>
            Try adjusting your search criteria or
            <%= link_to "view all policies", admin_other_insurances_path, class: "text-decoration-none" %>.
          <% else %>
            Start by adding your first general insurance policy to the system.
          <% end %>
        </p>
        <% if can_create?('other_insurances') %>
          <%= link_to new_admin_other_insurance_path, class: "btn btn-primary" do %>
            <i class="bi bi-plus-lg me-1"></i>
            Add First Policy
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<!-- Other Insurance Column Config Modal -->
<div class="modal fade" id="oiColConfigModal" tabindex="-1" aria-labelledby="oiColConfigModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-semibold" id="oiColConfigModalLabel">
          <i class="bi bi-layout-three-columns me-2 text-primary"></i>Customize Columns
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body pt-3">
        <div class="border rounded p-3" style="background:#f8fbff;">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="fw-semibold text-primary">Select Columns</span>
            <div class="form-check mb-0">
              <input type="checkbox" class="form-check-input" id="oi-col-check-all">
              <label class="form-check-label fw-semibold" for="oi-col-check-all">Check All</label>
            </div>
          </div>
          <div class="row g-2" id="oi-col-checkboxes"></div>
          <div class="mt-3 text-muted small">
            <i class="bi bi-info-circle me-1"></i>Maximum <strong>9 columns</strong> can be selected. <strong>Actions</strong> is always visible.
          </div>
          <div id="oi-col-validation" class="alert alert-danger mt-2 mb-0 py-2 d-none">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>
            <span id="oi-col-validation-text">Maximum 9 columns allowed.</span>
          </div>
        </div>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary px-4" id="oi-apply-cols">
          <i class="bi bi-check-lg me-1"></i>Apply Changes
        </button>
      </div>
    </div>
  </div>
</div>

<script>
// ── Other Insurance Column Config ─────────────────────────────────────────
const OI_COL_CONFIG = [
  { key: 'oi-policy',      label: 'Policy',         defaultOn: true  },
  { key: 'oi-customer',    label: 'Customer',        defaultOn: true  },
  { key: 'oi-company',     label: 'Company',         defaultOn: true  },
  { key: 'oi-source',      label: 'Source & Type',   defaultOn: true  },
  { key: 'oi-coverage',    label: 'Coverage',        defaultOn: true  },
  { key: 'oi-premium',     label: 'Premium',         defaultOn: true  },
  { key: 'oi-status',      label: 'Status',          defaultOn: true  },
  { key: 'oi-start-date',  label: 'Start Date',      defaultOn: false },
  { key: 'oi-end-date',    label: 'End Date',        defaultOn: false },
  { key: 'oi-net-premium', label: 'Net Premium',     defaultOn: false },
  { key: 'oi-payment-mode',label: 'Payment Mode',    defaultOn: false },
  { key: 'oi-policy-type', label: 'Policy Type',     defaultOn: false },
  { key: 'oi-agent',       label: 'Agent/Affiliate', defaultOn: false },
  { key: 'oi-booking-date',label: 'Booking Date',    defaultOn: false },
];
const OI_COL_MAX = 9;
const OI_COL_KEY = 'other_insurance_columns_v1';

function oiGetCols() {
  try { var s = localStorage.getItem(OI_COL_KEY); if (s) return JSON.parse(s); } catch(e) {}
  return OI_COL_CONFIG.filter(function(c) { return c.defaultOn; }).map(function(c) { return c.key; });
}
function oiSaveCols(cols) { localStorage.setItem(OI_COL_KEY, JSON.stringify(cols)); }
function oiApplyCols(cols) {
  OI_COL_CONFIG.forEach(function(col) {
    var show = cols.includes(col.key);
    document.querySelectorAll('[data-col="' + col.key + '"]').forEach(function(el) { el.style.display = show ? '' : 'none'; });
  });
  var badge = document.getElementById('oi-col-count-badge');
  if (badge) badge.textContent = cols.length;
}
function oiBuildCbs(cols) {
  var c = document.getElementById('oi-col-checkboxes');
  c.innerHTML = '';
  OI_COL_CONFIG.forEach(function(col) {
    var d = document.createElement('div'); d.className = 'col-md-4';
    d.innerHTML = '<div class="form-check" style="padding:.35rem .5rem .35rem 1.75rem;border-radius:6px;">' +
      '<input class="form-check-input oi-col-cb" type="checkbox" id="oi-cb-' + col.key + '" value="' + col.key + '"' + (cols.includes(col.key) ? ' checked' : '') + '>' +
      '<label class="form-check-label" for="oi-cb-' + col.key + '">' + col.label + '</label></div>';
    c.appendChild(d);
  });
}
function oiSyncCheckAll() {
  var cbs = document.querySelectorAll('.oi-col-cb');
  var all = Array.from(cbs).every(function(cb) { return cb.checked; });
  var any = Array.from(cbs).some(function(cb) { return cb.checked; });
  var ca = document.getElementById('oi-col-check-all');
  ca.checked = all; ca.indeterminate = !all && any;
}
function oiHideVal() { document.getElementById('oi-col-validation').classList.add('d-none'); }
function oiShowVal(msg) { document.getElementById('oi-col-validation-text').textContent = msg; document.getElementById('oi-col-validation').classList.remove('d-none'); }

document.addEventListener('DOMContentLoaded', function() {
  oiApplyCols(oiGetCols());

  var btn = document.getElementById('oi-col-config-btn');
  if (btn) btn.addEventListener('click', function() {
    oiBuildCbs(oiGetCols()); oiSyncCheckAll(); oiHideVal();
    new bootstrap.Modal(document.getElementById('oiColConfigModal')).show();
  });

  document.getElementById('oi-col-check-all').addEventListener('change', function() {
    var cbs = document.querySelectorAll('.oi-col-cb');
    if (this.checked && cbs.length > OI_COL_MAX) { oiShowVal('Cannot select all — maximum is ' + OI_COL_MAX + ' columns.'); this.checked = false; return; }
    oiHideVal();
    cbs.forEach(function(cb) { cb.checked = true; });
    if (!this.checked) cbs.forEach(function(cb) { cb.checked = false; });
    oiSyncCheckAll();
  });

  document.getElementById('oi-col-checkboxes').addEventListener('change', function(e) {
    if (!e.target.classList.contains('oi-col-cb')) return;
    var count = document.querySelectorAll('.oi-col-cb:checked').length;
    if (count > OI_COL_MAX) { e.target.checked = false; oiShowVal('Maximum ' + OI_COL_MAX + ' columns allowed.'); }
    else oiHideVal();
    oiSyncCheckAll();
  });

  document.getElementById('oi-apply-cols').addEventListener('click', function() {
    var sel = Array.from(document.querySelectorAll('.oi-col-cb:checked')).map(function(cb) { return cb.value; });
    if (!sel.length) { oiShowVal('Please select at least 1 column.'); return; }
    if (sel.length > OI_COL_MAX) { oiShowVal('Maximum ' + OI_COL_MAX + ' columns allowed.'); return; }
    oiSaveCols(sel); oiApplyCols(sel);
    bootstrap.Modal.getInstance(document.getElementById('oiColConfigModal')).hide();
  });

  // ── Advanced filter toggle ────────────────────────────────────────────────
  var oiToggle = document.getElementById('toggle-oi-adv-filter');
  var oiPanel  = document.getElementById('oi-adv-panel');
  var oiDot    = document.getElementById('oi-adv-dot');
  if (oiToggle) {
    oiToggle.addEventListener('click', function() {
      var open = oiPanel.style.display !== 'none';
      oiPanel.style.display = open ? 'none' : 'block';
      oiToggle.classList.toggle('btn-outline-secondary', open);
      oiToggle.classList.toggle('btn-secondary', !open);
      if (!open) initOiSelect2();
    });
  }
  function initOiSelect2() {
    if (typeof $ === 'undefined') return;
    $('.oi-adv-select2').each(function() {
      if ($(this).data('select2')) return;
      $(this).select2({ theme: 'bootstrap-5', width: '100%', allowClear: true, placeholder: $(this).find('option:first').text() });
    });
  }
  if (oiPanel && oiPanel.style.display !== 'none') initOiSelect2();
  if (oiPanel) {
    var oiAdvFields = oiPanel.querySelectorAll('select, input[type=date]');
    oiAdvFields.forEach(function(el) {
      el.addEventListener('change', function() {
        var any = Array.from(oiAdvFields).some(function(f) { return f.value !== ''; });
        oiDot.classList.toggle('d-none', !any);
      });
    });
  }
});

function confirmOtherPolicyDeletion(element, event) {
  // Prevent the default link behavior
  event.preventDefault();

  const policyNumber = element.dataset.policyNumber;
  const customerName = element.dataset.customerName;
  const insuranceType = element.dataset.insuranceType;
  const companyName = element.dataset.companyName;
  const premiumAmount = element.dataset.premiumAmount;

  const confirmMessage = `⚠️ PERMANENT DELETION WARNING ⚠️

You are about to permanently delete:

📋 Policy: ${policyNumber}
👤 Customer: ${customerName}
🛡️ Type: ${insuranceType}
🏢 Company: ${companyName}
💰 Premium: ${premiumAmount}

🗑️ This will also delete ALL associated data:
• Policy nominees and beneficiaries
• Commission payouts and invoices
• Related lead records
• All uploaded documents (R2 storage)
• Policy and additional documents

❌ THIS CANNOT BE UNDONE!

Are you absolutely sure you want to proceed?`;

  if (confirm(confirmMessage)) {
    // If user confirms, create and submit a form with DELETE method
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = element.href;
    form.style.display = 'none';

    // Add CSRF token
    const csrfToken = document.querySelector('meta[name="csrf-token"]');
    if (csrfToken) {
      const csrfInput = document.createElement('input');
      csrfInput.type = 'hidden';
      csrfInput.name = 'authenticity_token';
      csrfInput.value = csrfToken.getAttribute('content');
      form.appendChild(csrfInput);
    }

    // Add method override for DELETE
    const methodInput = document.createElement('input');
    methodInput.type = 'hidden';
    methodInput.name = '_method';
    methodInput.value = 'delete';
    form.appendChild(methodInput);

    document.body.appendChild(form);
    form.submit();
  }

  return false;
}
</script>