<% content_for :page_title, "General Insurance Policy Details" %>
<% content_for :page_subtitle, "Policy ##{@other_insurance.policy_number}" %>

<!-- Action Buttons -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <%= link_to admin_other_insurances_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-2"></i>
      Back to Policies
    <% end %>
  </div>

  <div class="d-flex gap-2">
    <% if @other_insurance.is_admin_added? && !Payout.exists?(policy_type: 'other', policy_id: @other_insurance.id) %>
      <%= button_to regenerate_payout_admin_other_insurance_path(@other_insurance), method: :post, class: "btn btn-warning", data: { confirm: 'Generate payout for this policy?' } do %>
        <i class="bi bi-cash-coin me-2"></i>
        Generate Payout
      <% end %>
    <% end %>
    <%= link_to edit_admin_other_insurance_path(@other_insurance), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-2"></i>
      Edit Policy
    <% end %>
  </div>
</div>

<!-- Client & Agent Details Section -->
<div class="info-section-card">
  <div class="section-header" data-bs-toggle="collapse" data-bs-target="#clientAgentCollapse" aria-expanded="true">
    <div class="d-flex align-items-center">
      <div class="section-icon">
        <i class="bi bi-person"></i>
      </div>
      <h5 class="section-title">Client & Agent Details</h5>
    </div>
    <i class="bi bi-chevron-down collapse-icon"></i>
  </div>
  <div id="clientAgentCollapse" class="collapse show">
    <div class="section-body">
    <div class="row">
      <div class="col-md-4 mb-3">
        <label class="form-label">Client Name*</label>
        <input type="text" class="form-control" value="<%= @other_insurance.customer&.display_name %>" readonly>
      </div>

      <div class="col-md-4 mb-3">
        <label class="form-label">Policy Holder*</label>
        <input type="text" class="form-control" value="<%= @other_insurance.policy_holder %>" readonly>
      </div>

      <div class="col-md-4 mb-3">
        <label class="form-label">Affiliate</label>
        <input type="text" class="form-control" value="<%= @other_insurance.sub_agent&.display_name || 'Self' %>" readonly>
      </div>
    </div>
    </div>
  </div>
</div>

