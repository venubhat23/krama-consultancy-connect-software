        <input type="text" class="form-control" value="<%= indian_currency(@other_insurance.sum_insured) if @other_insurance.sum_insured %>" readonly>
      </div>

      <div class="col-md-4 mb-3">
        <label class="form-label">Net Premium*</label>
        <input type="text" class="form-control" value="<%= indian_currency(@other_insurance.net_premium) if @other_insurance.net_premium %>" readonly>
      </div>

      <div class="col-md-4 mb-3">
        <label class="form-label">GST Percentage</label>
        <input type="text" class="form-control" value="<%= @other_insurance.gst_percentage %>%" readonly>
      </div>
    </div>

    <div class="row">
      <div class="col-md-4 mb-3">
        <label class="form-label">Total Premium*</label>
        <input type="text" class="form-control" value="<%= indian_currency(@other_insurance.total_premium) if @other_insurance.total_premium %>" readonly>
      </div>

      <div class="col-md-4 mb-3">
        <label class="form-label">Status</label>
        <input type="text" class="form-control" value="<%= @other_insurance.active? ? 'Active' : 'Expired' %>" readonly>
      </div>

      <div class="col-md-4 mb-3">
        <label class="form-label">Days Until Expiry</label>
        <% if @other_insurance.policy_end_date.present? %>
          <% days_until_expiry = (@other_insurance.policy_end_date - Date.current).to_i %>
          <input type="text" class="form-control <%= days_until_expiry <= 30 ? 'text-danger' : days_until_expiry <= 60 ? 'text-warning' : 'text-success' %>"
                 value="<%= days_until_expiry %> days" readonly>
        <% else %>
          <input type="text" class="form-control" value="N/A" readonly>
        <% end %>
