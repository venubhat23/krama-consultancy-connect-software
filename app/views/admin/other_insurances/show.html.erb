    <i class="bi bi-chevron-down collapse-icon"></i>
  </div>
  <div id="policyDocumentsCollapse" class="collapse">
    <div class="section-body">
      <%
        # Calculate total documents from different sources
        r2_documents = @other_insurance.other_insurance_documents.count
        active_storage_documents = @other_insurance.documents.attached? ? @other_insurance.documents.count : 0
        policy_documents = @other_insurance.policy_documents.attached? ? @other_insurance.policy_documents.count : 0
        uploaded_documents = @other_insurance.respond_to?(:uploaded_documents) ? @other_insurance.uploaded_documents.count : 0
        total_documents = r2_documents + active_storage_documents + policy_documents + uploaded_documents
      %>

      <!-- Document Statistics -->
      <div class="row mb-4">
        <div class="col-md-3">
          <div class="card border-0 bg-light">
            <div class="card-body text-center">
              <h4 class="text-primary mb-2"><%= total_documents %></h4>
              <p class="mb-0 text-muted">Total Documents</p>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card border-0 bg-light">
            <div class="card-body text-center">
              <h4 class="text-success mb-2"><%= r2_documents %></h4>
              <p class="mb-0 text-muted">R2 Stored</p>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card border-0 bg-light">
            <div class="card-body text-center">
              <h4 class="text-info mb-2"><%= active_storage_documents + policy_documents %></h4>
              <p class="mb-0 text-muted">Active Storage</p>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card border-0 bg-light">
            <div class="card-body text-center">
              <h4 class="text-warning mb-2"><%= uploaded_documents %></h4>
              <p class="mb-0 text-muted">Legacy Uploads</p>
            </div>
          </div>
        </div>
      </div>

      <% if total_documents > 0 %>

        <!-- R2 Documents Section -->
        <% if @other_insurance.other_insurance_documents.any? %>
          <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent">
              <h6 class="mb-0 text-success">
                <i class="bi bi-cloud-check me-2"></i>
                R2 Documents (<%= @other_insurance.other_insurance_documents.count %>)
              </h6>
            </div>
            <div class="card-body p-0">
              <div class="list-group list-group-flush">
                <% @other_insurance.other_insurance_documents.each do |document| %>
                  <div class="list-group-item border-0">
                    <div class="d-flex align-items-center py-2">
                      <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                          <% if document.r2_content_type&.include?('pdf') %>
                            <i class="bi bi-file-earmark-pdf text-danger fs-5"></i>
                          <% elsif document.r2_content_type&.include?('image') %>
                            <i class="bi bi-file-earmark-image text-success fs-5"></i>
                          <% else %>
                            <i class="bi bi-file-earmark text-primary fs-5"></i>
                          <% end %>
                        </div>
                      </div>
                      <div class="flex-grow-1">
                        <h6 class="mb-1"><%= document.title %></h6>
                        <div class="mb-1">
                          <span class="badge bg-light text-dark me-2"><%= document.document_type %></span>
                          <% if document.r2_file_size %>
                            <span class="text-muted small">
                              <i class="bi bi-file-earmark me-1"></i><%= number_to_human_size(document.r2_file_size) %>
                            </span>
                          <% end %>
                        </div>
                        <% if document.description.present? %>
                          <p class="text-muted mb-1 small"><%= truncate(document.description, length: 100) %></p>
                        <% end %>
                        <small class="text-success">
                          <i class="bi bi-cloud-check me-1"></i>Stored in Cloudflare R2 • Uploaded <%= document.created_at.strftime("%B %d, %Y") %>
                        </small>
                      </div>
                      <div class="btn-group" role="group">
                        <% if document.r2_file_key.present? %>
                          <% begin %>
                            <% r2_url = R2Service.public_url(document.r2_file_key) if document.r2_file_key %>
                            <% if r2_url %>
                              <%= link_to r2_url, class: "btn btn-outline-success btn-sm", target: "_blank", title: "View Document" do %>
                                <i class="bi bi-eye"></i>
                              <% end %>
                              <%= link_to r2_url, class: "btn btn-outline-primary btn-sm", download: document.r2_filename, title: "Download Document" do %>
                                <i class="bi bi-download"></i>
                              <% end %>
                            <% end %>
                          <% rescue => e %>
                            <span class="text-muted small">View not available</span>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Active Storage Documents Section -->
        <% if @other_insurance.documents.attached? %>
          <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent">
              <h6 class="mb-0 text-primary">
                <i class="bi bi-folder me-2"></i>
                Additional Documents (<%= @other_insurance.documents.count %>)
              </h6>
            </div>
            <div class="card-body p-0">
              <div class="list-group list-group-flush">
                <% @other_insurance.documents.each do |document| %>
                  <div class="list-group-item border-0">
                    <div class="d-flex align-items-center py-2">
                      <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                          <% if document.content_type&.include?('pdf') %>
                            <i class="bi bi-file-earmark-pdf text-danger fs-5"></i>
                          <% elsif document.content_type&.include?('image') %>
                            <i class="bi bi-file-earmark-image text-success fs-5"></i>
                          <% else %>
                            <i class="bi bi-file-earmark text-primary fs-5"></i>
                          <% end %>
                        </div>
                      </div>
                      <div class="flex-grow-1">
                        <h6 class="mb-1"><%= document.filename %></h6>
                        <div class="mb-1">
                          <span class="badge bg-light text-dark me-2">Additional Document</span>
                          <span class="text-muted small">
                            <i class="bi bi-file-earmark me-1"></i><%= number_to_human_size(document.byte_size) %>
                          </span>
                        </div>
                        <small class="text-info">
                          <i class="bi bi-server me-1"></i>Stored in Active Storage • <%= document.content_type %>
                        </small>
                      </div>
                      <div class="btn-group" role="group">
                        <%= link_to rails_blob_path(document, disposition: "inline"), class: "btn btn-outline-primary btn-sm", target: "_blank", title: "View Document" do %>
                          <i class="bi bi-eye"></i>
                        <% end %>
                        <%= link_to rails_blob_path(document, disposition: "attachment"), class: "btn btn-outline-success btn-sm", title: "Download Document" do %>
                          <i class="bi bi-download"></i>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Policy Documents (Active Storage) Section -->
        <% if @other_insurance.policy_documents.attached? %>
          <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent">
              <h6 class="mb-0 text-warning">
                <i class="bi bi-shield-check me-2"></i>
                Policy Documents (<%= @other_insurance.policy_documents.count %>)
              </h6>
            </div>
            <div class="card-body p-0">
              <div class="list-group list-group-flush">
                <% @other_insurance.policy_documents.each do |document| %>
                  <div class="list-group-item border-0">
                    <div class="d-flex align-items-center py-2">
                      <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle bg-warning bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                          <% if document.content_type&.include?('pdf') %>
                            <i class="bi bi-file-earmark-pdf text-danger fs-5"></i>
                          <% elsif document.content_type&.include?('image') %>
                            <i class="bi bi-file-earmark-image text-success fs-5"></i>
                          <% else %>
                            <i class="bi bi-file-earmark text-primary fs-5"></i>
                          <% end %>
                        </div>
                      </div>
                      <div class="flex-grow-1">
                        <h6 class="mb-1"><%= document.filename %></h6>
                        <div class="mb-1">
                          <span class="badge bg-warning text-dark me-2">Policy Document</span>
                          <span class="text-muted small">
                            <i class="bi bi-file-earmark me-1"></i><%= number_to_human_size(document.byte_size) %>
                          </span>
                        </div>
                        <small class="text-warning">
                          <i class="bi bi-server me-1"></i>Stored in Active Storage • <%= document.content_type %>
                        </small>
                      </div>
                      <div class="btn-group" role="group">
                        <%= link_to rails_blob_path(document, disposition: "inline"), class: "btn btn-outline-warning btn-sm", target: "_blank", title: "View Document" do %>
                          <i class="bi bi-eye"></i>
                        <% end %>
                        <%= link_to rails_blob_path(document, disposition: "attachment"), class: "btn btn-outline-success btn-sm", title: "Download Document" do %>
                          <i class="bi bi-download"></i>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Legacy Uploaded Documents Section -->
        <% if @other_insurance.respond_to?(:uploaded_documents) && @other_insurance.uploaded_documents.any? %>
          <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent">
              <h6 class="mb-0 text-secondary">
                <i class="bi bi-archive me-2"></i>
                Legacy Documents (<%= @other_insurance.uploaded_documents.count %>)
              </h6>
            </div>
            <div class="card-body p-0">
              <div class="list-group list-group-flush">
                <% @other_insurance.uploaded_documents.each do |document| %>
                  <div class="list-group-item border-0">
                    <div class="d-flex align-items-center py-2">
                      <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                          <% if document.file&.content_type&.include?('pdf') %>
                            <i class="bi bi-file-earmark-pdf text-danger fs-5"></i>
                          <% elsif document.file&.content_type&.include?('image') %>
                            <i class="bi bi-file-earmark-image text-success fs-5"></i>
                          <% else %>
                            <i class="bi bi-file-earmark text-secondary fs-5"></i>
                          <% end %>
                        </div>
                      </div>
                      <div class="flex-grow-1">
                        <h6 class="mb-1"><%= document.title || document.file&.filename || 'Untitled Document' %></h6>
                        <div class="mb-1">
                          <span class="badge bg-light text-dark me-2"><%= document.document_type || 'Document' %></span>
                          <% if document.file&.byte_size %>
                            <span class="text-muted small">
                              <i class="bi bi-file-earmark me-1"></i><%= number_to_human_size(document.file.byte_size) %>
                            </span>
                          <% end %>
                        </div>
                        <% if document.description.present? %>
                          <p class="text-muted mb-1 small"><%= truncate(document.description, length: 100) %></p>
                        <% end %>
                        <small class="text-secondary">
                          <i class="bi bi-archive me-1"></i>Legacy Upload • Uploaded <%= document.created_at.strftime("%B %d, %Y") %>
                        </small>
                      </div>
                      <div class="btn-group" role="group">
                        <% if document.respond_to?(:has_file?) && document.has_file? %>
                          <%= link_to document.public_document_url, class: "btn btn-outline-secondary btn-sm", target: "_blank", title: "View Document" do %>
                            <i class="bi bi-eye"></i>
                          <% end %>
                          <%= link_to document.download_url, class: "btn btn-outline-success btn-sm", title: "Download Document" do %>
                            <i class="bi bi-download"></i>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

      <% else %>
        <!-- No Documents Message -->
        <div class="text-center py-4">
          <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
            <i class="bi bi-files text-muted" style="font-size: 2rem;"></i>
          </div>
          <h6 class="text-muted mb-2">No documents uploaded</h6>
          <p class="text-muted mb-0">Documents for this other insurance policy will appear here once uploaded.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>