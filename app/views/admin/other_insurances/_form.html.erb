<!-- jQuery (required for Select2) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

<!-- Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Initialize Select2 for searchable dropdowns
  $('#customer_select').select2({
    theme: 'bootstrap-5',
    placeholder: 'Type to search clients...',
    allowClear: false,
    width: '100%'
  });

  $('#affiliate_select').select2({
    theme: 'bootstrap-5',
    placeholder: 'Type to search affiliates...',
    allowClear: true,
    width: '100%'
  });

  $('#policy_holder_select').select2({
    theme: 'bootstrap-5',
    placeholder: 'Select policy holder...',
    allowClear: false,
    width: '100%'
  });

  $('#other_insurance_agency_code_id').select2({
    theme: 'bootstrap-5',
    placeholder: 'Type to search agency codes...',
    allowClear: true,
    width: '100%'
  });

  $('#insurance_company_select').select2({
    theme: 'bootstrap-5',
    placeholder: 'Type to search companies...',
    allowClear: false,
    width: '100%'
  });

  // Handle customer selection change to update policy holder options
  $('#customer_select').on('select2:select', function(e) {
    const customerId = $(this).val();

    if (customerId) {
      // Fetch customer family members and update policy holder options
      fetch('/admin/customers/' + customerId + '/family_members')
        .then(response => response.json())
        .then(data => {
          const policyHolderSelect = $('#policy_holder_select');

          // Destroy existing Select2 instance
          if (policyHolderSelect.data('select2')) {
            policyHolderSelect.select2('destroy');
          }

          // Clear and rebuild options
          policyHolderSelect.empty();
          policyHolderSelect.append('<option value="Self">Self</option>');

          if (data.family_members && data.family_members.length > 0) {
            data.family_members.forEach(member => {
              if (member.name && member.name.trim().length > 0) {
                // Use member NAME as value, NOT the ID
                policyHolderSelect.append(`<option value="${member.name}">${member.name} (${member.relationship})</option>`);
              }
            });
          }

          // Reinitialize Select2 with new options
          policyHolderSelect.select2({
            theme: 'bootstrap-5',
            placeholder: 'Select policy holder...',
            allowClear: false,
            width: '100%'
          });

          // Set value to Self
          policyHolderSelect.val('Self').trigger('change');
        })
        .catch(error => {
          console.error('Error fetching family members:', error);
        });

      // Clear and refresh affiliate dropdown when customer changes
      $('#affiliate_select').val(null).trigger('change');
      console.log('Customer selected, filtering affiliates for customer ID:', customerId);
    }
  });

  // Handle customer clearing
  $('#customer_select').on('select2:clear', function(e) {
    console.log('Customer cleared');
    // Reset policy holder options to default
    const policyHolderSelect = $('#policy_holder_select');

    // Destroy existing Select2 instance
    if (policyHolderSelect.data('select2')) {
      policyHolderSelect.select2('destroy');
    }

    // Clear and rebuild with default options
    policyHolderSelect.empty();
    policyHolderSelect.append('<option value="Self">Self</option>');

    // Reinitialize Select2
    policyHolderSelect.select2({
      theme: 'bootstrap-5',
      placeholder: 'Select policy holder...',
      allowClear: false,
      width: '100%'
    });

    // Set to Self and refresh Select2
    policyHolderSelect.val('Self').trigger('change');

    // Clear affiliate dropdown when customer is cleared
    $('#affiliate_select').val(null).trigger('change');
    console.log('Customer cleared, showing all affiliates');
  });

  // Check if customer is already selected on page load (for edit forms)
  const initialCustomerId = $('#customer_select').val();
  if (initialCustomerId) {
    // Trigger the customer selection to load family members
    $('#customer_select').trigger('select2:select');
  }

  // Broker code type handling - Dynamic Agency Loading
  const brokerCodeType = document.getElementById('other_insurance_broker_code_type');
  const agencyCodeSelect = document.getElementById('other_insurance_agency_code_id');
  const companyNameSelect = document.getElementById('other_insurance_insurance_company_name');
  const labelText = document.getElementById('agency_code_label_text');

  if (brokerCodeType) {
    brokerCodeType.addEventListener('change', function() {
      const brokerType = this.value;

      if (brokerType) {
        // Update label based on selection
        if (labelText) {
          labelText.textContent = brokerType === 'direct' ? ' (Select Agent)' : ' (Select Broker)';
        }

        // Clear existing options
        $('#other_insurance_agency_code_id').empty();
        $('#other_insurance_agency_code_id').append('<option value="">Loading...</option>');

        // Fetch agency codes or brokers based on type
        fetch(`/admin/insurance/other/agency_codes_for_broker_type?broker_type=${brokerType}`)
          .then(response => response.json())
          .then(data => {
            if (data.success && data.data) {
              // Clear and rebuild options
              $('#other_insurance_agency_code_id').empty();
              $('#other_insurance_agency_code_id').append('<option value="">Search and select...</option>');

              data.data.forEach(item => {
                let optionText = item.text;
                if (item.code) {
                  optionText += ` - ${item.code}`;
                }
                $('#other_insurance_agency_code_id').append(
                  `<option value="${item.id}" data-company="${item.company_name || ''}" data-broker-name="${item.broker_name || ''}">${optionText}</option>`
                );
              });

              // Reinitialize Select2
              $('#other_insurance_agency_code_id').select2('destroy');
              $('#other_insurance_agency_code_id').select2({
                theme: 'bootstrap-5',
                placeholder: brokerType === 'direct' ? 'Type to search agents...' : 'Type to search brokers...',
                allowClear: true,
                width: '100%'
              });

              // Enable company name dropdown
              $('#other_insurance_insurance_company_name').prop('disabled', false);
            }
          })
          .catch(error => {
            console.error('Error loading agency codes:', error);
            $('#other_insurance_agency_code_id').empty();
            $('#other_insurance_agency_code_id').append('<option value="">Error loading data</option>');
          });
      }
    });

    // Handle agency/broker selection
    $('#other_insurance_agency_code_id').on('change', function() {
      const selectedOption = $(this).find('option:selected');
      const selectedValue = $(this).val();
      const brokerType = brokerCodeType.value;

      if (selectedValue) {
        if (brokerType === 'direct') {

          // Auto-populate company name if available
          const companyName = selectedOption.data('company');
          if (companyName && companyNameSelect) {
            // Check if company exists in select options
            const existingOption = Array.from(companyNameSelect.options).find(opt => opt.value === companyName);
            if (!existingOption) {
              // Add the company as an option
              $(companyNameSelect).append(`<option value="${companyName}">${companyName}</option>`);
            }
            $(companyNameSelect).val(companyName).trigger('change');
          }
        }

        // Load insurance companies based on selection
        loadInsuranceCompanies(brokerType, selectedValue);
      }
    });

    // Function to load insurance companies
    function loadInsuranceCompanies(brokerType, agencyOrBrokerId) {
      $('#other_insurance_insurance_company_name').empty();
      $('#other_insurance_insurance_company_name').append('<option value="">Loading companies...</option>');

      // Fetch insurance companies
      fetch(`/admin/insurance/other/insurance_companies_for_type?insurance_type=General%20Insurance`)
        .then(response => response.json())
        .then(data => {
          if (data.success && data.data) {
            $('#other_insurance_insurance_company_name').empty();
            $('#other_insurance_insurance_company_name').append('<option value="">Search and select company...</option>');

            data.data.forEach(company => {
              $('#other_insurance_insurance_company_name').append(
                `<option value="${company.id}">${company.text}</option>`
              );
            });

            // Reinitialize Select2
            $('#other_insurance_insurance_company_name').select2('destroy');
            $('#other_insurance_insurance_company_name').select2({
              theme: 'bootstrap-5',
              placeholder: 'Type to search companies...',
              allowClear: false,
              width: '100%'
            });
          }
        })
        .catch(error => {
          console.error('Error loading companies:', error);
        });
    }

    // Trigger initial load if broker type is selected
    if (brokerCodeType.value) {
      brokerCodeType.dispatchEvent(new Event('change'));
    }
  }

  // Auto-calculation functions
  function calculateTotalPremium() {
    const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
    const gstPercentage = parseFloat(document.getElementById('gst_percentage').value) || 0;

    const gstAmount = netPremium * (gstPercentage / 100);
    const totalPremium = netPremium + gstAmount;

    document.getElementById('total_premium').value = totalPremium.toFixed(2);

    // Trigger commission calculations
    calculateCommissions();
  }

  // Commission calculations
  function calculateCommissions() {
    const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;

    // Main Agent Commission
    const mainCommissionPercentage = parseFloat(document.getElementById('commission_percentage').value) || 0;
    const mainCommissionAmount = (netPremium * mainCommissionPercentage / 100);
    const mainTdsPercentage = parseFloat(document.getElementById('tds_percentage').value) || 0;
    const mainTdsAmount = (mainCommissionAmount * mainTdsPercentage / 100);
    const mainAfterTds = mainCommissionAmount - mainTdsAmount;

    document.getElementById('commission_amount').value = mainCommissionAmount.toFixed(2);
    document.getElementById('tds_amount').value = mainTdsAmount.toFixed(2);
    document.getElementById('after_tds_value').value = mainAfterTds.toFixed(2);

    // Affiliate Commission
    const subAgentPercentage = parseFloat(document.querySelector('.sub-agent-commission-percentage').value) || 0;
    const subAgentAmount = (netPremium * subAgentPercentage / 100);
    const subAgentTdsPercentage = parseFloat(document.querySelector('.sub-agent-tds-percentage').value) || 0;
    const subAgentTdsAmount = (subAgentAmount * subAgentTdsPercentage / 100);
    const subAgentAfterTds = subAgentAmount - subAgentTdsAmount;

    document.querySelector('.sub-agent-commission-amount').value = subAgentAmount.toFixed(2);
    document.querySelector('.sub-agent-tds-amount').value = subAgentTdsAmount.toFixed(2);
    document.querySelector('.sub-agent-after-tds-value').value = subAgentAfterTds.toFixed(2);

    // Investor Commission
    const investorPercentage = parseFloat(document.querySelector('.investor-commission-percentage').value) || 0;
    const investorAmount = (netPremium * investorPercentage / 100);
    document.querySelector('.investor-commission-amount').value = investorAmount.toFixed(2);

    // Update investor after TDS display (no TDS for investor)
    const investorAfterTdsDisplay = document.getElementById('investor_after_tds_display');
    if (investorAfterTdsDisplay) {
      investorAfterTdsDisplay.textContent = 'Rs. ' + investorAmount.toFixed(2);
    }

    // Ambassador Commission
    const ambassadorPercentage = parseFloat(document.querySelector('.ambassador-commission-percentage').value) || 0;
    const ambassadorAmount = (netPremium * ambassadorPercentage / 100);
    const ambassadorTdsPercentage = parseFloat(document.querySelector('.ambassador-tds-percentage').value) || 0;
    const ambassadorTdsAmount = (ambassadorAmount * ambassadorTdsPercentage / 100);
    const ambassadorAfterTds = ambassadorAmount - ambassadorTdsAmount;

    document.querySelector('.ambassador-commission-amount').value = ambassadorAmount.toFixed(2);
    document.querySelector('.ambassador-tds-amount').value = ambassadorTdsAmount.toFixed(2);
    document.querySelector('.ambassador-after-tds-value').value = ambassadorAfterTds.toFixed(2);

    // Company Expenses
    const companyExpensesPercentage = parseFloat(document.querySelector('.company-expenses-percentage').value) || 0;
    const companyExpensesAmount = (netPremium * companyExpensesPercentage / 100);

    // Update company expenses amount display
    const companyExpensesAmountDisplay = document.getElementById('company_expenses_amount');
    if (companyExpensesAmountDisplay) {
      companyExpensesAmountDisplay.textContent = 'Rs. ' + companyExpensesAmount.toFixed(2);
    }

    // Total Distribution & Profit
    const totalDistribution = subAgentPercentage + investorPercentage + ambassadorPercentage;
    const profitPercentage = mainCommissionPercentage - totalDistribution - companyExpensesPercentage;
    const profitAmount = (netPremium * profitPercentage / 100);

    document.querySelector('.total-distribution-percentage').value = totalDistribution.toFixed(2);
    document.querySelector('.profit-percentage').value = profitPercentage.toFixed(2);
    document.querySelector('.profit-amount').value = profitAmount.toFixed(2);
    document.querySelector('.profit-amount-display').value = profitAmount.toFixed(2);

    // Update profit display in table
    const profitPercentageDisplay = document.getElementById('profit_percentage_display');
    const profitAmountDisplay = document.getElementById('profit_amount_display');

    if (profitPercentageDisplay) {
      profitPercentageDisplay.textContent = profitPercentage.toFixed(2) + '%';
    }
    if (profitAmountDisplay) {
      profitAmountDisplay.textContent = 'Rs. ' + profitAmount.toFixed(2);
    }

    // Format amounts with Indian currency formatting
    const formatIndianCurrency = (amount) => {
      return 'Rs. ' + amount.toLocaleString('en-IN', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      });
    };

    // Update all display elements with Indian formatting
    if (companyExpensesAmountDisplay) {
      companyExpensesAmountDisplay.textContent = formatIndianCurrency(companyExpensesAmount);
    }
    if (investorAfterTdsDisplay) {
      investorAfterTdsDisplay.textContent = formatIndianCurrency(investorAmount);
    }
    if (profitAmountDisplay) {
      profitAmountDisplay.textContent = formatIndianCurrency(profitAmount);
    }
  }

  // Event listeners for real-time updates
  document.getElementById('net_premium')?.addEventListener('input', calculateTotalPremium);
  document.getElementById('gst_percentage')?.addEventListener('input', calculateTotalPremium);

  // Commission field listeners
  document.getElementById('commission_percentage')?.addEventListener('input', calculateCommissions);
  document.getElementById('tds_percentage')?.addEventListener('input', calculateCommissions);
  document.querySelector('.sub-agent-commission-percentage')?.addEventListener('input', calculateCommissions);
  document.querySelector('.sub-agent-tds-percentage')?.addEventListener('input', calculateCommissions);
  document.querySelector('.investor-commission-percentage')?.addEventListener('input', calculateCommissions);
  document.querySelector('.ambassador-commission-percentage')?.addEventListener('input', calculateCommissions);
  document.querySelector('.ambassador-tds-percentage')?.addEventListener('input', calculateCommissions);
  document.querySelector('.company-expenses-percentage')?.addEventListener('input', calculateCommissions);

  // Calculate policy end date based on start date and payment mode
  function calculatePolicyEndDate() {
    const startDateField = document.getElementById('start_date');
    const endDateField = document.getElementById('end_date');
    const paymentModeField = document.getElementById('payment_mode_select');

    if (!startDateField || !endDateField || !paymentModeField) {
      return;
    }

    const startDate = new Date(startDateField.value);
    const paymentMode = paymentModeField.value;

    if (!startDateField.value || !paymentMode) {
      return;
    }

    let endDate = new Date(startDate);

    switch(paymentMode) {
      case 'Yearly':
        endDate.setFullYear(endDate.getFullYear() + 1);
        endDate.setDate(endDate.getDate() - 1);
        break;
      case 'Half Yearly':
        endDate.setMonth(endDate.getMonth() + 6);
        endDate.setDate(endDate.getDate() - 1);
        break;
      case 'Quarterly':
        endDate.setMonth(endDate.getMonth() + 3);
        endDate.setDate(endDate.getDate() - 1);
        break;
      case 'Monthly':
        endDate.setMonth(endDate.getMonth() + 1);
        endDate.setDate(endDate.getDate() - 1);
        break;
      default:
        endDate.setFullYear(endDate.getFullYear() + 1);
        endDate.setDate(endDate.getDate() - 1);
    }

    endDateField.value = endDate.toISOString().split('T')[0];
  }

  // Event listeners for date calculations
  document.getElementById('start_date')?.addEventListener('change', calculatePolicyEndDate);
  document.getElementById('payment_mode_select')?.addEventListener('change', calculatePolicyEndDate);

  // Initialize calculations on page load
  if (document.getElementById('net_premium')?.value) {
    calculateTotalPremium();
  }

  // Convert sum insured text to number before form submission
  const form = document.querySelector('form.needs-validation');
  const sumInsuredField = document.querySelector('[name="other_insurance[sum_insured]"]');

  if (form && sumInsuredField) {
    form.addEventListener('submit', function(e) {
      const value = sumInsuredField.value.toLowerCase().trim();
      let numericValue = 0;

      if (value) {
        // Extract number and unit from text like "90 lakhs" or "5 crores"
        const match = value.match(/([\d.]+)\s*(lakh|lac|crore|cr|thousand|k|million|m)?/i);
        if (match) {
          const number = parseFloat(match[1]);
          const unit = match[2] ? match[2].toLowerCase() : '';

          switch(unit) {
            case 'lakh':
            case 'lac':
            case 'lakhs':
              numericValue = number * 100000;
              break;
            case 'crore':
            case 'crores':
            case 'cr':
              numericValue = number * 10000000;
              break;
            case 'thousand':
            case 'k':
              numericValue = number * 1000;
              break;
            case 'million':
            case 'm':
              numericValue = number * 1000000;
              break;
            default:
              numericValue = number;
          }
        } else {
          // If no unit specified, try to parse as plain number
          numericValue = parseFloat(value.replace(/[^\d.]/g, '')) || 0;
        }

        // Update the field with numeric value
        sumInsuredField.value = numericValue;
      }
    });
  }


  // Initialize date pickers with proper constraints
  function initializeDatePickers() {
    const dateFields = [
      'policy_booking_date',
      'start_date',
      'end_date',
      'main_agent_commission_paid_date',
      'installment_autopay_start_date',
      'installment_autopay_end_date'
    ];

    dateFields.forEach(fieldId => {
      const field = document.getElementById(fieldId) || document.querySelector(`[name*="${fieldId}"]`);
      if (field) {
        // Ensure proper min/max attributes are set
        field.setAttribute('min', '1900-01-01');
        field.setAttribute('max', '2099-12-31');

        // Fix any existing invalid values
        if (field.value && (field.value.includes('275760') || field.value.length > 10)) {
          field.value = new Date().toISOString().split('T')[0];
        }

        // Add event listener to prevent manual entry of invalid dates
        field.addEventListener('input', function() {
          const value = this.value;
          if (value && value.length > 10) {
            this.value = value.substring(0, 10);
          }
        });

        console.log(`✅ Initialized date picker for ${fieldId}`);
      }
    });
  }

  // Add Document Button Handler
  let otherDocumentIndex = 0;

  document.getElementById('add_other_document')?.addEventListener('click', function() {
    const container = document.getElementById('other_documents_container');
    const documentHtml = `
      <div class="document-entry p-3 mb-3 border rounded position-relative" data-index="${otherDocumentIndex}" style="background: #f8f9fa;">
        <button type="button" class="btn btn-sm btn-outline-danger position-absolute" style="top: 10px; right: 10px;" onclick="this.closest('.document-entry').remove()">
          <i class="bi bi-trash"></i>
        </button>
        <div class="row">
          <div class="col-md-4">
            <label class="form-label">Document Title <span class="text-danger">*</span></label>
            <input type="text" name="other_insurance[other_insurance_documents_attributes][${otherDocumentIndex}][title]" class="form-control" placeholder="Enter document title" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">Document Type <span class="text-danger">*</span></label>
            <select name="other_insurance[other_insurance_documents_attributes][${otherDocumentIndex}][document_type]" class="form-select" required>
              <option value="">Select Document Type</option>
              <option value="policy_document">Policy Document</option>
              <option value="identity_proof">Identity Proof</option>
              <option value="address_proof">Address Proof</option>
              <option value="income_proof">Income Proof</option>
              <option value="medical_report">Medical Report</option>
              <option value="claim_form">Claim Form</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label">Document File <span class="text-danger">*</span></label>
            <input type="file" name="other_insurance[other_insurance_documents_attributes][${otherDocumentIndex}][file]" class="form-control" accept="application/pdf,image/jpeg,image/jpg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required>
          </div>
        </div>
        <div class="row mt-2">
          <div class="col-md-12">
            <label class="form-label">Description (Optional)</label>
            <textarea name="other_insurance[other_insurance_documents_attributes][${otherDocumentIndex}][description]" class="form-control" rows="2" placeholder="Optional description"></textarea>
          </div>
        </div>
        <div class="mt-2">
          <small class="text-muted">
            <i class="bi bi-info-circle me-1"></i>
            Supported formats: PDF, JPG, PNG, Word documents (Max: 10MB per file)
          </small>
        </div>
      </div>
    `;

    container.insertAdjacentHTML('beforeend', documentHtml);
    otherDocumentIndex++;
  });

  // Call date picker initialization
  initializeDatePickers();
});

// Document deletion functions
function deleteOtherDocument(documentId, documentTitle) {
  if (confirm(`Are you sure you want to delete "${documentTitle}"?`)) {
    fetch(`/admin/other_insurance_documents/${documentId}`, {
      method: 'DELETE',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Accept': 'application/json'
      }
    })
    .then(response => {
      if (response.ok) {
        // Reload the page to update the document list
        window.location.reload();
      } else {
        alert('Failed to delete document. Please try again.');
      }
    })
    .catch(error => {
      console.error('Error deleting document:', error);
      alert('Error deleting document. Please try again.');
    });
  }
}

function deleteUploadedDocument(documentId, documentTitle) {
  if (confirm(`Are you sure you want to delete "${documentTitle}"?`)) {
    fetch(`/admin/documents/${documentId}`, {
      method: 'DELETE',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Accept': 'application/json'
      }
    })
    .then(response => {
      if (response.ok) {
        // Reload the page to update the document list
        window.location.reload();
      } else {
        alert('Failed to delete document. Please try again.');
      }
    })
    .catch(error => {
      console.error('Error deleting document:', error);
      alert('Error deleting document. Please try again.');
    });
  }
}
</script>

