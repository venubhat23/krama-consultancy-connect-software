<%= form_with model: [:admin, @other_insurance], local: true, class: "needs-validation", novalidate: true do |form| %>

  <!-- Client & Agent Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-person me-2 text-primary"></i>
        Client & Agent Details
      </h5>
    </div>
    <div class="card-body">
      <% if @other_insurance.errors.any? %>
        <div class="alert alert-danger alert-dismissible fade show">
          <i class="bi bi-exclamation-triangle me-2"></i>
          <strong>Please correct the following errors:</strong>
          <ul class="mb-0 mt-2">
            <% @other_insurance.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :customer_id, "Client Name*", class: "form-label" %>
          <%= form.select :customer_id,
              options_for_select(@customers.map { |c| [c.display_name, c.id] }, @other_insurance.customer_id),
              { prompt: 'Search and select client...' },
              { class: "form-control #{'is-invalid' if @other_insurance.errors[:customer_id].any?}",
                required: true,
                id: "customer_select",
                data: { placeholder: "Type to search clients..." } } %>
          <% if @other_insurance.errors[:customer_id].any? %>
            <div class="invalid-feedback"><%= @other_insurance.errors[:customer_id].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_holder, "Policy Holder", class: "form-label" %>
          <%
            policy_holder_options = [['Self', 'Self']]
            selected_policy_holder = @other_insurance.policy_holder || 'Self'

            # Add family members to options if available
            if @customer_family_members&.any?
              @customer_family_members.each do |member|
                if member.name.present? && member.name.strip.length > 0
                  display_name = "#{member.name} (#{member.relationship.humanize})"
                  # Use member name as value, not ID
                  policy_holder_options << [display_name, member.name]

                  # If policy_holder was incorrectly saved as member ID, convert to name
                  if @other_insurance.policy_holder == member.id.to_s
                    selected_policy_holder = member.name
                  end
                end
              end
            end

            # Add current policy holder if not in options
            if selected_policy_holder.present? &&
               selected_policy_holder != 'Self' &&
               !policy_holder_options.any? { |opt| opt[1] == selected_policy_holder }
              policy_holder_options << ["#{selected_policy_holder} (Custom)", selected_policy_holder]
            end
          %>
          <%= form.select :policy_holder,
              options_for_select(policy_holder_options, selected_policy_holder),
              {},
              { class: "form-control",
                id: "policy_holder_select",
                data: { placeholder: "Type to search policy holders..." } } %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :sub_agent_id, "Affiliate", class: "form-label" %>
          <%= form.select :sub_agent_id,
              options_for_select([['Self', '']] + @sub_agents.map { |a| [a.display_name, a.id] }, @other_insurance.sub_agent_id),
              { prompt: 'Search and select affiliate...' },
              { class: "form-control",
                id: "affiliate_select",
                data: { placeholder: "Type to search affiliates..." } } %>
        </div>
      </div>

    </div>
  </div>

  <!-- Policy Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-file-text me-2 text-primary"></i>
        Policy Details
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <!-- 1st: Broker Code dropdown with Direct/Broking options -->
        <div class="col-md-4 mb-3">
          <%= form.label :broker_code_type, "Broker Code", class: "form-label" %>
          <%= form.select :broker_code_type,
              options_for_select([
                ['Direct', 'direct'],
                ['Broking', 'broking']
              ], @other_insurance.broker_code_type),
              { prompt: 'Select Broker Code' },
              { class: "form-control", id: "other_insurance_broker_code_type" } %>
        </div>

        <!-- 2nd: Agency Code (shows Agents when Direct selected, Brokers when Broking selected) -->
        <div class="col-md-4 mb-3">
          <%
            # Build options and label based on saved data for edit mode
            agency_options = []
            selected_value = nil
            label_text = "Agency Code"

            if @other_insurance.persisted?
              # If we have an agency_code_id, show the agency code (direct mode)
              if @other_insurance.agency_code_id.present?
                agency_code = AgencyCode.find_by(id: @other_insurance.agency_code_id)
                if agency_code
                  agency_options << ["#{agency_code.agent_name} - #{agency_code.code}", agency_code.id]
                  selected_value = agency_code.id
                  label_text = agency_code.agent_name  # Show the agent name as label
                end
              end
            end

            # If no specific options loaded (new record or no saved data), use default agency codes
            if agency_options.empty?
              agency_options = @agency_codes.map { |a| ["#{a.agent_name} - #{a.code}", a.id] }
              # For edit mode, try to select the saved agency_code_id if it exists
              if @other_insurance.persisted? && @other_insurance.agency_code_id.present?
                selected_value = @other_insurance.agency_code_id
              end
            end
          %>
          <%= form.label :agency_code_id, label_text, class: "form-label" %>
          <span class="dynamic-label" id="agency_code_label_text"></span>
          <%= form.select :agency_code_id,
              options_for_select(agency_options, selected_value),
              { prompt: 'Search and select agency code...' },
              { class: "form-control", id: "other_insurance_agency_code_id", data: { placeholder: "Type to search agency codes..." } } %>
        </div>


        <!-- 3rd: Insurance Company Name (Dynamic based on Agent/Broker selection) -->
        <div class="col-md-4 mb-3">
          <%= form.label :insurance_company_name, "Insurance Company Name*", class: "form-label" %>
          <%= form.select :insurance_company_name,
              options_for_select(@insurance_companies&.map { |c| [c, c] } || [], @other_insurance.insurance_company_name),
              { prompt: 'Search and select company...' },
              { class: "form-control #{'is-invalid' if @other_insurance.errors[:insurance_company_name].any?}", required: true, id: "other_insurance_insurance_company_name", data: { placeholder: "Type to search companies..." } } %>
          <% if @other_insurance.errors[:insurance_company_name].any? %>
            <div class="invalid-feedback"><%= @other_insurance.errors[:insurance_company_name].first %></div>
          <% end %>
        </div>
      </div>

      <div class="row">

        <div class="col-md-4 mb-3">
          <%= form.label :insurance_type, "Insurance Type*", class: "form-label" %>
          <%= form.select :insurance_type,
              options_for_select([
                ['Travel Insurance', 'Travel Insurance'],
                ['Home Insurance', 'Home Insurance'],
                ['Personal Accident Insurance', 'Personal Accident Insurance'],
                ['Property Insurance', 'Property Insurance'],
                ['Cyber Insurance', 'Cyber Insurance'],
                ['Professional Indemnity', 'Professional Indemnity'],
                ['Directors & Officers', 'Directors & Officers'],
                ['Marine Insurance', 'Marine Insurance'],
                ['Credit Insurance', 'Credit Insurance'],
                ['Other', 'Other']
              ], @other_insurance.insurance_type),
              { prompt: 'Select Insurance Type' },
              { class: "form-control #{'is-invalid' if @other_insurance.errors[:insurance_type].any?}",
                required: true } %>
          <% if @other_insurance.errors[:insurance_type].any? %>
            <div class="invalid-feedback"><%= @other_insurance.errors[:insurance_type].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_type, "Policy Type*", class: "form-label" %>
          <%= form.select :policy_type,
              options_for_select([
                ['New', 'New'],
                ['Renewal', 'Renewal'],
                ['Portability', 'Portability']
              ], @other_insurance.policy_type),
              { prompt: 'Select Policy Type' },
              { class: "form-control #{'is-invalid' if @other_insurance.errors[:policy_type].any?}",
                required: true } %>
          <% if @other_insurance.errors[:policy_type].any? %>
            <div class="invalid-feedback"><%= @other_insurance.errors[:policy_type].first %></div>
          <% end %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :policy_number, "Policy Number*", class: "form-label" %>
          <%= form.text_field :policy_number,
              class: "form-control #{'is-invalid' if @other_insurance.errors[:policy_number].any?}",
              placeholder: "Enter policy number",
              required: true %>
          <% if @other_insurance.errors[:policy_number].any? %>
            <div class="invalid-feedback"><%= @other_insurance.errors[:policy_number].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :plan_name, "Plan Name", class: "form-label" %>
          <%= form.text_field :plan_name,
              class: "form-control",
              placeholder: "Enter plan name" %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_term, "Policy Term (Years)", class: "form-label" %>
          <%= form.text_field :policy_term,
              class: "form-control",
              placeholder: "e.g., 1, 2, 3" %>
          <div class="form-text">Enter policy term in years (e.g., 1, 2, 3)</div>
        </div>
      </div>

      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :policy_booking_date, "Policy Booking Date", class: "form-label" %>
          <%= form.date_field :policy_booking_date,
              class: "form-control",
              min: "1900-01-01",
              max: "2099-12-31" %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_start_date, "Policy Start Date*", class: "form-label" %>
          <%= form.date_field :policy_start_date,
              class: "form-control #{'is-invalid' if @other_insurance.errors[:policy_start_date].any?}",
              required: true,
              id: "start_date",
              min: "1900-01-01",
              max: "2099-12-31" %>
          <% if @other_insurance.errors[:policy_start_date].any? %>
            <div class="invalid-feedback"><%= @other_insurance.errors[:policy_start_date].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_end_date, "Policy End Date*", class: "form-label" %>
          <%= form.date_field :policy_end_date,
              class: "form-control #{'is-invalid' if @other_insurance.errors[:policy_end_date].any?}",
              required: true,
              id: "end_date",
              min: "1900-01-01",
              max: "2099-12-31" %>
          <% if @other_insurance.errors[:policy_end_date].any? %>
            <div class="invalid-feedback"><%= @other_insurance.errors[:policy_end_date].first %></div>
          <% end %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :payment_mode, "Payment Mode*", class: "form-label" %>
          <%= form.select :payment_mode,
              options_for_select([
                ['Yearly', 'Yearly'],
                ['Half Yearly', 'Half Yearly'],
                ['Quarterly', 'Quarterly'],
                ['Monthly', 'Monthly']
              ], @other_insurance.payment_mode),
              { prompt: 'Select Payment Mode' },
              { class: "form-control #{'is-invalid' if @other_insurance.errors[:payment_mode].any?}",
                required: true,
                id: "payment_mode_select" } %>
          <% if @other_insurance.errors[:payment_mode].any? %>
            <div class="invalid-feedback"><%= @other_insurance.errors[:payment_mode].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :sum_insured, "Sum Insured*", class: "form-label" %>
          <%= form.text_field :sum_insured,
              class: "form-control #{'is-invalid' if @other_insurance.errors[:sum_insured].any?}",
              placeholder: "e.g., 90 lakhs, 5 crores, 1.5 crore",
              required: true %>
          <div class="form-text">Enter amount like: 90 lakhs, 5 crores, 1.5 crore, etc.</div>
          <% if @other_insurance.errors[:sum_insured].any? %>
            <div class="invalid-feedback"><%= @other_insurance.errors[:sum_insured].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :status, "Policy Status", class: "form-label" %>
          <%= form.select :status,
              options_for_select([
                ['Active', 'active'],
                ['Expired', 'expired'],
                ['Pending', 'pending'],
                ['Cancelled', 'cancelled']
              ], @other_insurance.try(:status) || 'active'),
              {},
              { class: "form-control" } %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :claim_process, "Claim Process", class: "form-label" %>
          <%= form.select :claim_process,
              options_for_select([
                ['Cashless', 'Cashless'],
                ['Reimbursement', 'Reimbursement'],
                ['Both', 'Both']
              ], @other_insurance.claim_process),
              { prompt: 'Select Claim Process' },
              { class: "form-control" } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Premium Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-currency-rupee me-2 text-primary"></i>
        Premium Details
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :net_premium, "Net Premium*", class: "form-label" %>
          <%= form.number_field :net_premium,
              class: "form-control #{'is-invalid' if @other_insurance.errors[:net_premium].any?}",
              placeholder: "Enter net premium",
              step: 0.01,
              required: true,
              id: "net_premium" %>
          <% if @other_insurance.errors[:net_premium].any? %>
            <div class="invalid-feedback"><%= @other_insurance.errors[:net_premium].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :gst_percentage, "GST %", class: "form-label" %>
          <%= form.number_field :gst_percentage,
              class: "form-control",
              step: 0.01,
              id: "gst_percentage",
              value: @other_insurance.gst_percentage || 18.0 %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :total_premium, "Total Premium*", class: "form-label" %>
          <%= form.number_field :total_premium,
              class: "form-control #{'is-invalid' if @other_insurance.errors[:total_premium].any?}",
              step: 0.01,
              required: true,
              id: "total_premium",
              readonly: true %>
          <% if @other_insurance.errors[:total_premium].any? %>
            <div class="invalid-feedback"><%= @other_insurance.errors[:total_premium].first %></div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <% if @other_insurance.new_record? || @other_insurance.drwise_policy? %>
  <!-- Commission Calculation Table -->
  <div class="card mb-4 shadow-sm commission-table">
    <div class="card-header" style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0 text-dark fw-bold">
            <i class="bi bi-calculator me-2 text-primary"></i>
            Commission Calculation
          </h5>
        </div>
        <div class="text-end">
          <small class="text-muted fw-bold">Profit Formula:</small>
          <div class="badge bg-light text-dark border" style="font-size: 0.8rem;">
            Main Agent Commission - Total Distribution - Company Expenses
          </div>
        </div>
      </div>
    </div>
    <div class="card-body p-0">
      <!-- Commission Table -->
      <div class="table-responsive">
        <table class="table mb-0" style="font-size: 0.95rem;">
          <thead style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
            <tr>
              <th class="py-3 px-4 fw-bold text-dark border-0" style="width: 20%;">COMMISSION DETAILS</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 12%;">(%)</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 18%;">COMMISSION</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 12%;">TDS (%)</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 15%;">TDS AMOUNT</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 23%; background: #f8f9fa;">ACTUAL AMOUNT</th>
            </tr>
          </thead>
          <tbody>
            <!-- Main Agent -->
            <tr style="border-bottom: 1px solid #e9ecef;">
              <td class="py-3 px-4 fw-bold text-dark bg-light">Main Agent</td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :main_agent_commission_percentage,
                    class: "form-control border-1 text-center fw-bold shadow-sm",
                    value: @other_insurance.main_agent_commission_percentage || 10.0,
                    step: 0.01, id: "commission_percentage",
                    style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :commission_amount,
                    class: "form-control border-1 text-center",
                    value: @other_insurance.commission_amount || 0,
                    step: 0.01, readonly: true, id: "commission_amount",
                    style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :tds_percentage,
                    class: "form-control border-1 text-center",
                    value: @other_insurance.tds_percentage || 0,
                    step: 0.01, id: "tds_percentage",
                    style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :tds_amount,
                    class: "form-control border-1 text-center",
                    value: @other_insurance.tds_amount || 0,
                    step: 0.01, readonly: true, id: "tds_amount",
                    style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
                <%= form.number_field :after_tds_value,
                    class: "form-control border-1 text-center fw-bold fs-6",
                    value: @other_insurance.after_tds_value || 0,
                    step: 0.01, readonly: true, id: "after_tds_value",
                    style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
            </tr>
            <!-- Affiliate -->
            <tr style="border-bottom: 1px solid #e9ecef;">
              <td class="py-3 px-4 fw-bold text-dark">Affiliate</td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :sub_agent_commission_percentage,
                    class: "form-control border-1 text-center fw-bold shadow-sm sub-agent-commission-percentage",
                    value: @other_insurance.sub_agent_commission_percentage || 0,
                    step: 0.01, style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :sub_agent_commission_amount,
                    class: "form-control border-1 text-center sub-agent-commission-amount",
                    value: @other_insurance.sub_agent_commission_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :sub_agent_tds_percentage,
                    class: "form-control border-1 text-center sub-agent-tds-percentage",
                    value: @other_insurance.sub_agent_tds_percentage || 0,
                    step: 0.01, style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :sub_agent_tds_amount,
                    class: "form-control border-1 text-center sub-agent-tds-amount",
                    value: @other_insurance.sub_agent_tds_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
                <%= form.number_field :sub_agent_after_tds_value,
                    class: "form-control border-1 text-center fw-bold fs-6 sub-agent-after-tds-value",
                    value: @other_insurance.sub_agent_after_tds_value || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
            </tr>
            <!-- Investor -->
            <tr style="border-bottom: 1px solid #e9ecef;">
              <td class="py-3 px-4 fw-bold text-dark">Investor</td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :investor_commission_percentage,
                    class: "form-control border-1 text-center fw-bold shadow-sm investor-commission-percentage",
                    value: @other_insurance.investor_commission_percentage || 0,
                    step: 0.01, style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :investor_commission_amount,
                    class: "form-control border-1 text-center investor-commission-amount",
                    value: @other_insurance.investor_commission_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-3 text-center fw-bold text-muted">—</td>
              <td class="py-2 px-3 text-center fw-bold text-muted">—</td>
              <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
                <%= form.number_field :investor_commission_amount,
                    class: "form-control border-1 text-center fw-bold fs-6 investor-commission-amount-display",
                    value: @other_insurance.investor_commission_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
            </tr>
            <!-- Ambassador -->
            <tr style="border-bottom: 1px solid #e9ecef;">
              <td class="py-3 px-4 fw-bold text-dark">Ambassador</td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :ambassador_commission_percentage,
                    class: "form-control border-1 text-center fw-bold shadow-sm ambassador-commission-percentage",
                    value: @other_insurance.ambassador_commission_percentage || 0,
                    step: 0.01, style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :ambassador_commission_amount,
                    class: "form-control border-1 text-center ambassador-commission-amount",
                    value: @other_insurance.ambassador_commission_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :ambassador_tds_percentage,
                    class: "form-control border-1 text-center ambassador-tds-percentage",
                    value: @other_insurance.ambassador_tds_percentage || 0,
