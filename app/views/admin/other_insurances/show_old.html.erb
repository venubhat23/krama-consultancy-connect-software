<% content_for :page_title, "General Insurance Policy Details" %>
<% content_for :page_subtitle, "Policy ##{@other_insurance.policy_number}" %>

<!-- Action Buttons -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <%= link_to admin_other_insurances_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-2"></i>
      Back to Policies
    <% end %>
  </div>

  <div class="btn-toolbar">
    <%= link_to edit_admin_other_insurance_path(@other_insurance), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-2"></i>
      Edit Policy
    <% end %>
  </div>
</div>

<!-- Main Policy Card -->
<div class="row">
  <div class="col-lg-8">
    <div class="card mb-4">
      <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
          <h5 class="mb-0">
            <i class="bi bi-shield-check me-2 text-primary"></i>
            Policy Information
          </h5>
          <span class="premium-badge">General Insurance</span>
        </div>
      </div>

      <div class="card-body">
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Policy Number</label>
            <h6 class="fw-bold"><%= @other_insurance.policy_number %></h6>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Policy Type</label>
            <h6><%= @other_insurance.policy_type&.humanize || 'General Insurance' %></h6>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Sum Insured</label>
            <h5 class="text-warning mb-0"><%= indian_currency(@other_insurance.sum_insured) %></h5>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Total Premium</label>
            <h5 class="text-success mb-0"><%= indian_currency(@other_insurance.total_premium) %></h5>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Premium Frequency</label>
            <h6><%= @other_insurance.payment_mode&.humanize || 'Annual' %></h6>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Status</label>
            <div>
              <% if @other_insurance.policy_end_date.present? && @other_insurance.policy_end_date < Date.current %>
                <span class="badge bg-danger fs-6">
                  <i class="bi bi-x-circle me-1"></i>
                  Expired
                </span>
              <% elsif @other_insurance.policy_start_date.present? && @other_insurance.policy_start_date > Date.current %>
                <span class="badge bg-warning fs-6">
                  <i class="bi bi-clock me-1"></i>
                  Pending
                </span>
              <% elsif @other_insurance.policy_end_date.present? && @other_insurance.policy_end_date >= Date.current %>
                <span class="badge bg-success fs-6">
                  <i class="bi bi-check-circle me-1"></i>
                  Active
                </span>
              <% else %>
                <span class="badge bg-secondary fs-6">
                  <i class="bi bi-question-circle me-1"></i>
                  Unknown
                </span>
              <% end %>
            </div>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Policy Start Date</label>
            <h6><%= @other_insurance.policy_start_date.strftime("%B %d, %Y") if @other_insurance.policy_start_date %></h6>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Policy End Date</label>
            <h6 class="<%= 'text-danger' if @other_insurance.policy_end_date && @other_insurance.policy_end_date < 30.days.from_now %>">
              <%= @other_insurance.policy_end_date.strftime("%B %d, %Y") if @other_insurance.policy_end_date %>
              <% if @other_insurance.policy_end_date && @other_insurance.policy_end_date < 30.days.from_now %>
                <br><small class="text-danger">
                  <i class="bi bi-exclamation-triangle me-1"></i>
                  Expires soon
                </small>
              <% end %>
            </h6>
          </div>
        </div>

        <% if @other_insurance.plan_name.present? %>
          <div class="luxury-divider"></div>
          <div class="mt-3">
            <label class="form-label text-muted">Plan Name</label>
            <div class="bg-light p-3 rounded">
              <%= @other_insurance.plan_name %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Reference Information -->
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="bi bi-building me-2 text-info"></i>
          Insurance Details
        </h5>
      </div>

      <div class="card-body">
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Insurance Company</label>
            <h6><%= @other_insurance.insurance_company_name %></h6>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Insurance Type</label>
            <h6><%= @other_insurance.insurance_type&.humanize || 'Not specified' %></h6>
          </div>

          <% if @other_insurance.claim_process.present? %>
            <div class="col-12">
              <label class="form-label text-muted">Claim Process</label>
              <div class="bg-light p-3 rounded">
                <%= simple_format(@other_insurance.claim_process) %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <!-- Customer Information -->
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="bi bi-person me-2 text-primary"></i>
          Customer Details
        </h5>
      </div>

      <div class="card-body">
        <% if @other_insurance.customer %>
          <div class="d-flex align-items-center mb-3">
            <div class="stats-icon primary me-3" style="width: 50px; height: 50px; font-size: 1.2rem;">
              <i class="bi bi-person"></i>
            </div>
            <div>
              <h6 class="mb-1"><%= @other_insurance.customer.display_name %></h6>
              <small class="text-muted">
                <%= @other_insurance.customer.customer_type&.humanize || 'Individual' %>
              </small>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label text-muted small">Email</label>
            <div><%= @other_insurance.customer.email || 'N/A' %></div>
          </div>

          <div class="mb-3">
            <label class="form-label text-muted small">Mobile</label>
            <div><%= @other_insurance.customer.mobile || 'N/A' %></div>
          </div>

          <div class="mb-3">
            <label class="form-label text-muted small">Address</label>
            <div>
              <%= @other_insurance.customer.address.present? ? @other_insurance.customer.address : 'Not provided' %><br>
              <%= @other_insurance.customer.city %>, <%= @other_insurance.customer.state %>
              <% if @other_insurance.customer.pincode.present? %>
                - <%= @other_insurance.customer.pincode %>
              <% end %>
            </div>
          </div>

          <%= link_to admin_customer_path(@other_insurance.customer), class: "btn btn-outline-primary btn-sm w-100" do %>
            <i class="bi bi-eye me-2"></i>
            View Customer Profile
          <% end %>
        <% else %>
          <p class="text-muted mb-0">No customer information available.</p>
        <% end %>
      </div>
    </div>
    <!-- Premium Breakdown -->
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="bi bi-calculator me-2 text-success"></i>
          Premium Breakdown
        </h5>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-12 mb-2">
            <div class="d-flex justify-content-between">
              <span class="text-muted">Net Premium:</span>
              <strong><%= indian_currency(@other_insurance.net_premium) %></strong>
            </div>
          </div>
          <div class="col-12 mb-2">
            <div class="d-flex justify-content-between">
              <span class="text-muted">GST (<%= @other_insurance.gst_percentage %>%):</span>
              <span><%= indian_currency((@other_insurance.net_premium * @other_insurance.gst_percentage / 100)) %></span>
            </div>
          </div>
          <hr>
          <div class="col-12">
            <div class="d-flex justify-content-between">
              <span class="text-muted"><strong>Total Premium:</strong></span>
              <strong class="text-success"><%= indian_currency(@other_insurance.total_premium) %></strong>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Documents Section - Simple UI -->
<% if @other_insurance.uploaded_documents.any? ||
      (@other_insurance.respond_to?(:policy_documents) && @other_insurance.policy_documents.attached?) ||
      (@other_insurance.respond_to?(:documents) && @other_insurance.documents.attached?) ||
      (@other_insurance.respond_to?(:additional_documents) && @other_insurance.additional_documents.attached?) %>
  <div class="row mt-4">
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <!-- New Documents -->
          <% if @other_insurance.uploaded_documents.any? %>
            <div class="row g-3 mb-4">
              <% @other_insurance.uploaded_documents.each do |document| %>
                <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
                  <div class="card h-100 border-0 shadow-sm document-card">
                    <div class="card-body p-3 text-center">
                      <div class="mb-2">
                        <% case document.file_extension&.downcase %>
                        <% when 'pdf' %>
                          <div class="bg-danger bg-opacity-10 rounded d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-file-earmark-pdf text-danger fs-4"></i>
                          </div>
                        <% when 'jpg', 'jpeg', 'png', 'gif' %>
                          <div class="bg-info bg-opacity-10 rounded d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-file-earmark-image text-info fs-4"></i>
                          </div>
                        <% when 'doc', 'docx' %>
                          <div class="bg-primary bg-opacity-10 rounded d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-file-earmark-word text-primary fs-4"></i>
                          </div>
                        <% else %>
                          <div class="bg-secondary bg-opacity-10 rounded d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-file-earmark text-secondary fs-4"></i>
                          </div>
                        <% end %>
                      </div>
                      <h6 class="card-title small mb-2" title="<%= document.title %>">
                        <%= truncate(document.title, length: 20) %>
                      </h6>
                      <p class="small text-muted mb-3">
                        <%= number_to_human_size(document.file_size) if document.file_size %>
                      </p>
                      <div class="btn-group-vertical btn-group-sm w-100">
                        <%= link_to admin_document_path(document),
                            class: "btn btn-outline-primary btn-sm mb-1",
                            target: "_blank",
                            title: "View" do %>
                          <i class="bi bi-eye"></i>
                        <% end %>
                        <%= link_to admin_document_path(document),
                            class: "btn btn-outline-success btn-sm",
                            download: true,
                            title: "Download" do %>
                          <i class="bi bi-download"></i>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>

          <!-- Legacy Documents -->
          <% if (@other_insurance.respond_to?(:policy_documents) && @other_insurance.policy_documents.attached?) ||
                (@other_insurance.respond_to?(:documents) && @other_insurance.documents.attached?) ||
                (@other_insurance.respond_to?(:additional_documents) && @other_insurance.additional_documents.attached?) %>
            <div class="row g-3">
              <!-- Policy Documents -->
              <% if @other_insurance.respond_to?(:policy_documents) && @other_insurance.policy_documents.attached? %>
                <% @other_insurance.policy_documents.each do |doc| %>
                  <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
                    <div class="card h-100 border-0 shadow-sm document-card">
                      <div class="card-body p-3 text-center">
                        <div class="mb-2">
                          <div class="bg-danger bg-opacity-10 rounded d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-file-earmark-pdf text-danger fs-4"></i>
                          </div>
                        </div>
                        <h6 class="card-title small mb-2" title="<%= doc.filename.to_s %>">
                          <%= truncate(doc.filename.to_s, length: 20) %>
                        </h6>
                        <p class="small text-muted mb-3">
                          <%= number_to_human_size(doc.byte_size) %>
                        </p>
                        <div class="btn-group-vertical btn-group-sm w-100">
                          <% if doc.persisted? %>
                            <%= link_to rails_blob_path(doc, disposition: "inline"),
                                class: "btn btn-outline-primary btn-sm mb-1",
                                target: "_blank",
                                title: "View" do %>
                              <i class="bi bi-eye"></i>
                            <% end %>
                            <%= link_to rails_blob_path(doc, disposition: "attachment"),
                                class: "btn btn-outline-success btn-sm",
                                title: "Download" do %>
                              <i class="bi bi-download"></i>
                            <% end %>
                          <% else %>
                            <span class="btn btn-outline-secondary btn-sm disabled">
                              <i class="bi bi-clock"></i>
                            </span>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% end %>

              <!-- Documents -->
              <% if @other_insurance.respond_to?(:documents) && @other_insurance.documents.attached? %>
                <% @other_insurance.documents.each do |doc| %>
                  <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
                    <div class="card h-100 border-0 shadow-sm document-card">
                      <div class="card-body p-3 text-center">
                        <div class="mb-2">
                          <% if doc.content_type&.include?('image') %>
                            <div class="bg-info bg-opacity-10 rounded d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                              <i class="bi bi-file-earmark-image text-info fs-4"></i>
                            </div>
                          <% elsif doc.content_type&.include?('pdf') %>
                            <div class="bg-danger bg-opacity-10 rounded d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                              <i class="bi bi-file-earmark-pdf text-danger fs-4"></i>
                            </div>
                          <% else %>
                            <div class="bg-secondary bg-opacity-10 rounded d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                              <i class="bi bi-file-earmark text-secondary fs-4"></i>
                            </div>
                          <% end %>
                        </div>
                        <h6 class="card-title small mb-2" title="<%= doc.filename.to_s %>">
                          <%= truncate(doc.filename.to_s, length: 20) %>
                        </h6>
                        <p class="small text-muted mb-3">
                          <%= number_to_human_size(doc.byte_size) %>
                        </p>
                        <div class="btn-group-vertical btn-group-sm w-100">
                          <% if doc.persisted? %>
                            <%= link_to rails_blob_path(doc, disposition: "inline"),
                                class: "btn btn-outline-primary btn-sm mb-1",
                                target: "_blank",
                                title: "View" do %>
                              <i class="bi bi-eye"></i>
                            <% end %>
                            <%= link_to rails_blob_path(doc, disposition: "attachment"),
                                class: "btn btn-outline-success btn-sm",
                                title: "Download" do %>
                              <i class="bi bi-download"></i>
                            <% end %>
                          <% else %>
                            <span class="btn btn-outline-secondary btn-sm disabled">
                              <i class="bi bi-clock"></i>
                            </span>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% end %>

              <!-- Additional Documents -->
              <% if @other_insurance.respond_to?(:additional_documents) && @other_insurance.additional_documents.attached? %>
                <% @other_insurance.additional_documents.each do |doc| %>
                  <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
                    <div class="card h-100 border-0 shadow-sm document-card">
                      <div class="card-body p-3 text-center">
                        <div class="mb-2">
                          <% if doc.content_type&.include?('image') %>
                            <div class="bg-info bg-opacity-10 rounded d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                              <i class="bi bi-file-earmark-image text-info fs-4"></i>
                            </div>
                          <% elsif doc.content_type&.include?('pdf') %>
                            <div class="bg-danger bg-opacity-10 rounded d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                              <i class="bi bi-file-earmark-pdf text-danger fs-4"></i>
                            </div>
                          <% else %>
                            <div class="bg-secondary bg-opacity-10 rounded d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                              <i class="bi bi-file-earmark text-secondary fs-4"></i>
                            </div>
                          <% end %>
                        </div>
                        <h6 class="card-title small mb-2" title="<%= doc.filename.to_s %>">
                          <%= truncate(doc.filename.to_s, length: 20) %>
                        </h6>
                        <p class="small text-muted mb-3">
                          <%= number_to_human_size(doc.byte_size) %>
                        </p>
                        <div class="btn-group-vertical btn-group-sm w-100">
                          <% if doc.persisted? %>
                            <%= link_to rails_blob_path(doc, disposition: "inline"),
                                class: "btn btn-outline-primary btn-sm mb-1",
                                target: "_blank",
                                title: "View" do %>
                              <i class="bi bi-eye"></i>
                            <% end %>
                            <%= link_to rails_blob_path(doc, disposition: "attachment"),
                                class: "btn btn-outline-success btn-sm",
                                title: "Download" do %>
                              <i class="bi bi-download"></i>
                            <% end %>
                          <% else %>
                            <span class="btn btn-outline-secondary btn-sm disabled">
                              <i class="bi bi-clock"></i>
                            </span>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <style>
    .document-card {
      transition: all 0.2s ease;
    }
    .document-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important;
    }
  </style>
<% end %>

<style>
/* Scroll to top fix */
html {
  scroll-behavior: smooth !important;
}

body {
  position: relative !important;
  overflow-x: hidden !important;
  overflow-y: auto !important;
}

.main-content {
  position: relative !important;
  overflow: visible !important;
  height: auto !important;
}

.premium-badge {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 0.5rem 1rem;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
}

.luxury-divider {
  height: 2px;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border: none;
  margin: 1rem 0;
}

.stats-icon.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
}

@media print {
  .btn, .card-header, nav {
    display: none !important;
  }

  .card {
    border: none !important;
    box-shadow: none !important;
  }

  .card-body {
    padding: 0 !important;
  }
}

/* Add scroll-to-top button */
.scroll-to-top {
  position: fixed;
  bottom: 20px;
  right: 20px;
  width: 50px;
  height: 50px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 50%;
  display: none;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 9999;
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.scroll-to-top:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
}

.scroll-to-top.show {
  display: flex;
}
</style>

<!-- Scroll to top button -->
<button class="scroll-to-top" id="scrollToTop" onclick="scrollToTop()" title="Back to top">
  <i class="bi bi-arrow-up"></i>
</button>

<script>
// Scroll to top functionality
function scrollToTop() {
  window.scrollTo({
    top: 0,
    behavior: 'smooth'
  });
}

// Show/hide scroll to top button
window.addEventListener('scroll', function() {
  const scrollToTopBtn = document.getElementById('scrollToTop');
  if (window.pageYOffset > 300) {
    scrollToTopBtn.classList.add('show');
  } else {
    scrollToTopBtn.classList.remove('show');
  }
});

// Ensure proper scrolling behavior
document.addEventListener('DOMContentLoaded', function() {
  // Reset any scroll blocking styles
  document.body.style.position = 'relative';
  document.body.style.overflowY = 'auto';
  document.body.style.overflowX = 'hidden';

  // Enable smooth scrolling
  document.documentElement.style.scrollBehavior = 'smooth';
});
</script>