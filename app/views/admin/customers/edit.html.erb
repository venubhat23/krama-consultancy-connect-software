            <div class="form-text">Select height from the dropdown</div>
          </div>
        </div>

        <div class="row mt-3">
          <div class="col-md-4">
            <label class="form-label">Weight (Kg)</label>
            <input type="number" name="customer[family_members_attributes][${familyMemberIndex}][weight_kg]" class="form-control" step="0.1">
          </div>
          <div class="col-md-4">
            <label class="form-label">PAN No</label>
            <input type="text" name="customer[family_members_attributes][${familyMemberIndex}][pan_no]" class="form-control">
          </div>
          <div class="col-md-4">
            <label class="form-label">Additional Information</label>
            <textarea name="customer[family_members_attributes][${familyMemberIndex}][additional_information]" class="form-control" rows="1"></textarea>
          </div>
        </div>
      </div>
    `;
    familyMembersContainer.insertAdjacentHTML('beforeend', familyMemberHtml);
    familyMemberIndex++;
  });

  // Event delegation for removing family members
  document.addEventListener('click', function(e) {
    if (e.target.closest('.remove-family-member')) {
      e.target.closest('.family-member-entry').remove();
    }
  });

  // Auto-calculate family member ages
  document.addEventListener('change', function(e) {
    if (e.target.matches('input[name*="birth_date"]') && e.target.closest('.family-member-entry')) {
      const ageField = e.target.closest('.family-member-entry').querySelector('input[name*="[age]"]');

      if (ageField && e.target.value) {
        const birthDate = new Date(e.target.value);
        const today = new Date();
        let age = today.getFullYear() - birthDate.getFullYear();
        const monthDiff = today.getMonth() - birthDate.getMonth();

        if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
          age--;
        }

        ageField.value = age >= 0 ? age + ' years' : '';
      }
    }
  });


  // Legacy Document Management System
  const addLegacyDocumentBtn = document.getElementById('add_legacy_document');
  const legacyDocumentForm = document.getElementById('legacy_document_form');
  const legacyDocumentFormPlaceholder = document.getElementById('legacy_document_form_placeholder');
  const newDocumentForm = document.getElementById('new_document_form');

  // Show legacy document form
  addLegacyDocumentBtn?.addEventListener('click', function() {
    // Move the form to the placeholder position
    if (legacyDocumentForm && legacyDocumentFormPlaceholder) {
      legacyDocumentFormPlaceholder.appendChild(legacyDocumentForm);
      legacyDocumentFormPlaceholder.style.display = 'block';
    }
    legacyDocumentForm.style.display = 'block';
    addLegacyDocumentBtn.style.display = 'none';
  });

  // Handle legacy document form submission
  newDocumentForm?.addEventListener('ajax:success', function(event) {
    const response = event.detail[0];
    if (response.success) {
      // Show success message
      const alertDiv = document.createElement('div');
      alertDiv.className = 'alert alert-success alert-dismissible fade show mt-3';
      alertDiv.innerHTML = `
        <i class="bi bi-check-circle me-2"></i>
        ${response.message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      `;
      legacyDocumentForm.insertAdjacentElement('afterend', alertDiv);

      // Add the new document to the existing list
      addDocumentToList(response.document);

      // Reset and hide form
      newDocumentForm.reset();
      cancelAddDocument();

      // Auto-dismiss success message after 3 seconds
      setTimeout(() => {
        alertDiv.remove();
      }, 3000);
    }
  });

  // Function to add new document to the existing list without page reload
  function addDocumentToList(uploadedDoc) {
    // Find the documents list container
    let documentsContainer = document.querySelector('.list-group');

    // If no documents exist yet, create the list structure
    if (!documentsContainer) {
      const currentFilesCard = document.querySelector('#legacy_document_form_placeholder').closest('.card-body');
      if (currentFilesCard) {
        const existingContainer = currentFilesCard.querySelector('.list-group');
        if (!existingContainer) {
          // Create new list group
          const listGroup = document.createElement('div');
          listGroup.className = 'list-group mb-3';

          // Find the add document button container and insert before it
          const addButtonContainer = currentFilesCard.querySelector('.d-flex.justify-content-between');
          if (addButtonContainer) {
            addButtonContainer.insertAdjacentElement('afterend', listGroup);
          }
          documentsContainer = listGroup;
        } else {
          documentsContainer = existingContainer;
        }
      }
    }

    if (documentsContainer) {
      // Create new document list item
      const documentItem = document.createElement('div');
      documentItem.className = 'list-group-item';
      documentItem.innerHTML = `
        <div class="d-flex justify-content-between align-items-center">
          <div class="d-flex align-items-center">
            <i class="bi bi-file-earmark me-2"></i>
            <div>
              <span class="fw-medium">${uploadedDoc.type}</span>
              <br><small class="text-muted">${uploadedDoc.name} • ${uploadedDoc.size}</small>
            </div>
          </div>
          <div class="d-flex gap-2 align-items-center">
            <span class="badge bg-success">✓ Cloud Stored</span>
            <a href="${uploadedDoc.url}" class="btn btn-sm btn-outline-primary" target="_blank">
              <i class="bi bi-download"></i> Download
            </a>
            <a href="/admin/customers/${window.location.pathname.split('/')[3]}/documents/${uploadedDoc.id}"
               data-method="delete"
               data-confirm="Are you sure you want to unlink this document from the customer? The file will remain in cloud storage."
               data-turbo-method="delete"
               class="btn btn-sm btn-outline-danger"
               title="Unlink Document">
              <i class="bi bi-unlink"></i>
            </a>
          </div>
        </div>
      `;

      // Add to the beginning of the list
      documentsContainer.insertAdjacentElement('afterbegin', documentItem);
    }
  }

  newDocumentForm?.addEventListener('ajax:error', function(event) {
    const response = event.detail[0];
    let errorMessage = 'Upload failed';

    if (response && response.message) {
      errorMessage = response.message;
    } else if (response && response.errors && Array.isArray(response.errors)) {
      errorMessage = response.errors.join(', ');
    }

    // Show error message
    const alertDiv = document.createElement('div');
    alertDiv.className = 'alert alert-danger alert-dismissible fade show mt-3';
    alertDiv.innerHTML = `
      <i class="bi bi-exclamation-triangle me-2"></i>
      ${errorMessage}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    legacyDocumentForm.insertAdjacentElement('afterend', alertDiv);
  });

  // Cancel add document function (global scope for onclick handler)
  window.cancelAddDocument = function() {
    legacyDocumentForm.style.display = 'none';
    legacyDocumentFormPlaceholder.style.display = 'none';
    addLegacyDocumentBtn.style.display = 'inline-block';
    newDocumentForm.reset();

    // Move form back to original position (outside main form)
    document.body.appendChild(legacyDocumentForm);

    // Remove any existing alerts
    const alerts = document.querySelectorAll('.alert');
    alerts.forEach(alert => {
      if (alert.parentElement === legacyDocumentForm.parentElement) {
        alert.remove();
      }
    });
  };

  // Profile Image Upload Functionality
  const profileImageFile = document.getElementById('profile_image_file');
  const imagePreview = document.getElementById('image_preview');
  const imagePreviewContainer = document.getElementById('image_preview_container');
  const uploadProgress = document.getElementById('upload_progress');
  const uploadBtn = document.getElementById('upload_profile_image_btn');

  // Handle file selection for preview
  profileImageFile?.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
      // Validate file type
      const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
      if (!allowedTypes.includes(file.type)) {
        alert('Please select a valid image file (JPEG, PNG, GIF, or WebP)');
        this.value = '';
        imagePreviewContainer.style.display = 'none';
        return;
      }

      // Validate file size (10MB max)
      if (file.size > 10 * 1024 * 1024) {
        alert('File size must be less than 10MB');
        this.value = '';
        imagePreviewContainer.style.display = 'none';
        return;
      }

      // Show preview
      const reader = new FileReader();
      reader.onload = function(e) {
        imagePreview.src = e.target.result;
        imagePreviewContainer.style.display = 'block';
      };
      reader.readAsDataURL(file);
    } else {
      imagePreviewContainer.style.display = 'none';
    }
  });

  // Handle profile image upload button click
  uploadBtn?.addEventListener('click', async function(e) {
    e.preventDefault();

    const file = profileImageFile.files[0];
    if (!file) {
      alert('Please select an image file first');
      return;
    }

    // Show upload progress
    uploadProgress.style.display = 'block';
    imagePreviewContainer.style.display = 'none';

    // Disable upload button
    const originalText = this.textContent;
    this.disabled = true;
    this.textContent = 'Uploading...';

    try {
      // Get CSRF token
      const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');

      // Create FormData
      const formData = new FormData();
      formData.append('customer_document[document_type]', 'Profile Image');
      formData.append('customer_document[document_file]', file);
      formData.append('authenticity_token', csrfToken);

      // Upload to customer documents endpoint
      const response = await fetch('<%= admin_customer_documents_path(@customer) %>', {
        method: 'POST',
        headers: {
          'X-CSRF-Token': csrfToken,
          'Accept': 'application/json'
        },
        body: formData
      });

      const result = await response.json();

      if (result.success) {
        // Show success message
        showProfileImageAlert('success', result.message || 'Profile image uploaded successfully!');

        // Reset form
        profileImageFile.value = '';
        imagePreviewContainer.style.display = 'none';

        // Reload page to show new profile image
        setTimeout(() => {
          window.location.reload();
        }, 1500);
      } else {
        throw new Error(result.message || 'Upload failed');
      }
    } catch (error) {
      console.error('Upload error:', error);
      showProfileImageAlert('danger', error.message || 'Upload failed');
    } finally {
      // Re-enable button and hide progress
      uploadProgress.style.display = 'none';
      this.disabled = false;
      this.textContent = originalText;
    }
  });

  // Function to show profile image alerts
  function showProfileImageAlert(type, message) {
    // Remove existing alerts
    const existingAlerts = document.querySelectorAll('.profile-image-alert');
    existingAlerts.forEach(alert => alert.remove());

    // Create new alert
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${type} alert-dismissible fade show mt-3 profile-image-alert`;
    alertDiv.innerHTML = `
      <i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>
      ${message}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;

    // Insert after the profile image form
    document.getElementById('profile_image_upload_form').insertAdjacentElement('afterend', alertDiv);

    // Auto-dismiss success alerts after 3 seconds
    if (type === 'success') {
      setTimeout(() => {
        if (alertDiv.parentElement) {
          alertDiv.remove();
        }
      }, 3000);
    }
  }

  // Form validation
  const forms = document.querySelectorAll('.needs-validation');
  Array.prototype.slice.call(forms).forEach(function(form) {
    form.addEventListener('submit', function(event) {
      // Strip +91/91/0 prefix from mobile fields before checkValidity runs
      form.querySelectorAll('input[name*="[mobile]"]').forEach(function(field) {
        let v = field.value.replace(/\D/g, '');
        if (v.length === 13 && v.startsWith('91')) v = v.slice(2);
        else if (v.length === 12 && v.startsWith('91')) v = v.slice(2);
        else if (v.length === 11 && v.startsWith('0'))  v = v.slice(1);
        else if (v.length === 11)                        v = v.slice(1);
        field.value = v;
      });

      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }
      form.classList.add('was-validated');
    }, false);
  });

  // Mobile Number Validation for Indian Numbers (6, 7, 8, 9 starting digits)
  function validateMobileNumber(input) {
    const mobilePattern = /^[6789]\d{9}$/;
    let rawValue = input.value.trim();
    let digits = rawValue.replace(/\D/g, '');

    // Strip country code / extra leading digit (mirrors Ruby format_mobile_number)
    if (digits.length === 13 && digits.startsWith('91')) digits = digits.slice(2);
    else if (digits.length === 12 && digits.startsWith('91')) digits = digits.slice(2);
    else if (digits.length === 11 && digits.startsWith('0'))  digits = digits.slice(1);
    else if (digits.length === 11)                             digits = digits.slice(1);

    // Clear previous validation state (do NOT change input.value to preserve user's formatted input)
    input.classList.remove('is-valid', 'is-invalid');
    const feedback = input.parentNode.querySelector('.mobile-feedback');
    if (feedback) feedback.remove();

    if (rawValue.length === 0) {
      return; // Don't validate empty input
    }

    if (digits.length !== 10) {
      showMobileError(input, 'Mobile number must be exactly 10 digits (you entered ' + digits.length + ')');
    } else if (!mobilePattern.test(digits)) {
      showMobileError(input, 'Mobile number must start with 6, 7, 8, or 9');
    } else {
      input.classList.add('is-valid');
    }
  }

  function showMobileError(input, message) {
    input.classList.add('is-invalid');
    const errorDiv = document.createElement('div');
    errorDiv.className = 'invalid-feedback mobile-feedback';
    errorDiv.textContent = message;
    input.parentNode.appendChild(errorDiv);
  }

  // Clean mobile fields on page load (strip stored +91 prefix)
  const mobileFields = document.querySelectorAll('input[name*="[mobile]"]');
  mobileFields.forEach(function(field) {
    validateMobileNumber(field);

    field.addEventListener('input', function() {
      validateMobileNumber(this);
    });

    field.addEventListener('blur', function() {
      validateMobileNumber(this);
    });
  });

});
</script>

<!-- Profile Preview Modal -->
<% if @customer.has_profile_image? %>
  <% image_data = @customer.safe_profile_image_display %>
  <% if image_data %>
    <div class="modal fade" id="profilePreviewModal" tabindex="-1" aria-labelledby="profilePreviewModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="profilePreviewModalLabel">
              <i class="bi bi-person-circle me-2"></i>Profile Image - <%= @customer.display_name %>
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body text-center">
            <div class="position-relative">
              <%= image_tag image_data[:url],
                  class: "img-fluid rounded shadow",
                  style: "max-height: 500px; max-width: 100%;",
                  alt: "Profile image of #{@customer.display_name}",
                  onerror: "this.style.display='none'; this.nextElementSibling.style.display='block';",
                  loading: "lazy" %>

              <div style="display: none;" class="alert alert-warning">
                <i class="bi bi-exclamation-triangle me-2"></i>
                Unable to load image. The file may be corrupted or temporarily unavailable.
              </div>
            </div>

            <div class="mt-3">
              <p class="text-muted mb-1">
                <strong>File:</strong> <%= image_data[:filename] %>
              </p>
              <p class="text-muted mb-1">
                <strong>Size:</strong> <%= number_to_human_size(image_data[:size]) %>
              </p>
              <p class="text-muted mb-0">
                <strong>Type:</strong> <%= image_data[:content_type] %>
              </p>
            </div>
          </div>
          <div class="modal-footer">
            <a href="<%= image_data[:url] %>"
               class="btn btn-primary"
               download="<%= image_data[:filename] %>">
              <i class="bi bi-download me-1"></i>Download
            </a>
            <a href="<%= image_data[:url] %>"
               class="btn btn-outline-secondary"
               target="_blank">
              <i class="bi bi-arrows-fullscreen me-1"></i>Open in New Tab
            </a>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
              <i class="bi bi-x-lg me-1"></i>Close
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>