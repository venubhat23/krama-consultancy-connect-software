    function setupDropZone(inputId, zoneId, previewId, imgId, nameId) {
      var input = document.getElementById(inputId);
      var zone = document.getElementById(zoneId);
      var preview = document.getElementById(previewId);
      var img = document.getElementById(imgId);
      var nameEl = document.getElementById(nameId);
      if (!input || !zone) return;

      zone.addEventListener('click', function(e) {
        if (e.target.closest('button')) return; // don't trigger on Remove button
        input.click();
      });

      input.addEventListener('change', function() {
        var file = this.files[0];
        if (!file) return;
        if (nameEl) nameEl.textContent = file.name;

        // Remove any previous resolution badges
        preview.querySelectorAll('.res-warning, .res-info').forEach(function(el) { el.remove(); });
        zone.classList.remove('res-low');

        var objectUrl = URL.createObjectURL(file);

        if (file.type.startsWith('image/')) {
          // Check resolution and show info badge — always allow extraction
          var checkImg = new Image();
          checkImg.onload = function() {
            var w = checkImg.naturalWidth, h = checkImg.naturalHeight;
            var MIN_W = 600, MIN_H = 300;
            var content = zone.querySelector('.doc-zone-content');
            if (content) content.style.display = 'none';
            if (preview) preview.style.display = 'block';
            zone.classList.add('has-file');

            var sizeKB = Math.round(file.size / 1024);
            var dimInfo = w + '×' + h + 'px · ' + sizeKB + ' KB';
            if (img) { img.src = objectUrl; img.style.display = 'block'; }
            if (nameEl) nameEl.textContent = file.name;

            if (w < MIN_W || h < MIN_H) {
              zone.classList.add('res-low');
              var warn = document.createElement('div');
              warn.className = 'res-warning alert alert-warning py-1 px-2 mt-2 mb-0 small text-center';
              warn.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-1"></i>' +
                '<strong>' + dimInfo + '</strong> — Low resolution.<br>' +
                '<span class="text-muted" style="font-size:11px">Results may be inaccurate but extraction is still allowed.</span>';
              preview.appendChild(warn);
            } else {
              var info = document.createElement('div');
              info.className = 'res-info text-muted mt-1 small text-center';
              info.innerHTML = '<i class="bi bi-check-circle-fill text-success me-1"></i>' + dimInfo;
              preview.appendChild(info);
            }
            updateExtractBtn();
          };
          checkImg.onerror = function() {
            // Can't check — allow anyway
            if (img) { img.src = objectUrl; img.style.display = 'block'; }
            var content = zone.querySelector('.doc-zone-content');
            if (content) content.style.display = 'none';
            if (preview) preview.style.display = 'block';
            zone.classList.add('has-file');
            updateExtractBtn();
          };
          checkImg.src = objectUrl;
        } else {
          // Non-image file (PDF, etc.)
          if (img) img.style.display = 'none';
          var content = zone.querySelector('.doc-zone-content');
          if (content) content.style.display = 'none';
          if (preview) preview.style.display = 'block';
          zone.classList.add('has-file');
          updateExtractBtn();
        }
      });

      zone.addEventListener('dragover', function(e) { e.preventDefault(); this.classList.add('drag-over'); });
      zone.addEventListener('dragleave', function() { this.classList.remove('drag-over'); });
      zone.addEventListener('drop', function(e) {
        e.preventDefault();
        this.classList.remove('drag-over');
        if (e.dataTransfer.files.length) {
          input.files = e.dataTransfer.files;
          input.dispatchEvent(new Event('change'));
        }
      });
    }

    setupDropZone('aadhaar_front_input', 'aadhaar_front_zone', 'aadhaar_front_preview', 'aadhaar_front_img', 'aadhaar_front_name');
    setupDropZone('aadhaar_back_input', 'aadhaar_back_zone', 'aadhaar_back_preview', 'aadhaar_back_img', 'aadhaar_back_name');
    setupDropZone('pan_input', 'pan_zone', 'pan_preview', 'pan_img', 'pan_name');
    setupDropZone('cheque_input', 'cheque_zone', 'cheque_preview', 'cheque_img', 'cheque_name');

    function setProgress(pct, text) {
      var bar = document.getElementById('ocr_progress_bar');
      var pctEl = document.getElementById('ocr_progress_pct');
      var textEl = document.getElementById('ocr_status_text');
      var p = Math.round(Math.min(100, Math.max(0, pct)));
      if (bar) { bar.style.width = p + '%'; bar.setAttribute('aria-valuenow', p); }
      if (pctEl) pctEl.textContent = p + '%';
      if (textEl && text) textEl.textContent = text;
    }

    // Upscale small images before OCR — Tesseract works poorly below ~1200px wide
    function preprocessImage(file) {
      return new Promise(function(resolve) {
        var img = new Image();
        var url = URL.createObjectURL(file);
        img.onload = function() {
          var minW = 1400;
          var scale = img.width < minW ? minW / img.width : 1;
          var canvas = document.createElement('canvas');
          canvas.width = Math.round(img.width * scale);
          canvas.height = Math.round(img.height * scale);
          var ctx = canvas.getContext('2d');
          ctx.imageSmoothingEnabled = true;
          ctx.imageSmoothingQuality = 'high';
          ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
          // Boost contrast to help OCR on low-quality scans
          var id = ctx.getImageData(0, 0, canvas.width, canvas.height);
          var d = id.data;
          for (var i = 0; i < d.length; i += 4) {
            d[i]   = Math.min(255, Math.max(0, (d[i]   - 128) * 1.4 + 128));
            d[i+1] = Math.min(255, Math.max(0, (d[i+1] - 128) * 1.4 + 128));
            d[i+2] = Math.min(255, Math.max(0, (d[i+2] - 128) * 1.4 + 128));
          }
          ctx.putImageData(id, 0, 0);
          canvas.toBlob(function(blob) { URL.revokeObjectURL(url); resolve(blob); }, 'image/png');
        };
        img.onerror = function() { URL.revokeObjectURL(url); resolve(file); };
        img.src = url;
      });
    }

    async function runOCR(file, offset, scale, lang) {
      offset = offset || 0; scale = scale || 1; lang = lang || 'eng';
      setProgress(offset + 1 * scale, 'Enhancing image...');
      var processedFile = await preprocessImage(file);
      var worker = await Tesseract.createWorker(lang, 1, {
        logger: function(m) {
          if (m.status === 'loading tesseract core') setProgress(offset + 2 * scale, 'Loading OCR engine...');
          else if (m.status === 'initializing tesseract') setProgress(offset + 10 * scale, 'Initializing...');
          else if (m.status === 'loading language traineddata') setProgress(offset + 20 * scale, 'Loading ' + lang + ' language data...');
          else if (m.status === 'initializing api') setProgress(offset + 30 * scale, 'Starting recognition...');
          else if (m.status === 'recognizing text') setProgress(offset + (30 + m.progress * 70) * scale, 'Reading text...');
        }
      });
      var result = await worker.recognize(processedFile);
      await worker.terminate();
      return result.data.text;
    }

    var extractBtn = document.getElementById('extract_info_btn');
    if (extractBtn) {
      extractBtn.addEventListener('click', function() {
        var self = this;
        var progressContainer = document.getElementById('ocr_progress_container');
        self.disabled = true;
        self.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';
        progressContainer.style.display = 'block';
        setProgress(0, 'Loading OCR engine...');

        ensureTesseract().then(async function() {
          try {
            if (selectedDocType === 'aadhaar') {
              var frontFile = document.getElementById('aadhaar_front_input').files[0];
              var backFile = document.getElementById('aadhaar_back_input').files[0];
              var frontText = '', backText = '';
              var scale = backFile ? 0.5 : 1;
              if (frontFile) { setProgress(0, 'Processing Aadhaar front...'); frontText = await runOCR(frontFile, 0, scale, 'eng+hin'); }
              if (backFile) { setProgress(50, 'Processing Aadhaar back...'); backText = await runOCR(backFile, 50, 0.5, 'eng+hin'); }
              extractedData = parseAadhaarText(frontText, backText);
            } else if (selectedDocType === 'pan') {
              var panFile = document.getElementById('pan_input').files[0];
              if (panFile) { setProgress(0, 'Processing PAN card...'); var text = await runOCR(panFile, 0, 1, 'eng+hin'); extractedData = parsePanText(text); }
            } else if (selectedDocType === 'cheque') {
              var chequeFile = document.getElementById('cheque_input').files[0];
              if (chequeFile) { setProgress(0, 'Processing cheque...'); var text = await runOCR(chequeFile, 0, 1); extractedData = parseChequeText(text); }
            }
            setProgress(100, 'Extraction complete!');
            setTimeout(function() {
              showInfoModal(extractedData);
              self.disabled = false;
              self.innerHTML = '<i class="bi bi-magic me-2"></i>Extract Info';
              progressContainer.style.display = 'none';
            }, 600);
          } catch(err) {
            console.error('OCR error:', err);
            self.disabled = false;
            self.innerHTML = '<i class="bi bi-magic me-2"></i>Extract Info';
            progressContainer.style.display = 'none';
            alert('Could not process document. Please ensure the image is clear and try again.');
          }
        }).catch(function(err) {
          console.error('Tesseract load error:', err);
          self.disabled = false;
          self.innerHTML = '<i class="bi bi-magic me-2"></i>Extract Info';
          progressContainer.style.display = 'none';
          alert('Failed to load OCR engine. Please check your internet connection.');
        });
      });
    }

    // Clean up raw OCR address text: strip non-ASCII lines (Hindi garbage), remove pincode, normalise
    function cleanAddress(raw) {
      var lines = raw.split('\n').map(function(l) { return l.trim(); }).filter(function(l) {
        if (!l) return false;
        // Drop lines that are mostly non-ASCII (Devanagari/Kannada garble)
        var ascii = l.replace(/[^\x20-\x7E]/g, '').length;
        return ascii / l.length > 0.6; // keep line if >60% ASCII
      }).map(function(l) {
        return l
          .replace(/[^\x20-\x7E]/g, '')  // strip residual non-ASCII chars (Hindi, etc.)
          .replace(/[|!]+/g, ' ')         // remove pipe/exclamation OCR artifacts
          .replace(/\s{2,}/g, ' ')
          .trim();
      }).filter(function(l) { return l.length > 2; });
      return lines.join(', ')
        .replace(/\s*[-–]\s*\d{6}[\s\S]*$/, '') // "State - 560066" → remove
        .replace(/\d{6}[\s\S]*$/, '')            // bare pincode at end → remove
        .replace(/,\s*,/g, ',')
        .replace(/,\s*$/, '')
        .replace(/\s{2,}/g, ' ')
        .trim();
    }

    // Among all "Address: ..." blocks in text, pick the one with highest ASCII ratio (cleanest)
    function bestAddressMatch(text) {
      var re = /Address[\s:]+(.+?)(?=(?:Address[\s:]|\d{4}\s\d{4}|^\s*$))/gsi;
      var best = null, bestScore = 0;
      var m;
      while ((m = re.exec(text)) !== null) {
        var raw = m[1];
        var ascii = raw.replace(/[^\x20-\x7E\n]/g, '').length;
        var score = raw.length > 10 ? ascii / raw.length : 0;
        if (score > bestScore) { bestScore = score; best = raw; }
      }
      // Also try a simple last-match (regex might miss the last block)
      var simple = text.match(/Address[\s:]+(.+)$/si);
      if (simple) {
        var raw2 = simple[1];
        var ascii2 = raw2.replace(/[^\x20-\x7E\n]/g, '').length;
        var score2 = raw2.length > 10 ? ascii2 / raw2.length : 0;
        if (score2 > bestScore) { best = raw2; }
      }
      return best ? cleanAddress(best) : null;
    }

    function parseAadhaarText(frontText, backText) {
      var result = {};
      var allText = (frontText || '') + '\n' + (backText || '');

      // Aadhaar number — 12 digits with spaces, or 12 consecutive digits
      var am = allText.match(/\d{4}\s\d{4}\s\d{4}/);
      if (!am) am = allText.match(/\b(\d{12})\b/);
      if (am) result.aadhaar_number = am[0];

      // DOB — always prefer labeled patterns; bare-date fallback skips Download/Issue/Enrolment dates
      var dobPatterns = [
        /(?:DOB|Date of Birth|जन्म.{0,10})[\s:\/]+(\d{2}[\/\-]\d{2}[\/\-]\d{4})/i,
        /(?:Year of Birth|YOB)[\s:]+(\d{4})/i
      ];
      for (var i = 0; i < dobPatterns.length; i++) {
        var dm = frontText.match(dobPatterns[i]);
        if (dm) { result.dob = dm[1]; break; }
      }
      // Bare date fallback: skip lines that contain Download/Issue/Enrolment/Expiry labels
      if (!result.dob) {
        var allLines = frontText.split('\n');
        for (var i = 0; i < allLines.length; i++) {
          if (/download|issue|enrol|expiry|valid|from\s*:|to\s*:/i.test(allLines[i])) continue;
          var bdm = allLines[i].match(/(\d{2}[\/\-]\d{2}[\/\-]\d{4})/);
          if (bdm) { result.dob = bdm[1]; break; }
        }
      }

      // Gender — scan full front text (handles "महिला / Female" mixed lines)
      if (/female|महिला/i.test(frontText)) result.gender = 'female';
      else if (/\bmale\b|पुरुष/i.test(frontText)) result.gender = 'male';
      else if (/transgender/i.test(frontText)) result.gender = 'other';

      // Name — shared validator used for both passes
      var frontLines = frontText.split('\n').map(function(l) { return l.trim(); }).filter(function(l) { return l.length > 2; });

      function isValidNameLine(line) {
        if (/\d/.test(line)) return false;
        if (/[^A-Za-z\s]/.test(line)) return false;
        if (/aadhaar|govt|india|unique|authority|uid|help|enrol|dob|birth|gender|address|government|election|commission|department|issue|identification|verification|download|information/i.test(line)) return false;
        if (/s\/o|d\/o|w\/o|c\/o/i.test(line)) return false; // skip father/husband name lines
        if (line.length < 8 || line.length > 60) return false;
        var words = line.trim().split(/\s+/);
        if (words.length < 2) return false;
        // First word Title Case; rest Title Case or lowercase ≥3 chars
        var firstOK = /^[A-Z][a-z]{2,}$/.test(words[0]);
        var restOK = words.slice(1).every(function(w) {
          return /^[A-Z][a-z]{2,}$/.test(w) || /^[a-z]{3,}$/.test(w);
        });
        return firstOK && restOK;
      }

      // DOB line index — only stop at explicitly labeled DOB, NOT "Download Date" / "Issue Date"
      var dobLineIdx = frontLines.length;
      for (var i = 0; i < frontLines.length; i++) {
        if (/\bDOB\b|\bDate of Birth\b/i.test(frontLines[i]) &&
            !/download|issue|enrol/i.test(frontLines[i])) { dobLineIdx = i; break; }
      }

      // Pass 1: search before DOB line (most reliable — name comes before DOB on card)
      for (var i = 0; i < dobLineIdx; i++) {
        if (isValidNameLine(frontLines[i])) { result.full_name = frontLines[i]; break; }
      }
      // Pass 2: if not found, search ALL lines (handles screenshots, letter-format, combined images)
      if (!result.full_name) {
        for (var i = 0; i < frontLines.length; i++) {
          if (isValidNameLine(frontLines[i])) { result.full_name = frontLines[i]; break; }
        }
      }
      // Pass 3: mixed Hindi+English lines — extract the English Title Case name portion
      if (!result.full_name) {
        var allFrontRaw = frontText.split('\n').map(function(l) { return l.trim(); }).filter(function(l) { return l.length > 2; });
        for (var i = 0; i < allFrontRaw.length; i++) {
          var line = allFrontRaw[i];
          if (/aadhaar|govt|india|unique|authority|uid|help|enrol|dob|birth|gender|address|government|download|identification|election|commission|department|verification/i.test(line)) continue;
          if (/s\/o|d\/o|w\/o|c\/o/i.test(line)) continue;
          var engMatch = line.match(/([A-Z][a-z]{2,}(?:\s+[A-Z][a-z]{2,})+)/);
          if (engMatch) { result.full_name = engMatch[1]; break; }
        }
      }

      // From back — address (pick cleanest occurrence), pincode, state
      if (backText) {
        var addrClean = bestAddressMatch(backText);
        if (addrClean && addrClean.length > 5) result.address = addrClean;

        // Fallback: lines after S/O, C/O, H.No, Flat, etc.
        if (!result.address) {
          var backLines = backText.split('\n').map(function(l) { return l.trim(); }).filter(function(l) { return l.length > 0; });
          var addrLines = []; var collecting = false;
          for (var i = 0; i < backLines.length; i++) {
            var bl = backLines[i];
            if (/^[SCWD]\/[OA]|^H\.?\s*No|^Flat|^Door|^Plot|^Vill|^Near|^House|^Address/i.test(bl)) {
              collecting = true;
              bl = bl.replace(/^Address[\s:]+/i, '');
            }
            if (collecting) {
              if (/^\d{6}$/.test(bl)) break;
              if (bl.length > 0) addrLines.push(bl);
              if (addrLines.length >= 6) break;
            }
          }
          if (addrLines.length > 0) result.address = cleanAddress(addrLines.join('\n'));
        }

        // Pincode (6-digit number)
        var pm = backText.match(/\b(\d{6})\b/);
        if (pm) result.pincode = pm[1];

        // State name
        var STATES = ['Andhra Pradesh','Arunachal Pradesh','Assam','Bihar','Chhattisgarh','Goa','Gujarat','Haryana','Himachal Pradesh','Jharkhand','Karnataka','Kerala','Madhya Pradesh','Maharashtra','Manipur','Meghalaya','Mizoram','Nagaland','Odisha','Punjab','Rajasthan','Sikkim','Tamil Nadu','Telangana','Tripura','Uttar Pradesh','Uttarakhand','West Bengal','Delhi','Jammu and Kashmir','Ladakh','Chandigarh','Puducherry'];
        for (var i = 0; i < STATES.length; i++) {
          if (backText.toLowerCase().indexOf(STATES[i].toLowerCase()) !== -1) { result.state = STATES[i]; break; }
        }
      }

      // If front was a combined image (both sides) — also search frontText for cleanest Address block
      if (!result.address) {
        var addrClean2 = bestAddressMatch(frontText);
        if (addrClean2 && addrClean2.length > 5) result.address = addrClean2;
      }
      if (!result.address) {
        var soMatch = frontText.match(/S\/O[\s:]+(.+?)(?:\n\d{4}|\n\d{6}|$)/si);
        if (soMatch) result.address = cleanAddress(soMatch[1]);
      }
      // Pincode and state from frontText as fallback
      if (!result.pincode) {
        var pfm = frontText.match(/\b(\d{6})\b/);
        if (pfm) result.pincode = pfm[1];
      }
      if (!result.state) {
        var STATES2 = ['Andhra Pradesh','Arunachal Pradesh','Assam','Bihar','Chhattisgarh','Goa','Gujarat','Haryana','Himachal Pradesh','Jharkhand','Karnataka','Kerala','Madhya Pradesh','Maharashtra','Manipur','Meghalaya','Mizoram','Nagaland','Odisha','Punjab','Rajasthan','Sikkim','Tamil Nadu','Telangana','Tripura','Uttar Pradesh','Uttarakhand','West Bengal','Delhi','Jammu and Kashmir','Ladakh','Chandigarh','Puducherry'];
        for (var i = 0; i < STATES2.length; i++) {
          if (frontText.toLowerCase().indexOf(STATES2[i].toLowerCase()) !== -1) { result.state = STATES2[i]; break; }
        }
      }

      // Phone — labeled pattern only (avoids confusing Aadhaar/pincode digits)
      var phoneSearchText = allText;
      var phonePats = [
        /(?:Mob(?:ile)?|Phone|Contact|Tel(?:\.)?|Mo\.)[\s.:]+(?:\+?91[\s\-]?)?([6-9]\d{9})/i,
        /\bVID[\s:]+\d+[\s\S]{0,200}?([6-9]\d{9})/i
      ];
      for (var i = 0; i < phonePats.length; i++) {
        var phm = phoneSearchText.match(phonePats[i]);
        if (phm) { result.phone = phm[1]; break; }
      }

      // City / District — look for labeled district/taluk/city, or infer from address
      var citySearchText = (backText || '') + '\n' + (frontText || '');
      var cityPats = [
        /(?:Dist(?:rict)?|District|Taluk|Tehsil|Taluq|City|Town)[\s.:]+([A-Za-z][A-Za-z\s]{2,25}?)(?:\n|\r|,|$)/i
      ];
      for (var i = 0; i < cityPats.length; i++) {
        var cm = citySearchText.match(cityPats[i]);
        if (cm) { result.city = cm[1].trim().replace(/\s{2,}/g,' '); break; }
      }
      // Fallback: if address parsed, second-to-last comma-segment before state is usually city
      if (!result.city && result.address && result.state) {
        var addrParts = result.address.split(',').map(function(p) { return p.trim(); }).filter(function(p) { return p.length > 2; });
        for (var i = addrParts.length - 1; i >= 0; i--) {
          var part = addrParts[i];
          if (part.toLowerCase() === result.state.toLowerCase()) continue;
          if (/^\d{6}$/.test(part)) continue;
          if (/^\d+$/.test(part)) continue;
          result.city = part; break;
        }
      }

      // Split full_name → first / middle / last
      if (result.full_name) {
        var parts = result.full_name.trim().split(/\s+/);
        if (parts.length === 1) { result.first_name = parts[0]; }
        else if (parts.length === 2) { result.first_name = parts[0]; result.last_name = parts[1]; }
        else { result.first_name = parts[0]; result.last_name = parts[parts.length - 1]; result.middle_name = parts.slice(1, -1).join(' '); }
      }

      return result;
    }

    function parsePanText(text) {
      var result = {};

      console.log('[PAN OCR raw]', JSON.stringify(text));

      // PAN number: ABCDE1234F (case-insensitive, normalise to upper)
      var pm = text.match(/[A-Z]{5}[0-9]{4}[A-Z]/i);
      if (pm) result.pan_no = pm[0].toUpperCase();

      // DOB — first DD/MM/YYYY date in the text
      var dm = text.match(/(\d{2}\/\d{2}\/\d{4})/);
      if (dm) result.dob = dm[1];

      var lines = text.split('\n').map(function(l) { return l.trim(); }).filter(function(l) { return l.length > 1; });

      function cleanForName(ln) {
        return ln
          .replace(/[^\x20-\x7E]/g, ' ')   // kill non-ASCII (Hindi chars)
          .replace(/(\s+\d+)+\s*$/, '')     // strip trailing right-column numbers
          .replace(/\s{2,}/g, ' ')
          .trim();
      }

      function isNameLine(c) {
        // Accept ALL-CAPS or Title Case — Tesseract produces either on faded blue PAN cards
        if (!/^[A-Za-z][A-Za-z\s]+$/.test(c)) return false;
        if (c.replace(/\s/g, '').length < 3) return false;
        if (c.length >= 55) return false;
        var cu = c.toUpperCase();
        if (/^(PERMANENT|ACCOUNT|NUMBER|CARD|TAX|INCOME|GOVT|INDIA|DEPARTMENT|SIGNATURE|SIGN|DATE|DOB|VALID|FROM|TO)$/.test(cu.trim())) return false;
        if (/PERMANENT ACCOUNT|INCOME TAX|GOVT OF INDIA/i.test(c)) return false;
        return true;
      }

      var nameLine1 = null, nameLine2 = null, nameLineIdx = -1;

      // Pass 1 — name after "INCOME TAX" or "GOVT OF INDIA" header
      for (var i = 0; i < lines.length; i++) {
        var cl = cleanForName(lines[i]);
        if (/income tax|govt of india/i.test(cl)) {
          for (var j = i + 1; j < Math.min(i + 10, lines.length); j++) {
            var c = cleanForName(lines[j]);
            if (isNameLine(c)) { nameLine1 = c.toUpperCase(); nameLineIdx = j; break; }
          }
          if (nameLine1) break;
        }
      }

      // Pass 2 — fallback: first qualifying name line anywhere
      if (!nameLine1) {
        for (var i = 0; i < lines.length; i++) {
          var c = cleanForName(lines[i]);
          if (isNameLine(c)) { nameLine1 = c.toUpperCase(); nameLineIdx = i; break; }
        }
      }

      // Father's name = next qualifying name line after nameLine1
      if (nameLineIdx >= 0) {
        for (var j = nameLineIdx + 1; j < Math.min(nameLineIdx + 6, lines.length); j++) {
          var c = cleanForName(lines[j]);
          if (isNameLine(c)) { nameLine2 = c.toUpperCase(); break; }
        }
      }

      console.log('[PAN OCR] nameLine1:', nameLine1, '| nameLine2:', nameLine2);

      if (nameLine1) {
        var parts = nameLine1.trim().split(/\s+/);
        var lastPart = parts[parts.length - 1];
        if (lastPart.length === 1 && nameLine2) {
          // Patronymic: "JAGADISH S" + "SHIVANNA" → first=JAGADISH, last=SHIVANNA
          result.first_name = parts.slice(0, -1).join(' ') || parts[0];
          result.last_name  = nameLine2;
        } else if (parts.length === 1) {
          result.first_name = parts[0];
        } else if (parts.length === 2) {
          result.first_name = parts[0];
          result.last_name  = parts[1];
        } else {
          result.first_name  = parts[0];
          result.middle_name = parts.slice(1, -1).join(' ');
          result.last_name   = parts[parts.length - 1];
        }
      }

      if (nameLine2) result.father_name = nameLine2;

      return result;
    }

    function parseChequeText(text) {
      var result = {};
      var lines = text.split('\n').map(function(l) { return l.trim(); }).filter(function(l) { return l.length > 1; });

      // ── IFSC code ──────────────────────────────────────────────────────────
      // OCR commonly confuses digit-0 with letter-O in IFSC (e.g. SBIN0003067 → SBINO003067).
      // Pattern: 4 letters + [0 or O] + 6 alphanumeric chars (11 chars total).
      // Try labeled keywords first, then bare scan.
      function extractIfsc(t) {
        // Label patterns: "IFS Code", "IFSC Code", "IFSC:", "IFS:", etc.
        var lm = t.match(/(?:IFSC?\s*(?:Code)?)[\s.:]+([A-Z]{4}[0O][A-Z0-9]{6})/i);
        if (lm) return lm[1];
        // Bare scan — find any 11-char sequence matching IFSC format
        var bm = t.match(/\b([A-Z]{4}[0O][A-Z0-9]{6})\b/);
        if (bm) return bm[1];
        return null;
      }
      var rawIfsc = extractIfsc(text);
      if (rawIfsc) {
        // Normalise: 5th char must be digit 0 (not letter O)
        rawIfsc = rawIfsc.toUpperCase();
        result.ifsc_code = rawIfsc.slice(0, 4) + '0' + rawIfsc.slice(5);
      }

      // ── Account number ─────────────────────────────────────────────────────
      // "PREFIX" on SBI cheques holds the account number, possibly on the next line.
      // "A/c No." label — the field may be blacked out in scanned cheques; try anyway.
      // Use [\s\S]{0,10} to bridge a newline between label and value.
      var acctPatterns = [
        /(?:A[\/\s]?[Cc]\.?\s*[Nn]o\.?|Account\s*(?:No|Number|#))[\s\S]{0,10}?([0-9]{8,20})/i,
        /PREFIX[\s\S]{0,10}?([0-9]{8,20})/i,
        /(?:SB\s*ACCOUNT|CURRENT\s*ACCOUNT|SAVINGS\s*ACCOUNT)\b[\s\S]{0,80}?([0-9]{9,20})/i
      ];
      for (var i = 0; i < acctPatterns.length; i++) {
        var am = text.match(acctPatterns[i]);
        if (am) { result.account_no = am[1]; break; }
      }
      // Fallback: first 10–18 digit standalone number (skips 9-digit MICR & 6-digit cheque number)
      if (!result.account_no) {
        var longNums = text.match(/\b([0-9]{10,18})\b/g);
        if (longNums && longNums.length > 0) result.account_no = longNums[0];
      }

      // ── Bank name ──────────────────────────────────────────────────────────
      // Longer/more-specific names first so "State Bank of India" beats "Bank of India"
      var BANKS = [
        'State Bank of India','Punjab National Bank','Bank of Baroda','Canara Bank',
        'Union Bank of India','Indian Bank','Central Bank of India','UCO Bank',
        'Bank of Maharashtra','Bank of India','Indian Overseas Bank','Corporation Bank',
        'Allahabad Bank','Oriental Bank','Andhra Bank','Vijaya Bank','Dena Bank',
        'Syndicate Bank','HDFC Bank','ICICI Bank','Axis Bank','Kotak Mahindra Bank',
        'Yes Bank','IndusInd Bank','Federal Bank','IDBI Bank','IDFC First Bank',
        'Nainital Bank','Karnataka Bank','South Indian Bank','City Union Bank',
        'Karur Vysya Bank','Lakshmi Vilas Bank','Bandhan Bank','RBL Bank',
        'Saraswat Bank','AU Small Finance Bank','Jana Small Finance Bank',
        'Equitas Small Finance Bank','ESAF Small Finance Bank','SBI'
      ];
      var fullText = text.toLowerCase();
      for (var b = 0; b < BANKS.length; b++) {
        if (fullText.indexOf(BANKS[b].toLowerCase()) !== -1) {
          result.bank_name = BANKS[b]; break;
        }
      }
      // Fallback: extract the first line that contains "bank" but isn't an address/IFSC line
      if (!result.bank_name) {
        for (var i = 0; i < lines.length; i++) {
          if (/\bbank\b/i.test(lines[i]) && lines[i].length < 70 &&
              !/branch|ifsc|swift|address|road|nagar|colony|district/i.test(lines[i])) {
            result.bank_name = lines[i].replace(/[^A-Za-z0-9 &.(),-]/g, '').trim(); break;
          }
        }
      }

      // ── Branch ─────────────────────────────────────────────────────────────
      var branchM = text.match(/Branch[\s:]+([A-Za-z][A-Za-z0-9 ,.()\-]{3,60}?)(?:\n|IFSC|$)/i);
      if (branchM) result.branch = branchM[1].trim();

      // ── Account holder name ────────────────────────────────────────────────
      // Priority 1: salutation "Mr. / Mrs. / Ms." near signature area (all-caps names on cheques)
      var salutM = text.match(/(?:Mr\.|Mrs\.|Ms\.|Dr\.)\s+([A-Z][A-Z\s]{3,40}?)(?:\n|$)/);
      if (salutM) result.full_name = salutM[1].trim().replace(/\s{2,}/g, ' ');

      // Priority 2: PAY <NAME> OR ORDER  (payee line)
      if (!result.full_name) {
        var payM = text.match(/^PAY\s+([A-Za-z][A-Za-z\s]{3,50}?)(?:\s+OR\s+ORDER|\n|$)/im);
        if (payM) result.full_name = payM[1].trim();
      }

      // Priority 3: A/C Name or Account Name label
      if (!result.full_name) {
        var acNameM = text.match(/(?:A\/C\s*Name|Account\s*Name|A\/C\s*Holder)[\s:]+([A-Za-z][A-Za-z\s.]{3,50}?)(?:\n|$)/i);
        if (acNameM) result.full_name = acNameM[1].trim();
      }

      // Priority 4: standalone all-caps name (2+ words, no digits, not bank keywords)
      if (!result.full_name) {
        for (var i = 0; i < lines.length; i++) {
          var ln = lines[i];
          if (/bank|branch|ifsc|micr|account|cheque|cheque|date|rupees|amount|pay|sign|nominee|address|swift|code|valid|multi|city|prefix|order|only|lacs|state/i.test(ln)) continue;
          if (/\d/.test(ln)) continue;
          // ALL-CAPS two-word+ name (common on Indian cheques)
          if (/^[A-Z]{2,}(?:\s+[A-Z]{2,})+$/.test(ln) && ln.length >= 5 && ln.length <= 50) {
            result.full_name = ln; break;
          }
          // Title-case two-word+ name
          if (/^[A-Z][a-z]{1,}(?:\s+[A-Z][a-z]{1,})+$/.test(ln) && ln.length >= 5 && ln.length <= 50) {
            result.full_name = ln; break;
          }
        }
      }

      if (result.full_name) {
        // Normalise: convert ALL CAPS to Title Case
        var nameStr = result.full_name.replace(/\b[A-Z]{2,}\b/g, function(w) {
          return w.charAt(0) + w.slice(1).toLowerCase();
        });
        var parts = nameStr.trim().split(/\s+/);
        if (parts.length === 1) { result.first_name = parts[0]; }
        else if (parts.length === 2) { result.first_name = parts[0]; result.last_name = parts[1]; }
        else { result.first_name = parts[0]; result.last_name = parts[parts.length - 1]; result.middle_name = parts.slice(1, -1).join(' '); }
      }

      return result;
    }

    function showInfoModal(data) {
      var FIELDS = [
        { key: 'first_name',    label: 'First Name' },
        { key: 'middle_name',   label: 'Middle Name' },
        { key: 'last_name',     label: 'Last Name' },
        { key: 'aadhaar_number',label: 'Aadhaar Number' },
        { key: 'phone',         label: 'Phone' },
        { key: 'address',       label: 'Address' },
        { key: 'state',         label: 'State' },
        { key: 'city',          label: 'City' },
        { key: 'dob',           label: 'Date of Birth' },
        { key: 'gender',        label: 'Gender' },
        { key: 'pan_no',        label: 'PAN Number' },
        { key: 'pincode',       label: 'Pincode' },
        { key: 'father_name',   label: "Father's Name" },
        { key: 'bank_name',     label: 'Bank Name' },
        { key: 'account_no',    label: 'Account Number' },
        { key: 'ifsc_code',     label: 'IFSC Code' },
        { key: 'branch',        label: 'Branch' }
      ];

      var rows = '';
      FIELDS.forEach(function(f) {
        var alwaysShow = (f.key === 'first_name' || f.key === 'last_name');
        if (!data[f.key] && !alwaysShow) return;
        var safeVal = data[f.key] ? String(data[f.key]).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/"/g,'&quot;') : '';
        rows += '<tr>' +
          '<td class="fw-semibold text-muted small" style="width:32%">' + f.label + '</td>' +
          '<td>' +
            '<span class="extracted-val-display small">' + safeVal + '</span>' +
            '<input type="text" class="form-control form-control-sm extracted-val-input" style="display:none" value="' + safeVal + '">' +
          '</td>' +
          '<td class="text-center" style="width:36px">' +
            '<button type="button" class="btn btn-sm btn-link p-0 text-secondary edit-extracted-btn" title="Edit value">' +
              '<i class="bi bi-pencil" style="font-size:13px"></i>' +
            '</button>' +
          '</td>' +
          '<td class="text-center" style="width:52px">' +
            '<input type="checkbox" class="form-check-input import-field-check" data-field="' + f.key + '" checked>' +
          '</td>' +
          '</tr>';
      });

      var tableEl = document.getElementById('extracted_info_table');
      if (rows) {
        tableEl.innerHTML =
          '<table class="table table-bordered table-sm align-middle mb-2">' +
            '<thead class="table-light"><tr>' +
              '<th>Field</th>' +
              '<th>Extracted Value</th>' +
              '<th style="width:36px"></th>' +
              '<th class="text-center" style="width:52px">Import</th>' +
            '</tr></thead>' +
            '<tbody>' + rows + '</tbody>' +
          '</table>' +
          '<p class="text-muted small mb-0">Click <i class="bi bi-pencil"></i> to edit a value before importing. Uncheck fields you do not want.</p>';

        // Wire up edit-toggle buttons
        tableEl.querySelectorAll('.edit-extracted-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var row = this.closest('tr');
            var display = row.querySelector('.extracted-val-display');
            var input   = row.querySelector('.extracted-val-input');
            if (input.style.display === 'none') {
              input.value = display.textContent.trim();
              display.style.display = 'none';
              input.style.display = '';
              input.focus();
              this.querySelector('i').className = 'bi bi-check-lg';
              this.title = 'Confirm edit';
            } else {
              display.textContent = input.value.trim();
              input.style.display = 'none';
              display.style.display = '';
              this.querySelector('i').className = 'bi bi-pencil';
              this.title = 'Edit value';
            }
          });
        });
      } else {
        tableEl.innerHTML = '<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle me-2"></i>' +
          'Could not extract readable text. Please ensure the image is clear, well-lit, and not blurred, then try again.</div>';
      }

      new bootstrap.Modal(document.getElementById('docInfoModal')).show();
    }

    var importBtn = document.getElementById('import_to_form_btn');
    if (importBtn) {
      importBtn.addEventListener('click', function() {
        document.querySelectorAll('.import-field-check:checked').forEach(function(cb) {
          var field = cb.dataset.field;
          var row = cb.closest('tr');
          var valInput = row ? row.querySelector('.extracted-val-input') : null;
          var valDisplay = row ? row.querySelector('.extracted-val-display') : null;
          var value = valInput ? valInput.value.trim() : (valDisplay ? valDisplay.textContent.trim() : extractedData[field]);
          if (!value) return;

          switch(field) {
            case 'first_name':     setDocVal('#individual_first_name', value); break;
            case 'middle_name':    setDocVal('[name="customer[middle_name]"]', value); break;
            case 'last_name':      setDocVal('#individual_last_name', value); break;
            case 'pan_no':         setDocVal('[name="customer[pan_no]"]', value); break;
            case 'aadhaar_number': setDocVal('[name="customer[aadhaar_no]"]', value); break;
            case 'phone':          setDocVal('#individual_mobile', value); break;
            case 'address':        setDocVal('[name="customer[address]"]', value); break;
            case 'pincode':        setDocVal('[name="customer[pincode]"]', value); break;
            case 'gender':         setDocVal('[name="customer[gender]"]', value); break;
            case 'dob':
              var parts = value.split(/[\/\-]/);
              if (parts.length === 3) {
                var yr, mo, dy;
                if (parts[2].length === 4) { dy = parts[0]; mo = parts[1]; yr = parts[2]; }
                else { yr = parts[0]; mo = parts[1]; dy = parts[2]; }
                setDocVal('[name="customer[birth_date]"]', yr + '-' + mo.padStart(2,'0') + '-' + dy.padStart(2,'0'));
              }
              break;
            case 'state':
              // Find city value from modal (may have been edited)
              var pendingCity = null;
              var cityRow = document.querySelector('.import-field-check[data-field="city"]');
              if (cityRow && cityRow.checked) {
                var cityRowTr = cityRow.closest('tr');
                var cityValIn = cityRowTr ? cityRowTr.querySelector('.extracted-val-input') : null;
                var cityValDi = cityRowTr ? cityRowTr.querySelector('.extracted-val-display') : null;
                pendingCity = cityValIn ? cityValIn.value.trim() : (cityValDi ? cityValDi.textContent.trim() : null);
              }
              ['#customer_state_individual', '#customer_state_corporate'].forEach(function(sel) {
                var stateEl = document.querySelector(sel);
                if (!stateEl) return;
                for (var i = 0; i < stateEl.options.length; i++) {
                  var opt = stateEl.options[i];
                  if (opt.text.toLowerCase() === value.toLowerCase() || opt.value.toLowerCase() === value.toLowerCase()) {
                    stateEl.value = opt.value;
                    if (typeof $ !== 'undefined') $(stateEl).trigger('change');
                    // Load cities and pre-select city if available
                    var citySelId = sel.indexOf('individual') !== -1 ? '#customer_city_individual' : '#customer_city_corporate';
                    var cityEl = document.querySelector(citySelId);
                    if (typeof loadCitiesForState !== 'undefined' && cityEl) {
                      loadCitiesForState(opt.value, cityEl, pendingCity);
                    }
                    break;
                  }
                }
              });
              break;
            case 'city':
              // Best-effort direct set; usually handled via loadCitiesForState in state case
              ['#customer_city_individual', '#customer_city_corporate'].forEach(function(sel) {
                var cityEl = document.querySelector(sel);
                if (!cityEl) return;
                for (var i = 0; i < cityEl.options.length; i++) {
                  if (cityEl.options[i].text.toLowerCase() === value.toLowerCase()) {
                    cityEl.value = cityEl.options[i].value;
                    if (typeof $ !== 'undefined') $(cityEl).trigger('change');
                    break;
                  }
                }
              });
              break;
            case 'bank_name':   setDocVal('#customer_bank_name_individual', value); break;
            case 'account_no':  setDocVal('#customer_account_no_individual', value); break;
            case 'ifsc_code':   setDocVal('#customer_ifsc_code_individual', value); break;
          }
        });

        var bsModal = bootstrap.Modal.getInstance(document.getElementById('docInfoModal'));
        if (bsModal) bsModal.hide();

        var toast = document.createElement('div');
        toast.className = 'alert alert-success alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';
        toast.style.zIndex = '99999';
        toast.innerHTML = '<i class="bi bi-check2-circle me-2"></i><strong>Imported!</strong> Customer details auto-filled from document.' +
          '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
        document.body.appendChild(toast);
        setTimeout(function() { if (toast.parentNode) toast.remove(); }, 4000);

        document.getElementById('individual_sections').scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    function setDocVal(selector, value) {
      var el = document.querySelector(selector);
      if (el) {
        el.value = value;
        el.dispatchEvent(new Event('input', { bubbles: true }));
        el.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }
  })();
  // ===== END DOCUMENT OCR QUICK IMPORT =====

  // Add mobile validation to both individual and corporate mobile fields
  document.addEventListener('DOMContentLoaded', function() {
    const individualMobile = document.getElementById('individual_mobile');
    const corporateMobile = document.getElementById('corporate_mobile');

    if (individualMobile) {
      individualMobile.addEventListener('input', function() {
        validateMobileNumber(this);
      });

      individualMobile.addEventListener('blur', function() {
        validateMobileNumber(this);
      });
    }

    if (corporateMobile) {
      corporateMobile.addEventListener('input', function() {
        validateMobileNumber(this);
      });

      corporateMobile.addEventListener('blur', function() {
        validateMobileNumber(this);
      });
    }
  });
});
</script>