  // Mobile Number Validation for Indian Numbers (7, 8, 9 starting digits)
  function validateMobileNumber(input) {
    const mobilePattern = /^[6789]\d{9}$/;
    let value = input.value.replace(/\D/g, ''); // Remove non-digits

    // Handle +91 country code prefix
    if (value.length === 12 && value.startsWith('91')) {
      value = value.substring(2); // Remove '91' prefix
    } else if (value.length === 13 && value.startsWith('91')) {
      value = value.substring(2); // Remove '91' prefix
    } else if (value.length === 11 && value.startsWith('0')) {
      value = value.substring(1); // Remove leading '0'
    } else if (value.length === 11 && !value.startsWith('0')) {
      value = value.substring(1); // Remove first digit if 11 digits and doesn't start with 0
    }

    // Auto-format the input to only contain the final 10 digits
    input.value = value;

    // Clear previous validation state
    input.classList.remove('is-valid', 'is-invalid');
    const feedback = input.parentNode.querySelector('.mobile-feedback');
    if (feedback) feedback.remove();

    if (value.length === 0) {
      return; // Don't validate empty input
    }

    if (value.length !== 10) {
      showMobileError(input, 'Mobile number must be exactly 10 digits (you entered ' + value.length + ')');
    } else if (!mobilePattern.test(value)) {
      showMobileError(input, 'Mobile number must start with 6, 7, 8, or 9');
    } else {
      input.classList.add('is-valid');
    }
  }

  function showMobileError(input, message) {
    input.classList.add('is-invalid');
    const errorDiv = document.createElement('div');
    errorDiv.className = 'invalid-feedback mobile-feedback';
    errorDiv.textContent = message;
    input.parentNode.appendChild(errorDiv);
  }

