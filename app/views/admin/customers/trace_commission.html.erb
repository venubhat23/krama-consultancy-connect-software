<script>
function showCommissionBreakdown(policyNumber, policyType, payoutsJson) {
  console.log('🔍 Opening commission breakdown modal for policy:', policyNumber);

  try {
    // Parse the payouts JSON data
    const payouts = JSON.parse(payoutsJson);
    console.log('📊 Payouts data:', payouts);

    // Set modal title and policy information
    document.getElementById('modalPolicyNumber').textContent = policyNumber;
    document.getElementById('modalPolicyType').textContent = policyType.charAt(0).toUpperCase() + policyType.slice(1) + ' Insurance';

    // Calculate totals
    const totalBreakdownCount = payouts.length;
    const mainAgentPayout = payouts.find(p => p.payout_to === 'main_agent');
    const mainAgentAmount = mainAgentPayout ? parseFloat(mainAgentPayout.payout_amount || 0) : 0;

    // Update summary statistics
    document.getElementById('totalBreakdownCount').textContent = totalBreakdownCount;
    document.getElementById('totalCommissionSum').textContent = 'Rs. ' + mainAgentAmount.toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2});

    // Check if all payouts are paid
    const allPaid = payouts.every(payout => payout.status === 'paid');
    const allPending = payouts.every(payout => payout.status === 'pending');

    let statusBadge;
    if (allPaid) {
      statusBadge = '<span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>All Paid</span>';
    } else if (allPending) {
      statusBadge = '<span class="badge bg-warning"><i class="bi bi-clock me-1"></i>All Pending</span>';
    } else {
      statusBadge = '<span class="badge bg-info"><i class="bi bi-hourglass-split me-1"></i>Mixed</span>';
    }
    document.getElementById('breakdownStatus').innerHTML = statusBadge;

    // Generate breakdown content
    let breakdownHtml = '';

    if (payouts.length === 0) {
      breakdownHtml = `
        <div class="text-center py-5">
          <i class="bi bi-info-circle text-muted" style="font-size: 4rem;"></i>
          <h5 class="mt-3 text-muted">No Commission Breakdown Found</h5>
          <p class="text-muted">No commission payouts found for this policy.</p>
        </div>
      `;
    } else {
      breakdownHtml = '<div class="row">';

      payouts.forEach((payout, index) => {
        const statusClass = payout.status === 'paid' ? 'success' : (payout.status === 'pending' ? 'warning' : 'secondary');
        const statusIcon = payout.status === 'paid' ? 'bi-check-circle' : (payout.status === 'pending' ? 'bi-clock' : 'bi-question-circle');

        // Determine the color scheme based on payout_to
        let colorScheme = 'primary';
        let iconClass = 'bi-person';

        switch (payout.payout_to) {
          case 'main_agent':
            colorScheme = 'primary';
            iconClass = 'bi-person-badge';
            break;
          case 'sub_agent':
          case 'affiliate':
            colorScheme = 'success';
            iconClass = 'bi-people';
            break;
          case 'ambassador':
            colorScheme = 'warning';
            iconClass = 'bi-award';
            break;
          case 'investor':
            colorScheme = 'purple';
            iconClass = 'bi-bank';
            break;
          case 'company_expenses':
            colorScheme = 'danger';
            iconClass = 'bi-building';
            break;
          default:
            colorScheme = 'secondary';
            iconClass = 'bi-question';
        }

        breakdownHtml += `
          <div class="col-md-6 mb-3">
            <div class="card h-100 border-${colorScheme} commission-breakdown-card">
              <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                  <div class="commission-icon bg-${colorScheme} bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                    <i class="${iconClass} text-${colorScheme} fs-4"></i>
                  </div>
                  <div class="flex-grow-1">
                    <h6 class="mb-0 text-${colorScheme} fw-bold">${payout.payout_to.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}</h6>
                    <small class="text-muted fw-semibold">${payout.recipient_name || 'Commission Recipient'}</small>
                  </div>
                </div>

                <div class="commission-details">
                  <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="text-muted small">Gross Commission:</span>
                    <span class="fw-semibold">Rs. ${parseFloat(payout.gross_amount || 0).toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2})}</span>
                  </div>

                  ${payout.tds_pct > 0 ? `
                  <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="text-muted small">TDS (${payout.tds_pct}%):</span>
                    <span class="text-danger small">- Rs. ${parseFloat(payout.tds_amt || 0).toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2})}</span>
                  </div>
                  ` : ''}

                  <div class="d-flex justify-content-between align-items-center mb-2 pt-1 border-top">
                    <span class="text-muted small fw-semibold">Net Payable:</span>
                    <span class="fw-bold text-${colorScheme} fs-6">Rs. ${parseFloat(payout.payout_amount || 0).toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2})}</span>
                  </div>

                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted small">Status:</span>
                    <span class="badge bg-${statusClass}">
                      <i class="${statusIcon} me-1"></i>${payout.status ? payout.status.charAt(0).toUpperCase() + payout.status.slice(1) : 'Unknown'}
                    </span>
                  </div>

                  <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted small">Paid Date:</span>
                    <span class="text-dark small">${payout.payout_date ? new Date(payout.payout_date).toLocaleDateString('en-IN') : 'Pending'}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        `;
      });

      breakdownHtml += '</div>';
    }

    // Set the content
    document.getElementById('commissionBreakdownContent').innerHTML = breakdownHtml;

    // Show the modal
    const modalElement = document.getElementById('commissionBreakdownModal');
    const modal = new bootstrap.Modal(modalElement, {
      backdrop: true,
      keyboard: true,
      focus: true
    });

    modal.show();
    console.log('✅ Commission breakdown modal shown successfully');

  } catch (error) {
    console.error('❌ Error in showCommissionBreakdown:', error);
    alert('Error opening commission breakdown: ' + error.message);
  }
}

function showInsurancePolicies(customerId, type, insuranceType) {
  // Open the modal
  const modal = document.getElementById('insurancePoliciesModal');

  // Move modal to document body for proper z-index handling
  if (modal.parentNode !== document.body) {
    document.body.appendChild(modal);
  }

  // Apply aggressive modal styling
  modal.style.cssText = `
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    z-index: 9999 !important;
    width: 100% !important;
    height: 100% !important;
    outline: 0 !important;
    display: block !important;
  `;

  const modalDialog = modal.querySelector('.modal-dialog');
  if (modalDialog) {
    modalDialog.style.cssText = `
      z-index: 10000 !important;
      position: relative !important;
      margin: 1.75rem auto !important;
      pointer-events: none !important;
      transform: none !important;
    `;
  }

  const modalContent = modal.querySelector('.modal-content');
  if (modalContent) {
    modalContent.style.cssText = `
      z-index: 10001 !important;
      position: relative !important;
      background-color: white !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      box-shadow: 0 0.25rem 0.5rem rgba(0, 0, 0, 0.8) !important;
    `;
  }

  // Create and show modal instance
  const modalInstance = new bootstrap.Modal(modal, {
    backdrop: true,
    keyboard: true,
    focus: true
  });

  modalInstance.show();

  // Force backdrop positioning after show
  setTimeout(() => {
    const backdrop = document.querySelector('.modal-backdrop');
    if (backdrop) {
      backdrop.style.cssText = `
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        z-index: 9998 !important;
        width: 100% !important;
        height: 100% !important;
        background-color: rgba(0, 0, 0, 0.6) !important;
        opacity: 1 !important;
      `;
    }

    document.body.classList.add('modal-open');
    document.body.style.overflow = 'hidden';
  }, 100);

  // Update modal title
  const titleType = type === 'drwise' ? 'DrWise' : 'Non-DrWise';
  const insuranceTypeTitle = insuranceType.charAt(0).toUpperCase() + insuranceType.slice(1) + ' Insurance';
  const modalTitle = document.getElementById('insurancePoliciesModalLabel');
  const icon = getInsuranceIcon(insuranceType);

  modalTitle.innerHTML = `
    <i class="${icon} text-primary me-2"></i>
    ${titleType} ${insuranceTypeTitle} Policies - <span id="modalCustomerName"><%= @customer.display_name %></span>
  `;

  // Fetch and display insurance policies
  fetchInsurancePolicies(customerId, type, insuranceType);
}

function fetchInsurancePolicies(customerId, type, insuranceType) {
  const contentDiv = document.getElementById('insurancePoliciesContent');

  // Show loading state
  contentDiv.innerHTML = `
    <div class="text-center py-4">
      <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
      </div>
      <p class="mt-3 text-muted">Loading ${insuranceType} insurance policies...</p>
    </div>
  `;

  // Fetch policies with updated endpoint
  fetch(`/admin/customers/${customerId}/trace_commission?type=${type}&insurance_type=${insuranceType}`, {
    method: 'GET',
    headers: {
      'Content-Type': 'application/json',
      'Accept': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
    }
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      displayInsurancePolicies(data.policies, type, insuranceType);
    } else {
      showErrorMessage(`Failed to load ${insuranceType} insurance policies: ${data.error}`);
    }
  })
  .catch(error => {
    console.error('Error:', error);
    showErrorMessage(`Error loading ${insuranceType} insurance policies: ${error.message}`);
  });
}

function displayInsurancePolicies(policies, type, insuranceType) {
  const contentDiv = document.getElementById('insurancePoliciesContent');

  if (policies.length === 0) {
    const icon = getInsuranceIcon(insuranceType);
    const insuranceTitle = insuranceType.charAt(0).toUpperCase() + insuranceType.slice(1) + ' Insurance';

    contentDiv.innerHTML = `
      <div class="text-center py-5">
        <i class="${icon} text-muted" style="font-size: 4rem;"></i>
        <h5 class="mt-3 text-muted">No ${insuranceTitle} Policies Found</h5>
        <p class="text-muted">This customer doesn't have any ${type === 'drwise' ? 'DrWise' : 'Non-DrWise'} ${insuranceType} insurance policies yet.</p>
      </div>
    `;
    return;
  }

  const insuranceTitle = insuranceType.charAt(0).toUpperCase() + insuranceType.slice(1) + ' Insurance';
  let policiesHtml = `
    <div class="row mb-3">
      <div class="col-12">
        <h6 class="text-muted mb-3">
          <i class="bi bi-info-circle me-1"></i>
          Found ${policies.length} ${type === 'drwise' ? 'DrWise' : 'Non-DrWise'} ${insuranceType} insurance ${policies.length === 1 ? 'policy' : 'policies'}
        </h6>
      </div>
    </div>
  `;

  policies.forEach(policy => {
    const statusClass = getStatusClass(policy.status);
    const icon = getInsuranceIcon(insuranceType);

    policiesHtml += `
      <div class="motor-policy-card mb-4">
        <div class="policy-header">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <h6 class="mb-1 fw-bold">
                <i class="${icon} me-2 text-primary"></i>
                ${policy.policy_number || `Policy #${policy.id}`}
              </h6>
              <p class="text-muted mb-0">${getPolicyDescription(policy, insuranceType)}</p>
            </div>
            <div class="text-end">
              <span class="policy-status-badge bg-${statusClass}">${policy.status || 'Active'}</span>
              ${type === 'drwise' ? '<span class="badge bg-success ms-2">DrWise</span>' : '<span class="badge bg-warning ms-2">Non-DrWise</span>'}
            </div>
          </div>
        </div>

        <div class="policy-details-grid">
          <div class="detail-item">
            <div class="detail-label">Insurance Company</div>
            <div class="detail-value">${policy.insurance_company || 'N/A'}</div>
          </div>
          <div class="detail-item">
            <div class="detail-label">Policy Type</div>
            <div class="detail-value">${policy.policy_type || 'N/A'}</div>
          </div>
          <div class="detail-item">
            <div class="detail-label">Premium Amount</div>
            <div class="detail-value text-success">Rs. ${formatCurrency(policy.premium_amount || 0)}</div>
          </div>
          <div class="detail-item">
            <div class="detail-label">Policy Period</div>
            <div class="detail-value">${formatDate(policy.policy_start_date)} - ${formatDate(policy.policy_end_date)}</div>
          </div>
          ${getAdditionalPolicyDetails(policy, insuranceType)}
        </div>

        <div class="policy-actions mt-3">
          <div class="d-flex justify-content-center">
            <button class="btn btn-sm btn-primary" onclick="viewPolicyDetails('${insuranceType}', ${policy.id})">
              <i class="bi bi-eye me-1"></i>View Details
            </button>
          </div>
        </div>
      </div>
    `;
  });

  contentDiv.innerHTML = policiesHtml;
}

function getStatusClass(status) {
  switch(status) {
    case 'Active': return 'success';
    case 'Expired': return 'danger';
    case 'Expiring Soon': return 'warning';
    default: return 'secondary';
  }
}

function getInsuranceIcon(insuranceType) {
  switch(insuranceType) {
    case 'motor': return 'bi-car-front-fill';
    case 'motorinsurance': return 'bi-car-front-fill';
    case 'life': return 'bi-heart-pulse-fill';
    case 'lifeinsurance': return 'bi-heart-pulse-fill';
    case 'health': return 'bi-activity';
    case 'healthinsurance': return 'bi-activity';
    default: return 'bi-shield-check';
  }
}

function getPolicyDescription(policy, insuranceType) {
  switch(insuranceType) {
    case 'motor':
    case 'motorinsurance':
      return policy.vehicle_details || 'Vehicle details not available';
    case 'life':
    case 'lifeinsurance':
      return policy.policy_details || 'Life insurance policy';
    case 'health':
    case 'healthinsurance':
      return policy.policy_details || 'Health insurance policy';
    default:
      return 'Insurance policy details';
  }
}

function getAdditionalPolicyDetails(policy, insuranceType) {
  switch(insuranceType) {
    case 'motor':
    case 'motorinsurance':
      return `
        <div class="detail-item">
          <div class="detail-label">Vehicle Info</div>
          <div class="detail-value">${policy.additional_info?.vehicle_type || 'N/A'}</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">IDV Amount</div>
          <div class="detail-value text-info">Rs. ${formatCurrency(policy.additional_info?.idv_value || 0)}</div>
        </div>
      `;
    case 'life':
    case 'lifeinsurance':
      return `
        <div class="detail-item">
          <div class="detail-label">Sum Assured</div>
          <div class="detail-value text-info">Rs. ${formatCurrency(policy.additional_info?.sum_insured || 0)}</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Payment Mode</div>
          <div class="detail-value">${policy.additional_info?.payment_mode || 'N/A'}</div>
        </div>
      `;
    case 'health':
    case 'healthinsurance':
      return `
        <div class="detail-item">
          <div class="detail-label">Sum Insured</div>
          <div class="detail-value text-info">Rs. ${formatCurrency(policy.additional_info?.sum_insured || 0)}</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Payment Mode</div>
          <div class="detail-value">${policy.additional_info?.payment_mode || 'N/A'}</div>
        </div>
      `;
    default:
      return '';
  }
}

function formatCurrency(amount) {
  return new Intl.NumberFormat('en-IN').format(amount);
}

function formatDate(dateString) {
  if (!dateString) return 'N/A';
  return new Date(dateString).toLocaleDateString('en-IN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}

function showErrorMessage(message) {
  document.getElementById('insurancePoliciesContent').innerHTML = `
    <div class="alert alert-danger" role="alert">
      <i class="bi bi-exclamation-triangle me-2"></i>
      ${message}
    </div>
  `;
}

function viewPolicyDetails(insuranceType, policyId) {
  const basePath = getInsuranceBasePath(insuranceType);
  window.location.href = `/admin/${basePath}/${policyId}`;
}

function editPolicy(insuranceType, policyId) {
  const basePath = getInsuranceBasePath(insuranceType);
  window.location.href = `/admin/${basePath}/${policyId}/edit`;
}

function renewPolicy(insuranceType, policyId) {
  const basePath = getInsuranceBasePath(insuranceType);
  window.location.href = `/admin/${basePath}/${policyId}/renew`;
}

function removePolicy(insuranceType, policyId) {
  const basePath = getInsuranceBasePath(insuranceType);

  // Show confirmation dialog
  if (confirm('Are you sure you want to remove this policy? This action cannot be undone.')) {
    // Send DELETE request
    fetch(`/admin/${basePath}/${policyId}`, {
      method: 'DELETE',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      }
    })
    .then(response => {
      if (response.ok) {
        // Show success message
        alert('Policy removed successfully!');
        // Reload the modal or redirect to refresh the data
        location.reload();
      } else {
        throw new Error('Failed to remove policy');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Failed to remove policy. Please try again.');
    });
  }
}

function getInsuranceBasePath(insuranceType) {
  switch(insuranceType) {
    case 'motor':
    case 'motorinsurance':
      return 'insurance/motor';
    case 'life':
    case 'lifeinsurance':
      return 'insurance/life';
    case 'health':
    case 'healthinsurance':
      return 'insurance/health';
    default:
      return 'insurances';
  }
}
</script>