          <div class="col-4">
            <div class="metric-item">
              <h4 class="mb-1 text-warning"><%= indian_currency(@non_drwise_summary[:total_premium]) %></h4>
              <small class="text-muted">Premium</small>
            </div>
          </div>
          <div class="col-4">
            <div class="metric-item">
              <h4 class="mb-1 text-warning"><%= @non_drwise_summary[:opted_count] %></h4>
