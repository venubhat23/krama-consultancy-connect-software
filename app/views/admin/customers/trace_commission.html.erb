<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-transparent border-0">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Comprehensive Product Matrix</h5>
      <small class="text-muted">Complete portfolio overview Dr WISE all 17 product categories</small>
    </div>
  </div>
  <div class="card-body">
    <!-- Coverage Overview Chart -->
    <div class="row mb-5">
      <div class="col-md-6">
        <div class="coverage-chart-container">
          <canvas id="coverageChart" width="300" height="300"></canvas>
          <div class="chart-center-text">
            <div class="center-score">
              <span class="score-number"><%= @commission_summary[:opted_count] %></span>
              <span class="score-total">/<%= @commission_summary[:total_products] %></span>
            </div>
            <div class="score-label">Products</div>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="coverage-details">
          <h6 class="mb-3">Coverage Analysis</h6>
          <div class="coverage-metrics">
            <div class="metric-item mb-3">
              <div class="d-flex justify-content-between align-items-center">
                <span class="metric-label">Coverage Percentage</span>
                <span class="metric-value text-primary"><%= @commission_summary[:coverage_percentage] %>%</span>
              </div>
              <div class="progress mt-2" style="height: 8px;">
                <div class="progress-bar bg-primary" style="width: <%= @commission_summary[:coverage_percentage] %>%"></div>
              </div>
            </div>

            <div class="metric-item mb-3">
              <div class="d-flex justify-content-between align-items-center">
                <span class="metric-label">Total Investment</span>
                <span class="metric-value text-success"><%= indian_currency(@commission_summary[:total_premium]) %></span>
              </div>
            </div>

            <div class="metric-item">
              <div class="d-flex justify-content-between align-items-center">
                <span class="metric-label">Commission Status</span>
                <span class="badge bg-<%= @commission_payouts.where(status: 'paid').any? ? 'success' : 'warning' %>">
                  <%= @commission_payouts.where(status: 'paid').any? ? 'Payments Made' : 'Pending' %>
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Comprehensive Product Matrix Table - Side by Side Layout -->
    <div class="table-responsive product-matrix-side-by-side-container">
      <%
        product_categories = [
          {
            name: 'Insurance Products',
            icon: 'bi-shield-check',
            products: [
              { name: 'Life Insurance', icon: 'bi-heart-pulse', key: 'Life Insurance' },
              { name: 'Health Insurance', icon: 'bi-activity', key: 'Health Insurance' },
              { name: 'Motor Insurance', icon: 'bi-car-front', key: 'Motor Insurance' }
            ]
          },
          {
            name: 'Investment Products',
            icon: 'bi-graph-up',
            products: [
              { name: 'Mutual Fund', icon: 'bi-pie-chart', key: 'Mutual Fund' },
              { name: 'Gold', icon: 'bi-coin', key: 'Gold' },
              { name: 'NPS', icon: 'bi-building', key: 'NPS' },
              { name: 'Bonds', icon: 'bi-receipt', key: 'Bonds' }
            ]
          },
          {
            name: 'Loan Products',
            icon: 'bi-bank',
            products: [
              { name: 'Personal Loan', icon: 'bi-person', key: 'Personal Loan' },
              { name: 'Home Loan', icon: 'bi-house', key: 'Home Loan' },
              { name: 'Business Loan', icon: 'bi-briefcase', key: 'Business Loan' }
            ]
          },
          {
            name: 'Taxation Services',
            icon: 'bi-calculator',
            products: [
              { name: 'Income Tax Return (ITR)', icon: 'bi-file-earmark-text', key: 'ITR' }
            ]
          },
          {
            name: 'Travel Services',
            icon: 'bi-airplane',
            products: [
              { name: 'Domestic Travel', icon: 'bi-geo', key: 'Domestic Travel' },
              { name: 'International Travel', icon: 'bi-globe', key: 'International Travel' }
            ]
          }
        ]
      %>

      <% product_categories.each do |category| %>
        <div class="product-category-section mb-5">
          <div class="category-header-section">
            <h4 class="category-title">
              <i class="<%= category[:icon] %> me-2"></i>
              <%= category[:name] %>
            </h4>
          </div>

          <table class="table table-bordered product-comparison-table">
            <thead class="table-dark">
              <tr>
                <th style="width: 20%;">Product Type</th>
                <th style="width: 8%;" class="text-center">DrWise Status</th>
                <th style="width: 10%;" class="text-center">DrWise Policies</th>
                <th style="width: 22%;">DrWise Coverage Details</th>
                <th style="width: 8%;" class="text-center">NonDrWise Status</th>
                <th style="width: 10%;" class="text-center">NonDrWise Policies</th>
                <th style="width: 22%;">NonDrWise Coverage Details</th>
              </tr>
            </thead>
            <tbody>
              <% category[:products].each do |product| %>
                <%
                  drwise_data = @drwise_policy_status[product[:key]] || @drwise_product_status[product[:key]]
                  non_drwise_data = @non_drwise_policy_status[product[:key]] || @non_drwise_product_status[product[:key]]
                  drwise_opted = drwise_data && drwise_data[:opted]
                  non_drwise_opted = non_drwise_data && non_drwise_data[:opted]
                %>
                <tr class="product-comparison-row">
                  <td>
                    <div class="d-flex align-items-center">
                      <i class="<%= product[:icon] %> me-2 text-primary"></i>
                      <span class="fw-medium"><%= product[:name] %></span>
                    </div>
                  </td>

                  <!-- DrWise Status -->
                  <td class="text-center">
                    <% if drwise_opted %>
                      <span class="badge bg-success">
                        <i class="bi bi-check-circle me-1"></i>Yes
                      </span>
                    <% else %>
                      <span class="badge bg-secondary">
                        <i class="bi bi-x-circle me-1"></i>No
                      </span>
                    <% end %>
                  </td>

                  <!-- DrWise Policies Count -->
                  <td class="text-center">
                    <% if drwise_opted && drwise_data %>
                      <% count_label = category[:name].include?('Insurance') ? 'policies' : (category[:name].include?('Investment') ? 'investments' : (category[:name].include?('Loan') ? 'loans' : (category[:name].include?('Taxation') ? 'services' : 'packages'))) %>
                      <span class="badge bg-success"><%= drwise_data[:count] %> <%= count_label %></span>
                    <% else %>
                      <span class="text-muted">-</span>
                    <% end %>
                  </td>

                  <!-- DrWise Coverage Details -->
                  <td>
                    <% if drwise_opted && drwise_data %>
                      <% if category[:name].include?('Insurance') %>
                        <div class="small">
                          <div class="text-success mb-1">
                            <i class="bi bi-currency-rupee me-1"></i>
                            Total Premium: <%= indian_currency(drwise_data[:total_premium] || 0) %>
                          </div>
                          <% if drwise_data[:latest_policy] %>
                            <div class="text-muted mb-2">
                              <i class="bi bi-clock me-1"></i>
                              Latest: <%= drwise_data[:latest_policy].created_at.strftime('%b %d, %Y') %>
                            </div>
                          <% end %>
                          <% if ['Motor Insurance', 'Life Insurance', 'Health Insurance'].include?(product[:name]) %>
                            <button class="btn btn-sm btn-success mt-1" onclick="showInsurancePolicies('<%= @customer.id %>', 'drwise', '<%= product[:name].downcase.gsub(' ', '') %>')">
                              <i class="bi bi-eye me-1"></i>View Policies
                            </button>
                          <% end %>
                        </div>
                      <% else %>
                        <span class="text-muted">Product not yet implemented</span>
                      <% end %>
                    <% else %>
                      <span class="text-muted">No DrWise policies found</span>
                    <% end %>
                  </td>

                  <!-- NonDrWise Status -->
                  <td class="text-center">
                    <% if non_drwise_opted %>
                      <span class="badge bg-success">
                        <i class="bi bi-check-circle me-1"></i>Yes
                      </span>
                    <% else %>
                      <span class="badge bg-secondary">
                        <i class="bi bi-x-circle me-1"></i>No
                      </span>
                    <% end %>
                  </td>

                  <!-- NonDrWise Policies Count -->
                  <td class="text-center">
                    <% if non_drwise_opted && non_drwise_data %>
                      <% count_label = category[:name].include?('Insurance') ? 'policies' : (category[:name].include?('Investment') ? 'investments' : (category[:name].include?('Loan') ? 'loans' : (category[:name].include?('Taxation') ? 'services' : 'packages'))) %>
                      <span class="badge bg-warning"><%= non_drwise_data[:count] %> <%= count_label %></span>
                    <% else %>
                      <span class="text-muted">-</span>
                    <% end %>
                  </td>

                  <!-- NonDrWise Coverage Details -->
                  <td>
                    <% if non_drwise_opted && non_drwise_data %>
                      <% if category[:name].include?('Insurance') %>
                        <div class="small">
                          <div class="text-success mb-1">
                            <i class="bi bi-currency-rupee me-1"></i>
                            Total Premium: <%= indian_currency(non_drwise_data[:total_premium] || 0) %>
                          </div>
                          <% if non_drwise_data[:latest_policy] %>
                            <div class="text-muted mb-2">
                              <i class="bi bi-clock me-1"></i>
                              Latest: <%= non_drwise_data[:latest_policy].created_at.strftime('%b %d, %Y') %>
                            </div>
                          <% end %>
                          <% if ['Motor Insurance', 'Life Insurance', 'Health Insurance'].include?(product[:name]) %>
                            <button class="btn btn-sm btn-warning mt-1" onclick="showInsurancePolicies('<%= @customer.id %>', 'non-drwise', '<%= product[:name].downcase.gsub(' ', '') %>')">
                              <i class="bi bi-eye me-1"></i>View Policies
                            </button>
                          <% end %>
                        </div>
                      <% else %>
                        <span class="text-muted">Product not yet implemented</span>
                      <% end %>
                    <% else %>
                      <span class="text-muted">No Non-DrWise policies found</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>
</div>


<!-- Policy Details Cards -->
<div class="row mb-4">
  <% @policy_status.each_with_index do |(policy_type, data), index| %>
    <div class="col-lg-4 mb-3">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-header bg-transparent border-0">
          <div class="d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold">
              <i class="<%= data[:icon] %> text-<%= data[:color] %> me-2"></i>
              <%= policy_type %>
            </h6>
            <span class="badge bg-<%= data[:opted] ? 'success' : 'secondary' %>">
              <%= data[:opted] ? 'OPTED' : 'NOT OPTED' %>
            </span>
          </div>
        </div>
        <div class="card-body">
          <% if data[:opted] %>
            <div class="row g-3">
              <div class="col-6">
                <div class="stat-card">
                  <h4 class="text-primary mb-1"><%= data[:count] %></h4>
                  <small class="text-muted">Policies</small>
                </div>
              </div>
              <div class="col-6">
                <div class="stat-card">
                  <h4 class="text-success mb-1"><%= indian_currency(data[:total_premium]) %></h4>
                  <small class="text-muted">Premium</small>
                </div>
              </div>
              <% if data[:latest_policy] %>
                <div class="col-12">
                  <div class="latest-policy bg-light rounded p-3">
                    <h6 class="text-muted mb-2">Latest Policy:</h6>
                    <div class="d-flex justify-content-between">
                      <span class="fw-bold"><%= data[:latest_policy].policy_number || "Policy ##{data[:latest_policy].id}" %></span>
                      <small class="text-muted"><%= data[:latest_policy].created_at.strftime('%b %d, %Y') %></small>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-4">
              <i class="bi bi-plus-circle text-muted" style="font-size: 3rem;"></i>
              <h6 class="text-muted mt-3">No policies found</h6>
              <small class="text-muted">Customer has not opted for this policy type</small>
              <div class="mt-3">
                <% case policy_type %>
                <% when 'Health Insurance' %>
                  <%= link_to new_admin_health_insurance_path(customer_id: @customer.id), class: "btn btn-sm btn-success" do %>
                    <i class="bi bi-plus me-1"></i>Add Health Policy
                  <% end %>
                <% when 'Life Insurance' %>
                  <%= link_to new_admin_life_insurance_path(customer_id: @customer.id), class: "btn btn-sm btn-primary" do %>
                    <i class="bi bi-plus me-1"></i>Add Life Policy
                  <% end %>
                <% when 'Motor Insurance' %>
                  <%= link_to new_admin_motor_insurance_path(customer_id: @customer.id), class: "btn btn-sm btn-warning" do %>
                    <i class="bi bi-plus me-1"></i>Add Motor Policy
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Commission Payouts Table -->
<% if @commission_payouts.any? %>
  <%
    # Group payouts by policy number
    grouped_payouts = @commission_payouts.group_by { |p| p.policy_number || "Policy ##{p.policy_id}" }
  %>
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent border-0">
      <h5 class="mb-0">Commission Payouts</h5>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light">
            <tr>
              <th class="border-0">Policy</th>
              <th class="border-0">Type</th>
              <th class="border-0">Commission Breakdown</th>
              <th class="border-0">Total Amount</th>
              <th class="border-0">Status</th>
              <th class="border-0">Date</th>
            </tr>
          </thead>
          <tbody>
            <% grouped_payouts.each do |policy_number, payouts| %>
              <% first_payout = payouts.first %>
              <%
                # Fetch insurance policy — source of truth for commission amounts
                _policy_rec = case first_payout.policy_type
                              when 'motor'  then MotorInsurance.find_by(id: first_payout.policy_id)
                              when 'life'   then LifeInsurance.find_by(id: first_payout.policy_id)
                              when 'health' then HealthInsurance.find_by(id: first_payout.policy_id)
                              when 'other'  then OtherInsurance.find_by(id: first_payout.policy_id)
                              end

                # Resolve actual recipient names once (outside the map)
                _sub_agent   = _policy_rec&.sub_agent
                _distributor = _policy_rec.respond_to?(:distributor) ? _policy_rec.distributor : nil

                _corrected = payouts.map do |p|
                  if _policy_rec
                    case p.payout_to
                    when 'main_agent'
                      gross      = _policy_rec.try(:commission_amount).to_f
                      tds_pct    = _policy_rec.try(:tds_percentage).to_f || _policy_rec.try(:main_agent_tds_percent).to_f
                      tds_amt    = _policy_rec.try(:tds_amount).to_f || _policy_rec.try(:main_agent_tds_amount).to_f
                      actual     = _policy_rec.try(:after_tds_value).to_f
                      actual     = (gross - tds_amt).round(2) if actual.zero? && gross > 0
                    when 'affiliate'
                      gross      = _policy_rec.try(:sub_agent_commission_amount).to_f
                      tds_pct    = _policy_rec.try(:sub_agent_tds_percentage).to_f
                      tds_amt    = _policy_rec.try(:sub_agent_tds_amount).to_f
                      actual     = _policy_rec.try(:sub_agent_after_tds_value).to_f
                      actual     = (gross - tds_amt).round(2) if actual.zero? && gross > 0
                    when 'ambassador'
                      gross      = _policy_rec.try(:ambassador_commission_amount).to_f
                      tds_pct    = _policy_rec.try(:ambassador_tds_percentage).to_f
                      tds_amt    = _policy_rec.try(:ambassador_tds_amount).to_f
                      actual     = _policy_rec.try(:ambassador_after_tds_value).to_f
                      actual     = (gross - tds_amt).round(2) if actual.zero? && gross > 0
                    when 'investor'
                      gross      = _policy_rec.try(:investor_commission_amount).to_f
                      tds_pct    = _policy_rec.try(:investor_tds_percentage).to_f
                      tds_amt    = _policy_rec.try(:investor_tds_amount).to_f
                      actual     = _policy_rec.try(:investor_after_tds_value).to_f
                      actual     = (gross - tds_amt).round(2) if actual.zero? && gross > 0
                    when 'company_expense'
                      ca         = _policy_rec.try(:company_expenses_amount).to_f
                      gross      = ca > 0 ? ca : (_policy_rec.try(:company_expenses_percentage).to_f * _policy_rec.try(:net_premium).to_f / 100.0).round(2)
                      tds_pct    = 0.0; tds_amt = 0.0; actual = gross
                    else
                      gross      = p.payout_amount.to_f
                      tds_pct    = 0.0; tds_amt = 0.0; actual = gross
                    end
                  else
                    gross = p.payout_amount.to_f; tds_pct = 0.0; tds_amt = 0.0; actual = gross
                  end

                  recipient_name = case p.payout_to
                                   when 'main_agent'      then 'Dr Wise (Main Agent)'
                                   when 'affiliate'       then _sub_agent&.display_name.presence || 'Affiliate'
                                   when 'ambassador'      then _distributor&.display_name.presence || 'Ambassador'
                                   when 'investor'        then 'Investor'
                                   when 'company_expense' then 'Company Expense'
                                   else p.payout_to.humanize
                                   end

                  { payout_to: p.payout_to,
                    payout_amount: actual.round(2),
                    gross_amount:  gross.round(2),
                    tds_pct:       tds_pct.round(2),
                    tds_amt:       tds_amt.round(2),
                    status:        p.status,
                    payout_date:   p.payout_date,
                    customer_name: p.try(:customer_name),
                    recipient_name: recipient_name }
                end

                total_amount = _corrected.sum { |p| p[:payout_amount] }
                main_agent_rec = _corrected.find { |p| p[:payout_to] == 'main_agent' }
                main_agent_amount = main_agent_rec ? main_agent_rec[:payout_amount] : 0
              %>
              <tr>
                <td>
                  <div class="fw-bold"><%= policy_number %></div>
                  <small class="text-muted"><%= first_payout.customer_name %></small>
                </td>
                <td>
                  <span class="badge bg-<%=
                    case first_payout.policy_type
                    when 'health' then 'success'
                    when 'life' then 'primary'
                    when 'motor' then 'warning'
                    else 'secondary'
                    end
                  %>">
                    <%= first_payout.policy_type.humanize %>
                  </span>
                </td>
                <td>
                  <button type="button"
                          class="btn btn-info btn-sm text-white commission-breakdown-btn"
                          onclick="showCommissionBreakdown('<%= policy_number %>', '<%= first_payout.policy_type %>', '<%= _corrected.to_json.gsub("'", "\\'") %>')"
                          style="border-radius: 20px;">
                    <i class="bi bi-pie-chart me-1"></i><%= payouts.count %> breakdown
                  </button>
                  <br>
                  <small class="text-muted mt-1">
                    Main Agent: <%= indian_currency(main_agent_amount) %>
                  </small>
                </td>
                <td>
                  <div class="fw-bold text-success fs-6">
                    <%= indian_currency(main_agent_amount) %>
                  </div>
                  <small class="text-muted">
                    <%= payouts.count %> payments
                  </small>
                </td>
                <td>
                  <% all_paid = payouts.all? { |p| p.status == 'paid' } %>
                  <% all_pending = payouts.all? { |p| p.status == 'pending' } %>
                  <% if all_paid %>
                    <span class="badge bg-success">
                      <i class="bi bi-check-circle me-1"></i>All Paid
                    </span>
                  <% elsif all_pending %>
                    <span class="badge bg-warning">
                      <i class="bi bi-clock me-1"></i>All Pending
                    </span>
                  <% else %>
                    <span class="badge bg-info">
                      <i class="bi bi-hourglass-split me-1"></i>Mixed Status
                    </span>
                  <% end %>
                </td>
                <td>
                  <div class="text-dark fw-medium">
                    <%= first_payout.payout_date&.strftime('%b %d, %Y') || 'Pending' %>
                  </div>
                  <% if payouts.map(&:payout_date).uniq.length > 1 %>
                    <small class="text-muted">Multiple dates</small>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>

