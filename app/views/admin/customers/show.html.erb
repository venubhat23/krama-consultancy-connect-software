                             when 'follow_up'              then 'linear-gradient(135deg, #ffc107, #fd7e14)'
                             when 'consultation_scheduled' then 'linear-gradient(135deg, #17a2b8, #007bff)'
                             else                               'linear-gradient(135deg, #6c757d, #495057)'
                             end %>
                        <div class="stage-badge" style="background: <%= stage_bg %>; color: white; padding: 10px 15px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; text-transform: capitalize; box-shadow: 0 2px 8px rgba(0,0,0,0.2); display: inline-block;">
                          <i class="bi bi-<%= lead.current_stage == 'converted' ? 'check-circle-fill' : lead.current_stage == 'follow_up' ? 'clock-fill' : lead.current_stage == 'consultation_scheduled' ? 'calendar-check-fill' : 'hourglass-split' %> me-2"></i><%= lead.current_stage&.humanize || 'Unknown' %>
                        </div>
                      </div>
                    </div>

                    <!-- Date Section -->
                    <div class="col-lg-2 col-md-4 col-sm-6">
                      <div class="d-flex flex-column align-items-start">
                        <small class="text-muted fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 0.5px; text-transform: uppercase;">Date</small>
                        <div class="date-display" style="background: rgba(102, 126, 234, 0.1); padding: 8px 12px; border-radius: 12px; color: #667eea; font-weight: 600; border: 1px solid rgba(102, 126, 234, 0.2);">
                          <i class="bi bi-calendar-event me-2"></i><%= lead.created_at.strftime("%d %b %Y") %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center text-muted py-4">
          <i class="bi bi-funnel fs-3 d-block mb-3"></i>
          <h6>No Leads Found</h6>
          <p class="mb-3">This client doesn't have any associated leads.</p>
          <%= link_to new_admin_lead_path(customer_id: @customer.id), class: "btn btn-primary btn-sm" do %>
            <i class="bi bi-plus me-1"></i>Create New Lead
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

