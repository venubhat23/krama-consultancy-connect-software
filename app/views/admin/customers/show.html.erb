<script>
function copyCredentials() {
  const username = document.getElementById('customer-id-value').textContent.trim();
  const password = document.getElementById('customer-password-value').textContent.trim();
  
  const text = `Username: ${username}\nPassword: ${password}`;
  
  navigator.clipboard.writeText(text).then(function() {
    // Show success message or change button text temporarily
    const btn = event.target.closest('button');
    const originalHTML = btn.innerHTML;
    btn.innerHTML = '<i class="bi bi-check me-1"></i>Copied!';
    btn.classList.add('btn-success');
    btn.classList.remove('btn-outline-primary');
    
    setTimeout(() => {
      btn.innerHTML = originalHTML;
      btn.classList.remove('btn-success');
      btn.classList.add('btn-outline-primary');
    }, 2000);
  });
}

function openPreviewModal(documentId) {
  // Implementation for document preview
  const modal = new bootstrap.Modal(document.getElementById('documentPreviewModal'));
  // Load document preview content based on documentId
  modal.show();
}

function openProfileModal() {
  const modal = new bootstrap.Modal(document.getElementById('profilePreviewModal'));
  modal.show();
}

function shareDocument(documentId) {
  // Implementation for sharing document
  alert('Share functionality coming soon!');
}

function copyDocumentLink(url) {
  navigator.clipboard.writeText(url).then(function() {
    // Show success feedback
    const btn = event.target.closest('.share-btn');
    const originalIcon = btn.innerHTML;
    btn.innerHTML = '<i class="bi bi-check2"></i>';
    btn.classList.add('text-success');

    setTimeout(() => {
      btn.innerHTML = originalIcon;
      btn.classList.remove('text-success');
    }, 2000);
  }).catch(function() {
    alert('Unable to copy link to clipboard');
  });
}

// Generic copy to clipboard function
function copyToClipboard(text) {
  navigator.clipboard.writeText(text).then(function() {
    // Show success feedback
    const btn = event.target.closest('button');
    const originalHTML = btn.innerHTML;
    btn.innerHTML = '<i class="bi bi-check text-success"></i>';
    btn.classList.add('text-success');

    setTimeout(() => {
      btn.innerHTML = originalHTML;
      btn.classList.remove('text-success');
    }, 2000);
  }).catch(function() {
    alert('Unable to copy URL to clipboard');
  });
}

// Enhanced cleanup for layout wrapper containers
function cleanupEmptyContainers() {
  console.log('🧹 Running enhanced container cleanup...');

  // Remove empty info-section-cards
  const allSections = document.querySelectorAll('.info-section-card');
  allSections.forEach(section => {
    const sectionBody = section.querySelector('.section-body');
    if (sectionBody) {
      const bodyContent = sectionBody.innerHTML.trim();
      const textContent = sectionBody.textContent.trim();
      if (bodyContent === '' || textContent === '' || textContent === 'No data available') {
        console.log('🗑️ Removing empty section:', section);
        section.remove();
      }
    }
  });

  // Remove any empty cards
  const allCards = document.querySelectorAll('.card');
  allCards.forEach(card => {
    if (card.innerHTML.trim() === '' || card.children.length === 0) {
      console.log('🗑️ Removing empty card:', card);
      card.remove();
    }
  });

  // Target layout wrapper containers specifically
  const layoutContainers = [
    '.container-fluid',
    '.content-area',
    '.main-content',
    'main'
  ];

  layoutContainers.forEach(selector => {
    const containers = document.querySelectorAll(selector);
    containers.forEach(container => {
      // Find last children that are empty divs
      const children = Array.from(container.children);
      children.reverse().forEach((child, index) => {
        // Only check last few children to avoid removing necessary structure
        if (index < 5 &&
            child.tagName === 'DIV' &&
            child.innerHTML.trim() === '' &&
            !child.classList.contains('bottom-actions') &&
            !child.classList.contains('modal') &&
            !child.classList.contains('dropdown-menu') &&
            !child.id.includes('modal') &&
            !child.id.includes('Collapse')) {
          console.log('🗑️ Removing empty layout child from', selector, ':', child);
          child.remove();
        }
      });
    });
  });

  // Clean up any rogue empty containers at end of page
  const allDivs = document.querySelectorAll('div');
  const lastDivs = Array.from(allDivs).slice(-10); // Check last 10 divs
  lastDivs.reverse().forEach(div => {
    if (div.innerHTML.trim() === '' &&
        !div.classList.contains('bottom-actions') &&
        !div.classList.contains('modal') &&
        !div.classList.contains('dropdown-menu') &&
        !div.id.includes('modal') &&
        !div.id.includes('Collapse') &&
        div.offsetHeight > 20) { // Only remove if it has visible height
      console.log('🗑️ Removing trailing empty div:', div);
      div.remove();
    }
  });

  // Force layout recalculation
  document.body.offsetHeight;

  console.log('✅ Container cleanup completed');
}

// Run cleanup with multiple triggers and delays
document.addEventListener('DOMContentLoaded', cleanupEmptyContainers);
window.addEventListener('load', cleanupEmptyContainers);
setTimeout(cleanupEmptyContainers, 300);  // Quick cleanup
setTimeout(cleanupEmptyContainers, 1000); // Secondary cleanup
setTimeout(cleanupEmptyContainers, 2000); // Final cleanup

// Also run on turbo events
document.addEventListener('turbo:load', cleanupEmptyContainers);
document.addEventListener('turbo:frame-load', cleanupEmptyContainers);


// Handle document upload form submission
document.addEventListener('DOMContentLoaded', function() {
  const uploadForm = document.querySelector('.document-upload-form');
  if (uploadForm) {
    uploadForm.addEventListener('ajax:success', function(event) {
      const response = event.detail[0];
      if (response.success) {
        // Show success message
        const alert = document.createElement('div');
        alert.className = 'alert alert-success alert-dismissible fade show mt-3';
        alert.innerHTML = `
          <i class="bi bi-check-circle me-2"></i>
          ${response.message}
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        uploadForm.appendChild(alert);

        // Reset form
        uploadForm.reset();

        // Reload the page after a short delay to show the new document
        setTimeout(() => {
          window.location.reload();
        }, 1500);
      }
    });

    uploadForm.addEventListener('ajax:error', function(event) {
      const response = event.detail[0];
      const errorMessage = response.message || 'Upload failed. Please try again.';

      // Show error message
      const alert = document.createElement('div');
      alert.className = 'alert alert-danger alert-dismissible fade show mt-3';
      alert.innerHTML = `
        <i class="bi bi-exclamation-triangle me-2"></i>
        ${errorMessage}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      `;
      uploadForm.appendChild(alert);
    });
  }
});
</script>

