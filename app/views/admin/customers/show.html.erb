                        <div class="mb-2">
                          <div class="d-flex align-items-center mb-1">
                            <div class="icon-circle me-3" style="width: 35px; height: 35px; background: linear-gradient(135deg, #28a745, #20c997); border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(40, 167, 69, 0.3);">
