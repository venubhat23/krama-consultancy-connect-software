                        <span class="badge bg-primary">Renewed</span>
                      <% else %>
                        <span class="badge bg-danger">Expired</span>
                      <% end %>
                    </td>
                  <% end %>
                  <td>
                    <% p_view_path = case p[:type]
                       when 'Health Insurance' then admin_health_insurance_path(p[:policy])
                       when 'Life Insurance'   then admin_life_insurance_path(p[:policy])
                       when 'Motor Insurance'  then admin_motor_insurance_path(p[:policy])
                       when 'Other Insurance'  then admin_other_insurance_path(p[:policy])
                       end %>
