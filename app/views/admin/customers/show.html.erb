<!-- Family Members Section -->
<div class="info-section-card">
  <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#familyMembersCollapse" aria-expanded="false">
    <div class="d-flex align-items-center">
      <div class="section-icon">
        <i class="bi bi-people"></i>
      </div>
      <h5 class="section-title">Family Members</h5>
      <span class="section-count"><%= @family_members&.count || 0 %> Members</span>
    </div>
    <i class="bi bi-chevron-down collapse-icon"></i>
  </div>
  <div id="familyMembersCollapse" class="collapse">
    <div class="section-body">
    <% if @family_members&.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <tr>
              <th class="border-0 text-white fw-bold py-3">
                <i class="bi bi-person-fill me-2"></i>Name
              </th>
              <th class="border-0 text-white fw-bold py-3">
                <i class="bi bi-heart-fill me-2"></i>Relationship
              </th>
              <th class="border-0 text-white fw-bold py-3">
                <i class="bi bi-calendar-fill me-2"></i>Birth Date
              </th>
              <th class="border-0 text-white fw-bold py-3">
                <i class="bi bi-stopwatch-fill me-2"></i>Age
              </th>
              <th class="border-0 text-white fw-bold py-3">
                <i class="bi bi-gender-ambiguous me-2"></i>Gender
              </th>
              <th class="border-0 text-white fw-bold py-3">
                <i class="bi bi-gear-fill me-2"></i>Actions
              </th>
            </tr>
          </thead>
            <tbody>
              <% @family_members.each do |family_member| %>
                <tr>
                  <td><%= family_member.name %></td>
                  <td><span class="badge bg-info"><%= family_member.relationship.humanize %></span></td>
                  <td><%= family_member.birth_date&.strftime("%B %d, %Y") %></td>
                  <td><%= family_member.age %> years</td>
                  <td><%= family_member.gender&.humanize %></td>
                  <td>
                    <div class="d-flex gap-1">
                      <%= link_to edit_admin_customer_family_member_path(@customer, family_member), class: "btn btn-sm btn-outline-warning" do %>
                        <i class="bi bi-pencil"></i>
                      <% end %>
                      <%= link_to admin_customer_family_member_path(@customer, family_member), method: :delete,
                          class: "btn btn-sm btn-outline-danger",
                          data: { confirm: "Are you sure?", turbo_method: :delete } do %>
                        <i class="bi bi-trash"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center text-muted py-4">
          <i class="bi bi-people fs-3 d-block mb-2"></i>
          <p class="mb-3">No family members added yet</p>
          <%= link_to new_admin_customer_family_member_path(@customer), class: "btn btn-primary btn-sm" do %>
            <i class="bi bi-plus me-1"></i>Add Family Member
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Corporate Members Section (for corporate customers) -->
<% if @customer.customer_type == 'corporate' %>
<div class="info-section-card">
  <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#corporateCollapse" aria-expanded="false">
    <div class="d-flex align-items-center">
      <div class="section-icon">
        <i class="bi bi-building"></i>
      </div>
      <h5 class="section-title">Corporate Members</h5>
      
    </div>
    <i class="bi bi-chevron-down collapse-icon"></i>
  </div>
  <div id="corporateCollapse" class="collapse">
    <div class="section-body">
      <div class="text-center text-muted py-4">
        <i class="bi bi-building fs-3 d-block mb-2"></i>
        <p class="mb-0">No corporate members added yet</p>
      </div>
    </div>
  </div>
</div>
<% end %>

<!-- Uploaded Documents Section -->
<div class="info-section-card">
  <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#documentsCollapse" aria-expanded="false">
    <div class="d-flex align-items-center">
      <div class="section-icon">
        <i class="bi bi-folder"></i>
      </div>
      <h5 class="section-title">Document Library <%= @customer.documents&.any? ? "(#{@customer.documents.count})" : "(0)" %></h5>
      
    </div>
    <i class="bi bi-chevron-down collapse-icon"></i>
  </div>
  <div id="documentsCollapse" class="collapse">
    <div class="section-body">


      <!-- Customer Documents Section -->
      <% if @customer.documents.any? %>
        <div class="customer-documents-section mb-4">
          <div class="d-flex align-items-center mb-3">
            <i class="bi bi-file-earmark-text me-2 text-primary fs-5"></i>
            <h6 class="mb-0">Customer Documents</h6>
            <span class="badge bg-primary ms-2"><%= @customer.documents.count %></span>
          </div>
          <div class="simple-documents-list">
            <% @customer.documents.each do |document| %>
              <div class="simple-document-item">
                <div class="document-icon">
                  <% if document.has_file? %>
                    <% file_extension = File.extname(document.r2_filename.to_s).downcase %>
                    <% if ['.jpg', '.jpeg', '.png', '.gif'].include?(file_extension) %>
                      <i class="bi bi-image text-info"></i>
                    <% elsif file_extension == '.pdf' %>
                      <i class="bi bi-file-earmark-pdf text-danger"></i>
                    <% else %>
                      <i class="bi bi-file-earmark text-secondary"></i>
                    <% end %>
                  <% else %>
                    <i class="bi bi-file-earmark-x text-danger"></i>
                  <% end %>
                </div>
                <div class="document-details">
                  <div class="document-name fw-medium"><%= document.document_type %></div>
                  <div class="document-meta text-muted small">
                    <%= document.document_name %> • <%= document.document_size %>
                  </div>
                  <% if document.has_file? %>
                    <div class="public-url-section mt-2">
                      <small class="text-muted">Public URL:</small>
                      <div class="url-display">
                        <input type="text" class="form-control form-control-sm" readonly
                               value="<%= document.download_url || document.document_url %>"
                               onclick="this.select()"
                               style="font-size: 11px;">
                        <button class="btn btn-sm btn-outline-secondary ms-1"
                                onclick="copyToClipboard('<%= document.download_url || document.document_url %>')"
                                title="Copy URL">
                          <i class="bi bi-copy"></i>
                        </button>
                      </div>
                    </div>
                  <% end %>
                </div>
                <div class="document-actions-simple">
                  <% if document.has_file? %>
                    <%= link_to document.document_url, class: "btn btn-sm btn-outline-primary", title: "View", target: "_blank" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to (document.download_url || document.document_url), class: "btn btn-sm btn-outline-success", title: "Download", target: "_blank", download: true do %>
                      <i class="bi bi-download"></i>
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <p class="text-muted mb-0">No documents uploaded yet.</p>
      <% end %>
    </div>
  </div>
</div>

<!-- ===== 8 Insurance Policy Sections ===== -->
<%
  _ins_sections = [
    { policies: @health_policies || [],                   id: 'insSecHealth',       icon: 'bi-heart-pulse',    color: '#e74c3c', title: 'Health Insurance' },
    { policies: @life_policies || [],                     id: 'insSecLife',          icon: 'bi-shield-heart',   color: '#2980b9', title: 'Life Insurance' },
    { policies: @motor_policies || [],                    id: 'insSecMotor',         icon: 'bi-car-front',      color: '#f39c12', title: 'Motor Insurance' },
    { policies: @other_policies || [],                    id: 'insSecOther',         icon: 'bi-shield-check',   color: '#27ae60', title: 'Other Insurance' },
    { policies: @expired_policies || [],                  id: 'insSecExpired',       icon: 'bi-clock',          color: '#c0392b', title: 'Expired Policy' },
    { policies: @past_policies || [],                     id: 'insSecPast',          icon: 'bi-clock-history',  color: '#7f8c8d', title: 'Past Policy' },
    { policies: @upcoming_installment_policies || [],     id: 'insSecInstallment',   icon: 'bi-calendar-check', color: '#8e44ad', title: 'Upcoming Installment Policy', installment: true },
    { policies: @upcoming_renewal_policies || [],         id: 'insSecRenewal',       icon: 'bi-arrow-repeat',   color: '#16a085', title: 'Upcoming Renewal Policy',     renewal: true }
  ]
%>
<% _ins_sections.each do |sec| %>
<div class="info-section-card">
  <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#<%= sec[:id] %>" aria-expanded="false">
    <div class="d-flex align-items-center gap-2">
      <div class="section-icon">
        <i class="bi <%= sec[:icon] %>" style="color:<%= sec[:color] %>;"></i>
      </div>
      <h5 class="section-title"><%= sec[:title] %></h5>
      <span class="section-count"><%= sec[:policies].count %> Total</span>
    </div>
    <i class="bi bi-chevron-down collapse-icon"></i>
  </div>
  <div id="<%= sec[:id] %>" class="collapse">
    <div class="section-body p-0">
      <% if sec[:policies].any? %>
        <div class="table-responsive">
          <table class="table table-sm table-hover mb-0">
            <thead style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
              <% if sec[:installment] %>
              <tr>
                <th class="text-white border-0 py-3">Policy Number</th>
                <th class="text-white border-0 py-3">Type</th>
                <th class="text-white border-0 py-3">Company</th>
                <th class="text-white border-0 py-3">Payment Mode</th>
                <th class="text-white border-0 py-3">Next Installment</th>
                <th class="text-white border-0 py-3"></th>
              </tr>
              <% elsif sec[:renewal] %>
              <tr>
                <th class="text-white border-0 py-3">Policy Number</th>
                <th class="text-white border-0 py-3">Type</th>
                <th class="text-white border-0 py-3">Company</th>
                <th class="text-white border-0 py-3">End Date</th>
                <th class="text-white border-0 py-3">Days Left</th>
                <th class="text-white border-0 py-3"></th>
              </tr>
              <% else %>
              <tr>
                <th class="text-white border-0 py-3">Policy Number</th>
                <th class="text-white border-0 py-3">Type</th>
                <th class="text-white border-0 py-3">Company</th>
                <th class="text-white border-0 py-3">Premium</th>
                <th class="text-white border-0 py-3">Start Date</th>
                <th class="text-white border-0 py-3">End Date</th>
                <th class="text-white border-0 py-3">Status</th>
                <th class="text-white border-0 py-3"></th>
              </tr>
              <% end %>
            </thead>
            <tbody>
              <% sec[:policies].each do |p| %>
                <tr>
                  <td><code><%= p[:policy_number] %></code></td>
                  <% if sec[:installment] %>
                    <td><small class="text-muted"><%= p[:type] %></small></td>
                    <td><%= p[:company_name] %></td>
                    <td><span class="badge bg-info text-dark"><%= p[:policy].respond_to?(:payment_mode) ? p[:policy].payment_mode : '—' %></span></td>
                    <td>
                      <% if p[:next_installment_date] %>
                        <span class="badge bg-warning text-dark"><%= p[:next_installment_date].strftime("%d %b %Y") %></span>
                      <% else %>
                        <span class="text-muted">—</span>
                      <% end %>
                    </td>
                  <% elsif sec[:renewal] %>
                    <td><small class="text-muted"><%= p[:type] %></small></td>
                    <td><%= p[:company_name] %></td>
                    <td><span class="text-danger fw-bold"><%= p[:end_date]&.strftime("%d %b %Y") || '—' %></span></td>
                    <td>
                      <% days_left = p[:end_date] ? (p[:end_date] - Date.current).to_i : nil %>
                      <% if days_left %>
                        <span class="badge <%= days_left <= 15 ? 'bg-danger' : days_left <= 30 ? 'bg-warning text-dark' : 'bg-info text-dark' %>"><%= days_left %> days</span>
                      <% end %>
                    </td>
                  <% else %>
                    <td><%= p[:type] %></td>
                    <td><%= p[:company_name] %></td>
                    <td><%= respond_to?(:indian_currency) ? indian_currency(p[:premium].to_i) : "Rs. #{p[:premium].to_i}" %></td>
                    <td><%= p[:start_date]&.strftime("%d %b %Y") || '—' %></td>
                    <td><%= p[:end_date]&.strftime("%d %b %Y") || '—' %></td>
                    <td>
                      <% if p[:status] == 'Active' %>
                        <span style="color:#16a34a; font-weight:600;">Active</span>
                      <% elsif p[:status] == 'Renewed' %>
                        <span style="color:#2563eb; font-weight:600;">Renewed</span>
                      <% else %>
                        <span style="color:#dc2626; font-weight:600;">Expired</span>
                      <% end %>
                    </td>
                  <% end %>
                  <td>
                    <% ins_view_path = case p[:type]
                       when 'Health Insurance' then admin_health_insurance_path(p[:policy])
                       when 'Life Insurance'   then admin_life_insurance_path(p[:policy])
                       when 'Motor Insurance'  then admin_motor_insurance_path(p[:policy])
                       when 'Other Insurance'  then admin_other_insurance_path(p[:policy])
                       end %>
                    <% if ins_view_path %>
                      <%= link_to ins_view_path, class: "btn btn-sm btn-outline-primary" do %><i class="bi bi-eye"></i><% end %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center text-muted py-4">
          <i class="bi bi-inbox fs-3 d-block mb-2"></i>
          <p class="mb-0">No policies in this category.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
<% end %>

      <% if false # @uploaded_documents&.any? %>
        <div class="documents-grid">
          <% @uploaded_documents.each_with_index do |document, index| %>
            <div class="enhanced-document-card" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
              <!-- Document Preview -->
              <div class="document-preview" onclick="openPreviewModal('<%= document.id %>')">
                <% if document.file&.attached? %>
                  <% file_extension = File.extname(document.file.filename.to_s).downcase %>
                  <% if ['.jpg', '.jpeg', '.png', '.gif'].include?(file_extension) %>
                    <div class="image-preview">
                      <%= image_tag rails_blob_url(document.file), alt: document.title, class: "preview-image" %>
                      <div class="preview-overlay">
                        <i class="bi bi-eye preview-icon"></i>
                      </div>
                    </div>
                  <% elsif file_extension == '.pdf' %>
                    <div class="file-type-preview pdf-preview">
                      <i class="bi bi-file-pdf file-type-icon"></i>
                      <span class="file-type-label">PDF</span>
                      <div class="preview-overlay">
                        <i class="bi bi-eye preview-icon"></i>
                      </div>
                    </div>
                  <% elsif ['.doc', '.docx'].include?(file_extension) %>
                    <div class="file-type-preview doc-preview">
                      <i class="bi bi-file-word file-type-icon"></i>
                      <span class="file-type-label">DOC</span>
                      <div class="preview-overlay">
                        <i class="bi bi-download preview-icon"></i>
                      </div>
                    </div>
                  <% elsif ['.xls', '.xlsx'].include?(file_extension) %>
                    <div class="file-type-preview excel-preview">
                      <i class="bi bi-file-excel file-type-icon"></i>
                      <span class="file-type-label">XLS</span>
                      <div class="preview-overlay">
                        <i class="bi bi-download preview-icon"></i>
                      </div>
                    </div>
                  <% else %>
                    <div class="file-type-preview default-preview">
                      <i class="bi bi-file-earmark file-type-icon"></i>
                      <span class="file-type-label">FILE</span>
                      <div class="preview-overlay">
                        <i class="bi bi-download preview-icon"></i>
                      </div>
                    </div>
                  <% end %>
                <% else %>
                  <div class="file-type-preview default-preview">
                    <i class="bi bi-file-earmark file-type-icon"></i>
                    <span class="file-type-label">NO FILE</span>
                    <div class="preview-overlay">
                      <i class="bi bi-exclamation-triangle preview-icon"></i>
                    </div>
                  </div>
                <% end %>
              </div>

              <!-- Document Info -->
              <div class="document-info">
                <div class="document-header">
                  <h6 class="document-title" title="<%= document.title %>"><%= truncate(document.title, length: 20) %></h6>
                  <div class="document-type-badge">
                    <%= document.human_document_type %>
                  </div>
                </div>

                <div class="document-meta">
                  <div class="meta-item">
                    <i class="bi bi-file-earmark meta-icon"></i>
                    <span class="meta-text"><%= document.file&.attached? ? truncate(document.file.filename.to_s, length: 15) : 'No file' %></span>
                  </div>
                  <div class="meta-item">
                    <i class="bi bi-hdd meta-icon"></i>
                    <span class="meta-text"><%= document.file&.attached? ? number_to_human_size(document.file.byte_size) : '0 B' %></span>
                  </div>
                  <div class="meta-item">
                    <i class="bi bi-calendar3 meta-icon"></i>
                    <span class="meta-text"><%= document.created_at.strftime("%b %d") %></span>
                  </div>
                </div>
              </div>

              <!-- Document Actions -->
              <div class="document-actions">
                <div class="action-buttons">
                  <% if document.downloadable? && document.file&.attached? %>
                    <%= link_to rails_blob_url(document.file, disposition: "attachment"),
                        class: "action-btn download-btn",
                        title: "Download",
                        target: "_blank" do %>
                      <i class="bi bi-download"></i>
                    <% end %>
                  <% end %>

                  <button class="action-btn preview-btn" title="Preview" onclick="openPreviewModal('<%= document.id %>')">
                    <i class="bi bi-eye"></i>
                  </button>

                  <button class="action-btn share-btn" title="Share" onclick="shareDocument('<%= document.id %>')">
                    <i class="bi bi-share"></i>
                  </button>
                </div>
              </div>
            </div>
          <% end %>
        </div>

      <!-- Document Upload Section -->
      <div class="document-upload-section mt-4">
        <div class="upload-header d-flex align-items-center mb-3">
          <i class="bi bi-cloud-upload me-2 text-success fs-5"></i>
          <h6 class="mb-0">Upload New Document</h6>
        </div>

        <%= form_with url: admin_customer_documents_path(@customer), method: :post, local: false, multipart: true, class: "document-upload-form" do |f| %>
          <div class="row g-3">
            <div class="col-md-6">
              <%= f.select :document_type,
                  options_for_select([
                    ['Aadhaar Card', 'Aadhaar Card'],
                    ['Pancard', 'Pancard'],
                    ['Driving License', 'Driving License'],
                    ['Mediclaim', 'Mediclaim'],
                    ['RC Book', 'RC Book'],
                    ['Other File', 'Other File']
                  ]),
                  { prompt: 'Select document type' },
                  { class: "form-select", required: true } %>
            </div>
            <div class="col-md-6">
              <%= f.file_field :document_file,
                  class: "form-control",
                  accept: "application/pdf,image/jpeg,image/jpg,image/png",
                  required: true %>
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-success">
                <i class="bi bi-cloud-upload me-1"></i>
                Upload Document
              </button>
            </div>
          </div>
        <% end %>
      </div>

      <% unless @customer.documents.any? %>
        <div class="empty-documents-state">
          <div class="empty-state-icon">
            <i class="bi bi-folder2-open"></i>
          </div>
          <h6 class="empty-state-title">No Documents Available</h6>
          <p class="empty-state-subtitle">Use the upload section above to add documents to this customer's file.</p>
        </div>
      <% end %>

<!-- Document Preview Modal -->
<div class="modal fade" id="documentPreviewModal" tabindex="-1" aria-labelledby="documentPreviewModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="documentPreviewModalLabel">Document Preview</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="preview-container" id="previewContainer">
          <!-- Preview content will be loaded here -->
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <a href="#" id="downloadPreviewBtn" class="btn btn-primary" target="_blank">
          <i class="bi bi-download me-1"></i>Download
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Profile Image Preview Modal -->
<div class="modal fade" id="profilePreviewModal" tabindex="-1" aria-labelledby="profilePreviewModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="profilePreviewModalLabel">Profile Image</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center">
        <% if @customer.profile_image.attached? %>
          <% image_data = @customer.safe_profile_image_display %>
          <% if image_data %>
            <%= image_tag image_data[:url],
                class: "img-fluid rounded",
                alt: @customer.display_name,
                style: "max-height: 400px; width: auto;" %>
            <div class="mt-3">
              <h6 class="mb-2"><%= @customer.display_name %></h6>
              <p class="text-muted mb-0"><%= image_data[:filename] %></p>
              <small class="text-muted"><%= number_to_human_size(image_data[:size]) %></small>
            </div>
          <% else %>
            <div class="alert alert-warning">
              <i class="bi bi-exclamation-triangle me-2"></i>
              Profile image unavailable or corrupted
            </div>
          <% end %>
        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <% if @customer.profile_image.attached? %>
          <% image_data = @customer.safe_profile_image_display %>
          <% if image_data %>
            <a href="<%= image_data[:public_url] || image_data[:url] %>" class="btn btn-primary" download="<%= image_data[:filename] %>" target="_blank">
              <i class="bi bi-download me-1"></i>Download
            </a>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
<% end %>

<!-- Nominee Information Section -->
