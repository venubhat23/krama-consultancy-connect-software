                            </div>
                            <strong style="color: #2c3e50; font-size: 1.1rem;"><%= lead.name %></strong>
                          </div>
                        </div>
                        <div class="contact-info" style="margin-left: 45px;">
                          <% if lead.contact_number.present? %>
                            <a href="tel:<%= lead.contact_number %>" class="text-decoration-none d-flex align-items-center mb-1 contact-link" style="color: #28a745; font-size: 0.9rem; transition: all 0.2s ease;" onmouseover="this.style.color='#1e7e34'; this.style.transform='translateX(3px)';" onmouseout="this.style.color='#28a745'; this.style.transform='';">
                              <i class="bi bi-telephone-fill me-2" style="font-size: 0.8rem;"></i><%= lead.contact_number %>
                            </a>
                          <% end %>
                          <% if lead.email.present? %>
                            <a href="mailto:<%= lead.email %>" class="text-decoration-none d-flex align-items-center contact-link" style="color: #dc3545; font-size: 0.9rem; transition: all 0.2s ease;" onmouseover="this.style.color='#c82333'; this.style.transform='translateX(3px)';" onmouseout="this.style.color='#dc3545'; this.style.transform='';">
                              <i class="bi bi-envelope-fill me-2" style="font-size: 0.8rem;"></i><%= lead.email %>
                            </a>
                          <% end %>
                          <% if lead.contact_number.blank? && lead.email.blank? %>
                            <span class="text-muted"><i class="bi bi-dash me-2"></i>No contact info</span>
                          <% end %>
                        </div>
                      </div>
                    </div>

                    <!-- Product Section -->
                    <div class="col-lg-2 col-md-4 col-sm-6 mb-3 mb-lg-0">
                      <div class="d-flex flex-column align-items-start">
                        <small class="text-muted fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 0.5px; text-transform: uppercase;">Product</small>
                        <div class="d-flex flex-column gap-1">
                          <span class="badge product-badge" style="background: linear-gradient(135deg, #fd7e14, #dc3545); color: white; padding: 8px 12px; border-radius: 15px; font-size: 0.85rem; font-weight: 600; box-shadow: 0 2px 8px rgba(253, 126, 20, 0.3);">
                            <i class="bi bi-grid-fill me-2"></i><%= lead.product_category %>
                          </span>
                          <% if lead.product_subcategory.present? %>
                            <small class="badge" style="background: rgba(108, 117, 125, 0.1); color: #495057; padding: 4px 8px; border-radius: 10px; border: 1px solid rgba(108, 117, 125, 0.2); font-size: 0.75rem;">
