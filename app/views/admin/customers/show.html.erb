  <div id="upcomingInstallmentsCollapse" class="collapse">
    <div class="section-body">
      <% if upcoming_installments.any? %>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
              <tr>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-shield-check me-2"></i>Policy Type
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-receipt me-2"></i>Policy Number
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-credit-card me-2"></i>Payment Mode
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-currency-rupee me-2"></i>Premium
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-calendar-event me-2"></i>Next Due Date
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-clock me-2"></i>Days Until Due
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-gear-fill me-2"></i>Actions
                </th>
              </tr>
            </thead>
            <tbody>
              <% upcoming_installments.each do |policy| %>
                <%
                  policy_obj = policy[:policy]
                  start_date = policy_obj.policy_start_date
                  today = Date.current
                  case policy_obj.payment_mode
                  when 'Monthly'
                    next_date = start_date
                    while next_date <= today
                      next_date = next_date + 1.month
                    end
                  when 'Quarterly'
                    next_date = start_date
                    while next_date <= today
                      next_date = next_date + 3.months
                    end
                  when 'Half Yearly', 'Semi-Annual'
                    next_date = start_date
                    while next_date <= today
                      next_date = next_date + 6.months
                    end
                  end
                  days_until_due = (next_date - today).to_i
                %>
                <tr>
                  <td><strong><%= policy[:type] %></strong></td>
                  <td><code class="bg-light px-2 py-1 rounded"><%= policy[:policy_number] %></code></td>
                  <td><span class="badge bg-info"><%= policy_obj.payment_mode %></span></td>
                  <td><span class="text-warning fw-bold"><%= indian_currency(policy[:premium].to_i) %></span></td>
                  <td><span class="text-warning"><%= next_date.strftime("%d %b %Y") %></span></td>
                  <td><span class="badge bg-<%= days_until_due <= 7 ? 'danger' : (days_until_due <= 15 ? 'warning' : 'info') %>"><%= days_until_due %> days</span></td>
                  <td>
                    <% installment_view_path = case policy[:type]
                       when 'Health Insurance' then admin_health_insurance_path(policy[:policy])
                       when 'Life Insurance'   then admin_life_insurance_path(policy[:policy])
                       when 'Motor Insurance'  then admin_motor_insurance_path(policy[:policy])
                       end %>
                    <%= link_to installment_view_path, class: "btn btn-sm btn-outline-primary", title: "View Details" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center text-muted py-4">
          <i class="bi bi-calendar-check fs-3 d-block mb-2 text-success"></i>
          <p class="mb-0">No upcoming installments in the next 45 days</p>
          <small class="text-muted">All installments are up to date</small>
        </div>
      <% end %>
    </div>
  </div>
</div>
<% end %>

