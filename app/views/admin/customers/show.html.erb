<!-- Upcoming Renewals & Installments (Next 45 Days) -->
      <%
        # Policies needing renewal in next 45 days
        renewal_policies = @all_policies&.select do |p|
          next false unless p[:status] == 'Active'
          next false unless p[:end_date]
          days_until_expiry = (p[:end_date] - Date.current).to_i
          days_until_expiry > 0 && days_until_expiry <= 30
        end || []

        # Installments due in next 45 days
        installment_policies = @all_policies&.select do |p|
          policy_obj = p[:policy]
          next false unless policy_obj.respond_to?(:payment_mode)
          next false unless ['Monthly', 'Quarterly', 'Half Yearly', 'Semi-Annual'].include?(policy_obj.payment_mode)
          next false unless p[:status] == 'Active'
          next false unless policy_obj.respond_to?(:policy_start_date) && policy_obj.policy_start_date
          start_date = policy_obj.policy_start_date
          today = Date.current
          case policy_obj.payment_mode
          when 'Monthly'
            next_date = start_date
            while next_date <= today
              next_date = next_date + 1.month
            end
          when 'Quarterly'
            next_date = start_date
            while next_date <= today
              next_date = next_date + 3.months
            end
          when 'Half Yearly', 'Semi-Annual'
            next_date = start_date
            while next_date <= today
              next_date = next_date + 6.months
            end
          else
            next false
          end
          next_date <= 45.days.from_now
        end || []

        total_upcoming = (renewal_policies + installment_policies).uniq { |p| p[:policy].id }
      %>
<div class="info-section-card">
  <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#upcomingRenewalsCollapse" aria-expanded="false">
    <div class="d-flex align-items-center">
      <div class="section-icon">
        <i class="bi bi-calendar-check"></i>
      </div>
      <h5 class="section-title">Upcoming Renewals & Installments (Next 45 Days) (<%= total_upcoming.count %>)</h5>

    </div>
    <i class="bi bi-chevron-down collapse-icon"></i>
  </div>
  <div id="upcomingRenewalsCollapse" class="collapse">
    <div class="section-body">
      <% if total_upcoming.any? %>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead style="background: linear-gradient(135deg, #ffc107 0%, #ff8c00 100%);">
              <tr>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-tag me-2"></i>Type
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-receipt me-2"></i>Policy
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-building me-2"></i>Company
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-currency-rupee me-2"></i>Amount
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-calendar-event me-2"></i>Due Date
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-clock me-2"></i>Days Left
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-info-circle me-2"></i>Due For
                </th>
                <th class="border-0 text-white fw-bold py-3">
                  <i class="bi bi-gear-fill me-2"></i>Actions
                </th>
              </tr>
            </thead>
            <tbody>
              <% total_upcoming.each do |policy| %>
                <%
                  policy_obj = policy[:policy]
                  # Check if it's a renewal or installment
                  days_until_expiry = policy[:end_date] ? (policy[:end_date] - Date.current).to_i : nil
                  is_renewal = days_until_expiry && days_until_expiry > 0 && days_until_expiry <= 30

                  # Calculate installment date if applicable
                  if !is_renewal && policy_obj.respond_to?(:payment_mode) && policy_obj.respond_to?(:policy_start_date)
                    start_date = policy_obj.policy_start_date
                    today = Date.current
                    case policy_obj.payment_mode
                    when 'Monthly'
                      next_date = start_date
                      while next_date <= today
                        next_date = next_date + 1.month
                      end
                    when 'Quarterly'
                      next_date = start_date
                      while next_date <= today
                        next_date = next_date + 3.months
                      end
                    when 'Half Yearly', 'Semi-Annual'
                      next_date = start_date
                      while next_date <= today
                        next_date = next_date + 6.months
                      end
                    else
                      next_date = nil
                    end
                    is_installment = next_date && next_date <= 45.days.from_now
                    days_until_installment = next_date ? (next_date - today).to_i : nil
                  else
                    is_installment = false
                    next_date = nil
                    days_until_installment = nil
                  end
                %>
                <tr>
                  <td><strong><%= policy[:type] %></strong></td>
                  <td><code class="bg-light px-2 py-1 rounded"><%= policy[:policy_number] %></code></td>
                  <td><%= policy[:company_name] %></td>
                  <td><span class="text-success fw-bold"><%= indian_currency(policy[:premium].to_i) %></span></td>
                  <td>
                    <% if is_renewal %>
                      <span class="text-warning"><%= policy[:end_date].strftime("%d %b %Y") %></span>
                    <% elsif is_installment %>
                      <span class="text-info"><%= next_date.strftime("%d %b %Y") %></span>
                    <% else %>
                      N/A
                    <% end %>
                  </td>
                  <td>
                    <% if is_renewal %>
                      <span class="badge bg-<%= days_until_expiry <= 7 ? 'danger' : (days_until_expiry <= 15 ? 'warning' : 'info') %>">
                        <%= days_until_expiry %> days
                      </span>
                    <% elsif is_installment %>
                      <span class="badge bg-<%= days_until_installment <= 7 ? 'danger' : (days_until_installment <= 15 ? 'warning' : 'info') %>">
                        <%= days_until_installment %> days
                      </span>
                    <% else %>
                      N/A
                    <% end %>
                  </td>
                  <td>
                    <% if is_renewal %>
                      <span class="badge bg-warning">Renewal</span>
                    <% elsif is_installment %>
                      <span class="badge bg-info">Installment</span>
                    <% else %>
                      -
                    <% end %>
                  </td>
                  <td>
                    <% if is_renewal %>
                      <%= link_to "Renew", "#", class: "btn btn-sm btn-success me-1" %>
                    <% elsif is_installment %>
                      <%= link_to "Pay", "#", class: "btn btn-sm btn-primary me-1" %>
                    <% end %>
                    <% action_view_path = case policy[:type]
                       when 'Health Insurance' then admin_health_insurance_path(policy[:policy])
                       when 'Life Insurance'   then admin_life_insurance_path(policy[:policy])
                       when 'Motor Insurance'  then admin_motor_insurance_path(policy[:policy])
                       end %>
                    <%= link_to action_view_path, class: "btn btn-sm btn-outline-primary" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center text-muted py-4">
          <i class="bi bi-calendar-check fs-3 d-block mb-2 text-success"></i>
          <p class="mb-0">No renewals or installments due in the next 45 days</p>
          <small class="text-muted">All policies and payments are up to date</small>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Upcoming Installments (Next 45 Days) -->
<%
  upcoming_installments = @all_policies&.select do |p|
          policy_obj = p[:policy]
          next false unless policy_obj.respond_to?(:payment_mode)
          next false unless ['Monthly', 'Quarterly', 'Half Yearly', 'Semi-Annual'].include?(policy_obj.payment_mode)
          next false unless p[:status] == 'Active'
          next false unless policy_obj.respond_to?(:policy_start_date) && policy_obj.policy_start_date
          start_date = policy_obj.policy_start_date
          today = Date.current
          case policy_obj.payment_mode
          when 'Monthly'
            next_date = start_date
            while next_date <= today
              next_date = next_date + 1.month
            end
          when 'Quarterly'
            next_date = start_date
            while next_date <= today
              next_date = next_date + 3.months
            end
          when 'Half Yearly', 'Semi-Annual'
            next_date = start_date
            while next_date <= today
              next_date = next_date + 6.months
            end
          else
            next false
          end
          next_date <= 45.days.from_now
        end || []
%>

<% if upcoming_installments.any? %>
<div class="info-section-card">
