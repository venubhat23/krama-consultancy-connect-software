<!-- ===== Policy Summary Sections ===== -->
<%
  ps_sections = [
    { policies: @health_policies || [],                   id: 'psSec1', icon: 'bi-heart-pulse',    color: '#e74c3c', title: 'Health Insurance' },
    { policies: @life_policies || [],                     id: 'psSec2', icon: 'bi-shield-heart',   color: '#2980b9', title: 'Life Insurance' },
    { policies: @motor_policies || [],                    id: 'psSec3', icon: 'bi-car-front',      color: '#f39c12', title: 'Motor Insurance' },
    { policies: @other_policies || [],                    id: 'psSec4', icon: 'bi-shield-check',   color: '#27ae60', title: 'Other Insurance' },
    { policies: @expired_policies || [],                  id: 'psSec5', icon: 'bi-clock',          color: '#c0392b', title: 'Expired Policy' },
    { policies: @past_policies || [],                     id: 'psSec6', icon: 'bi-clock-history',  color: '#7f8c8d', title: 'Past Policy' },
    { policies: @upcoming_installment_policies || [],     id: 'psSec7', icon: 'bi-calendar-check', color: '#8e44ad', title: 'Upcoming Installment Policy', installment: true },
    { policies: @upcoming_renewal_policies || [],         id: 'psSec8', icon: 'bi-arrow-repeat',   color: '#16a085', title: 'Upcoming Renewal Policy',     renewal: true }
  ]
%>

<% ps_sections.each do |sec| %>
<div class="info-section-card">
  <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#<%= sec[:id] %>" aria-expanded="false">
    <div class="d-flex align-items-center gap-2">
      <i class="bi <%= sec[:icon] %> fs-5" style="color:<%= sec[:color] %>; width:24px;"></i>
      <span class="fw-semibold" style="color:#1a3a5c; font-size:15px;"><%= sec[:title] %></span>
