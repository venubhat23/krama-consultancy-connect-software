<% content_for :title, "Commission Payouts" %>
<% content_for :page_header, "Commission Payouts & Transactions" %>

<div class="container-fluid">
  <!-- Payout Summary Cards -->
  <div class="row mb-4">
    <div class="col-lg-3 col-md-6 mb-3">
      <div class="card border-0 shadow-sm bg-gradient-primary text-white">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="flex-grow-1">
              <h6 class="text-white-50 mb-0">Total Payouts</h6>
              <h4 class="mb-0"><%= indian_currency(@payout_summary[:total_payouts], delimiter: ',') %></h4>
            </div>
            <div class="ms-3">
              <i class="bi bi-cash-stack bg-white bg-opacity-20 rounded-circle p-3 fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-3 col-md-6 mb-3">
      <div class="card border-0 shadow-sm bg-gradient-success text-white">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="flex-grow-1">
              <h6 class="text-white-50 mb-0">Completed</h6>
              <h4 class="mb-0"><%= indian_currency(@payout_summary[:completed_payouts], delimiter: ',') %></h4>
            </div>
            <div class="ms-3">
              <i class="bi bi-check-circle bg-white bg-opacity-20 rounded-circle p-3 fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-3 col-md-6 mb-3">
      <div class="card border-0 shadow-sm bg-gradient-warning text-white">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="flex-grow-1">
              <h6 class="text-white-50 mb-0">Pending</h6>
              <h4 class="mb-0"><%= indian_currency(@payout_summary[:pending_payouts], delimiter: ',') %></h4>
            </div>
            <div class="ms-3">
              <i class="bi bi-clock-history bg-white bg-opacity-20 rounded-circle p-3 fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-3 col-md-6 mb-3">
      <div class="card border-0 shadow-sm bg-gradient-info text-white">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="flex-grow-1">
              <h6 class="text-white-50 mb-0">Total Transactions</h6>
              <h4 class="mb-0"><%= @payout_summary[:total_count] %></h4>
            </div>
            <div class="ms-3">
              <i class="bi bi-receipt bg-white bg-opacity-20 rounded-circle p-3 fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Filter and Search -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-3 align-items-end">
        <div class="col-md-3">
          <label class="form-label">Status Filter</label>
          <select class="form-select" id="statusFilter">
            <option value="all">All Status</option>
            <option value="completed">Completed</option>
            <option value="pending">Pending</option>
            <option value="processing">Processing</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Policy Type</label>
          <select class="form-select" id="policyTypeFilter">
            <option value="all">All Types</option>
            <option value="HealthInsurance">Health Insurance</option>
            <option value="LifeInsurance">Life Insurance</option>
            <option value="MotorInsurance">Motor Insurance</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Search</label>
          <input type="text" class="form-control" id="searchInput" placeholder="Search by policy ID, customer name...">
        </div>
        <div class="col-md-2">
          <button class="btn btn-outline-primary w-100" onclick="applyFilters()">
            <i class="bi bi-funnel me-2"></i>Filter
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Payouts Table -->
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
      <h5 class="mb-0 text-primary">
        <i class="bi bi-list-ul me-2"></i>
        Commission Payout History
      </h5>
      <div class="dropdown">
        <button class="btn btn-outline-primary dropdown-toggle btn-sm" type="button" data-bs-toggle="dropdown">
          <i class="bi bi-download me-1"></i>Export
        </button>
        <ul class="dropdown-menu">
          <li><a class="dropdown-item" href="#"><i class="bi bi-file-pdf me-2"></i>PDF Report</a></li>
          <li><a class="dropdown-item" href="#"><i class="bi bi-file-excel me-2"></i>Excel Export</a></li>
          <li><a class="dropdown-item" href="#"><i class="bi bi-file-text me-2"></i>CSV Export</a></li>
        </ul>
      </div>
    </div>
    <div class="card-body p-0">
      <% if @payouts.any? %>
        <div class="table-responsive">
          <table class="table table-hover mb-0" id="payoutsTable">
            <thead class="table-light">
              <tr>
                <th class="border-0">Payout ID</th>
                <th class="border-0">Policy Type</th>
                <th class="border-0">Policy ID</th>
                <th class="border-0">Customer</th>
                <th class="border-0">Amount</th>
                <th class="border-0">Status</th>
                <th class="border-0">Date</th>
                <th class="border-0">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @payouts.each do |payout| %>
                <tr class="payout-row"
                    data-status="<%= payout.status %>"
                    data-policy-type="<%= payout.policy_type %>"
                    data-policy-id="<%= payout.policy_id %>">
                  <td>
                    <code class="bg-primary bg-opacity-10 border rounded px-2 py-1 text-primary">
                      #PY<%= payout.id.to_s.rjust(6, '0') %>
                    </code>
                  </td>
                  <td>
                    <span class="badge bg-<%= payout.policy_type == 'HealthInsurance' ? 'primary' : payout.policy_type == 'LifeInsurance' ? 'success' : 'warning' %>">
                      <%= payout.policy_type.gsub('Insurance', '') %> Insurance
                    </span>
                  </td>
                  <td>
                    <code class="bg-light border rounded px-2 py-1">#<%= payout.policy_id %></code>
                  </td>
                  <td class="customer-name">
                    <% customer_name = begin
                         case payout.policy_type
                         when 'HealthInsurance'
                           HealthInsurance.find(payout.policy_id).customer.display_name rescue 'N/A'
                         when 'LifeInsurance'
                           LifeInsurance.find(payout.policy_id).customer.display_name rescue 'N/A'
                         when 'MotorInsurance'
                           MotorInsurance.find(payout.policy_id).customer.display_name rescue 'N/A'
                         else
                           'N/A'
                         end
                       end %>
                    <div class="fw-medium"><%= customer_name %></div>
                    <small class="text-muted">Customer ID: #<%= payout.customer_id %></small>
                  </td>
                  <td>
                    <div class="fw-bold text-success fs-6">
                      <%= indian_currency(payout.payout_amount, delimiter: ',') %>
                    </div>
                  </td>
                  <td>
                    <span class="badge fs-6 bg-<%= payout.status == 'completed' ? 'success' : payout.status == 'pending' ? 'warning' : 'info' %>">
                      <i class="bi bi-<%= payout.status == 'completed' ? 'check-circle' : payout.status == 'pending' ? 'clock' : 'arrow-clockwise' %> me-1"></i>
                      <%= payout.status.humanize %>
                    </span>
                  </td>
                  <td class="text-muted">
                    <div><%= payout.created_at.strftime("%b %d, %Y") %></div>
                    <small class="text-muted"><%= payout.created_at.strftime("%I:%M %p") %></small>
                  </td>
                  <td>
                    <div class="btn-group btn-group-sm" role="group">
                      <button type="button" class="btn btn-outline-primary" title="View Details"
                              onclick="viewPayoutDetails(<%= payout.id %>)">
                        <i class="bi bi-eye"></i>
                      </button>
                      <button type="button" class="btn btn-outline-success" title="Download Receipt">
                        <i class="bi bi-download"></i>
                      </button>
                      <% if payout.status == 'pending' %>
                        <button type="button" class="btn btn-outline-info" title="Process Payout">
                          <i class="bi bi-arrow-clockwise"></i>
                        </button>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="d-flex justify-content-between align-items-center p-3 border-top">
          <div class="text-muted">
            Showing <%= @payouts.count %> of <%= @payout_summary[:total_count] %> payouts
          </div>
          <nav>
            <ul class="pagination pagination-sm mb-0">
              <li class="page-item">
                <a class="page-link" href="#" aria-label="Previous">
                  <span aria-hidden="true">&laquo;</span>
                </a>
              </li>
              <li class="page-item active"><a class="page-link" href="#">1</a></li>
              <li class="page-item"><a class="page-link" href="#">2</a></li>
              <li class="page-item"><a class="page-link" href="#">3</a></li>
              <li class="page-item">
                <a class="page-link" href="#" aria-label="Next">
                  <span aria-hidden="true">&raquo;</span>
                </a>
              </li>
            </ul>
          </nav>
        </div>
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-cash-stack text-muted" style="font-size: 4rem;"></i>
          <div class="mt-3">
            <h6 class="text-muted">No commission payouts found</h6>
            <p class="text-muted">Commission payouts will appear here once they are processed.</p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Payout Details Modal -->
<div class="modal fade" id="payoutDetailsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title text-primary">
          <i class="bi bi-receipt me-2"></i>
          Payout Details
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="payoutDetailsContent">
        <!-- Content will be loaded here -->
      </div>
    </div>
  </div>
</div>

<script>
function applyFilters() {
  const statusFilter = document.getElementById('statusFilter').value;
  const policyTypeFilter = document.getElementById('policyTypeFilter').value;
  const searchTerm = document.getElementById('searchInput').value.toLowerCase();
  const rows = document.querySelectorAll('.payout-row');

  rows.forEach(row => {
    let showRow = true;

    // Status filter
    if (statusFilter !== 'all' && row.dataset.status !== statusFilter) {
      showRow = false;
    }

    // Policy type filter
    if (policyTypeFilter !== 'all' && row.dataset.policyType !== policyTypeFilter) {
      showRow = false;
    }

    // Search filter
    if (searchTerm && !row.textContent.toLowerCase().includes(searchTerm)) {
      showRow = false;
    }

    row.style.display = showRow ? '' : 'none';
  });
}

function viewPayoutDetails(payoutId) {
  // Simulate loading payout details
  const modalContent = document.getElementById('payoutDetailsContent');
  modalContent.innerHTML = `
    <div class="text-center">
      <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
      </div>
      <div class="mt-2">Loading payout details...</div>
    </div>
  `;

  // Show modal
  const modal = new bootstrap.Modal(document.getElementById('payoutDetailsModal'));
  modal.show();

  // Simulate API call delay
  setTimeout(() => {
    modalContent.innerHTML = \`
      <div class="row">
        <div class="col-md-6">
          <h6 class="text-primary">Payout Information</h6>
          <div class="mb-3">
            <label class="form-label text-muted small">Payout ID</label>
            <div class="fw-bold">#PY\${payoutId.toString().padStart(6, '0')}</div>
          </div>
          <div class="mb-3">
            <label class="form-label text-muted small">Status</label>
            <div><span class="badge bg-success">Completed</span></div>
          </div>
          <div class="mb-3">
            <label class="form-label text-muted small">Amount</label>
            <div class="fw-bold text-success fs-5">Rs. 12,500</div>
          </div>
        </div>
        <div class="col-md-6">
          <h6 class="text-primary">Policy Information</h6>
          <div class="mb-3">
            <label class="form-label text-muted small">Policy Type</label>
            <div><span class="badge bg-primary">Health Insurance</span></div>
          </div>
          <div class="mb-3">
            <label class="form-label text-muted small">Customer</label>
            <div class="fw-bold">John Doe</div>
          </div>
          <div class="mb-3">
            <label class="form-label text-muted small">Processing Date</label>
            <div>January 15, 2025</div>
          </div>
        </div>
      </div>
      <div class="text-end pt-3 border-top">
        <button class="btn btn-outline-primary me-2">
          <i class="bi bi-download me-2"></i>Download Receipt
        </button>
        <button class="btn btn-primary">
          <i class="bi bi-printer me-2"></i>Print Details
        </button>
      </div>
    \`;
  }, 1500);
}

// Real-time search
document.getElementById('searchInput').addEventListener('input', function() {
  applyFilters();
});

// Filter change events
document.getElementById('statusFilter').addEventListener('change', applyFilters);
document.getElementById('policyTypeFilter').addEventListener('change', applyFilters);
</script>

<style>
.bg-gradient-primary {
  background: linear-gradient(45deg, #0d6efd, #6610f2);
}

.bg-gradient-success {
  background: linear-gradient(45deg, #198754, #20c997);
}

.bg-gradient-warning {
  background: linear-gradient(45deg, #ffc107, #fd7e14);
}

.bg-gradient-info {
  background: linear-gradient(45deg, #0dcaf0, #6f42c1);
}

.table-hover tbody tr:hover {
  background-color: rgba(13, 110, 253, 0.04);
  transform: scale(1.001);
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.card {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important;
}

.btn-group .btn {
  transition: all 0.2s ease;
}

.btn-group .btn:hover {
  transform: translateY(-1px);
}

.payout-row {
  transition: all 0.2s ease;
}
</style>