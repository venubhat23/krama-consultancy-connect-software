<% content_for :title, "Commission Reports" %>
<% content_for :page_header, "Commission Reports & Analytics" %>

<div class="container-fluid">
  <!-- Filter Controls -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <%= form_tag admin_commissions_reports_path, method: :get, local: true, class: "row g-3 align-items-end" do %>
        <div class="col-md-3">
          <label for="date_range" class="form-label">Date Range</label>
          <%= select_tag :date_range,
              options_for_select([
                ['This Week', 'this_week'],
                ['This Month', 'this_month'],
                ['Last Month', 'last_month'],
                ['This Year', 'this_year']
              ], @date_range),
              { class: "form-select", id: "date_range" } %>
        </div>
        <div class="col-md-3">
          <label for="policy_type" class="form-label">Policy Type</label>
          <%= select_tag :policy_type,
              options_for_select([
                ['All Types', 'all'],
                ['Health Insurance', 'HealthInsurance'],
                ['Life Insurance', 'LifeInsurance'],
                ['Motor Insurance', 'MotorInsurance']
              ], @policy_type),
              { class: "form-select", id: "policy_type" } %>
        </div>
        <div class="col-md-3">
          <label for="status_filter" class="form-label">Status</label>
          <select class="form-select" id="status_filter">
            <option value="all">All Status</option>
            <option value="completed">Completed</option>
            <option value="pending">Pending</option>
            <option value="processing">Processing</option>
          </select>
        </div>
        <div class="col-md-3">
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-funnel me-2"></i>Apply Filters
          </button>
        </div>
      <% end %>
    </div>
  </div>

  <div class="row">
    <!-- Commission Breakdown Chart -->
    <div class="col-lg-8 mb-4">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
          <h5 class="mb-0 text-primary">
            <i class="bi bi-pie-chart me-2"></i>
            Commission Breakdown by Insurance Type
          </h5>
          <div class="dropdown">
            <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
              <i class="bi bi-download"></i> Export
            </button>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="#"><i class="bi bi-file-pdf me-2"></i>PDF Report</a></li>
              <li><a class="dropdown-item" href="#"><i class="bi bi-file-excel me-2"></i>Excel Report</a></li>
              <li><a class="dropdown-item" href="#"><i class="bi bi-file-text me-2"></i>CSV Report</a></li>
            </ul>
          </div>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-8">
              <canvas id="commissionBreakdownChart" style="height: 300px;"></canvas>
            </div>
            <div class="col-md-4">
              <div class="d-flex flex-column gap-3">
                <div class="d-flex align-items-center">
                  <div class="bg-primary rounded" style="width: 20px; height: 20px;"></div>
                  <div class="ms-3">
                    <div class="fw-bold">Health Insurance</div>
                    <div class="text-muted"><%= indian_currency(@commission_breakdown[:health_insurance], delimiter: ',') %></div>
                  </div>
                </div>
                <div class="d-flex align-items-center">
                  <div class="bg-success rounded" style="width: 20px; height: 20px;"></div>
                  <div class="ms-3">
                    <div class="fw-bold">Life Insurance</div>
                    <div class="text-muted"><%= indian_currency(@commission_breakdown[:life_insurance], delimiter: ',') %></div>
                  </div>
                </div>
                <div class="d-flex align-items-center">
                  <div class="bg-warning rounded" style="width: 20px; height: 20px;"></div>
                  <div class="ms-3">
                    <div class="fw-bold">Motor Insurance</div>
                    <div class="text-muted"><%= indian_currency(@commission_breakdown[:motor_insurance], delimiter: ',') %></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Summary Stats -->
    <div class="col-lg-4 mb-4">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0">
          <h5 class="mb-0 text-primary">
            <i class="bi bi-graph-up-arrow me-2"></i>
            Performance Summary
          </h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-12">
              <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded">
                <div>
                  <div class="text-muted small">Total Commission</div>
                  <div class="fw-bold fs-5"><%= indian_currency(@commission_breakdown.values.sum, delimiter: ',') %></div>
                </div>
                <i class="bi bi-currency-rupee text-primary fs-3"></i>
              </div>
            </div>
            <div class="col-12">
              <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded">
                <div>
                  <div class="text-muted small">Average per Policy</div>
                  <div class="fw-bold fs-5">
                    <%= indian_currency(@commission_reports.any? ? (@commission_breakdown.values.sum / @commission_reports.count.to_f) : 0) %>
                  </div>
                </div>
                <i class="bi bi-calculator text-success fs-3"></i>
              </div>
            </div>
            <div class="col-12">
              <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded">
                <div>
                  <div class="text-muted small">Total Policies</div>
                  <div class="fw-bold fs-5"><%= @commission_reports.count %></div>
                </div>
                <i class="bi bi-shield-check text-info fs-3"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Detailed Commission Table -->
  <div class="row">
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0">
          <h5 class="mb-0 text-primary">
            <i class="bi bi-table me-2"></i>
            Detailed Commission Records
          </h5>
        </div>
        <div class="card-body p-0">
          <% if @commission_reports.any? %>
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead class="table-light">
                  <tr>
                    <th class="border-0">Policy Type</th>
                    <th class="border-0">Policy ID</th>
                    <th class="border-0">Customer</th>
                    <th class="border-0">Commission Amount</th>
                    <th class="border-0">Status</th>
                    <th class="border-0">Date</th>
                    <th class="border-0">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @commission_reports.each do |report| %>
                    <tr>
                      <td>
                        <span class="badge bg-<%= report.policy_type == 'HealthInsurance' ? 'primary' : report.policy_type == 'LifeInsurance' ? 'success' : 'warning' %>">
                          <%= report.policy_type.gsub('Insurance', '') %>
                        </span>
                      </td>
                      <td>
                        <code class="bg-light border rounded px-2 py-1">#<%= report.policy_id %></code>
                      </td>
                      <td>
                        <% customer_name = begin
                             case report.policy_type
                             when 'HealthInsurance'
                               HealthInsurance.find(report.policy_id).customer.display_name rescue 'N/A'
                             when 'LifeInsurance'
                               LifeInsurance.find(report.policy_id).customer.display_name rescue 'N/A'
                             when 'MotorInsurance'
                               MotorInsurance.find(report.policy_id).customer.display_name rescue 'N/A'
                             else
                               'N/A'
                             end
                           end %>
                        <%= customer_name %>
                      </td>
                      <td class="fw-bold text-success"><%= indian_currency(report.payout_amount, delimiter: ',') %></td>
                      <td>
                        <span class="badge bg-<%= report.status == 'completed' ? 'success' : report.status == 'pending' ? 'warning' : 'info' %>">
                          <%= report.status.humanize %>
                        </span>
                      </td>
                      <td class="text-muted">
                        <%= report.created_at.strftime("%b %d, %Y") %>
                      </td>
                      <td>
                        <div class="btn-group btn-group-sm">
                          <button class="btn btn-outline-primary btn-sm" title="View Details">
                            <i class="bi bi-eye"></i>
                          </button>
                          <button class="btn btn-outline-success btn-sm" title="Download Receipt">
                            <i class="bi bi-download"></i>
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-5">
              <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
              <div class="mt-3">
                <h6 class="text-muted">No commission records found</h6>
                <p class="text-muted">Commission records matching your criteria will appear here.</p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Commission Breakdown Chart
  const ctx = document.getElementById('commissionBreakdownChart').getContext('2d');
  const breakdownData = {
    health: <%= @commission_breakdown[:health_insurance] %>,
    life: <%= @commission_breakdown[:life_insurance] %>,
    motor: <%= @commission_breakdown[:motor_insurance] %>
  };

  new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['Health Insurance', 'Life Insurance', 'Motor Insurance'],
      datasets: [{
        data: [breakdownData.health, breakdownData.life, breakdownData.motor],
        backgroundColor: ['#0d6efd', '#198754', '#ffc107'],
        borderWidth: 2,
        borderColor: '#fff'
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        },
        tooltip: {
          callbacks: {
            label: function(context) {
              const value = context.parsed;
              return context.label + ': Rs. ' + value.toLocaleString();
            }
          }
        }
      }
    }
  });

  // Status filter functionality
  document.getElementById('status_filter').addEventListener('change', function() {
    const selectedStatus = this.value;
    const rows = document.querySelectorAll('tbody tr');

    rows.forEach(row => {
      if (selectedStatus === 'all') {
        row.style.display = '';
      } else {
        const statusBadge = row.querySelector('td:nth-child(5) .badge');
        const statusText = statusBadge.textContent.toLowerCase().trim();

        if (statusText.includes(selectedStatus.toLowerCase())) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      }
    });
  });
});
</script>

<style>
.table-hover tbody tr:hover {
  background-color: rgba(0,0,0,0.02);
}

.card {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important;
}

.btn-group-sm .btn {
  transition: all 0.2s ease;
}

.btn-group-sm .btn:hover {
  transform: translateY(-1px);
}
</style>