<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Family Members</h2>
    <p class="text-muted mb-0">Family members of <%= @customer.display_name %></p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to new_admin_customer_family_member_path(@customer), class: "btn btn-primary" do %>
      <i class="bi bi-plus me-1"></i>
      Add Family Member
    <% end %>
    <%= link_to admin_customer_path(@customer), class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>
      Back to Customer
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-lg">
  <% if @family_members.any? %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0" style="border: 2px solid #dee2e6; border-radius: 0.5rem; overflow: hidden;">
        <thead style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
          <tr>
            <th style="border-right: 1px solid rgba(255,255,255,0.2); padding: 15px; font-weight: 600;">Name</th>
            <th style="border-right: 1px solid rgba(255,255,255,0.2); padding: 15px; font-weight: 600;">Relationship</th>
            <th style="border-right: 1px solid rgba(255,255,255,0.2); padding: 15px; font-weight: 600;">Birth Date</th>
            <th style="border-right: 1px solid rgba(255,255,255,0.2); padding: 15px; font-weight: 600;">Age</th>
            <th style="border-right: 1px solid rgba(255,255,255,0.2); padding: 15px; font-weight: 600;">Gender</th>
            <th style="border-right: 1px solid rgba(255,255,255,0.2); padding: 15px; font-weight: 600;">Mobile</th>
            <th style="padding: 15px; font-weight: 600; text-align: center;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @family_members.each_with_index do |family_member, index| %>
            <tr style="border-bottom: 1px solid #e9ecef; transition: all 0.3s ease;" onmouseover="this.style.backgroundColor='#f8f9fa'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 8px rgba(0,0,0,0.1)'" onmouseout="this.style.backgroundColor=''; this.style.transform=''; this.style.boxShadow=''">
              <td style="border-right: 1px solid #e9ecef; padding: 15px; vertical-align: middle;">
                <%= link_to admin_customer_family_member_path(@customer, family_member), class: "text-decoration-none fw-semibold" style="color: #495057;" do %>
                  <i class="bi bi-person-circle me-2" style="color: #6c757d;"></i><%= family_member.name %>
                <% end %>
              </td>
              <td style="border-right: 1px solid #e9ecef; padding: 15px; vertical-align: middle;">
                <span class="badge bg-gradient" style="background: linear-gradient(135deg, #28a745, #20c997); padding: 8px 12px; border-radius: 20px; font-size: 0.85rem;"><%= family_member.relationship.humanize %></span>
              </td>
              <td style="border-right: 1px solid #e9ecef; padding: 15px; vertical-align: middle; color: #6c757d;">
                <i class="bi bi-calendar3 me-1"></i><%= family_member.birth_date&.strftime("%b %d, %Y") %>
              </td>
              <td style="border-right: 1px solid #e9ecef; padding: 15px; vertical-align: middle;">
                <span class="badge bg-light text-dark border" style="padding: 6px 10px; border-radius: 15px;"><%= family_member.age %> years</span>
              </td>
              <td style="border-right: 1px solid #e9ecef; padding: 15px; vertical-align: middle;">
                <span class="<%= family_member.gender&.downcase == 'male' ? 'text-primary' : 'text-danger' %> fw-semibold">
                  <i class="bi bi-<%= family_member.gender&.downcase == 'male' ? 'person-standing' : 'person-standing-dress' %> me-1"></i><%= family_member.gender&.humanize %>
                </span>
              </td>
              <td style="border-right: 1px solid #e9ecef; padding: 15px; vertical-align: middle;">
                <% if family_member.mobile.present? %>
                  <a href="tel:<%= family_member.mobile %>" class="text-decoration-none" style="color: #0d6efd;">
                    <i class="bi bi-telephone me-1"></i><%= family_member.mobile %>
                  </a>
                <% else %>
                  <span class="text-muted">-</span>
                <% end %>
              </td>
              <td style="padding: 15px; vertical-align: middle; text-align: center;">
                <div class="d-flex gap-2 justify-content-center">
                  <%= link_to admin_customer_family_member_path(@customer, family_member), class: "btn btn-sm", style: "background: linear-gradient(135deg, #17a2b8, #138496); color: white; border: none; border-radius: 20px; padding: 8px 12px; transition: all 0.3s ease;" do %>
                    <i class="bi bi-eye"></i>
                  <% end %>
                  <%= link_to edit_admin_customer_family_member_path(@customer, family_member), class: "btn btn-sm", style: "background: linear-gradient(135deg, #ffc107, #e0a800); color: white; border: none; border-radius: 20px; padding: 8px 12px; transition: all 0.3s ease;" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <%= link_to admin_customer_family_member_path(@customer, family_member), method: :delete,
                      class: "btn btn-sm",
                      style: "background: linear-gradient(135deg, #dc3545, #c82333); color: white; border: none; border-radius: 20px; padding: 8px 12px; transition: all 0.3s ease;",
                      data: { confirm: "Are you sure?", turbo_method: :delete } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card-body text-center py-5">
      <i class="bi bi-people fs-1 text-muted d-block mb-3"></i>
      <h5>No Family Members</h5>
      <p class="text-muted mb-4">No family members have been added for this customer yet.</p>
      <%= link_to new_admin_customer_family_member_path(@customer), class: "btn btn-primary" do %>
        <i class="bi bi-plus me-1"></i>
        Add First Family Member
      <% end %>
    </div>
  <% end %>
</div>