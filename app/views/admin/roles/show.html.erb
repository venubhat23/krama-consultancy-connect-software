<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @role.display_name %></h2>
    <p class="text-muted mb-0">Role details and assigned users</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_role_path(@role), class: "btn btn-outline-warning" do %>
      <i class="bi bi-pencil me-1"></i>
      Edit Role
    <% end %>
    <%= link_to admin_roles_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>
      Back to Roles
    <% end %>
  </div>
</div>

<!-- Role Info Card -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Role Information</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-3 fw-semibold text-muted">Name</div>
      <div class="col-md-9"><%= @role.display_name %></div>
    </div>
    <hr>
    <div class="row">
      <div class="col-md-3 fw-semibold text-muted">Description</div>
      <div class="col-md-9"><%= @role.description.present? ? @role.description : 'No description provided' %></div>
    </div>
    <hr>
    <div class="row">
      <div class="col-md-3 fw-semibold text-muted">Status</div>
      <div class="col-md-9">
        <span class="badge bg-<%= @role.status? ? 'success' : 'secondary' %>">
          <%= @role.status? ? 'Active' : 'Inactive' %>
        </span>
      </div>
    </div>
  </div>
</div>

<!-- Assigned Users -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Assigned Users (<%= @users.count %>)</h5>
  </div>
  <div class="card-body p-0">
    <% if @users.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light">
            <tr>
              <th class="border-0">Name</th>
              <th class="border-0">Email</th>
              <th class="border-0">Type</th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <tr>
                <td><%= user.full_name %></td>
                <td><%= user.email %></td>
                <td><%= user.user_type&.humanize %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-4">
        <p class="text-muted mb-0">No users assigned to this role.</p>
      </div>
    <% end %>
  </div>
</div>

<!-- Permissions -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Permissions (<%= @role.permissions.count %>)</h5>
  </div>
  <div class="card-body">
    <% if @permissions.any? %>
      <% @permissions.each do |module_name, perms| %>
        <div class="mb-3">
          <h6 class="text-primary"><%= module_name.humanize %></h6>
          <div class="d-flex flex-wrap gap-2">
            <% perms.each do |perm| %>
              <span class="badge bg-secondary"><%= perm.action_type %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-muted mb-0">No permissions assigned to this role.</p>
    <% end %>
  </div>
</div>
