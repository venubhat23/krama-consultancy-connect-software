function updateFilters() {
  const reportType = document.getElementById('reportType').value;
  const filtersDiv = document.getElementById('dynamicFilters');

  // Clear existing filters
  filtersDiv.innerHTML = '';

  // Add report-specific filters
  switch(reportType) {
    case 'commission':
      filtersDiv.innerHTML = `
        <div class="mb-3">
          <label class="form-label">Insurance Type</label>
          <select class="form-select" id="insuranceType">
            <option value="">All Types</option>
            <option value="life">Life Insurance</option>
            <option value="health">Health Insurance</option>
            <option value="motor">Motor Insurance</option>
          </select>
        </div>
      `;
      break;
    case 'leads':
      filtersDiv.innerHTML = `
        <div class="mb-3">
          <label class="form-label">Lead Status</label>
          <select class="form-select" id="leadStatus">
            <option value="">All Status</option>
            <option value="new">New</option>
            <option value="contacted">Contacted</option>
            <option value="qualified">Qualified</option>
            <option value="converted">Converted</option>
          </select>
        </div>
      `;
      break;
  }
}

// Quick Report Generation Function
function generateQuickReport(reportType) {
  // Close the quick report modal
  const quickModal = bootstrap.Modal.getInstance(document.getElementById('quickReportModal'));
  if (quickModal) {
    quickModal.hide();
  }

  // Set the report type in the form
  document.getElementById('reportType').value = reportType;

  // Generate the report automatically
  generateReport(reportType);

  // Add a message to the chat
  addMessageToChat('user', `Generate ${reportType.replace('_', ' ')} report`, []);
  addMessageToChat('ai', `🚀 Generating ${reportType.replace('_', ' ')} report for you...`, []);
}
