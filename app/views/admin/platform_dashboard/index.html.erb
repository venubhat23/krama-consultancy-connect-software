<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.min.js"></script>

<style>
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .kpi-card {
    background: var(--bs-body-bg, white);
    border-radius: 14px;
    border: 1px solid rgba(0,0,0,0.08);
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: all 0.2s ease;
  }
  .kpi-card:hover { box-shadow: 0 8px 20px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .kpi-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
    background: var(--card-color);
  }
  .kpi-icon {
    width: 3rem; height: 3rem; border-radius: 12px; display: flex; align-items: center;
    justify-content: center; font-size: 1.4rem; color: white; margin-bottom: 1rem;
    background: var(--card-color);
  }
  .kpi-value { font-size: 1.9rem; font-weight: 700; line-height: 1; margin-bottom: 0.35rem; }
  .kpi-label { color: #6b7280; font-weight: 500; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; }
  [data-theme="dark"] .kpi-card { background: rgba(30, 33, 48, 0.6); border-color: rgba(255,255,255,0.08); }
  [data-theme="dark"] .kpi-label { color: rgba(255,255,255,0.6); }
  .chart-card { background: var(--bs-body-bg, white); border-radius: 14px; border: 1px solid rgba(0,0,0,0.08); padding: 1.25rem; margin-bottom: 1.5rem; }
  [data-theme="dark"] .chart-card { background: rgba(30, 33, 48, 0.6); border-color: rgba(255,255,255,0.08); }
</style>

<div class="mb-4">
  <h2 class="mb-1">Platform Dashboard</h2>
  <p class="text-muted mb-0">Krama Consultancy — overview across every forum</p>
</div>

<div class="kpi-grid">
  <div class="kpi-card" style="--card-color: #3b82f6;">
    <div class="kpi-icon"><i class="bi bi-diagram-3"></i></div>
    <div class="kpi-value"><%= @total_forums %></div>
    <div class="kpi-label">Total Forums</div>
  </div>
  <div class="kpi-card" style="--card-color: #10b981;">
    <div class="kpi-icon"><i class="bi bi-people-fill"></i></div>
    <div class="kpi-value"><%= number_with_delimiter(@total_members) %></div>
    <div class="kpi-label">Total Members</div>
  </div>
  <div class="kpi-card" style="--card-color: #8b5cf6;">
    <div class="kpi-icon"><i class="bi bi-diagram-2"></i></div>
    <div class="kpi-value"><%= @total_chapters %></div>
    <div class="kpi-label">Chapters</div>
  </div>
  <div class="kpi-card" style="--card-color: #f59e0b;">
    <div class="kpi-icon"><i class="bi bi-cash-coin"></i></div>
    <div class="kpi-value">₹<%= number_with_delimiter(@mrr.to_i) %></div>
    <div class="kpi-label">Monthly Recurring Revenue</div>
  </div>
  <div class="kpi-card" style="--card-color: #ef4444;">
    <div class="kpi-icon"><i class="bi bi-inbox"></i></div>
    <div class="kpi-value"><%= @pending_requests %></div>
    <div class="kpi-label">Pending Forum Requests</div>
  </div>
  <div class="kpi-card" style="--card-color: #06b6d4;">
    <div class="kpi-icon"><i class="bi bi-life-preserver"></i></div>
    <div class="kpi-value"><%= @open_tickets %></div>
    <div class="kpi-label">Open Support Tickets</div>
  </div>
</div>

<div class="row">
  <div class="col-lg-7">
    <div class="chart-card">
      <h6 class="mb-3">Member Growth (last 6 months)</h6>
      <canvas id="memberGrowthChart" height="110"></canvas>
    </div>
  </div>
  <div class="col-lg-5">
    <div class="chart-card">
      <h6 class="mb-3">Forums by Plan</h6>
      <canvas id="forumsByPlanChart" height="110"></canvas>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Recent Forum Requests</h5>
        <%= link_to "View all", admin_forum_requests_path, class: "small" %>
      </div>
      <div class="card-body">
        <% if @recent_requests.any? %>
          <% @recent_requests.each do |req| %>
            <div class="d-flex justify-content-between border-bottom py-2">
              <span><%= link_to req.company_name, admin_forum_request_path(req) %></span>
              <span class="badge bg-<%= { 'pending' => 'warning', 'approved' => 'success', 'rejected' => 'secondary' }[req.status] %>"><%= req.status.humanize %></span>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">No requests yet.</p>
        <% end %>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Open Support Tickets</h5>
        <%= link_to "View all", admin_platform_support_tickets_path, class: "small" %>
      </div>
      <div class="card-body">
        <% if @recent_tickets.any? %>
          <% @recent_tickets.each do |t| %>
            <div class="d-flex justify-content-between border-bottom py-2">
              <span><%= link_to t.subject, admin_platform_support_ticket_path(t) %></span>
              <small class="text-muted"><%= t.forum&.name %></small>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">No open tickets. 🎉</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const gridColor = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
    const textColor = isDark ? 'rgba(255,255,255,0.75)' : '#495057';

    new Chart(document.getElementById('memberGrowthChart'), {
      type: 'line',
      data: {
        labels: <%= raw @member_growth.keys.map { |d| d.strftime("%b %Y") }.to_json %>,
        datasets: [{
          label: 'New Members',
          data: <%= raw @member_growth.values.to_json %>,
          borderColor: '#3b82f6',
          backgroundColor: 'rgba(59, 130, 246, 0.15)',
          tension: 0.35,
          fill: true
        }]
      },
      options: {
        plugins: { legend: { display: false } },
        scales: {
          x: { ticks: { color: textColor }, grid: { color: gridColor } },
          y: { ticks: { color: textColor, precision: 0 }, grid: { color: gridColor }, beginAtZero: true }
        }
      }
    });

    new Chart(document.getElementById('forumsByPlanChart'), {
      type: 'doughnut',
      data: {
        labels: <%= raw @forums_by_plan.keys.to_json %>,
        datasets: [{
          data: <%= raw @forums_by_plan.values.to_json %>,
          backgroundColor: ['#f59e0b', '#94a3b8', '#fbbf24', '#3b82f6', '#8b5cf6']
        }]
      },
      options: {
        plugins: { legend: { position: 'bottom', labels: { color: textColor } } }
      }
    });
  });
</script>
