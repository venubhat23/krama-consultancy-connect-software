<div class="mb-4">
  <h2 class="mb-1">Support Tickets</h2>
  <p class="text-muted mb-0">All tickets across every forum</p>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-2">
    <div class="btn-group">
      <%= link_to "All", admin_platform_support_tickets_path, class: "btn btn-sm btn-outline-secondary #{'active' unless params[:status].present?}" %>
      <% %w[open in_progress resolved closed].each do |s| %>
        <%= link_to s.humanize, admin_platform_support_tickets_path(status: s), class: "btn btn-sm btn-outline-secondary #{'active' if params[:status] == s}" %>
      <% end %>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if @tickets.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light">
            <tr><th class="border-0">Subject</th><th class="border-0">Raised By</th><th class="border-0">Forum</th><th class="border-0">Priority</th><th class="border-0">Status</th></tr>
          </thead>
          <tbody>
            <% @tickets.each do |t| %>
              <tr>
                <td><%= link_to t.subject, admin_platform_support_ticket_path(t), class: "text-decoration-none fw-medium" %></td>
                <td><%= t.raised_by.full_name %> <small class="text-muted">(<%= t.raised_by.user_type.humanize %>)</small></td>
                <td><%= t.forum&.name || "—" %></td>
                <td><span class="badge bg-<%= { 'low' => 'secondary', 'medium' => 'info', 'high' => 'danger' }[t.priority] %>-subtle text-<%= { 'low' => 'secondary', 'medium' => 'info', 'high' => 'danger' }[t.priority] %>"><%= t.priority.humanize %></span></td>
                <td><span class="badge bg-<%= { 'open' => 'warning', 'in_progress' => 'primary', 'resolved' => 'success', 'closed' => 'secondary' }[t.status] %>"><%= t.status.humanize %></span></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-transparent border-0">
        <%= render "shared/pagination", records: @tickets %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-life-preserver fs-1 text-muted d-block mb-3"></i>
        <h5 class="text-muted">No support tickets</h5>
      </div>
    <% end %>
  </div>
</div>
