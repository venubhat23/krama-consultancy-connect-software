<% content_for :title, "Appointment — #{@appointment.customer_name}" %>

<% colors = ['#667eea','#764ba2','#f093fb','#43e97b','#f5576c','#4facfe','#fa709a','#30cfd0'] %>
<% color = colors[@appointment.id % colors.length] %>

<div class="d-flex align-items-center gap-3 mb-4">
  <div style="width:60px;height:60px;border-radius:16px;background:<%= color %>22;color:<%= color %>;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:700;">
    <%= @appointment.customer_name.split.map(&:first).first(2).join.upcase %>
  </div>
  <div>
    <h5 class="mb-0 fw-bold"><%= @appointment.customer_name %></h5>
    <% if @appointment.customer_email.present? %>
      <small class="text-muted"><i class="bi bi-envelope me-1"></i><%= @appointment.customer_email %></small>
    <% end %>
  </div>
  <span class="ms-auto badge bg-<%= @appointment.status_color %>" style="font-size:0.8rem;padding:6px 14px;border-radius:20px;">
    <%= @appointment.status.capitalize %>
  </span>
</div>

<div class="row g-3 mb-3">
  <div class="col-6">
    <div style="background:#f9fafb;border-radius:12px;padding:12px 16px;">
      <div style="font-size:0.72rem;color:#9ca3af;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">Date</div>
      <div class="fw-semibold mt-1"><%= @appointment.appointment_date.strftime('%A, %d %B %Y') %></div>
    </div>
  </div>
  <div class="col-6">
    <div style="background:#f9fafb;border-radius:12px;padding:12px 16px;">
      <div style="font-size:0.72rem;color:#9ca3af;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">Time</div>
      <div class="fw-semibold mt-1"><i class="bi bi-clock me-1" style="color:#667eea;"></i><%= @appointment.time_slot %></div>
    </div>
  </div>
  <% if @appointment.customer_phone.present? %>
    <div class="col-6">
      <div style="background:#f9fafb;border-radius:12px;padding:12px 16px;">
        <div style="font-size:0.72rem;color:#9ca3af;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">Phone</div>
        <div class="fw-semibold mt-1"><%= @appointment.customer_phone %></div>
      </div>
    </div>
  <% end %>
  <% if @appointment.meeting_agenda.present? %>
    <div class="col-12">
      <div style="background:#f9fafb;border-radius:12px;padding:12px 16px;">
        <div style="font-size:0.72rem;color:#9ca3af;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">Meeting Agenda</div>
        <div class="mt-1"><%= @appointment.meeting_agenda %></div>
      </div>
    </div>
  <% end %>
  <% if @appointment.notes.present? %>
    <div class="col-12">
      <div style="background:#f9fafb;border-radius:12px;padding:12px 16px;">
        <div style="font-size:0.72rem;color:#9ca3af;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">Notes</div>
        <div class="mt-1 text-muted small"><%= @appointment.notes %></div>
      </div>
    </div>
  <% end %>
</div>

<div class="d-flex gap-2">
  <%= link_to edit_admin_appointment_path(@appointment),
      onclick: "var m=document.getElementById('appointmentDetailModal');if(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();}",
      class: "btn btn-sm btn-outline-primary rounded-pill px-3" do %>
    <i class="bi bi-pencil me-1"></i>Edit
  <% end %>
  <%= link_to admin_appointment_path(@appointment), method: :delete,
      data: { confirm: 'Delete this appointment?' },
      onclick: "var m=document.getElementById('appointmentDetailModal');if(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();}",
      class: "btn btn-sm btn-outline-danger rounded-pill px-3" do %>
    <i class="bi bi-trash me-1"></i>Delete
  <% end %>
</div>
