<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @business_plan.name %> Plan</h2>
    <p class="text-muted mb-0">₹<%= number_with_delimiter(@business_plan.price) %> · <%= @business_plan.unlimited_chapters? ? "Unlimited" : @business_plan.chapter_limit %> chapters · <%= @business_plan.unlimited_members? ? "Unlimited" : @business_plan.member_limit %> members</p>
  </div>
  <%= link_to edit_admin_business_plan_path(@business_plan), class: "btn btn-outline-primary" do %>
    <i class="bi bi-pencil me-1"></i> Edit
  <% end %>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Forums on this plan</h5>
  </div>
  <div class="card-body p-0">
    <% if @forums.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light">
            <tr><th class="border-0">Forum</th><th class="border-0">Status</th></tr>
          </thead>
          <tbody>
            <% @forums.each do |forum| %>
              <tr>
                <td><%= link_to forum.name, admin_forum_path(forum) %></td>
                <td>
                  <span class="badge bg-<%= forum.active? ? 'success' : 'secondary' %>"><%= forum.status.humanize %></span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-4 text-muted">No forums on this plan yet.</div>
    <% end %>
  </div>
</div>
