<!-- Include Location Data -->
<script>
<%= File.read(Rails.root.join('app/assets/javascripts/location_data.js')).html_safe %>
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Initialize searchable state-city dropdowns
  const stateSelect = document.getElementById('distributor_state');
  const citySelect = document.getElementById('distributor_city');
  const currentCityId = '<%= @distributor.city_id %>';

  // Use global location data
  let citiesData = {};
  if (window.LocationData && window.LocationData.states) {
    citiesData = Object.keys(window.LocationData.states).reduce((acc, key) => {
      acc[key] = window.LocationData.states[key].cities;
      return acc;
    }, {});
  }

  function loadCitiesForState(stateValue, selectedCityValue = null) {
    console.log('Loading cities for distributor state:', stateValue);
    if (!stateValue) {
      populateCityDropdown([], selectedCityValue);
      citySelect.disabled = true;
      return;
    }

    // Get cities for this state from local data
    let cities = citiesData[stateValue] || [];
    populateCityDropdown(cities, selectedCityValue);
  }

  function populateCityDropdown(cities, selectedCityValue = null) {
    // First destroy Select2 if it exists
    const $citySelect = $(citySelect);
    if ($citySelect.hasClass('select2-hidden-accessible')) {
      $citySelect.select2('destroy');
    }

    // Clear dropdown and add cities
    citySelect.innerHTML = '<option value="">Select City</option>';
    cities.forEach(city => {
      const option = document.createElement('option');
      option.value = city.value || city;
      option.textContent = city.text || city;
      if ((city.value || city) == selectedCityValue) {
        option.selected = true;
      }
      citySelect.appendChild(option);
    });

    citySelect.disabled = false;
    console.log(`Loaded ${cities.length} cities for distributor`);

    // Reinitialize Select2
    setTimeout(() => {
      $citySelect.select2({
        theme: 'bootstrap-5',
        placeholder: 'Search and select city...',
        allowClear: true,
        width: '100%',
        minimumResultsForSearch: 0
      });

      // Set the selected value after Select2 initialization
      if (selectedCityValue) {
        $citySelect.val(selectedCityValue).trigger('change');
      }
    }, 50);
  }

  // Initialize Select2 for state and city dropdowns
  if (typeof $ !== 'undefined' && $.fn.select2) {
    $(stateSelect).select2({
      theme: 'bootstrap-5',
      placeholder: 'Search and select state...',
      allowClear: true,
      width: '100%',
      minimumResultsForSearch: 0
    });

    $(citySelect).select2({
      theme: 'bootstrap-5',
      placeholder: 'Search and select city...',
      allowClear: true,
      width: '100%',
      minimumResultsForSearch: 0
    });
  }

  // Handle state change
  stateSelect.addEventListener('change', function() {
    loadCitiesForState(this.value);
  });

  // Handle Select2 change event specifically
  $('#distributor_state').on('select2:select', function (e) {
    const selectedValue = e.params.data.id;
    loadCitiesForState(selectedValue);
  });

  // Load cities if state is pre-selected (for edit page auto-fill)
  const savedState = '<%= @distributor.state %>';
  const savedCity = '<%= @distributor.city %>';

  console.log('Initializing distributor edit form with saved state:', savedState, 'and city:', savedCity);

  // Initialize properly with saved values
  setTimeout(() => {
    console.log('Starting distributor edit form initialization...');
    console.log('Distributor state select value:', stateSelect.value);

    // If state has a value, load cities
    if (stateSelect.value || savedState) {
      const stateToUse = stateSelect.value || savedState;
      console.log('Loading cities for state:', stateToUse);

      // Set state value if not already set
      if (!stateSelect.value && savedState) {
        stateSelect.value = savedState;
        $('#distributor_state').val(savedState).trigger('change.select2');
      }

      // Load cities with proper saved city handling
      loadCitiesForStateWithCity(stateToUse, savedCity);
    } else if (savedCity) {
      // If there's a saved city but no state, still show it
      console.log('Saved city exists without state, adding it manually');
      const $citySelect = $(citySelect);
      citySelect.disabled = false;

      // Add the saved city option
      const option = document.createElement('option');
      option.value = savedCity;
      option.textContent = savedCity;
      option.selected = true;
      citySelect.appendChild(option);

      // Reinitialize Select2
      setTimeout(() => {
        if ($citySelect.hasClass('select2-hidden-accessible')) {
          $citySelect.select2('destroy');
        }
        $citySelect.select2({
          theme: 'bootstrap-5',
          placeholder: 'Search and select city...',
          allowClear: true,
          width: '100%',
          minimumResultsForSearch: 0
        });
        $citySelect.val(savedCity).trigger('change.select2');
      }, 100);
    }
  }, 200);

  function loadCitiesForStateWithCity(stateValue, selectedCityName = null) {
    console.log('Loading cities for distributor state:', stateValue, 'with city name:', selectedCityName);
    if (!stateValue) {
      populateCityDropdownWithCity([], selectedCityName);
      citySelect.disabled = true;
      return;
    }

    // Get cities for this state from local data
    let cities = citiesData[stateValue] || [];
    populateCityDropdownWithCity(cities, selectedCityName);
  }

  function populateCityDropdownWithCity(cities, selectedCityName = null) {
    // First destroy Select2 if it exists
    const $citySelect = $(citySelect);
    if ($citySelect.hasClass('select2-hidden-accessible')) {
      $citySelect.select2('destroy');
    }

    // Clear dropdown and add cities
    citySelect.innerHTML = '<option value="">Select City</option>';

    let selectedCityFound = false;

    cities.forEach(city => {
      const option = document.createElement('option');
      option.value = city.value || city;
      option.textContent = city.text || city;
      if (selectedCityName && (city.value || city) === selectedCityName) {
        option.selected = true;
        selectedCityFound = true;
      }
      citySelect.appendChild(option);
    });

    // If selected city wasn't found in the list but exists, add it as an option
    if (selectedCityName && !selectedCityFound) {
      const option = document.createElement('option');
      option.value = selectedCityName;
      option.textContent = selectedCityName;
      option.selected = true;
      citySelect.appendChild(option);
      selectedCityFound = true;
      console.log('Added saved city as additional option:', selectedCityName);
    }

    citySelect.disabled = false;
    console.log(`Loaded ${cities.length} cities for distributor, selected: ${selectedCityName}, found: ${selectedCityFound}`);

    // Reinitialize Select2
    setTimeout(() => {
      $citySelect.select2({
        theme: 'bootstrap-5',
        placeholder: 'Search and select city...',
        allowClear: true,
        width: '100%',
        minimumResultsForSearch: 0
      });

      // Set the selected value after Select2 initialization
      if (selectedCityName && selectedCityFound) {
        $citySelect.val(selectedCityName).trigger('change.select2');
      }
    }, 50);
  }

  // Document management
  let documentIndex = <%= @distributor.distributor_documents.size %>;
  const addDocumentBtn = document.getElementById('add_document');
  const documentsContainer = document.getElementById('documents_container');
  const noDocumentsMessage = document.getElementById('no-documents-message');

  addDocumentBtn?.addEventListener('click', function() {
    // Hide the no documents message if it exists
    if (noDocumentsMessage) {
      noDocumentsMessage.style.display = 'none';
    }

    const documentHtml = `
      <div class="document-entry p-3 mb-3 position-relative animate-in" data-index="${documentIndex}">
        <button type="button" class="btn btn-sm btn-danger remove-btn remove-document" title="Remove this document">
          <i class="bi bi-x-lg"></i>
        </button>
        <div class="row align-items-end">
          <div class="col-md-5">
            <label class="form-label">
              <i class="bi bi-file-earmark-text me-1"></i>Document Type <span class="text-danger">*</span>
            </label>
            <select name="distributor[distributor_documents_attributes][${documentIndex}][document_type]"
                    class="form-select" required>
              <option value="">Select Document Type</option>
              <option value="Aadhaar Card">Aadhaar Card</option>
              <option value="Pancard">Pancard</option>
              <option value="Driving License">Driving License</option>
              <option value="Mediclaim">Mediclaim</option>
              <option value="RC Book">RC Book</option>
              <option value="Other File">Other File</option>
            </select>
          </div>
          <div class="col-md-7">
            <label class="form-label">
              <i class="bi bi-upload me-1"></i>Upload File <span class="text-danger">*</span>
            </label>
            <input type="file"
                   name="distributor[distributor_documents_attributes][${documentIndex}][document_file]"
                   class="form-control"
                   accept="image/*,application/pdf"
                   required>
            <small class="text-muted mt-1">Supported: JPG, PNG, PDF (Max 10MB)</small>
          </div>
        </div>
      </div>
    `;
    documentsContainer.insertAdjacentHTML('beforeend', documentHtml);

    // Add animation
    setTimeout(() => {
      const newEntry = documentsContainer.lastElementChild;
      if (newEntry) {
        newEntry.classList.add('show');
      }
    }, 10);

    documentIndex++;
  });

  // Event delegation for remove buttons with animation
  document.addEventListener('click', function(e) {
    if (e.target.closest('.remove-document')) {
      const entry = e.target.closest('.document-entry');
      if (entry) {
        entry.style.transition = 'all 0.3s ease';
        entry.style.transform = 'translateX(100%)';
        entry.style.opacity = '0';
        setTimeout(() => {
          entry.remove();
          // Show no documents message if all removed
          const remainingDocs = documentsContainer.querySelectorAll('.document-entry');
          if (remainingDocs.length === 0 && noDocumentsMessage) {
            noDocumentsMessage.style.display = 'block';
          }
        }, 300);
      }
    }
  });
});

// Function to immediately delete distributor documents
function markDocumentForDeletion(documentId) {
  const documentCard = document.getElementById('document_card_' + documentId);

  if (!documentCard) return;

  const message = 'Are you sure you want to permanently delete this document? This action cannot be undone.';

  if (confirm(message)) {
    // Show loading state
    const deleteBtn = documentCard.querySelector('.delete-document');
    if (deleteBtn) {
      deleteBtn.disabled = true;
      deleteBtn.innerHTML = '<i class="bi bi-clock"></i>';
      deleteBtn.title = 'Deleting...';
    }

    // Make AJAX call to delete immediately
    const distributorId = document.querySelector('form').action.match(/\/distributors\/(\d+)/)[1];
    const deleteUrl = `/admin/distributors/${distributorId}/distributor_documents/${documentId}/destroy_immediate`;

    fetch(deleteUrl, {
      method: 'DELETE',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content'),
        'Accept': 'application/json',
        'Content-Type': 'application/json'
      }
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        // Remove the document card from DOM with animation
        documentCard.style.transition = 'all 0.3s ease';
        documentCard.style.transform = 'translateX(100%)';
        documentCard.style.opacity = '0';
        setTimeout(() => {
          documentCard.remove();
          // Show success message
          showNotification('Document deleted successfully', 'success');
        }, 300);
      } else {
        showNotification('Failed to delete document: ' + data.message, 'error');
        // Reset button state
        if (deleteBtn) {
          deleteBtn.disabled = false;
          deleteBtn.innerHTML = '<i class="bi bi-trash"></i>';
          deleteBtn.title = 'Delete Document';
        }
      }
    })
    .catch(error => {
      console.error('Error:', error);
      showNotification('An error occurred while deleting the document', 'error');
      // Reset button state
      if (deleteBtn) {
        deleteBtn.disabled = false;
        deleteBtn.innerHTML = '<i class="bi bi-trash"></i>';
        deleteBtn.title = 'Delete Document';
      }
    });
  }
}

// Helper function to show notifications
function showNotification(message, type) {
  const notification = document.createElement('div');
  notification.className = `alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show position-fixed`;
  notification.style.top = '20px';
  notification.style.right = '20px';
  notification.style.zIndex = '9999';
  notification.innerHTML = `
    ${message}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  `;
  document.body.appendChild(notification);

  // Auto-remove after 3 seconds
  setTimeout(() => {
    if (notification.parentNode) {
      notification.remove();
    }
  }, 3000);
}

// Affiliate Search Functionality
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('affiliate-search');
  const clearSearchBtn = document.getElementById('clear-search');
  const selectAllBtn = document.getElementById('select-all-visible');
  const deselectAllBtn = document.getElementById('deselect-all');
  const affiliatesContainer = document.getElementById('affiliates-container');
  const noResultsMessage = document.getElementById('no-results-message');
  const visibleCountSpan = document.getElementById('visible-count');
  const assignedCountSpan = document.getElementById('assigned-count');

  if (!searchInput) return; // Exit if elements don't exist

  // Function to update counts
  function updateCounts() {
    const visibleItems = document.querySelectorAll('.affiliate-item:not([style*="display: none"])');
    const checkedItems = document.querySelectorAll('.affiliate-checkbox:checked');

    visibleCountSpan.textContent = visibleItems.length;
    assignedCountSpan.textContent = checkedItems.length;

    // Show/hide no results message
    if (visibleItems.length === 0) {
      noResultsMessage.style.display = 'block';
      affiliatesContainer.style.display = 'none';
    } else {
      noResultsMessage.style.display = 'none';
      affiliatesContainer.style.display = 'block';
    }
  }

  // Search functionality
  function performSearch() {
    const searchTerm = searchInput.value.toLowerCase().trim();
    const affiliateItems = document.querySelectorAll('.affiliate-item');

    affiliateItems.forEach(item => {
      const name = item.dataset.name || '';
      const email = item.dataset.email || '';
      const mobile = item.dataset.mobile || '';

      // Search in name, email, and mobile
      const matches = searchTerm === '' ||
                     name.includes(searchTerm) ||
                     email.includes(searchTerm) ||
                     mobile.includes(searchTerm);

      item.style.display = matches ? 'block' : 'none';
    });

    updateCounts();

    // Show/hide clear button
    clearSearchBtn.style.display = searchTerm ? 'inline-block' : 'none';
  }

  // Event listeners
  searchInput.addEventListener('input', performSearch);
  searchInput.addEventListener('keyup', performSearch);

  // Clear search
  clearSearchBtn.addEventListener('click', function() {
    searchInput.value = '';
    performSearch();
    searchInput.focus();
  });

  // Select all visible
  selectAllBtn.addEventListener('click', function() {
    const visibleCheckboxes = document.querySelectorAll('.affiliate-item:not([style*="display: none"]) .affiliate-checkbox');
    visibleCheckboxes.forEach(checkbox => {
      checkbox.checked = true;
    });
    updateCounts();
  });

  // Deselect all
  deselectAllBtn.addEventListener('click', function() {
    const allCheckboxes = document.querySelectorAll('.affiliate-checkbox');
    allCheckboxes.forEach(checkbox => {
      checkbox.checked = false;
    });
    updateCounts();
  });

  // Update count when checkboxes change
  document.addEventListener('change', function(e) {
    if (e.target.classList.contains('affiliate-checkbox')) {
      updateCounts();
    }
  });

  // Initialize
  updateCounts();
  clearSearchBtn.style.display = 'none';

  // Auto-focus search on page load
  setTimeout(() => {
    searchInput.focus();
  }, 500);

  // Profile Picture Preview Functionality
  const profileImageInput = document.getElementById('distributor_profile_image');
  const profilePreviewContainer = document.getElementById('profile_picture_preview');
  const profilePreviewImage = document.getElementById('profile_preview_image');
  const profileFileName = document.getElementById('profile_file_name');
  const profileFileSize = document.getElementById('profile_file_size');
  const removeProfileBtn = document.getElementById('remove_profile_picture');

  if (profileImageInput) {
    profileImageInput.addEventListener('change', function(e) {
      const file = e.target.files[0];

      if (!file) {
        profilePreviewContainer.style.display = 'none';
        return;
      }

      // Validate file type
      if (!file.type.startsWith('image/')) {
        showProfileError('Please select a valid image file (JPG, PNG, GIF)');
        profileImageInput.value = '';
        profilePreviewContainer.style.display = 'none';
        return;
      }

      // Validate file size (5MB limit)
      if (file.size > 5 * 1024 * 1024) {
        showProfileError('File size exceeds 5MB limit');
        profileImageInput.value = '';
        profilePreviewContainer.style.display = 'none';
        return;
      }

      // Show preview
      const reader = new FileReader();
      reader.onload = function(e) {
        profilePreviewImage.src = e.target.result;
        profileFileName.textContent = file.name;
        profileFileSize.textContent = formatFileSize(file.size);
        profilePreviewContainer.style.display = 'block';

        // Smooth animation
        profilePreviewContainer.style.opacity = '0';
        setTimeout(() => {
          profilePreviewContainer.style.transition = 'opacity 0.3s ease';
          profilePreviewContainer.style.opacity = '1';
        }, 10);
      };
      reader.readAsDataURL(file);
    });
  }

  if (removeProfileBtn) {
    removeProfileBtn.addEventListener('click', function() {
      profileImageInput.value = '';
      profilePreviewContainer.style.display = 'none';
    });
  }

  function showProfileError(message) {
    const errorDiv = document.createElement('div');
    errorDiv.className = 'alert alert-danger alert-dismissible fade show mt-2';
    errorDiv.innerHTML = `
      <i class="bi bi-exclamation-triangle me-2"></i>
      ${message}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    profileImageInput.parentNode.insertBefore(errorDiv, profileImageInput.nextSibling);
    setTimeout(() => errorDiv.remove(), 5000);
  }

  function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }

  // Mobile number handling
  const mobileInput = document.querySelector('input[name="distributor[mobile]"]');
  if (mobileInput) {
    // Clean up existing value on page load
    if (mobileInput.value) {
      let cleanNumber = mobileInput.value.replace(/\D/g, ''); // Remove non-digits
      // Extract last 10 digits if longer
      if (cleanNumber.length > 10) {
        cleanNumber = cleanNumber.slice(-10);
      }
      mobileInput.value = cleanNumber;
    }

    // Add input validation for mobile number
    mobileInput.addEventListener('input', function(e) {
      // Remove non-digit characters and strip country code
      let value = this.value.replace(/\D/g, '');
      if (value.length === 12 && value.startsWith('91')) value = value.slice(2);
      else if (value.length === 11 && value.startsWith('0')) value = value.slice(1);
      if (value.length > 10) value = value.slice(0, 10);
      this.value = value;

      // Remove validation classes
      this.classList.remove('is-invalid', 'is-valid');

      // Check if valid (10 digits starting with 6, 7, 8, or 9)
      if (value.length === 10 && /^[6789]/.test(value)) {
        this.classList.add('is-valid');
      } else if (value.length > 0) {
        this.classList.add('is-invalid');
      }
    });

    // Prevent pasting invalid content
    mobileInput.addEventListener('paste', function(e) {
      e.preventDefault();
      let paste = (e.clipboardData || window.clipboardData).getData('text');
      let cleanPaste = paste.replace(/\D/g, ''); // Remove non-digits

      // Extract last 10 digits if longer
      if (cleanPaste.length > 10) {
        cleanPaste = cleanPaste.slice(-10);
      }

      this.value = cleanPaste;
      // Trigger input event to validate
      this.dispatchEvent(new Event('input'));
    });
  }

  // Bootstrap form validation
  const forms = document.querySelectorAll('.needs-validation');
  Array.from(forms).forEach(form => {
    form.addEventListener('submit', event => {
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }
      form.classList.add('was-validated');
    }, false);
  });
});
</script>
