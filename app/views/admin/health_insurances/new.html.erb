                        <option value="son" ${nominee.relationship === 'son' ? 'selected' : ''}>Son</option>
                        <option value="daughter" ${nominee.relationship === 'daughter' ? 'selected' : ''}>Daughter</option>
                        <option value="brother" ${nominee.relationship === 'brother' ? 'selected' : ''}>Brother</option>
                        <option value="sister" ${nominee.relationship === 'sister' ? 'selected' : ''}>Sister</option>
                        <option value="other" ${nominee.relationship === 'other' ? 'selected' : ''}>Other</option>
                      </select>
                    </div>
                    <div class="col-md-2 mb-3">
                      <label class="form-label required">Age</label>
                      <input type="number" name="health_insurance[health_insurance_nominees_attributes][${nomineeIndex}][age]" class="form-control" value="${nominee.age}" min="1" max="120" required>
                    </div>
                    <div class="col-md-2 mb-3">
                      <label class="form-label required">Share %</label>
                      <input type="number" name="health_insurance[health_insurance_nominees_attributes][${nomineeIndex}][share_percentage]" class="form-control" min="0" max="100" step="0.01" placeholder="100" required>
                    </div>
                    <div class="col-md-1 d-flex align-items-end mb-3">
                      <button type="button" class="btn btn-outline-danger remove-nominee-btn">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  </div>
                </div>
              `;
              document.getElementById('nominees').insertAdjacentHTML('beforeend', nomineeTemplate);
              nomineeIndex++;
            });

            toggleNoNomineesMessage();
            if (!silent) {
              alert(`Loaded ${data.nominees.length} nominee(s) from ${data.customer_name}`);
            }
          } else if (!silent) {
            alert(data.message || 'No nominees found for this client');
          }
        })
        .catch(error => {
          console.error('Error loading nominees:', error);
          if (!silent) alert('Error loading nominees. Please try again.');
        });
    }

    document.getElementById('load_customer_nominees_btn').addEventListener('click', function() {
      const customerSelect = document.getElementById('customer_select');
      const customerId = customerSelect ? customerSelect.value : null;

      if (!customerId) {
        alert('Please select a client first');
        return;
      }

      const btn = this;
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="bi bi-spinner bi-spin me-1"></i>Loading...';
      btn.disabled = true;

      fetchAndLoadNominees(customerId).finally(() => {
        btn.innerHTML = originalText;
        btn.disabled = false;
      });
    });

    // Initialize nominee display
    toggleNoNomineesMessage();

    // Auto-load nominees when page opens with a pre-selected customer
    (function autoLoadNomineesOnPageLoad() {
      const customerSelect = document.getElementById('customer_select');
      const customerId = customerSelect ? customerSelect.value : null;
      if (customerId) {
        document.querySelectorAll('.nominee-row').forEach(row => row.remove());
        nomineeIndex = 0;
        toggleNoNomineesMessage();
        fetchAndLoadNominees(customerId, { silent: true });
      }
    })();

    // Event listeners
    document.getElementById('net_premium').addEventListener('input', function() {
      calculateTotalPremium();
      calculateAllCommissions();
    });
    document.getElementById('gst_percentage').addEventListener('input', calculateTotalPremium);
    document.getElementById('commission_percentage').addEventListener('input', function() {
      calculateCommission();
      calculateProfitAndExpenses();
    });
    document.getElementById('tds_percentage').addEventListener('input', calculateCommission);
    document.getElementById('start_date').addEventListener('change', function() {
      calculateEndDate();
      updateAutopayStartDate(); // Also update autopay dates when policy start date changes
    });

    // Autopay date calculation event listeners
    if (document.getElementById('payment_mode_select')) {
      // Native change listener (backup)
      document.getElementById('payment_mode_select').addEventListener('change', calculateAutopayEndDate);

      // Select2 change listener (primary)
      $('#payment_mode_select').on('select2:select', function(e) {
        calculateAutopayEndDate();
      });

      // Calculate on page load if payment mode is already selected
      if (document.getElementById('payment_mode_select').value) {
        calculateAutopayEndDate();
      }
    }

    if (document.getElementById('autopay_start_date')) {
      document.getElementById('autopay_start_date').addEventListener('change', calculateAutopayEndDate);

      // Calculate on page load if start date exists
      if (document.getElementById('autopay_start_date').value && document.getElementById('payment_mode_select').value) {
        calculateAutopayEndDate();
      }
    }

    // Insurance type change listener
    document.getElementById('insurance_type_select').addEventListener('change', toggleFamilyCoverageSection);

    // Use Select2 event listener instead of native event
    $('#customer_select').on('select2:select', function(e) {
      loadPolicyHolderOptions();
      loadNomineeDetails();
      $('#affiliate_select').val(null).trigger('change');
      var selectedCustomerId = this.value;
      if (selectedCustomerId) {
        // Auto-load nominees for newly selected customer
        document.querySelectorAll('.nominee-row').forEach(row => row.remove());
        nomineeIndex = 0;
        toggleNoNomineesMessage();
        fetchAndLoadNominees(selectedCustomerId, { silent: true });
      }
    });

    // Handle customer clearing
    $('#customer_select').on('select2:clear', function(e) {
      $('#affiliate_select').val(null).trigger('change');
      console.log('Customer cleared, showing all affiliates');
    });

    // Sub-agent commission event listeners
    if (document.querySelector('.sub-agent-commission-percentage')) {
      document.querySelector('.sub-agent-commission-percentage').addEventListener('input', function() {
        calculateSubAgentCommission();
        calculateProfitAndExpenses();
      });
    }
    if (document.querySelector('.sub-agent-tds-percentage')) {
      document.querySelector('.sub-agent-tds-percentage').addEventListener('input', calculateSubAgentCommission);
    }

    // Investor commission event listeners
    if (document.querySelector('.investor-commission-percentage')) {
      document.querySelector('.investor-commission-percentage').addEventListener('input', function() {
        calculateInvestorCommission();
        calculateProfitAndExpenses();
      });
    }
    if (document.querySelector('.investor-tds-percentage')) {
      document.querySelector('.investor-tds-percentage').addEventListener('input', calculateInvestorCommission);
    }

    // Ambassador commission event listeners
    if (document.querySelector('.ambassador-commission-percentage')) {
      document.querySelector('.ambassador-commission-percentage').addEventListener('input', function() {
        calculateAmbassadorCommission();
        calculateProfitAndExpenses();
      });
    }
    if (document.querySelector('.ambassador-tds-percentage')) {
      document.querySelector('.ambassador-tds-percentage').addEventListener('input', calculateAmbassadorCommission);
    }

    // Company expenses event listener
    if (document.querySelector('.company-expenses-percentage')) {
      document.querySelector('.company-expenses-percentage').addEventListener('input', calculateProfitAndExpenses);
    }

    // Initialize date pickers with proper constraints
    function initializeDatePickers() {
      const dateFields = [
        'policy_booking_date',
        'start_date',
        'end_date',
        'nominee_dob',
        'autopay_start_date',
        'autopay_end_date'
      ];

      dateFields.forEach(fieldId => {
        const field = document.getElementById(fieldId) || document.querySelector(`[name*="${fieldId}"]`);
        if (field) {
          // Ensure proper min/max attributes are set
          field.setAttribute('min', '1900-01-01');
          field.setAttribute('max', '2099-12-31');

          // Fix any existing invalid values
          if (field.value && (field.value.includes('275760') || field.value.length > 10)) {
            field.value = new Date().toISOString().split('T')[0];
          }

          // Add event listener to prevent manual entry of invalid dates
          field.addEventListener('input', function() {
            const value = this.value;
            if (value && value.length > 10) {
              this.value = value.substring(0, 10);
            }
          });

          console.log(`✅ Initialized date picker for ${fieldId}`);
        }
      });
    }

    // Call date picker initialization
    initializeDatePickers();

    // Initialize calculations and summary on page load
    calculateAllCommissions();
    calculateEndDate();
    calculateAutopayEndDate();
    toggleFamilyCoverageSection();

  } catch (error) {
    console.warn('Health insurance form initialization error:', error.message);
  }
});
</script>

<!-- Dynamic dropdown initialization -->
