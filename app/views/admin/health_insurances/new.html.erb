          }
        });

        brokerCodeSelect.addEventListener('change', function() {
          const brokerType = this.value;
          console.log('🔥 BROKER CODE CHANGED! Value:', brokerType);

          // Enable Insurance Company dropdown when any option is selected
          if (insuranceCompanySelect && insuranceCompanySelect.disabled) {
            insuranceCompanySelect.disabled = false;
            console.log('✅ Insurance Company Name dropdown enabled on selection');

            // Also enable it for Select2 if initialized
            if (window.jQuery && $('#health_insurance_insurance_company_name').hasClass('select2-hidden-accessible')) {
              $('#health_insurance_insurance_company_name').prop('disabled', false);
            }
          }

          // Clear dependent dropdowns
          if (agencyCodeSelect) {
            agencyCodeSelect.innerHTML = '<option value="">Loading...</option>';
          }
          if (insuranceCompanySelect) {
            // Reset Select2 if it's being used
            if ($(insuranceCompanySelect).hasClass('select2-hidden-accessible')) {
              $(insuranceCompanySelect).select2('destroy');
            }

            insuranceCompanySelect.innerHTML = '<option value="">Loading...</option>';
            insuranceCompanySelect.disabled = false;

            // Reset styling
            insuranceCompanySelect.style.backgroundColor = '';
            insuranceCompanySelect.style.fontStyle = '';

            // Reinitialize Select2 with original settings
            setTimeout(() => {
              $(insuranceCompanySelect).select2({
                theme: 'bootstrap-5',
                placeholder: 'Search and select company...',
                allowClear: true,
                width: '100%',
                dropdownParent: $('body'),
                dropdownCssClass: 'select2-dropdown-large',
                minimumResultsForSearch: 0,
                closeOnSelect: true,
                templateResult: function(option) {
                  if (!option.id || option.element.value === '') {
                    return option.text;
                  }
                  var initials = option.text.split(' ').map(function(word) {
                    return word.charAt(0).toUpperCase();
                  }).join('').substring(0, 3);
                  var $option = $(
                    '<div class="company-option">' +
                      '<div class="company-option-avatar">' + initials + '</div>' +
                      '<div class="company-option-details">' +
                        '<div class="company-option-name">' + option.text + '</div>' +
                        '<div class="company-option-type">Insurance Company</div>' +
                      '</div>' +
                    '</div>'
                  );
                  return $option;
                },
                templateSelection: function(option) {
                  return option.text || 'Search and select company...';
                },
                escapeMarkup: function(markup) {
                  return markup;
                }
              });
            }, 50);
          }

          // No need to clear stored agent data since we're using API calls

          if (brokerType === 'direct') {
            console.log('📋 Calling Direct Mode API...');
            callDirectModeAPI();
          } else if (brokerType === 'broking') {
            console.log('🏢 Calling Broking Mode API...');
            callBrokingModeAPI();
          }
        });

        console.log('✅ Broker code event listener attached successfully!');
      }

      // Initial setup of agency code event listener
      attachAgencyCodeEventListener();

      return { brokerCodeSelect, agencyCodeSelect, insuranceCompanySelect };
    }

    // Flag to prevent duplicate event listeners
    let agencyCodeEventListenerAttached = false;

    function attachAgencyCodeEventListener() {
      // Only attach if not already attached
      if (agencyCodeEventListenerAttached) {
        console.log('ℹ️ Agency code event listener already attached, skipping...');
        return;
      }

      console.log('🎧 Setting up agency code auto-fill listener');

      // Use Select2 event listener for the agency code dropdown
      $('#health_insurance_agency_code_id').on('select2:select', function(e) {
        console.log('🔥 AGENCY CODE SELECT2 EVENT TRIGGERED!');

        const selectedAgentId = e.params.data.id;
        const selectedText = e.params.data.text;
        const brokerCodeSelect = document.getElementById('health_insurance_broker_code_type');
        const brokerType = brokerCodeSelect ? brokerCodeSelect.value : '';

        console.log(`Selected Agent ID: ${selectedAgentId}, Text: ${selectedText}, Broker Type: ${brokerType}`);

        if (brokerType === 'direct' && selectedAgentId) {
          console.log(`🎯 Auto-filling company for agent: ${selectedText}`);
          fetchCompanyNameForAgent(selectedAgentId);
        }
      });

      // Handle agency code clearing
      $('#health_insurance_agency_code_id').on('select2:clear', function(e) {
        console.log('🔥 AGENCY CODE CLEARED!');

        const brokerCodeSelect = document.getElementById('health_insurance_broker_code_type');
        const brokerType = brokerCodeSelect ? brokerCodeSelect.value : '';

        if (brokerType === 'direct') {
          // Clear company dropdown in direct mode when no agent selected
          const insuranceCompanySelect = document.getElementById('health_insurance_insurance_company_name');
          if (insuranceCompanySelect) {
            // Reset Select2 if it's being used
            if ($(insuranceCompanySelect).hasClass('select2-hidden-accessible')) {
              $(insuranceCompanySelect).select2('destroy');
            }
            insuranceCompanySelect.innerHTML = '<option value="">Select Agent First...</option>';

            // Reinitialize Select2
            setTimeout(() => {
              $(insuranceCompanySelect).select2({
                theme: 'bootstrap-5',
                placeholder: 'Select Agent First...',
                allowClear: true,
                width: '100%',
                dropdownParent: $('body'),
                dropdownCssClass: 'select2-dropdown-large'
              });
            }, 50);
          }
        }
      });

      // Fallback: Use native event delegation as backup
      document.addEventListener('change', function(event) {
        // Check if the changed element is the agency code select
        if (event.target && event.target.id === 'health_insurance_agency_code_id') {
          console.log('🔄 NATIVE CHANGE EVENT TRIGGERED (backup)');

          const agencyCodeSelect = event.target;
          const brokerCodeSelect = document.getElementById('health_insurance_broker_code_type');

          const selectedAgentId = agencyCodeSelect.value;
          const brokerType = brokerCodeSelect ? brokerCodeSelect.value : '';
          const selectedText = agencyCodeSelect.options[agencyCodeSelect.selectedIndex]?.text || 'Unknown';

          if (brokerType === 'direct' && selectedAgentId) {
            console.log(`🎯 Auto-filling company for agent (backup): ${selectedText}`);
            fetchCompanyNameForAgent(selectedAgentId);
          } else if (!selectedAgentId && brokerType === 'direct') {
            // Clear company dropdown in direct mode when no agent selected
            const insuranceCompanySelect = document.getElementById('health_insurance_insurance_company_name');
            if (insuranceCompanySelect) {
              insuranceCompanySelect.innerHTML = '<option value="">Select Agent First...</option>';
            }
          }
        }
      });

      agencyCodeEventListenerAttached = true;
      console.log('✅ Agency code auto-fill listener ready');
    }

    function callDirectModeAPI() {
      console.log('🌐 Fetching agents for direct mode...');
      fetch('/admin/insurance/health/agency_codes_for_broker_type?broker_type=direct')
        .then(response => {
          console.log('📡 API Response Status:', response.status);
          return response.json();
        })
        .then(data => {
          console.log('📊 API Data:', data);
          if (data.success && data.data) {
            populateAgencyCodeDropdown(data.data, 'Select Agent...', false);

            // Clear insurance company and show message to select agent first
            const insuranceCompanySelect = document.getElementById('health_insurance_insurance_company_name');
            if (insuranceCompanySelect) {
              insuranceCompanySelect.innerHTML = '<option value="">Select Agent First...</option>';
            }
          }
        })
        .catch(error => {
          console.error('❌ API Error:', error);
        });
    }

    function callBrokingModeAPI() {
      console.log('🌐 Fetching brokers for broking mode...');

      // Fetch brokers
      fetch('/admin/insurance/health/agency_codes_for_broker_type?broker_type=broking')
        .then(response => response.json())
        .then(data => {
          console.log('📊 Brokers Data:', data);
          if (data.success && data.data) {
            populateAgencyCodeDropdown(data.data, 'Select Broker...', true);
          }
        })
        .catch(error => {
          console.error('❌ Brokers API Error:', error);
        });

      // Fetch insurance companies
      fetch('/admin/insurance/health/insurance_companies_for_type')
        .then(response => response.json())
        .then(data => {
          console.log('📊 Companies Data:', data);
          if (data.success && data.data) {
            populateInsuranceCompanyDropdown(data.data);
          }
        })
        .catch(error => {
          console.error('❌ Companies API Error:', error);
        });
    }

    function populateAgencyCodeDropdown(data, placeholder, isBroking) {
      const agencyCodeSelect = document.getElementById('health_insurance_agency_code_id');
      if (!agencyCodeSelect) return;

      // Destroy existing Select2 instance if it exists
      if ($(agencyCodeSelect).hasClass('select2-hidden-accessible')) {
        $(agencyCodeSelect).select2('destroy');
      }

      agencyCodeSelect.innerHTML = `<option value="">${placeholder}</option>`;
      data.forEach(item => {
        const option = document.createElement('option');
        option.value = isBroking ? 'broker_' + item.id : item.id;
        // For brokers with codes, append the code to the text
        if (item.code && !item.text.includes(' - ')) {
          option.textContent = item.text + ' - ' + item.code;
        } else {
          option.textContent = item.text;
        }
        option.setAttribute('data-code', item.code || '');
        option.setAttribute('data-name', item.broker_name || item.agent_name || item.text);
        agencyCodeSelect.appendChild(option);
      });

      // Reinitialize Select2 with the same settings as before
      $(agencyCodeSelect).select2({
        theme: 'bootstrap-5',
        placeholder: placeholder,
        allowClear: true,
        width: '100%',
        dropdownParent: $('body'),
        dropdownCssClass: 'select2-dropdown-large',
        minimumResultsForSearch: 0,
        closeOnSelect: true,
        templateResult: function(option) {
          if (!option.id || option.element.value === '') {
            return option.text;
          }

          // Get the name and code from the option text or data attributes
          var parts = option.text.split(' - ');
          var name = parts[0] || option.text;
          var code = parts[1] || '';

          // If we have data attributes, use them
          if (option.element && option.element.getAttribute) {
            var dataCode = option.element.getAttribute('data-code');
            var dataName = option.element.getAttribute('data-name');
            if (dataName) name = dataName;
            if (dataCode) code = dataCode;
          }

          var initials = name.split(' ').map(function(word) {
            return word.charAt(0).toUpperCase();
          }).join('').substring(0, 2);

          var $option = $(
            '<div class="agency-option">' +
              '<div class="agency-option-avatar">' + initials + '</div>' +
              '<div class="agency-option-details">' +
                '<div class="agency-option-name">' + name + '</div>' +
                '<div class="agency-option-code">' + code + '</div>' +
              '</div>' +
            '</div>'
          );
          return $option;
        },
        templateSelection: function(option) {
          return option.text || placeholder;
        },
        escapeMarkup: function(markup) {
          return markup;
        }
      });

      // Re-attach the Select2 event listeners
      $('#health_insurance_agency_code_id').off('select2:select select2:clear'); // Remove any existing listeners first

      $('#health_insurance_agency_code_id').on('select2:select', function(e) {
        console.log('🔥 AGENCY CODE SELECT2 EVENT TRIGGERED!');

        const selectedAgentId = e.params.data.id;
        const selectedText = e.params.data.text;
        const brokerCodeSelect = document.getElementById('health_insurance_broker_code_type');
        const brokerType = brokerCodeSelect ? brokerCodeSelect.value : '';

        console.log(`Selected Agent ID: ${selectedAgentId}, Text: ${selectedText}, Broker Type: ${brokerType}`);

        if (brokerType === 'direct' && selectedAgentId) {
          console.log(`🎯 Auto-filling company for agent: ${selectedText}`);
          fetchCompanyNameForAgent(selectedAgentId);
        }
      });

      $('#health_insurance_agency_code_id').on('select2:clear', function(e) {
        console.log('🔥 AGENCY CODE CLEARED!');

        const brokerCodeSelect = document.getElementById('health_insurance_broker_code_type');
        const brokerType = brokerCodeSelect ? brokerCodeSelect.value : '';

        if (brokerType === 'direct') {
          // Clear company dropdown in direct mode when no agent selected
          const insuranceCompanySelect = document.getElementById('health_insurance_insurance_company_name');
          if (insuranceCompanySelect) {
            // Reset Select2 if it's being used
            if ($(insuranceCompanySelect).hasClass('select2-hidden-accessible')) {
              $(insuranceCompanySelect).select2('destroy');
            }
            insuranceCompanySelect.innerHTML = '<option value="">Select Agent First...</option>';

            // Reinitialize Select2
            setTimeout(() => {
              $(insuranceCompanySelect).select2({
                theme: 'bootstrap-5',
                placeholder: 'Select Agent First...',
                allowClear: true,
                width: '100%',
                dropdownParent: $('body'),
                dropdownCssClass: 'select2-dropdown-large'
              });
            }, 50);
          }
        }
      });

      console.log(`✅ Populated agency code dropdown with ${data.length} items and reattached Select2 events`);
    }

    function populateInsuranceCompanyDropdown(data) {
      const insuranceCompanySelect = document.getElementById('health_insurance_insurance_company_name');
      if (!insuranceCompanySelect) return;

      insuranceCompanySelect.innerHTML = '<option value="">Select Insurance Company...</option>';
      data.forEach(item => {
        const option = document.createElement('option');
        option.value = item.id;
        option.textContent = item.text;
        insuranceCompanySelect.appendChild(option);
      });

      console.log(`✅ Populated insurance company dropdown with ${data.length} items`);
    }

    function fetchCompanyNameForAgent(agentId) {
      console.log(`🌐 Fetching company for agent ID: ${agentId}`);

      // Show loading state
      const insuranceCompanySelect = document.getElementById('health_insurance_insurance_company_name');
      if (insuranceCompanySelect) {
        // Reset Select2 if it's being used
        if ($(insuranceCompanySelect).hasClass('select2-hidden-accessible')) {
          $(insuranceCompanySelect).select2('destroy');
        }

        insuranceCompanySelect.innerHTML = '<option value="">Loading company...</option>';
        insuranceCompanySelect.disabled = true;
      }

      // Call the company name API
      fetch(`/admin/insurance/health/company_name_by_agent?agency_code_id=${agentId}`)
        .then(response => {
          console.log(`📡 API Response: ${response.status} ${response.statusText}`);
          return response.json();
        })
        .then(data => {
          if (data.success && data.data) {
            if (data.data.multiple_companies && data.data.company_names) {
              // Multiple companies - show all options
              const companyNames = data.data.company_names;
              const agentName = data.data.agent_name;
              console.log(`✅ Found ${companyNames.length} companies for agent ${agentName}: ${companyNames.join(', ')}`);
              populateMultipleCompanies(companyNames, agentName);
            } else if (data.data.company_name) {
              // Single company - auto-fill as before
              const companyName = data.data.company_name;
              const agentName = data.data.agent_name;
              console.log(`✅ Auto-filling single company: ${companyName} for agent ${agentName}`);
              autoFillInsuranceCompany(companyName);
            } else {
              console.error(`❌ API Error: No company data found`);
              // Reset to normal state if error
              if (insuranceCompanySelect) {
                insuranceCompanySelect.innerHTML = '<option value="">Select Insurance Company...</option>';
                insuranceCompanySelect.disabled = false;
              }
            }
          } else {
            console.error(`❌ API Error: ${data.message || 'Unknown error'}`);
            // Reset to normal state if error
            if (insuranceCompanySelect) {
              insuranceCompanySelect.innerHTML = '<option value="">Select Insurance Company...</option>';
              insuranceCompanySelect.disabled = false;
            }
          }
        })
        .catch(error => {
          console.error(`❌ Fetch Error: ${error.message}`);
          // Reset to normal state if error
          if (insuranceCompanySelect) {
            insuranceCompanySelect.innerHTML = '<option value="">Error - Please select manually</option>';
            insuranceCompanySelect.disabled = false;
          }
        });
    }

    function autoFillInsuranceCompany(companyName) {
      console.log('🎯 Auto-filling insurance company with:', companyName);

      const insuranceCompanySelect = document.getElementById('health_insurance_insurance_company_name');
      if (!insuranceCompanySelect) return;

      // Clear and add the auto-filled company option
      insuranceCompanySelect.innerHTML = '';
      const option = document.createElement('option');
      option.value = companyName;
      option.textContent = companyName;
      option.selected = true;
      insuranceCompanySelect.appendChild(option);

      // Style and setup for auto-filled state (keep enabled for form submission)
      insuranceCompanySelect.disabled = false;
      insuranceCompanySelect.style.backgroundColor = '#e8f5e9';
      insuranceCompanySelect.style.fontStyle = 'italic';

      // Handle Select2 if present
      if (typeof $ !== 'undefined') {
        // Destroy existing Select2 first
        if ($(insuranceCompanySelect).hasClass('select2-hidden-accessible')) {
          $(insuranceCompanySelect).select2('destroy');
        }

        $(insuranceCompanySelect).select2({
          theme: 'bootstrap-5',
          placeholder: companyName,
          allowClear: false,
          disabled: false,
          width: '100%'
        });

        // Set the value explicitly for Select2
        $(insuranceCompanySelect).val(companyName).trigger('change');
      }

      console.log('🔒 Insurance company auto-filled:', companyName);
      console.log('🔍 Field value after auto-fill:', insuranceCompanySelect.value);
      console.log('🔍 Field disabled status:', insuranceCompanySelect.disabled);
    }

    function populateMultipleCompanies(companyNames, agentName) {
      console.log(`🏢 Populating multiple companies for agent ${agentName}:`, companyNames);

      const insuranceCompanySelect = document.getElementById('health_insurance_insurance_company_name');
      if (!insuranceCompanySelect) return;

      // Clear and populate with multiple company options
      insuranceCompanySelect.innerHTML = `<option value="">Choose from ${companyNames.length} companies for ${agentName}...</option>`;

      companyNames.forEach(companyName => {
        const option = document.createElement('option');
        option.value = companyName;
        option.textContent = companyName;
        insuranceCompanySelect.appendChild(option);
      });

      // Enable the dropdown for selection
      insuranceCompanySelect.disabled = false;
      insuranceCompanySelect.style.backgroundColor = '';
      insuranceCompanySelect.style.fontStyle = '';

      // Reinitialize Select2 with enhanced styling for multiple options
      if (typeof $ !== 'undefined') {
        // Destroy existing Select2 if present
        if ($(insuranceCompanySelect).hasClass('select2-hidden-accessible')) {
          $(insuranceCompanySelect).select2('destroy');
        }

        $(insuranceCompanySelect).select2({
          theme: 'bootstrap-5',
          placeholder: `Choose from ${companyNames.length} companies for ${agentName}...`,
          allowClear: true,
          width: '100%',
          dropdownParent: $('body'),
          dropdownCssClass: 'select2-dropdown-large',
          minimumResultsForSearch: 0,
          closeOnSelect: true,
          templateResult: function(option) {
            if (!option.id || option.element.value === '') {
              return option.text;
            }

            var initials = option.text.split(' ').map(function(word) {
              return word.charAt(0).toUpperCase();
            }).join('').substring(0, 3);

            var $option = $(
              '<div class="company-option">' +
                '<div class="company-option-avatar">' + initials + '</div>' +
                '<div class="company-option-details">' +
                  '<div class="company-option-name">' + option.text + '</div>' +
                  '<div class="company-option-type">Available for ' + agentName + '</div>' +
                '</div>' +
              '</div>'
            );
            return $option;
          },
          templateSelection: function(option) {
            return option.text || `Choose from ${companyNames.length} companies for ${agentName}...`;
          },
          escapeMarkup: function(markup) {
            return markup;
          }
        });
      }

      console.log(`✅ Populated ${companyNames.length} company options for agent ${agentName}`);
    }

    // Add a delay to ensure everything is loaded
    setTimeout(() => {
      console.log('🚀 Starting dropdown debugging...');
      debugDropdownElements();
    }, 300);

    // Add Document button handler
    const addDocumentBtn = document.getElementById('add_policy_document');
    if (addDocumentBtn) {
      addDocumentBtn.addEventListener('click', function() {
        console.log('📄 Add Document button clicked');

        // Create a simple document upload section
        const container = document.getElementById('policy_documents_container');
        if (container) {
          const documentIndex = container.children.length;

          const documentHTML = `
            <div class="border rounded p-3 mb-3 document-item" data-index="${documentIndex}">
              <div class="row">
                <div class="col-md-4">
                  <label class="form-label">Document Title*</label>
                  <input type="text" name="policy_documents[${documentIndex}][title]" class="form-control" placeholder="e.g., Policy Document" required>
                </div>
                <div class="col-md-3">
                  <label class="form-label">Document Type*</label>
                  <select name="policy_documents[${documentIndex}][document_type]" class="form-control" required>
                    <option value="">Select type</option>
                    <option value="Policy Document">Policy Document</option>
                    <option value="Medical Report">Medical Report</option>
                    <option value="Identity Proof">Identity Proof</option>
                    <option value="Other">Other</option>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Upload File*</label>
                  <input type="file" name="policy_documents[${documentIndex}][file]" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" required>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                  <button type="button" class="btn btn-outline-danger btn-sm remove-document-btn">
                    <i class="bi bi-trash"></i>
                  </button>
                </div>
              </div>
              <div class="row mt-2">
                <div class="col-md-11">
                  <label class="form-label">Description</label>
                  <textarea name="policy_documents[${documentIndex}][description]" class="form-control" rows="2" placeholder="Optional description"></textarea>
                </div>
              </div>
            </div>
          `;

          container.insertAdjacentHTML('beforeend', documentHTML);

          // Add remove handler for the new document
          const removeBtn = container.lastElementChild.querySelector('.remove-document-btn');
          if (removeBtn) {
            removeBtn.addEventListener('click', function() {
              if (confirm('Remove this document?')) {
                this.closest('.document-item').remove();
              }
            });
          }

          console.log('📄 Document upload section added');
        }
      });

      console.log('📄 Add Document button handler initialized');
    } else {
      console.log('❌ Add Document button not found');
    }

    // Health Insurance Policy Documents Manager
    let healthPolicyDocumentIndex = 0;
    const addHealthPolicyDocumentBtn = document.getElementById('add_health_policy_document');
    const healthPolicyDocumentsContainer = document.getElementById('health_policy_documents_container');

    if (addHealthPolicyDocumentBtn && healthPolicyDocumentsContainer) {
      addHealthPolicyDocumentBtn.addEventListener('click', function() {
        const documentHtml = `
          <div class="document-entry p-3 mb-3 border rounded position-relative" data-index="${healthPolicyDocumentIndex}" style="background: #f8f9fa;">
            <button type="button" class="btn btn-sm btn-outline-danger position-absolute" style="top: 10px; right: 10px;" onclick="this.closest('.document-entry').remove()">
              <i class="bi bi-trash"></i>
            </button>
            <div class="row">
              <div class="col-md-4">
                <label class="form-label">Document Title <span class="text-danger">*</span></label>
                <input type="text" name="health_insurance[health_insurance_documents_attributes][${healthPolicyDocumentIndex}][title]" class="form-control" placeholder="Enter document title" required>
              </div>
              <div class="col-md-4">
                <label class="form-label">Document Type <span class="text-danger">*</span></label>
                <select name="health_insurance[health_insurance_documents_attributes][${healthPolicyDocumentIndex}][document_type]" class="form-select" required>
                  <option value="">Select Document Type</option>
                  <option value="policy_document">Policy Document</option>
                  <option value="medical_report">Medical Report</option>
                  <option value="identity_proof">Identity Proof</option>
                  <option value="address_proof">Address Proof</option>
                  <option value="income_proof">Income Proof</option>
                  <option value="aadhar">Aadhar Card</option>
                  <option value="pan_card">PAN Card</option>
                  <option value="passport">Passport</option>
                  <option value="previous_policy">Previous Policy</option>
                  <option value="claim_form">Claim Form</option>
                  <option value="discharge_summary">Discharge Summary</option>
                  <option value="pre_policy_checkup">Pre-Policy Checkup</option>
                  <option value="prescription">Prescription</option>
                  <option value="lab_report">Lab Report</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label">Document File <span class="text-danger">*</span></label>
                <input type="file" name="health_insurance[health_insurance_documents_attributes][${healthPolicyDocumentIndex}][file]" class="form-control" accept="application/pdf,image/jpeg,image/jpg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required id="health_doc_file_${healthPolicyDocumentIndex}">
              </div>
            </div>
            <div class="row mt-2">
              <div class="col-md-12">
                <label class="form-label">Description (Optional)</label>
                <textarea name="health_insurance[health_insurance_documents_attributes][${healthPolicyDocumentIndex}][description]" class="form-control" rows="2" placeholder="Optional description"></textarea>
              </div>
            </div>
          </div>
        `;

        healthPolicyDocumentsContainer.insertAdjacentHTML('beforeend', documentHtml);
        healthPolicyDocumentIndex++;
      });

      console.log('✅ Health Insurance Policy Documents Manager initialized');
    } else {
      console.log('❌ Health Insurance Policy Documents Manager elements not found');
    }
  });
</script>

