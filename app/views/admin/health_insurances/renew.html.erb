    // Load policy holder options when customer changes (with policy holder preservation)
    function loadPolicyHolderOptions() {
      const customerId = document.getElementById('customer_select').value;
      const policyHolderSelect = document.getElementById('policy_holder_select');
      const currentPolicyHolder = '<%= j(@health_insurance.policy_holder) %>';

      if (customerId) {
        // Store current selected value before clearing
        const currentSelectedValue = policyHolderSelect.value;

        // Clear current options and show loading
        policyHolderSelect.innerHTML = '<option value="">Loading...</option>';

        fetch(`/admin/insurance/health/policy_holder_options?customer_id=${customerId}`)
          .then(response => response.json())
          .then(data => {
            // Rebuild options
            policyHolderSelect.innerHTML = '<option value="">Select Policy Holder</option>';
            data.options.forEach(option => {
              const optionElement = new Option(option.label, option.value);
              policyHolderSelect.add(optionElement);
            });

            // Try to restore the original policy holder value if it exists in new options
            let valueToSet = currentPolicyHolder || currentSelectedValue;
            if (valueToSet) {
              const matchingOption = Array.from(policyHolderSelect.options).find(opt =>
                opt.value === valueToSet || opt.text === valueToSet ||
                opt.text.toLowerCase().includes(valueToSet.toLowerCase())
              );

              if (matchingOption) {
                policyHolderSelect.value = matchingOption.value;
                console.log('✅ Restored policy holder after customer change:', matchingOption.value);
              } else {
                // Add the original value if it doesn't exist
                const newOption = new Option(valueToSet, valueToSet);
                policyHolderSelect.add(newOption);
                policyHolderSelect.value = valueToSet;
                console.log('✅ Added and selected original policy holder:', valueToSet);
              }

              // Trigger change event for Select2
              if (typeof $.fn.select2 !== 'undefined' && $(policyHolderSelect).hasClass('select2-hidden-accessible')) {
                $(policyHolderSelect).trigger('change.select2');
              }
            }
          })
          .catch(error => {
            console.error('Error loading policy holder options:', error);
            policyHolderSelect.innerHTML = '<option value="">Error loading options</option>';

            // Try to add the original policy holder even if loading failed
            if (currentPolicyHolder) {
              const newOption = new Option(currentPolicyHolder, currentPolicyHolder);
              policyHolderSelect.add(newOption);
              policyHolderSelect.value = currentPolicyHolder;
              console.log('⚠️  Added original policy holder after loading error:', currentPolicyHolder);
            }
          });
      } else {
        // If no customer selected, show default options including the original policy holder
        policyHolderSelect.innerHTML = '<option value="">Select Policy Holder</option><option value="Self">Self</option>';
        if (currentPolicyHolder && currentPolicyHolder !== 'Self') {
          const newOption = new Option(currentPolicyHolder, currentPolicyHolder);
          policyHolderSelect.add(newOption);
        }
      }
    }

    // Use Select2 event listener instead of native event
    $('#customer_select').on('select2:select', function(e) {
      loadPolicyHolderOptions();

      // Call our safe policy holder function after a delay to ensure options are loaded
      setTimeout(function() {
