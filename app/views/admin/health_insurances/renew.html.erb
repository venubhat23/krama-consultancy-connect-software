    // Function to safely set policy holder value with better error handling
    function setPolicyHolderValue() {
      <% if @health_insurance.policy_holder.present? %>
        let policyHolderValue = '<%= j(@health_insurance.policy_holder) %>';
        // Debug: Check if the option exists in the dropdown
        let optionExists = $('#policy_holder_select option[value="' + policyHolderValue + '"]').length > 0;

        // If exact match doesn't exist, try to find a similar option
        if (!optionExists) {
          const matchingOption = $('#policy_holder_select option').filter(function() {
            const optionValue = $(this).val().trim();
            const optionText = $(this).text().trim();
            const searchValue = policyHolderValue.trim();
            return optionValue === searchValue ||
                   optionText === searchValue ||
                   optionText.toLowerCase().includes(searchValue.toLowerCase()) ||
                   optionValue.toLowerCase().includes(searchValue.toLowerCase());
          });

          if (matchingOption.length > 0) {
            const bestMatch = matchingOption.first();
            policyHolderValue = bestMatch.val();
            optionExists = true;
          }
        }

        if (optionExists) {
          try {
            // Set the value using both native and Select2 methods
            $('#policy_holder_select').val(policyHolderValue);

            // Trigger change event for Select2
            if (typeof $.fn.select2 !== 'undefined' && $('#policy_holder_select').hasClass('select2-hidden-accessible')) {
              $('#policy_holder_select').trigger('change.select2');
            }

            // Value set successfully
          } catch(error) {
            // Try fallback approach
            document.getElementById('policy_holder_select').value = policyHolderValue;
          }
        } else {
          // Fallback: Add the missing option and select it
          try {
            const newOption = new Option(policyHolderValue, policyHolderValue, true, true);
            $('#policy_holder_select').append(newOption);

            if (typeof $.fn.select2 !== 'undefined' && $('#policy_holder_select').hasClass('select2-hidden-accessible')) {
              $('#policy_holder_select').trigger('change.select2');
            }
          } catch(error) {
            // Silent fallback
          }
        }
      <% else %>
        // No policy holder value to set
      <% end %>
    }

    // Set initial policy holder value after Select2 initialization
    setTimeout(function() {
      setPolicyHolderValue();
    }, 800);

    // Final safety check - try again if needed
    setTimeout(function() {
      const currentValue = $('#policy_holder_select').val();
      const expectedValue = <% if @health_insurance.policy_holder.present? %>'<%= j(@health_insurance.policy_holder) %>'<% else %>null<% end %>;
      if (!currentValue && expectedValue) {
        setPolicyHolderValue();
      }
    }, 2000);

    // Sum Insured Text Handler
    function parseIndianAmountText(text) {
      if (!text) return 0;
      const cleanText = text.toLowerCase().replace(/,/g, '');
      let amount = 0;
      const croreMatch = cleanText.match(/(\d+\.?\d*)\s*crores?/);
      const lakhMatch = cleanText.match(/(\d+\.?\d*)\s*lakhs?/);
      if (croreMatch) {
        amount += parseFloat(croreMatch[1]) * 10000000;
      }
      if (lakhMatch) {
        amount += parseFloat(lakhMatch[1]) * 100000;
      }
      if (!croreMatch && !lakhMatch) {
        const numberMatch = cleanText.match(/(\d+\.?\d*)/);
        if (numberMatch) {
          amount = parseFloat(numberMatch[1]);
        }
      }
      return amount;
    }

    function formatPreviewText(amount) {
      if (amount >= 10000000) {
        const crores = amount / 10000000;
        return `(Rs. ${crores === Math.floor(crores) ? crores.toString() : crores.toFixed(1)} crore${crores > 1 ? 's' : ''})`;
      } else if (amount >= 100000) {
        const lakhs = amount / 100000;
        return `(Rs. ${lakhs === Math.floor(lakhs) ? lakhs.toString() : lakhs.toFixed(1)} lakh${lakhs > 1 ? 's' : ''})`;
      } else if (amount > 0) {
        return `(Rs. ${amount.toLocaleString()})`;
      }
      return '';
    }

    // Sum insured text input handler
    if (document.getElementById('sum_insured_text_input')) {
      document.getElementById('sum_insured_text_input').addEventListener('input', function() {
        const textValue = this.value;
        const numericValue = parseIndianAmountText(textValue);
        const hiddenField = document.querySelector('input[name="health_insurance[sum_insured]"]');
        if (hiddenField) {
          hiddenField.value = numericValue;
        }
        const preview = document.getElementById('sum_insured_preview');
        if (preview) {
          preview.textContent = formatPreviewText(numericValue);
        }
      });

      // Initialize preview on page load
      const initialValue = document.getElementById('sum_insured_text_input').value;
      if (initialValue) {
        const numericValue = parseIndianAmountText(initialValue);
        const hiddenField = document.querySelector('input[name="health_insurance[sum_insured]"]');
        if (hiddenField) {
          hiddenField.value = numericValue;
        }
        const preview = document.getElementById('sum_insured_preview');
        if (preview) {
          preview.textContent = formatPreviewText(numericValue);
        }
      }
    }

    } else {
      console.log('⚠️  jQuery or Select2 not available, using basic dropdown functionality');
      console.log('   Enhanced dropdowns will not be initialized');
    }


    // Auto-fill autopay dates based on policy dates
    function autoFillAutopayDates() {
      const policyStartDate = document.getElementById('start_date')?.value;
      const policyEndDate = document.getElementById('end_date')?.value;

      const autopayStartField = document.querySelector('input[name="health_insurance[installment_autopay_start_date]"]');
      const autopayEndField = document.querySelector('input[name="health_insurance[installment_autopay_end_date]"]');

      if (policyStartDate && autopayStartField) {
        autopayStartField.value = policyStartDate;
