    // Auto-calculate total premium
    function calculateTotalPremium() {
      const netPremiumField = document.getElementById('net_premium');
      const gstField = document.getElementById('gst_percentage');
      const totalPremiumField = document.getElementById('total_premium');

      console.log('calculateTotalPremium called');
      console.log('Net Premium field:', netPremiumField);
      console.log('GST field:', gstField);
      console.log('Total Premium field:', totalPremiumField);

      if (!netPremiumField || !gstField || !totalPremiumField) {
        console.error('One or more required fields not found!');
        return;
      }

      const netPremium = parseFloat(netPremiumField.value) || 0;
      // Default GST to 18% if field is empty
      let gstPercentage = parseFloat(gstField.value);
      if (isNaN(gstPercentage) || gstField.value === '') {
        gstPercentage = 18.0;
        gstField.value = '18.0';
      }

      console.log('Net Premium value:', netPremium);
      console.log('GST Percentage:', gstPercentage);

      const gstAmount = netPremium * (gstPercentage / 100);
      const totalPremium = netPremium + gstAmount;

      console.log('GST Amount:', gstAmount);
      console.log('Total Premium:', totalPremium);

      // Force update the readonly field
      totalPremiumField.readOnly = false;
      totalPremiumField.value = totalPremium.toFixed(2);
      totalPremiumField.readOnly = true;

      console.log('Total Premium field updated to:', totalPremium.toFixed(2));
    }

    // Auto-calculate commission amounts
    function calculateCommission() {
      const netPremium = parseFloat(document.getElementById('net_premium')?.value) || 0;
      const commissionPercentage = parseFloat(document.getElementById('commission_percentage')?.value) || 0;
      const tdsPercentage = parseFloat(document.getElementById('tds_percentage')?.value) || 0;

      const commissionAmount = netPremium * (commissionPercentage / 100);
      const tdsAmount = commissionAmount * (tdsPercentage / 100);
      const afterTdsValue = commissionAmount - tdsAmount;

      const commissionField = document.getElementById('commission_amount');
      if (commissionField) {
        commissionField.removeAttribute('readonly');
        commissionField.value = commissionAmount.toFixed(2);
        commissionField.setAttribute('readonly', true);
      }

      const tdsField = document.getElementById('tds_amount');
      if (tdsField) {
        tdsField.removeAttribute('readonly');
        tdsField.value = tdsAmount.toFixed(2);
        tdsField.setAttribute('readonly', true);
      }

      const afterTdsField = document.getElementById('after_tds_value');
      if (afterTdsField) {
        afterTdsField.removeAttribute('readonly');
        afterTdsField.value = afterTdsValue.toFixed(2);
        afterTdsField.setAttribute('readonly', true);
      }
    }

    // Auto-calculate sub-agent commission
    function calculateSubAgentCommission() {
      const netPremium = parseFloat(document.getElementById('net_premium')?.value) || 0;
      const commissionPercentage = parseFloat(document.querySelector('.sub-agent-commission-percentage')?.value) || 0;
      const tdsPercentage = parseFloat(document.querySelector('.sub-agent-tds-percentage')?.value) || 0;

      const commissionAmount = netPremium * (commissionPercentage / 100);
      const tdsAmount = commissionAmount * (tdsPercentage / 100);
      const afterTdsValue = commissionAmount - tdsAmount;

      const commissionField = document.querySelector('.sub-agent-commission-amount');
      if (commissionField) {
        commissionField.removeAttribute('readonly');
        commissionField.value = commissionAmount.toFixed(2);
        commissionField.setAttribute('readonly', true);
      }
      const tdsField = document.querySelector('.sub-agent-tds-amount');
      if (tdsField) {
        tdsField.removeAttribute('readonly');
        tdsField.value = tdsAmount.toFixed(2);
        tdsField.setAttribute('readonly', true);
      }
      const afterTdsField = document.querySelector('.sub-agent-after-tds-value');
      if (afterTdsField) {
        afterTdsField.removeAttribute('readonly');
        afterTdsField.value = afterTdsValue.toFixed(2);
        afterTdsField.setAttribute('readonly', true);
      }
    }

    // Auto-calculate investor commission
    function calculateInvestorCommission() {
      const netPremium = parseFloat(document.getElementById('net_premium')?.value) || 0;
      const commissionPercentage = parseFloat(document.querySelector('.investor-commission-percentage')?.value) || 0;
      const tdsPercentage = parseFloat(document.querySelector('.investor-tds-percentage')?.value) || 0;

      const commissionAmount = netPremium * (commissionPercentage / 100);
      const tdsAmount = commissionAmount * (tdsPercentage / 100);
      const afterTdsValue = commissionAmount - tdsAmount;

      const commissionField = document.querySelector('.investor-commission-amount');
      if (commissionField) {
        commissionField.removeAttribute('readonly');
        commissionField.value = commissionAmount.toFixed(2);
        commissionField.setAttribute('readonly', true);
      }
      const tdsField = document.querySelector('.investor-tds-amount');
      if (tdsField) {
        tdsField.removeAttribute('readonly');
        tdsField.value = tdsAmount.toFixed(2);
        tdsField.setAttribute('readonly', true);
      }
      const afterTdsField = document.querySelector('.investor-after-tds-value');
      if (afterTdsField) {
        afterTdsField.removeAttribute('readonly');
        afterTdsField.value = afterTdsValue.toFixed(2);
        afterTdsField.setAttribute('readonly', true);
      }
    }

    // Auto-calculate ambassador commission
    function calculateAmbassadorCommission() {
      const netPremium = parseFloat(document.getElementById('net_premium')?.value) || 0;
      const commissionPercentage = parseFloat(document.querySelector('.ambassador-commission-percentage')?.value) || 0;
      const tdsPercentage = parseFloat(document.querySelector('.ambassador-tds-percentage')?.value) || 0;

      const commissionAmount = netPremium * (commissionPercentage / 100);
      const tdsAmount = commissionAmount * (tdsPercentage / 100);
      const afterTdsValue = commissionAmount - tdsAmount;

      const commissionField = document.querySelector('.ambassador-commission-amount');
      if (commissionField) {
        commissionField.removeAttribute('readonly');
        commissionField.value = commissionAmount.toFixed(2);
        commissionField.setAttribute('readonly', true);
      }
      const tdsField = document.querySelector('.ambassador-tds-amount');
      if (tdsField) {
        tdsField.removeAttribute('readonly');
        tdsField.value = tdsAmount.toFixed(2);
        tdsField.setAttribute('readonly', true);
      }
      const afterTdsField = document.querySelector('.ambassador-after-tds-value');
      if (afterTdsField) {
        afterTdsField.removeAttribute('readonly');
        afterTdsField.value = afterTdsValue.toFixed(2);
        afterTdsField.setAttribute('readonly', true);
      }
    }

    // Calculate company expenses and profit
    function calculateProfitAndExpenses() {
      const netPremium = parseFloat(document.getElementById('net_premium')?.value) || 0;
      const mainAgentCommissionPercentage = parseFloat(document.getElementById('commission_percentage')?.value) || 0;

      const subAgentPercentage = parseFloat(document.querySelector('.sub-agent-commission-percentage')?.value) || 0;
      const investorPercentage = parseFloat(document.querySelector('.investor-commission-percentage')?.value) || 0;
      const companyExpensesPercentage = parseFloat(document.querySelector('.company-expenses-percentage')?.value) || 0;
      const ambassadorPercentage = parseFloat(document.querySelector('.ambassador-commission-percentage')?.value) || 0;

      const totalDistributionPercentage = subAgentPercentage + investorPercentage + ambassadorPercentage;
      const profitPercentage = mainAgentCommissionPercentage - totalDistributionPercentage - companyExpensesPercentage;
      const profitAmount = netPremium * (profitPercentage / 100);
      const companyExpensesAmount = netPremium * (companyExpensesPercentage / 100);

      if (document.querySelector('.total-distribution-percentage')) {
        document.querySelector('.total-distribution-percentage').value = totalDistributionPercentage.toFixed(2);
      }
      if (document.querySelector('.profit-percentage')) {
        document.querySelector('.profit-percentage').value = profitPercentage.toFixed(2);
      }
      if (document.querySelector('.profit-amount')) {
        document.querySelector('.profit-amount').value = profitAmount.toFixed(2);
      }
      if (document.querySelector('.profit-amount-display')) {
        document.querySelector('.profit-amount-display').value = profitAmount.toFixed(2);
      }
      if (document.querySelector('.company-expenses-amount')) {
        document.querySelector('.company-expenses-amount').value = companyExpensesAmount.toFixed(2);
      }
      if (document.querySelector('.company-expenses-amount-display')) {
        document.querySelector('.company-expenses-amount-display').value = companyExpensesAmount.toFixed(2);
      }
      const investorDisplayField = document.querySelector('.investor-commission-amount-display');
      if (investorDisplayField) {
        investorDisplayField.value = (netPremium * (investorPercentage / 100)).toFixed(2);
      }
    }

    // Calculate all commissions when net premium changes
    function calculateAllCommissions() {
      console.log('Calculating all commissions for net premium:', document.getElementById('net_premium')?.value);
      calculateCommission();
      calculateSubAgentCommission();
      calculateInvestorCommission();
      calculateAmbassadorCommission();
      calculateProfitAndExpenses();
    }

    // Enhanced auto-calculation for renewal dates based on payment mode
    function formatDateForInput(date) {
      const year = date.getFullYear();
      const month = (date.getMonth() + 1).toString().padStart(2, '0');
      const day = date.getDate().toString().padStart(2, '0');
      return `${year}-${month}-${day}`;
    }

    function parseInputDate(dateString) {
      if (!dateString) return null;
      // Handle YYYY-MM-DD format (HTML date input format)
      if (dateString.includes('-')) {
        return new Date(dateString);
      }
      // Handle MM/DD/YYYY format
      if (dateString.includes('/')) {
        return new Date(dateString);
      }
      return new Date(dateString);
    }

    // Calculate Policy End Date based on Policy Start Date and Payment Mode
    function calculatePolicyEndDate() {
      console.log('🔄 Calculating Policy End Date based on Start Date and Payment Mode...');

      const startDateField = document.getElementById('start_date');
      const endDateField = document.getElementById('end_date');
      const paymentModeField = document.getElementById('payment_mode_select');

      if (!startDateField?.value || !paymentModeField?.value || !endDateField) {
        console.warn('Missing required fields for Policy End Date calculation');
        return;
      }

      const startDate = parseInputDate(startDateField.value);
      const paymentMode = paymentModeField.value;

      console.log('Policy Start Date:', startDateField.value);
      console.log('Payment Mode:', paymentMode);

      if (!startDate) {
        console.warn('Could not parse Policy Start Date:', startDateField.value);
        return;
      }

      // Calculate Policy End Date based on Payment Mode
      const endDate = new Date(startDate);

      switch(paymentMode) {
        case 'Yearly':
        case 'Annual':
          endDate.setFullYear(endDate.getFullYear() + 1);
          endDate.setDate(endDate.getDate() - 1);
          break;
        case 'Half Yearly':
        case 'Semi-Annual':
          endDate.setMonth(endDate.getMonth() + 6);
          endDate.setDate(endDate.getDate() - 1);
          break;
        case 'Quarterly':
          endDate.setMonth(endDate.getMonth() + 3);
          endDate.setDate(endDate.getDate() - 1);
          break;
        case 'Monthly':
          endDate.setMonth(endDate.getMonth() + 1);
          endDate.setDate(endDate.getDate() - 1);
          break;
        default:
          // Default to yearly
          endDate.setFullYear(endDate.getFullYear() + 1);
          endDate.setDate(endDate.getDate() - 1);
          console.log('Using default yearly calculation for payment mode:', paymentMode);
      }

      endDateField.value = formatDateForInput(endDate);
      console.log('✅ Policy End Date automatically calculated and set to:', formatDateForInput(endDate));

      // Also update autopay end date when policy dates change
      calculateAutopayEndDate();
    }

    function calculateRenewalDates() {
      console.log('🔄 Calculating initial renewal dates...');

      // Get the original policy end date from the model (for initial setup)
      const originalEndDate = <% if @health_insurance.policy_end_date %>'<%= @health_insurance.policy_end_date %>'<% else %>null<% end %>;
      const paymentMode = document.getElementById('payment_mode_select')?.value ||
                         document.getElementById('health_insurance_payment_mode')?.value;

      console.log('Original end date from model:', originalEndDate);
      console.log('Payment mode:', paymentMode);

      if (!originalEndDate) {
        console.warn('No original end date found from model');
        // Use today + 1 year as fallback
        const today = new Date();
        const nextYear = new Date(today);
        nextYear.setFullYear(nextYear.getFullYear() + 1);

        const startDateField = document.getElementById('start_date');
        if (startDateField && !startDateField.value) {
          const tomorrow = new Date(today);
          tomorrow.setDate(tomorrow.getDate() + 1);
          startDateField.value = formatDateForInput(tomorrow);
        }

        calculatePolicyEndDate();
        return;
      }

      // Calculate Policy Start Date (day after original policy ends)
      const endDate = parseInputDate(originalEndDate);
      if (!endDate) {
        console.warn('Could not parse original end date:', originalEndDate);
        return;
      }

      const startDate = new Date(endDate);
      startDate.setDate(startDate.getDate() + 1);

      // Set Policy Start Date
      const startDateField = document.getElementById('start_date');
      if (startDateField) {
        startDateField.value = formatDateForInput(startDate);
        console.log('✅ Policy Start Date set to:', formatDateForInput(startDate));
      }

      // Now calculate end date based on the payment mode
      calculatePolicyEndDate();

      // Set default Autopay Start Date to today
      setDefaultAutopayStartDate();
    }

    function setDefaultAutopayStartDate() {
      const autopayStartField = document.querySelector('input[name="health_insurance[installment_autopay_start_date]"]');

      if (autopayStartField && !autopayStartField.value) {
        const today = new Date();
        autopayStartField.value = formatDateForInput(today);
        console.log('✅ Autopay Start Date set to today:', formatDateForInput(today));

        // Trigger autopay end date calculation
        calculateAutopayEndDate();
      }
    }

    function calculateAutopayEndDate() {
      const autopayStartField = document.querySelector('input[name="health_insurance[installment_autopay_start_date]"]');
      const autopayEndField = document.querySelector('input[name="health_insurance[installment_autopay_end_date]"]');
      const paymentMode = document.getElementById('payment_mode_select')?.value ||
                         document.getElementById('health_insurance_payment_mode')?.value;

      if (!autopayStartField?.value || !paymentMode || !autopayEndField) {
        console.log('Missing fields for autopay calculation:', {
          autopayStart: !!autopayStartField?.value,
          paymentMode: !!paymentMode,
          autopayEnd: !!autopayEndField
        });
        return;
      }

      console.log('🔄 Calculating autopay end date...');
      console.log('Autopay start:', autopayStartField.value);
      console.log('Payment mode:', paymentMode);

      const startDate = parseInputDate(autopayStartField.value);
      if (!startDate) return;

      const endDate = new Date(startDate);

      // Calculate autopay end date based on payment frequency
      switch(paymentMode) {
        case 'Yearly':
        case 'Annual':
          endDate.setFullYear(endDate.getFullYear() + 1);
          break;
        case 'Half Yearly':
        case 'Semi-Annual':
          endDate.setMonth(endDate.getMonth() + 6);
          break;
        case 'Quarterly':
          endDate.setMonth(endDate.getMonth() + 3);
          break;
        case 'Monthly':
          endDate.setMonth(endDate.getMonth() + 1);
          break;
        default:
          endDate.setFullYear(endDate.getFullYear() + 1);
      }

      autopayEndField.value = formatDateForInput(endDate);
      console.log('✅ Autopay End Date automatically set to:', formatDateForInput(endDate));
    }

    // Auto-calculate end date (legacy function for backward compatibility)
    function calculateEndDate() {
      const startDate = document.getElementById('start_date')?.value;
      if (startDate) {
        const start = new Date(startDate);
        const end = new Date(start);
        end.setFullYear(end.getFullYear() + 1);
        end.setDate(end.getDate() - 1);
        if (document.getElementById('end_date')) {
          document.getElementById('end_date').value = end.toISOString().split('T')[0];
        }
      }
    }

    // Event listeners
    const netPremiumInput = document.getElementById('net_premium');
    console.log('Setting up Net Premium event listener...');
    console.log('Net Premium input field:', netPremiumInput);

    if (netPremiumInput) {
      // Use both input and change events to ensure it works
      netPremiumInput.addEventListener('input', function(e) {
        console.log('Net Premium input event triggered, value:', e.target.value);
        calculateTotalPremium();
        calculateAllCommissions();
      });

      netPremiumInput.addEventListener('change', function(e) {
        console.log('Net Premium change event triggered, value:', e.target.value);
        calculateTotalPremium();
        calculateAllCommissions();
      });

      console.log('Event listeners attached to net_premium field');
    } else {
      console.error('net_premium field not found - cannot attach event listeners!');
    }
    if (document.getElementById('gst_percentage')) {
      document.getElementById('gst_percentage').addEventListener('input', calculateTotalPremium);
    }
    if (document.getElementById('commission_percentage')) {
      document.getElementById('commission_percentage').addEventListener('input', function() {
        calculateCommission();
        calculateProfitAndExpenses();
      });
    }
    if (document.getElementById('tds_percentage')) {
      document.getElementById('tds_percentage').addEventListener('input', calculateCommission);
    }
    if (document.getElementById('start_date')) {
      document.getElementById('start_date').addEventListener('change', calculateEndDate);
    }

    // Auto-fill autopay dates when policy dates change
    if (document.getElementById('start_date')) {
      document.getElementById('start_date').addEventListener('change', autoFillAutopayDates);
    }
    if (document.getElementById('end_date')) {
      document.getElementById('end_date').addEventListener('change', autoFillAutopayDates);
    }

    // Initial auto-fill of autopay dates on page load
    autoFillAutopayDates();

    // Enhanced Payment Mode change listeners (for both regular and Select2 dropdowns)
    function setupPaymentModeListeners() {
      const paymentModeSelect = document.getElementById('payment_mode_select') ||
                               document.getElementById('health_insurance_payment_mode');

      if (paymentModeSelect) {
        // Regular dropdown change event
        paymentModeSelect.addEventListener('change', function() {
          console.log('Payment Mode changed to:', this.value);
          setTimeout(() => {
            calculatePolicyEndDate(); // Calculate new end date based on current start date + payment mode
          }, 100);
        });

        // Select2 specific events
        if (typeof $ !== 'undefined' && typeof $.fn.select2 !== 'undefined') {
          $(paymentModeSelect).on('select2:select', function() {
            console.log('Payment Mode changed via Select2 to:', this.value);
            setTimeout(() => {
              calculatePolicyEndDate(); // Calculate new end date based on current start date + payment mode
            }, 100);
          });
        }

        console.log('✅ Payment Mode event listeners attached');
      }
    }

    // Policy Start Date change listeners
    function setupPolicyStartDateListeners() {
      const startDateField = document.getElementById('start_date');

      if (startDateField) {
        startDateField.addEventListener('change', function() {
          console.log('Policy Start Date changed to:', this.value);
          setTimeout(() => {
            calculatePolicyEndDate(); // Recalculate end date when start date changes
          }, 100);
        });
        console.log('✅ Policy Start Date listener attached');
      }
    }

    // Autopay start date change listeners
    function setupAutopayStartDateListeners() {
      const autopayStartField = document.querySelector('input[name="health_insurance[installment_autopay_start_date]"]');

      if (autopayStartField) {
        autopayStartField.addEventListener('change', function() {
          console.log('Autopay Start Date changed to:', this.value);
          calculateAutopayEndDate();
        });
        console.log('✅ Autopay Start Date listener attached');
      }
    }

    // Setup all date calculation event listeners
    setupPaymentModeListeners();
    setupPolicyStartDateListeners();
    setupAutopayStartDateListeners();

    // Sub-agent commission event listeners
    if (document.querySelector('.sub-agent-commission-percentage')) {
      document.querySelector('.sub-agent-commission-percentage').addEventListener('input', function() {
        calculateSubAgentCommission();
        calculateProfitAndExpenses();
      });
    }
    if (document.querySelector('.sub-agent-tds-percentage')) {
      document.querySelector('.sub-agent-tds-percentage').addEventListener('input', calculateSubAgentCommission);
    }

    // Investor commission event listeners
    if (document.querySelector('.investor-commission-percentage')) {
      document.querySelector('.investor-commission-percentage').addEventListener('input', function() {
        calculateInvestorCommission();
        calculateProfitAndExpenses();
      });
    }
    if (document.querySelector('.investor-tds-percentage')) {
      document.querySelector('.investor-tds-percentage').addEventListener('input', calculateInvestorCommission);
    }

    // Ambassador commission event listeners
    if (document.querySelector('.ambassador-commission-percentage')) {
      document.querySelector('.ambassador-commission-percentage').addEventListener('input', function() {
        calculateAmbassadorCommission();
        calculateProfitAndExpenses();
      });
    }
    if (document.querySelector('.ambassador-tds-percentage')) {
      document.querySelector('.ambassador-tds-percentage').addEventListener('input', calculateAmbassadorCommission);
    }

    // Family Members Management (copied from working edit page)
    let memberIndex = <%= @health_insurance.health_insurance_members.length %>;
    console.log('Family Members - Initial memberIndex:', memberIndex);

    function toggleNoMembersMessage() {
      const memberRows = document.querySelectorAll('.family-member-row');
      const noMembersMsg = document.getElementById('no_members_message');

      if (memberRows.length === 0 || Array.from(memberRows).every(row => row.style.display === 'none')) {
        if (noMembersMsg) noMembersMsg.style.display = 'block';
      } else {
        if (noMembersMsg) noMembersMsg.style.display = 'none';
      }
    }

    // Add Family Member functionality (copied from working edit page)
    const addFamilyBtn = document.getElementById('add_family_member');
    console.log('ADD MEMBER button found:', addFamilyBtn);

    if (addFamilyBtn) {
      addFamilyBtn.addEventListener('click', function() {
        console.log('✅ ADD MEMBER button clicked! Current memberIndex:', memberIndex);
        const memberTemplate = `
          <div class="family-member-row border rounded p-3 mb-3 bg-light">
            <div class="row">
              <div class="col-md-3 mb-3">
                <label class="form-label">Member Name</label>
                <input type="text" name="health_insurance[health_insurance_members_attributes][${memberIndex}][member_name]" class="form-control" placeholder="Full Name">
              </div>
              <div class="col-md-2 mb-3">
                <label class="form-label">Age</label>
                <input type="number" name="health_insurance[health_insurance_members_attributes][${memberIndex}][age]" class="form-control" min="1" max="120">
              </div>
              <div class="col-md-3 mb-3">
                <label class="form-label">Relationship</label>
                <select name="health_insurance[health_insurance_members_attributes][${memberIndex}][relationship]" class="form-select">
                  <option value="">Select Relationship</option>
                  <option value="Self">Self</option>
                  <option value="Spouse">Spouse</option>
                  <option value="Son">Son</option>
                  <option value="Daughter">Daughter</option>
                  <option value="Father">Father</option>
                  <option value="Mother">Mother</option>
                  <option value="Brother">Brother</option>
                  <option value="Sister">Sister</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div class="col-md-3 mb-3">
                <label class="form-label">Sum Insured</label>
                <input type="number" name="health_insurance[health_insurance_members_attributes][${memberIndex}][sum_insured]" class="form-control" step="0.01">
              </div>
              <div class="col-md-1 d-flex align-items-end mb-3">
                <button type="button" class="btn btn-outline-danger remove-member-btn">
                  <i class="bi bi-trash"></i>
                </button>
              </div>
            </div>
          </div>
        `;

        document.getElementById('family_members').insertAdjacentHTML('beforeend', memberTemplate);
        memberIndex++;
        toggleNoMembersMessage();
        console.log('✅ Family member added, new memberIndex:', memberIndex);
      });
    } else {
      console.error('❌ ADD MEMBER button not found!');
    }

    // Remove family member
    document.addEventListener('click', function(e) {
      if (e.target.closest('.remove-member-btn')) {
        const memberRow = e.target.closest('.family-member-row');
        const destroyInput = memberRow.querySelector('input[name*="_destroy"]');

        if (destroyInput) {
          destroyInput.value = '1';
          memberRow.style.display = 'none';
        } else {
          memberRow.remove();
        }
        toggleNoMembersMessage();
        console.log('✅ Family member removed');
      }
    });

    // Initialize calculations after a short delay to ensure DOM is ready
    setTimeout(function() {
      console.log('🚀 Running initial renewal form calculations...');

      // Set default autopay start date first
      setDefaultAutopayStartDate();

      // Calculate renewal dates based on original policy
      calculateRenewalDates();

      // Calculate financial amounts
      calculateTotalPremium();
      calculateAllCommissions();

      console.log('✅ Initial calculations completed');
    }, 500); // Increased delay to ensure DOM and Select2 are ready

    // Initialize the no members message state (must be after DOM is ready)
    toggleNoMembersMessage();

    // Health Insurance Policy Documents Manager
    let healthPolicyDocumentIndex = 0;
    const addHealthPolicyDocumentBtn = document.getElementById('add_health_policy_document');
    const healthPolicyDocumentsContainer = document.getElementById('health_policy_documents_container');

    if (addHealthPolicyDocumentBtn && healthPolicyDocumentsContainer) {
      addHealthPolicyDocumentBtn.addEventListener('click', function() {
        const documentHtml = `
          <div class="document-entry p-3 mb-3 border rounded position-relative" data-index="${healthPolicyDocumentIndex}" style="background: #f8f9fa;">
            <button type="button" class="btn btn-sm btn-outline-danger position-absolute" style="top: 10px; right: 10px;" onclick="this.closest('.document-entry').remove()">
              <i class="bi bi-trash"></i>
            </button>
            <div class="row">
              <div class="col-md-4">
                <label class="form-label">Document Title <span class="text-danger">*</span></label>
                <input type="text" name="health_insurance[health_insurance_documents_attributes][${healthPolicyDocumentIndex}][title]" class="form-control" placeholder="Enter document title" required>
              </div>
              <div class="col-md-4">
                <label class="form-label">Document Type <span class="text-danger">*</span></label>
                <select name="health_insurance[health_insurance_documents_attributes][${healthPolicyDocumentIndex}][document_type]" class="form-select" required>
                  <option value="">Select Document Type</option>
                  <option value="policy_document">Policy Document</option>
                  <option value="medical_report">Medical Report</option>
                  <option value="identity_proof">Identity Proof</option>
                  <option value="address_proof">Address Proof</option>
                  <option value="income_proof">Income Proof</option>
                  <option value="aadhar">Aadhar Card</option>
                  <option value="pan_card">PAN Card</option>
                  <option value="passport">Passport</option>
                  <option value="claim_form">Claim Form</option>
                  <option value="discharge_summary">Discharge Summary</option>
                  <option value="pre_policy_checkup">Pre-Policy Checkup</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label">Document File <span class="text-danger">*</span></label>
                <input type="file" name="health_insurance[health_insurance_documents_attributes][${healthPolicyDocumentIndex}][file]" class="form-control" accept="application/pdf,image/jpeg,image/jpg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required id="health_doc_file_${healthPolicyDocumentIndex}">
              </div>
            </div>
            <div class="row mt-2">
              <div class="col-md-12">
                <label class="form-label">Description (Optional)</label>
                <textarea name="health_insurance[health_insurance_documents_attributes][${healthPolicyDocumentIndex}][description]" class="form-control" rows="2" placeholder="Optional description"></textarea>
              </div>
            </div>
          </div>
        `;
        healthPolicyDocumentsContainer.insertAdjacentHTML('beforeend', documentHtml);
        healthPolicyDocumentIndex++;
      });
    }

  } catch (error) {
    console.warn('Health insurance renewal form initialization error:', error.message);
  }
});
</script>