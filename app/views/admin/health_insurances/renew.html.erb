          <h6 class="mb-0">Organised Documents</h6>
          <button type="button" class="btn btn-sm btn-primary" id="add_health_policy_document">
            <i class="bi bi-plus-lg me-1"></i>
            Add Document
          </button>
        </div>
        <div id="health_policy_documents_container"></div>
        <p class="text-muted mb-0 mt-2">
          <small>Add documents with title and type for organised storage in R2</small>
        </p>
      </div>
    </div>
  </div>

  <!-- Original Policy Documents for Reference -->
