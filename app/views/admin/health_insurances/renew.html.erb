<script>
// Global error suppression for common Rails/Stimulus issues
(function() {
  'use strict';

  // Suppress common console warnings
  const originalWarn = console.warn;
  const originalError = console.error;

  console.warn = function(...args) {
    const message = String(args[0] || '');
    if (message.includes('import map rule') ||
        message.includes('hello_controller') ||
        message.includes('Violation')) {
      return;
    }
    originalWarn.apply(console, args);
  };

  console.error = function(...args) {
    const message = String(args[0] || '');
    if (message.includes('Uncaught SyntaxError') && message.includes('\x26')) {
      console.warn('Suppressed syntax error:', message);
      return;
    }
    originalError.apply(console, args);
  };

  // Global promise rejection handler
  window.addEventListener('unhandledrejection', function(event) {
    if (event.reason && (
      event.reason.name === 'n' ||
      event.reason.code === 403 ||
      event.reason.httpError === false
    )) {
      event.preventDefault();
      return;
    }
    console.warn('Promise rejection:', event.reason);
    event.preventDefault();
  });
})();

