<script>
document.addEventListener('DOMContentLoaded', function() {
  try {
    // Initialize Select2 for searchable dropdown
    $('#customer_select').select2({
      theme: 'bootstrap-5',
      placeholder: 'Search and select client...',
      allowClear: true,
      width: '100%',
      dropdownParent: $('body'),
      dropdownCssClass: 'select2-dropdown-large',
      minimumResultsForSearch: 0,
      closeOnSelect: true,
      templateResult: function(option) {
        if (!option.id || option.element.value === '') {
          return option.text;
        }

        // Generate avatar with initials
        var initials = option.text.split(' ').map(function(name) {
          return name.charAt(0).toUpperCase();
        }).join('').substring(0, 2);

        // Custom template for dropdown options with avatar
        var $option = $(
          '<div class="client-option">' +
            '<div class="client-option-avatar">' + initials + '</div>' +
            '<div class="client-option-details">' +
              '<div class="client-option-name">' + option.text + '</div>' +
              '<div class="client-option-id">Client ID: #' + option.id + '</div>' +
            '</div>' +
          '</div>'
        );
        return $option;
      },
      templateSelection: function(option) {
        return option.text || 'Search and select client...';
      },
      escapeMarkup: function(markup) {
        return markup;
      }
    });

    // Initialize Select2 for Affiliate dropdown with AJAX search
    $('#affiliate_select').select2({
      theme: 'bootstrap-5',
      placeholder: 'Search and select affiliate...',
      allowClear: true,
      width: '100%',
      dropdownParent: $('body'),
      dropdownCssClass: 'select2-dropdown-large',
      minimumInputLength: 0,
      ajax: {
        url: '/api/v1/public/search_sub_agents',
        dataType: 'json',
        delay: 250,
        data: function (params) {
          var selectedCustomerId = $('#customer_select').val();

          return {
            q: params.term || '',
            customer_id: selectedCustomerId,
            limit: params.term ? 20 : 10
          };
        },
        processResults: function (data) {
          return {
            results: data.results || []
          };
        },
        error: function(xhr, status, error) {
          console.error('Search affiliates AJAX error:', status, error);
          return {
            results: [{id: '', text: 'Error loading affiliates - please try again'}]
          };
        },
        cache: false
      },
      templateResult: function(option) {
        if (option.loading) return option.text;
        if (!option.id || option.id === '') {
          return option.text;
        }

        var initials = option.text.split(' ').map(function(name) {
          return name.charAt(0).toUpperCase();
        }).join('').substring(0, 2);

        var $option = $(
          '<div class="affiliate-option">' +
            '<div class="affiliate-option-avatar">' + initials + '</div>' +
            '<div class="affiliate-option-details">' +
              '<div class="affiliate-option-name">' + option.text + '</div>' +
              '<div class="affiliate-option-id">Affiliate ID: #' + option.id + '</div>' +
            '</div>' +
          '</div>'
        );
        return $option;
      },
      templateSelection: function(option) {
        return option.text || 'Search and select affiliate...';
      },
      escapeMarkup: function(markup) {
        return markup;
      }
    });

    // Initialize Select2 for Insurance Company dropdown
    $('#health_insurance_insurance_company_name').select2({
      theme: 'bootstrap-5',
      placeholder: 'Search and select company...',
      allowClear: true,
      width: '100%',
      dropdownParent: $('body'),
      dropdownCssClass: 'select2-dropdown-large',
      minimumResultsForSearch: 0,
      closeOnSelect: true,
      templateResult: function(option) {
        if (!option.id || option.element.value === '') {
          return option.text;
        }

        var initials = option.text.split(' ').map(function(word) {
          return word.charAt(0).toUpperCase();
        }).join('').substring(0, 3);

        var $option = $(
          '<div class="company-option">' +
            '<div class="company-option-avatar">' + initials + '</div>' +
            '<div class="company-option-details">' +
              '<div class="company-option-name">' + option.text + '</div>' +
              '<div class="company-option-type">Insurance Company</div>' +
            '</div>' +
          '</div>'
        );
        return $option;
      },
      templateSelection: function(option) {
        return option.text || 'Search and select company...';
      },
      escapeMarkup: function(markup) {
        return markup;
      }
    });

    // ---- Broker/Agency Code dynamic switching (same as new form) ----
    const savedBrokerCodeType = '<%= @health_insurance.broker_code_type %>';
    const savedBrokerId       = '<%= @health_insurance.broker_id %>';
    const savedAgencyCodeId   = '<%= @health_insurance.agency_code_id %>';

    function populateAgencyCodeDropdownEdit(data, placeholder, preselectId, isBroking) {
      const agencyCodeSelect = document.getElementById('health_insurance_agency_code_id');
      if (!agencyCodeSelect) return;
      if ($(agencyCodeSelect).hasClass('select2-hidden-accessible')) {
        $(agencyCodeSelect).select2('destroy');
      }
      agencyCodeSelect.innerHTML = `<option value="">${placeholder}</option>`;
      data.forEach(function(item) {
        const option = document.createElement('option');
        option.value = isBroking ? 'broker_' + item.id : item.id;
        option.textContent = item.code && !item.text.includes(' - ') ? item.text + ' - ' + item.code : item.text;
        option.setAttribute('data-code', item.code || '');
        option.setAttribute('data-name', item.broker_name || item.agent_name || item.text);
        var valueToCompare = isBroking ? 'broker_' + String(item.id) : String(item.id);
        if (valueToCompare === String(preselectId)) option.selected = true;
        agencyCodeSelect.appendChild(option);
      });
      $(agencyCodeSelect).select2({
        theme: 'bootstrap-5', placeholder: placeholder, allowClear: true,
        width: '100%', dropdownParent: $('body'), dropdownCssClass: 'select2-dropdown-large',
        minimumResultsForSearch: 0, closeOnSelect: true
      });
    }

    function loadBrokingMode(preselectBrokerId) {
      fetch('/admin/insurance/health/agency_codes_for_broker_type?broker_type=broking')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success && data.data) {
            var preselect = preselectBrokerId ? 'broker_' + preselectBrokerId : '';
            populateAgencyCodeDropdownEdit(data.data, 'Select Broker...', preselect, true);
          }
        });
    }

    function loadDirectMode(preselectAgencyCodeId) {
      fetch('/admin/insurance/health/agency_codes_for_broker_type?broker_type=direct')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success && data.data) {
            populateAgencyCodeDropdownEdit(data.data, 'Select Agent...', preselectAgencyCodeId, false);
          }
        });
    }

    // On page load: load the right list and pre-select saved value
    if (savedBrokerCodeType === 'broking') {
      // Fall back to savedAgencyCodeId for records saved before broker_id was correctly set
      loadBrokingMode(savedBrokerId || savedAgencyCodeId);
    } else if (savedBrokerCodeType === 'direct') {
      loadDirectMode(savedAgencyCodeId);
    }

    // On broker_code_type change: reload dropdown
    var brokerTypeSelect = document.getElementById('health_insurance_broker_code_type');
    if (brokerTypeSelect) {
      brokerTypeSelect.addEventListener('change', function() {
        if (this.value === 'broking') {
          loadBrokingMode(null);
        } else if (this.value === 'direct') {
          loadDirectMode(null);
        }
      });
    }
    // ---- End broker/agency switching ----

    // Initialize Select2 for Agency Code dropdown
    $('#health_insurance_agency_code_id').select2({
      theme: 'bootstrap-5',
      placeholder: 'Search and select agency code...',
      allowClear: true,
      width: '100%',
      dropdownParent: $('body'),
      dropdownCssClass: 'select2-dropdown-large',
      minimumResultsForSearch: 0,
      closeOnSelect: true,
      templateResult: function(option) {
        if (!option.id || option.element.value === '') {
          return option.text;
        }

        var parts = option.text.split(' - ');
        var agentName = parts[0] || option.text;
        var agencyCode = parts[1] || '';

        var initials = agentName.split(' ').map(function(word) {
          return word.charAt(0).toUpperCase();
        }).join('').substring(0, 2);

        var $option = $(
          '<div class="agency-option">' +
            '<div class="agency-option-avatar">' + initials + '</div>' +
            '<div class="agency-option-details">' +
              '<div class="agency-option-name">' + agentName + '</div>' +
              '<div class="agency-option-code">Code: ' + agencyCode + '</div>' +
            '</div>' +
          '</div>'
        );
        return $option;
      },
      templateSelection: function(option) {
        return option.text || 'Search and select agency code...';
      },
      escapeMarkup: function(markup) {
        return markup;
      }
    });

    // Initialize Select2 for Policy Holder dropdown
    $('#policy_holder_select').select2({
      theme: 'bootstrap-5',
      placeholder: 'Search and select policy holder...',
      allowClear: false,
      width: '100%',
      dropdownParent: $('body'),
      dropdownCssClass: 'select2-dropdown-large',
      minimumResultsForSearch: 0,
      closeOnSelect: true,
      templateResult: function(option) {
        if (!option.id || option.element.value === '') {
          return option.text;
        }

        // Generate avatar with initials for policy holder
        var initials = option.text.split(' ').map(function(name) {
          return name.charAt(0).toUpperCase();
        }).join('').substring(0, 2);

        // Custom template for dropdown options with avatar
        var $option = $(
          '<div class="client-option">' +
            '<div class="client-option-avatar">' + initials + '</div>' +
            '<div class="client-option-details">' +
              '<div class="client-option-name">' + option.text + '</div>' +
              '<div class="client-option-id">Policy Holder</div>' +
            '</div>' +
          '</div>'
        );
        return $option;
      },
      templateSelection: function(option) {
        return option.text || 'Search and select policy holder...';
      },
      escapeMarkup: function(markup) {
        return markup;
      }
    });

    // Initialize Select2 for Insurance Type dropdown
    $('#insurance_type_select').select2({
      theme: 'bootstrap-5',
      placeholder: 'Select Insurance Type...',
      allowClear: false,
      width: '100%',
      dropdownParent: $('body'),
      dropdownCssClass: 'select2-dropdown-large',
      minimumResultsForSearch: -1, // Disable search for small lists
      closeOnSelect: true
    });

    // Initialize Select2 for Policy Type dropdown
    $('#policy_type_select').select2({
      theme: 'bootstrap-5',
      placeholder: 'Select Policy Type...',
      allowClear: false,
      width: '100%',
      dropdownParent: $('body'),
      dropdownCssClass: 'select2-dropdown-large',
      minimumResultsForSearch: -1, // Disable search for small lists
      closeOnSelect: true
    });

    // Initialize Select2 for Payment Mode dropdown
    $('#payment_mode_select').select2({
      theme: 'bootstrap-5',
      placeholder: 'Select Payment Mode...',
      allowClear: false,
      width: '100%',
      dropdownParent: $('body'),
      dropdownCssClass: 'select2-dropdown-large',
      minimumResultsForSearch: -1, // Disable search for small lists
      closeOnSelect: true
    });

    // Initialize Select2 for Claim Process dropdown
    $('#claim_process_select').select2({
      theme: 'bootstrap-5',
      placeholder: 'Select Claim Process...',
      allowClear: false,
      width: '100%',
      dropdownParent: $('body'),
      dropdownCssClass: 'select2-dropdown-large',
      minimumResultsForSearch: -1, // Disable search for small lists
      closeOnSelect: true
    });

    // Sum Insured Text Handler
    function parseIndianAmountText(text) {
      if (!text) return 0;

      const cleanText = text.toLowerCase().replace(/,/g, '');
      let amount = 0;

      // Match patterns like "90 lakhs", "1.5 crore", "5 crores"
      const croreMatch = cleanText.match(/(\d+\.?\d*)\s*crores?/);
      const lakhMatch = cleanText.match(/(\d+\.?\d*)\s*lakhs?/);

      if (croreMatch) {
        amount += parseFloat(croreMatch[1]) * 10000000; // 1 crore = 10,000,000
      }
      if (lakhMatch) {
        amount += parseFloat(lakhMatch[1]) * 100000; // 1 lakh = 100,000
      }

      // If no crore/lakh found, try to parse as plain number
      if (!croreMatch && !lakhMatch) {
        const numberMatch = cleanText.match(/(\d+\.?\d*)/);
        if (numberMatch) {
          amount = parseFloat(numberMatch[1]);
        }
      }

      return amount;
    }

    function formatPreviewText(amount) {
      if (amount >= 10000000) {
        const crores = amount / 10000000;
        return `(Rs. ${crores === Math.floor(crores) ? crores.toString() : crores.toFixed(1)} crore${crores > 1 ? 's' : ''})`;
      } else if (amount >= 100000) {
        const lakhs = amount / 100000;
        return `(Rs. ${lakhs === Math.floor(lakhs) ? lakhs.toString() : lakhs.toFixed(1)} lakh${lakhs > 1 ? 's' : ''})`;
      } else if (amount > 0) {
        return `(Rs. ${amount.toLocaleString()})`;
      }
      return '';
    }

    // Sum insured text input handler
    if (document.getElementById('sum_insured_text_input')) {
      document.getElementById('sum_insured_text_input').addEventListener('input', function() {
        const textValue = this.value;
        const numericValue = parseIndianAmountText(textValue);

        // Update hidden field
        const hiddenField = document.querySelector('input[name="health_insurance[sum_insured]"]');
        if (hiddenField) {
          hiddenField.value = numericValue;
        }

        // Update preview
        const preview = document.getElementById('sum_insured_preview');
        if (preview) {
          preview.textContent = formatPreviewText(numericValue);
        }
      });

      // Initialize preview on page load if there's already a value
      const initialValue = document.getElementById('sum_insured_text_input').value;
      if (initialValue) {
        const numericValue = parseIndianAmountText(initialValue);
        const hiddenField = document.querySelector('input[name="health_insurance[sum_insured]"]');
        if (hiddenField) {
          hiddenField.value = numericValue;
        }
        const preview = document.getElementById('sum_insured_preview');
        if (preview) {
          preview.textContent = formatPreviewText(numericValue);
        }
      }
    }

    // Auto-calculate total premium
    function calculateTotalPremium() {
      const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
      const gstPercentage = parseFloat(document.getElementById('gst_percentage').value) || 0;

      const gstAmount = netPremium * (gstPercentage / 100);
      const totalPremium = netPremium + gstAmount;

      document.getElementById('total_premium').value = totalPremium.toFixed(2);
    }

    // Auto-calculate commission amounts
    function calculateCommission() {
      const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
      const commissionPercentage = parseFloat(document.getElementById('commission_percentage').value) || 0;
      const tdsPercentage = parseFloat(document.getElementById('tds_percentage').value) || 0;

      const commissionAmount = netPremium * (commissionPercentage / 100);
      const tdsAmount = commissionAmount * (tdsPercentage / 100);
      const afterTdsValue = commissionAmount - tdsAmount;

      document.getElementById('commission_amount').value = commissionAmount.toFixed(2);
      document.getElementById('tds_amount').value = tdsAmount.toFixed(2);
      document.getElementById('after_tds_value').value = afterTdsValue.toFixed(2);
    }

    // Auto-calculate sub-agent commission
    function calculateSubAgentCommission() {
      const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
      const commissionPercentage = parseFloat(document.querySelector('.sub-agent-commission-percentage').value) || 0;
      const tdsPercentage = parseFloat(document.querySelector('.sub-agent-tds-percentage').value) || 0;

      const commissionAmount = netPremium * (commissionPercentage / 100);
      const tdsAmount = commissionAmount * (tdsPercentage / 100);
      const afterTdsValue = commissionAmount - tdsAmount;

      document.querySelector('.sub-agent-commission-amount').value = commissionAmount.toFixed(2);
      document.querySelector('.sub-agent-tds-amount').value = tdsAmount.toFixed(2);
      document.querySelector('.sub-agent-after-tds-value').value = afterTdsValue.toFixed(2);
    }

    // Auto-calculate investor commission (no TDS for investors)
    function calculateInvestorCommission() {
      const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
      const commissionPercentage = parseFloat(document.querySelector('.investor-commission-percentage').value) || 0;

      const commissionAmount = netPremium * (commissionPercentage / 100);

      document.querySelector('.investor-commission-amount').value = commissionAmount.toFixed(2);
      // Update investor display field (since they don't have TDS)
      if (document.querySelector('.investor-commission-amount-display')) {
        document.querySelector('.investor-commission-amount-display').value = commissionAmount.toFixed(2);
      }
    }

    // Auto-calculate ambassador commission
    function calculateAmbassadorCommission() {
      const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
      const commissionPercentage = parseFloat(document.querySelector('.ambassador-commission-percentage').value) || 0;
      const tdsPercentage = parseFloat(document.querySelector('.ambassador-tds-percentage').value) || 0;

      const commissionAmount = netPremium * (commissionPercentage / 100);
      const tdsAmount = commissionAmount * (tdsPercentage / 100);
      const afterTdsValue = commissionAmount - tdsAmount;

      document.querySelector('.ambassador-commission-amount').value = commissionAmount.toFixed(2);
      document.querySelector('.ambassador-tds-amount').value = tdsAmount.toFixed(2);
      document.querySelector('.ambassador-after-tds-value').value = afterTdsValue.toFixed(2);
    }

    // Calculate company expenses and profit
    function calculateProfitAndExpenses() {
      const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
      const mainAgentCommissionPercentage = parseFloat(document.getElementById('commission_percentage').value) || 0;

      const subAgentPercentage = parseFloat(document.querySelector('.sub-agent-commission-percentage').value) || 0;
      const investorPercentage = parseFloat(document.querySelector('.investor-commission-percentage').value) || 0;
      const companyExpensesPercentage = parseFloat(document.querySelector('.company-expenses-percentage').value) || 0;
      const ambassadorPercentage = parseFloat(document.querySelector('.ambassador-commission-percentage').value) || 0;

      const totalDistributionPercentage = subAgentPercentage + investorPercentage + ambassadorPercentage;
      const profitPercentage = mainAgentCommissionPercentage - totalDistributionPercentage - companyExpensesPercentage;
      const profitAmount = netPremium * (profitPercentage / 100);
      const companyExpensesAmount = netPremium * (companyExpensesPercentage / 100);

      // Update company expenses amounts
      if (document.querySelector('.company-expenses-amount')) {
        document.querySelector('.company-expenses-amount').value = companyExpensesAmount.toFixed(2);
      }
      if (document.querySelector('.company-expenses-amount-display')) {
        document.querySelector('.company-expenses-amount-display').value = companyExpensesAmount.toFixed(2);
      }

      // Update totals
      document.querySelector('.total-distribution-percentage').value = totalDistributionPercentage.toFixed(2);

      // Update profit fields
      if (document.querySelector('.profit-percentage-display')) {
        document.querySelector('.profit-percentage-display').value = profitPercentage.toFixed(2);
      }
      if (document.querySelector('.profit-amount-display')) {
        document.querySelector('.profit-amount-display').value = profitAmount.toFixed(2);
      }
      // Legacy support for old field names
      if (document.querySelector('.profit-percentage')) {
        document.querySelector('.profit-percentage').value = profitPercentage.toFixed(2);
      }
      if (document.querySelector('.profit-amount')) {
        document.querySelector('.profit-amount').value = profitAmount.toFixed(2);
      }
    }

    // Calculate all commissions when net premium changes
    function calculateAllCommissions() {
      calculateCommission();
      calculateSubAgentCommission();
      calculateInvestorCommission();
      calculateAmbassadorCommission();
      calculateProfitAndExpenses();
    }

    // Auto-calculate autopay end date based on payment mode
    function calculateAutopayEndDate() {
      const paymentMode = document.getElementById('payment_mode_select').value;
      const startDate = document.getElementById('autopay_start_date').value;

      if (startDate && paymentMode) {
        const start = new Date(startDate);
        let end = new Date(start);

        switch (paymentMode) {
          case 'Yearly':
            end.setFullYear(end.getFullYear() + 1);
            end.setDate(end.getDate() - 1); // Subtract 1 day for proper end date
            break;
          case 'Half Yearly': // Fixed: Changed from 'Half-Yearly' to 'Half Yearly'
            end.setMonth(end.getMonth() + 6);
            end.setDate(end.getDate() - 1); // Subtract 1 day for proper end date
            break;
          case 'Quarterly':
            end.setMonth(end.getMonth() + 3);
            end.setDate(end.getDate() - 1); // Subtract 1 day for proper end date
            break;
          case 'Monthly':
            end.setMonth(end.getMonth() + 1);
            end.setDate(end.getDate() - 1); // Subtract 1 day for proper end date
            break;
          case 'Single':
            // For single payment, end date is same as start date
            end.setTime(start.getTime());
            break;
          default:
            // Default to yearly if unknown payment mode
            end.setFullYear(end.getFullYear() + 1);
            end.setDate(end.getDate() - 1);
            break;
        }

        // Format and set the end date
        const endDateField = document.getElementById('autopay_end_date');
        if (endDateField) {
          endDateField.value = end.toISOString().split('T')[0];
          console.log('✅ Autopay end date calculated:', endDateField.value, 'for payment mode:', paymentMode);
        }
      }
    }

    // Update autopay start date when policy start date changes
    function updateAutopayStartDate() {
      const policyStartDate = document.getElementById('start_date').value;
      if (policyStartDate) {
        document.getElementById('autopay_start_date').value = policyStartDate;
        calculateAutopayEndDate(); // Recalculate end date
      }
    }

    // Auto-calculate end date based on start date and default to 1 year
    function calculateEndDate() {
      const startDate = document.getElementById('start_date').value;

      if (startDate) {
        const start = new Date(startDate);
        const end = new Date(start);

        end.setFullYear(end.getFullYear() + 1);
        end.setDate(end.getDate() - 1);

        document.getElementById('end_date').value = end.toISOString().split('T')[0];
      }
    }

    // Load policy holder options when customer changes
    function loadPolicyHolderOptions() {
      const customerId = document.getElementById('customer_select').value;
      const policyHolderSelect = document.getElementById('policy_holder_select');

      if (customerId) {
        // Clear current options and show loading
        policyHolderSelect.innerHTML = '<option value="">Loading...</option>';

        fetch(`/admin/insurance/health/policy_holder_options?customer_id=${customerId}`)
          .then(response => response.json())
          .then(data => {
            policyHolderSelect.innerHTML = '<option value="">Select Policy Holder</option>';
            data.options.forEach(option => {
              const optionElement = new Option(option.label, option.value);
              policyHolderSelect.add(optionElement);
            });
          })
          .catch(error => {
            console.error('Error loading policy holder options:', error);
            policyHolderSelect.innerHTML = '<option value="">Error loading options</option>';
          });
      } else {
        // If no customer selected, show default options
        policyHolderSelect.innerHTML = '<option value="">Select Policy Holder</option><option value="Self">Self</option>';
      }
    }

    // Show/Hide family coverage section based on insurance type
    function toggleFamilyCoverageSection() {
      const insuranceType = document.getElementById('insurance_type_select').value;
      const familyCoverageSection = document.getElementById('family_coverage_section');

      if (insuranceType === 'Family Floater' || insuranceType === 'Group') {
        familyCoverageSection.style.display = 'block';
      } else {
        familyCoverageSection.style.display = 'none';
      }
    }

    // Dynamic family member management
    let memberIndex = <%= @health_insurance.health_insurance_members.length %>;

    function toggleNoMembersMessage() {
      const memberRows = document.querySelectorAll('.family-member-row');
      const noMembersMsg = document.getElementById('no_members_message');

      if (memberRows.length === 0 || Array.from(memberRows).every(row => row.style.display === 'none')) {
        if (noMembersMsg) noMembersMsg.style.display = 'block';
      } else {
        if (noMembersMsg) noMembersMsg.style.display = 'none';
      }
    }

    if (document.getElementById('add_family_member')) {
      document.getElementById('add_family_member').addEventListener('click', function() {
        const memberTemplate = `
          <div class="family-member-row border rounded p-3 mb-3 bg-light">
            <div class="row">
              <div class="col-md-3 mb-3">
                <label class="form-label">Member Name</label>
                <input type="text" name="health_insurance[health_insurance_members_attributes][${memberIndex}][member_name]" class="form-control" placeholder="Full Name">
              </div>
              <div class="col-md-2 mb-3">
                <label class="form-label">Age</label>
                <input type="number" name="health_insurance[health_insurance_members_attributes][${memberIndex}][age]" class="form-control" min="1" max="120">
              </div>
              <div class="col-md-3 mb-3">
                <label class="form-label">Relationship</label>
                <select name="health_insurance[health_insurance_members_attributes][${memberIndex}][relationship]" class="form-select">
                  <option value="">Select Relationship</option>
                  <option value="Self">Self</option>
                  <option value="Spouse">Spouse</option>
                  <option value="Son">Son</option>
                  <option value="Daughter">Daughter</option>
                  <option value="Father">Father</option>
                  <option value="Mother">Mother</option>
                  <option value="Brother">Brother</option>
                  <option value="Sister">Sister</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div class="col-md-3 mb-3">
                <label class="form-label">Sum Insured</label>
                <input type="number" name="health_insurance[health_insurance_members_attributes][${memberIndex}][sum_insured]" class="form-control" step="0.01">
              </div>
              <div class="col-md-1 d-flex align-items-end mb-3">
                <button type="button" class="btn btn-outline-danger remove-member-btn">
                  <i class="bi bi-trash"></i>
                </button>
              </div>
            </div>
          </div>
        `;

        document.getElementById('family_members').insertAdjacentHTML('beforeend', memberTemplate);
        memberIndex++;
        toggleNoMembersMessage();
      });
    }

    // Remove family member
    document.addEventListener('click', function(e) {
      if (e.target.closest('.remove-member-btn')) {
        const memberRow = e.target.closest('.family-member-row');
        const destroyInput = memberRow.querySelector('input[name*="_destroy"]');

        if (destroyInput) {
          destroyInput.value = '1';
          memberRow.style.display = 'none';
        } else {
          memberRow.remove();
        }
        toggleNoMembersMessage();
      }
    });

    // Event listeners
    if (document.getElementById('net_premium')) {
      document.getElementById('net_premium').addEventListener('input', function() {
        calculateTotalPremium();
        calculateAllCommissions();
      });
    }
    if (document.getElementById('gst_percentage')) {
      document.getElementById('gst_percentage').addEventListener('input', calculateTotalPremium);
    }
    if (document.getElementById('commission_percentage')) {
      document.getElementById('commission_percentage').addEventListener('input', function() {
        calculateCommission();
        calculateProfitAndExpenses();
      });
    }
    if (document.getElementById('tds_percentage')) {
      document.getElementById('tds_percentage').addEventListener('input', calculateCommission);
    }
    if (document.getElementById('start_date')) {
      document.getElementById('start_date').addEventListener('change', function() {
        calculateEndDate();
        updateAutopayStartDate(); // Also update autopay dates when policy start date changes
      });
    }

    // Autopay date calculation event listeners
    if (document.getElementById('payment_mode_select')) {
      // Native change listener (backup)
      document.getElementById('payment_mode_select').addEventListener('change', calculateAutopayEndDate);

      // Select2 change listener (primary)
      $('#payment_mode_select').on('select2:select', function(e) {
        calculateAutopayEndDate();
      });

      // Calculate on page load if payment mode is already selected
      if (document.getElementById('payment_mode_select').value) {
        calculateAutopayEndDate();
      }
    }

    if (document.getElementById('autopay_start_date')) {
      document.getElementById('autopay_start_date').addEventListener('change', calculateAutopayEndDate);

      // Calculate on page load if start date exists
      if (document.getElementById('autopay_start_date').value && document.getElementById('payment_mode_select').value) {
        calculateAutopayEndDate();
      }
    }

    // Insurance type change listener
    if (document.getElementById('insurance_type_select')) {
      document.getElementById('insurance_type_select').addEventListener('change', toggleFamilyCoverageSection);
    }

    // Use Select2 event listener instead of native event
    $('#customer_select').on('select2:select', function(e) {
      loadPolicyHolderOptions();
      $('#affiliate_select').val(null).trigger('change');
      var selectedCustomerId = this.value;
      if (selectedCustomerId) {
        console.log('Customer selected, filtering affiliates for customer ID:', selectedCustomerId);
      }
    });

    // Handle customer clearing
    $('#customer_select').on('select2:clear', function(e) {
      $('#affiliate_select').val(null).trigger('change');
      console.log('Customer cleared, showing all affiliates');
    });

    // Sub-agent commission event listeners
    if (document.querySelector('.sub-agent-commission-percentage')) {
      document.querySelector('.sub-agent-commission-percentage').addEventListener('input', function() {
        calculateSubAgentCommission();
        calculateProfitAndExpenses();
      });
    }
    if (document.querySelector('.sub-agent-tds-percentage')) {
      document.querySelector('.sub-agent-tds-percentage').addEventListener('input', calculateSubAgentCommission);
    }

    // Investor commission event listeners
    if (document.querySelector('.investor-commission-percentage')) {
      document.querySelector('.investor-commission-percentage').addEventListener('input', function() {
        calculateInvestorCommission();
        calculateProfitAndExpenses();
      });
    }
    if (document.querySelector('.investor-tds-percentage')) {
      document.querySelector('.investor-tds-percentage').addEventListener('input', calculateInvestorCommission);
    }

    // Ambassador commission event listeners
    if (document.querySelector('.ambassador-commission-percentage')) {
      document.querySelector('.ambassador-commission-percentage').addEventListener('input', function() {
        calculateAmbassadorCommission();
        calculateProfitAndExpenses();
      });
    }
    if (document.querySelector('.ambassador-tds-percentage')) {
      document.querySelector('.ambassador-tds-percentage').addEventListener('input', calculateAmbassadorCommission);
    }

    // Company expenses event listener
    if (document.querySelector('.company-expenses-percentage')) {
      document.querySelector('.company-expenses-percentage').addEventListener('input', calculateProfitAndExpenses);
    }

    // Initialize calculations and summary on page load
    calculateAllCommissions();
    updateCommissionSummary();
    toggleFamilyCoverageSection();
    toggleNoMembersMessage();

  } catch (error) {
    console.warn('Health insurance edit form initialization error:', error.message);
  }
});

