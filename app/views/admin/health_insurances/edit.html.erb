// Health Insurance Document deletion function
function deleteHealthInsuranceDocument(documentId, documentTitle) {
  if (confirm(`Are you sure you want to delete "${documentTitle}"?`)) {
    fetch(`/admin/health_insurance_documents/${documentId}`, {
      method: 'DELETE',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Accept': 'application/json'
      }
    })
    .then(response => {
      if (response.ok) {
        // Reload the page to update the document list
        window.location.reload();
      } else {
        alert('Failed to delete document. Please try again.');
      }
    })
    .catch(error => {
      console.error('Error deleting document:', error);
      alert('Error deleting document. Please try again.');
    });
  }
}

// Dynamic nominee management
document.addEventListener('DOMContentLoaded', function() {
  let nomineeIndex = <%= @health_insurance.health_insurance_nominees.size %>;

  function toggleNoNomineesMessage() {
    const nomineeRows = document.querySelectorAll('.nominee-row');
    const noNomineesMsg = document.getElementById('no_nominees_message');
    if (noNomineesMsg) {
      const hasVisible = Array.from(nomineeRows).some(row => row.style.display !== 'none');
      noNomineesMsg.style.display = hasVisible ? 'none' : 'block';
    }
  }

  const addNomineeBtn = document.getElementById('add_nominee');
  if (addNomineeBtn) {
    addNomineeBtn.addEventListener('click', function() {
      const nomineeTemplate = `
        <div class="nominee-row border rounded p-3 mb-3 bg-light">
          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label required">Nominee Name</label>
              <input type="text" name="health_insurance[health_insurance_nominees_attributes][${nomineeIndex}][nominee_name]" class="form-control" placeholder="Full Name" required>
            </div>
            <div class="col-md-3 mb-3">
              <label class="form-label required">Relationship</label>
              <select name="health_insurance[health_insurance_nominees_attributes][${nomineeIndex}][relationship]" class="form-select" required>
                <option value="">Select Relationship</option>
                <option value="father">Father</option>
                <option value="mother">Mother</option>
                <option value="spouse">Spouse</option>
                <option value="son">Son</option>
                <option value="daughter">Daughter</option>
                <option value="brother">Brother</option>
                <option value="sister">Sister</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="col-md-2 mb-3">
              <label class="form-label required">Age</label>
              <input type="number" name="health_insurance[health_insurance_nominees_attributes][${nomineeIndex}][age]" class="form-control" min="1" max="120" required>
            </div>
            <div class="col-md-2 mb-3">
              <label class="form-label required">Share %</label>
              <input type="number" name="health_insurance[health_insurance_nominees_attributes][${nomineeIndex}][share_percentage]" class="form-control" min="0" max="100" step="0.01" placeholder="100" required>
            </div>
            <div class="col-md-1 d-flex align-items-end mb-3">
              <button type="button" class="btn btn-outline-danger remove-nominee-btn">
                <i class="bi bi-trash"></i>
              </button>
            </div>
          </div>
        </div>
      `;
      document.getElementById('nominees').insertAdjacentHTML('beforeend', nomineeTemplate);
      nomineeIndex++;
      toggleNoNomineesMessage();
    });
  }

  // Remove nominee (handles both persisted and new rows)
  document.addEventListener('click', function(e) {
    if (e.target.closest('.remove-nominee-btn')) {
      const nomineeRow = e.target.closest('.nominee-row');
      const destroyInput = nomineeRow.querySelector('input[name*="_destroy"]');
      if (destroyInput) {
        destroyInput.value = '1';
        nomineeRow.style.display = 'none';
      } else {
        nomineeRow.remove();
      }
      toggleNoNomineesMessage();
    }
  });

  // Load customer nominees via AJAX
  const loadNomineesBtn = document.getElementById('load_customer_nominees_btn');
  if (loadNomineesBtn) {
    loadNomineesBtn.addEventListener('click', function() {
      const customerSelect = document.getElementById('customer_select');
      const customerId = customerSelect ? customerSelect.value : null;

      if (!customerId) {
        alert('Please select a client first');
        return;
      }

      const btn = this;
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Loading...';
      btn.disabled = true;

      fetch(`/admin/insurance/health/load_customer_nominees?customer_id=${customerId}`)
        .then(response => response.json())
        .then(data => {
          if (data.success && data.nominees && data.nominees.length > 0) {
            // Only remove non-persisted rows; mark persisted ones for destroy
            document.querySelectorAll('.nominee-row').forEach(row => {
              const destroyInput = row.querySelector('input[name*="_destroy"]');
              if (destroyInput) {
                destroyInput.value = '1';
                row.style.display = 'none';
              } else {
                row.remove();
              }
            });

            data.nominees.forEach((nominee) => {
              const relOptions = ['father','mother','spouse','son','daughter','brother','sister','other']
                .map(r => `<option value="${r}" ${nominee.relationship === r ? 'selected' : ''}>${r.charAt(0).toUpperCase()+r.slice(1)}</option>`)
                .join('');
              const nomineeTemplate = `
                <div class="nominee-row border rounded p-3 mb-3 bg-light">
                  <div class="row">
                    <div class="col-md-4 mb-3">
                      <label class="form-label required">Nominee Name</label>
                      <input type="text" name="health_insurance[health_insurance_nominees_attributes][${nomineeIndex}][nominee_name]" class="form-control" value="${nominee.nominee_name}" required>
                    </div>
                    <div class="col-md-3 mb-3">
                      <label class="form-label required">Relationship</label>
                      <select name="health_insurance[health_insurance_nominees_attributes][${nomineeIndex}][relationship]" class="form-select" required>
                        <option value="">Select Relationship</option>
                        ${relOptions}
                      </select>
                    </div>
                    <div class="col-md-2 mb-3">
                      <label class="form-label required">Age</label>
                      <input type="number" name="health_insurance[health_insurance_nominees_attributes][${nomineeIndex}][age]" class="form-control" value="${nominee.age}" min="1" max="120" required>
                    </div>
                    <div class="col-md-2 mb-3">
                      <label class="form-label required">Share %</label>
                      <input type="number" name="health_insurance[health_insurance_nominees_attributes][${nomineeIndex}][share_percentage]" class="form-control" min="0" max="100" step="0.01" placeholder="100" required>
                    </div>
                    <div class="col-md-1 d-flex align-items-end mb-3">
                      <button type="button" class="btn btn-outline-danger remove-nominee-btn">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  </div>
                </div>
              `;
              document.getElementById('nominees').insertAdjacentHTML('beforeend', nomineeTemplate);
              nomineeIndex++;
            });

            toggleNoNomineesMessage();
            alert(`Loaded ${data.nominees.length} nominee(s) from ${data.customer_name}`);
          } else {
            alert(data.message || 'No nominees found for this client');
          }
        })
        .catch(error => {
          console.error('Error loading nominees:', error);
          alert('Error loading nominees. Please try again.');
        })
        .finally(() => {
          btn.innerHTML = originalText;
          btn.disabled = false;
        });
    });
  }

  toggleNoNomineesMessage();
});

