<% content_for :page_title, "Edit Health Insurance" %>
<% content_for :page_subtitle, "Update health insurance policy details for #{@health_insurance.policy_number}" %>

<!-- Action Buttons -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <%= link_to admin_health_insurances_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-2"></i>
      Back to List
    <% end %>
  </div>

  <div class="d-flex gap-2">
    <%= link_to admin_health_insurance_path(@health_insurance), class: "btn btn-outline-info" do %>
      <i class="bi bi-eye me-2"></i>
      View Policy
    <% end %>
    <%= link_to admin_health_insurance_path(@health_insurance), class: "btn btn-outline-success" do %>
      <i class="bi bi-cloud-check me-2"></i>
      View Documents
    <% end %>
    <div class="trust-seal">
      <i class="bi bi-shield-check seal-icon"></i>
      <span>Update Policy</span>
    </div>
  </div>
</div>

<%= form_with model: [:admin, @health_insurance], local: true, class: "needs-validation", novalidate: true do |form| %>

  <!-- Client & Agent Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-person me-2 text-primary"></i>
        Client & Agent Details
      </h5>
    </div>
    <div class="card-body">
      <% if @health_insurance.errors.any? %>
        <div class="alert alert-danger alert-dismissible fade show">
          <i class="bi bi-exclamation-triangle me-2"></i>
          <strong>Please correct the following errors:</strong>
          <ul class="mb-0 mt-2">
            <% @health_insurance.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :customer_id, "Client Name*", class: "form-label" %>
          <%= form.select :customer_id,
              options_for_select(@customers.map { |c| [c.display_name, c.id] }, @health_insurance.customer_id),
              { prompt: 'Search and select client...' },
              { class: "form-control #{'is-invalid' if @health_insurance.errors[:customer_id].any?}", required: true, id: "customer_select", data: { placeholder: "Type to search clients..." } } %>
          <% if @health_insurance.errors[:customer_id].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:customer_id].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_holder, "Policy Holder", class: "form-label" %>
          <%
            # Load family members for the current customer
            @customer_family_members = @health_insurance.customer&.family_members || []
            policy_holder_options = [['Self', 'Self']]
            if @customer_family_members.any?
              @customer_family_members.each do |member|
                policy_holder_options << ["#{member.name} (#{member.relationship.humanize})", "#{member.name}"]
              end
            end
          %>
          <%= form.select :policy_holder,
              options_for_select(policy_holder_options, @health_insurance.policy_holder),
              {},
              { class: "form-control", id: "policy_holder_select", data: { placeholder: "Type to search policy holders..." } } %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :sub_agent_id, "Affiliate", class: "form-label" %>
          <%= form.select :sub_agent_id,
              options_for_select([['Self', '']] + @sub_agents.map { |a| [a.display_name, a.id] }, @health_insurance.sub_agent_id),
              { prompt: 'Search and select affiliate...' },
              { class: "form-control", id: "affiliate_select", data: { placeholder: "Type to search affiliates..." } } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Policy Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-file-text me-2 text-primary"></i>
        Policy Details
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <!-- 1st: Broker Code dropdown with Direct/Broking options -->
        <div class="col-md-4 mb-3">
          <%= form.label :broker_code_type, "Broker Code", class: "form-label" %>
          <%= form.select :broker_code_type,
              options_for_select([
                ['Direct', 'direct'],
                ['Broking', 'broking']
              ], @health_insurance.broker_code_type),
              { prompt: 'Select Broker Code' },
              { class: "form-control", id: "health_insurance_broker_code_type" } %>
        </div>

        <!-- 2nd: Agency Code (shows Agents when Direct selected, Brokers when Broking selected) -->
        <div class="col-md-4 mb-3">
          <%= form.label :agency_code_id, "Agency Code", class: "form-label" %>
          <span class="dynamic-label" id="agency_code_label_text"></span>
          <%= form.select :agency_code_id,
              options_for_select(@agency_codes.map { |a| ["#{a.agent_name} - #{a.code}", a.id] }, @health_insurance.agency_code_id),
              { prompt: 'Search and select agency code...' },
              { class: "form-control #{'is-invalid' if @health_insurance.errors[:agency_code_id].any?}", required: true, id: "health_insurance_agency_code_id", data: { placeholder: "Type to search agency codes..." } } %>
          <% if @health_insurance.errors[:agency_code_id].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:agency_code_id].first %></div>
          <% end %>
        </div>

        <!-- Hidden field for broker_id when needed -->
        <%= form.hidden_field :broker_id, id: "broker_id_hidden" %>

        <!-- 3rd: Insurance Company Name (Dynamic based on Agent/Broker selection) -->
        <div class="col-md-4 mb-3">
          <%= form.label :insurance_company_name, "Insurance Company Name*", class: "form-label" %>
          <%= form.select :insurance_company_name,
              options_for_select(@insurance_companies.map { |c| [c, c] }, @health_insurance.insurance_company_name),
              { prompt: 'Search and select company...' },
              { class: "form-control #{'is-invalid' if @health_insurance.errors[:insurance_company_name].any?}", required: true, id: "health_insurance_insurance_company_name", data: { placeholder: "Type to search companies..." } } %>
          <% if @health_insurance.errors[:insurance_company_name].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:insurance_company_name].first %></div>
          <% end %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :policy_type, "Policy Type*", class: "form-label" %>
          <%= form.select :policy_type,
              options_for_select(HealthInsurance::POLICY_TYPES.map { |type| [type, type] }, @health_insurance.policy_type),
              { prompt: 'Select Policy Type' },
              { class: "form-control #{'is-invalid' if @health_insurance.errors[:policy_type].any?}", required: true, id: "policy_type_select" } %>
          <% if @health_insurance.errors[:policy_type].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:policy_type].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :insurance_type, "Insurance Type*", class: "form-label" %>
          <%= form.select :insurance_type,
              options_for_select(HealthInsurance::INSURANCE_TYPES.map { |type| [type, type] }, @health_insurance.insurance_type),
              { prompt: 'Select Insurance Type' },
              { class: "form-control #{'is-invalid' if @health_insurance.errors[:insurance_type].any?}", required: true, id: "insurance_type_select" } %>
          <% if @health_insurance.errors[:insurance_type].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:insurance_type].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :payment_mode, "Payment Mode*", class: "form-label" %>
          <%= form.select :payment_mode,
              options_for_select(HealthInsurance::PAYMENT_MODES.map { |mode| [mode, mode] }, @health_insurance.payment_mode),
              { prompt: 'Select Payment Mode' },
              { class: "form-control #{'is-invalid' if @health_insurance.errors[:payment_mode].any?}", required: true, id: "payment_mode_select" } %>
          <% if @health_insurance.errors[:payment_mode].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:payment_mode].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_number, "Policy Number*", class: "form-label" %>
          <%= form.text_field :policy_number,
              class: "form-control #{'is-invalid' if @health_insurance.errors[:policy_number].any?}",
              placeholder: "Enter unique policy number", required: true %>
          <% if @health_insurance.errors[:policy_number].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:policy_number].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_booking_date, "Policy Booking Date", class: "form-label" %>
          <%= form.date_field :policy_booking_date,
              class: "form-control",
              value: @health_insurance.policy_booking_date,
              min: "1900-01-01",
              max: "2099-12-31" %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_start_date, "Policy Start Date*", class: "form-label" %>
          <%= form.date_field :policy_start_date,
              class: "form-control #{'is-invalid' if @health_insurance.errors[:policy_start_date].any?}",
              required: true, id: "start_date",
              min: "1900-01-01",
              max: "2099-12-31" %>
          <% if @health_insurance.errors[:policy_start_date].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:policy_start_date].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_end_date, "Policy End Date*", class: "form-label" %>
          <%= form.date_field :policy_end_date,
              class: "form-control #{'is-invalid' if @health_insurance.errors[:policy_end_date].any?}",
              required: true, id: "end_date",
              min: "1900-01-01",
              max: "2099-12-31" %>
          <% if @health_insurance.errors[:policy_end_date].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:policy_end_date].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :plan_name, "Plan Name", class: "form-label" %>
          <%= form.text_field :plan_name,
              class: "form-control",
              placeholder: "Enter plan name" %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :sum_insured_text, "Sum Insured*", class: "form-label" %>
          <%= form.text_field :sum_insured_text,
              class: "form-control #{'is-invalid' if @health_insurance.errors[:sum_insured].any?}",
              placeholder: "e.g., 90 lakhs, 5 crores, 1.5 crore",
              value: @health_insurance.sum_insured_display_text,
              required: true,
              id: "sum_insured_text_input" %>
          <div class="form-text">
            Enter amount like: 90 lakhs, 5 crores, 1.5 crore, etc.
            <span id="sum_insured_preview" class="text-primary fw-bold"></span>
          </div>
          <% if @health_insurance.errors[:sum_insured].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:sum_insured].first %></div>
          <% end %>
          <%= form.hidden_field :sum_insured %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :net_premium, "Net Premium*", class: "form-label" %>
          <%= form.number_field :net_premium,
              class: "form-control #{'is-invalid' if @health_insurance.errors[:net_premium].any?}",
              placeholder: "0", step: 0.01, required: true, id: "net_premium" %>
          <% if @health_insurance.errors[:net_premium].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:net_premium].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :gst_percentage, "GST %", class: "form-label" %>
          <%= form.number_field :gst_percentage,
              class: "form-control",
              value: @health_insurance.gst_percentage || 0,
              step: 0.01, min: 0, id: "gst_percentage" %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :total_premium, "Total Premium*", class: "form-label" %>
          <%= form.number_field :total_premium,
              class: "form-control #{'is-invalid' if @health_insurance.errors[:total_premium].any?}",
              placeholder: "0", step: 0.01, required: true, readonly: true, id: "total_premium" %>
          <% if @health_insurance.errors[:total_premium].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:total_premium].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_term, "Policy Term (Years)", class: "form-label" %>
          <%= form.number_field :policy_term,
              class: "form-control #{'is-invalid' if @health_insurance.errors[:policy_term].any?}",
              placeholder: "e.g., 1, 2, 3",
              min: 1,
              step: 1 %>
          <div class="form-text">Enter policy term in years (e.g., 1, 2, 3)</div>
          <% if @health_insurance.errors[:policy_term].any? %>
            <div class="invalid-feedback"><%= @health_insurance.errors[:policy_term].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :claim_process, "Claim Process", class: "form-label" %>
          <%= form.select :claim_process,
              options_for_select(HealthInsurance::CLAIM_PROCESSES.map { |process| [process, process] }, @health_insurance.claim_process),
              { prompt: 'Select Claim Process' },
              { class: "form-control", id: "claim_process_select" } %>
        </div>

        <!-- Additional fields from edit form -->
        <div class="col-md-4 mb-3">
          <%= form.label :premium_frequency, "Premium Frequency", class: "form-label" %>
          <%= form.select :premium_frequency,
              options_for_select([
                ['Annual', 'annual'],
                ['Semi-Annual', 'semi_annual'],
                ['Quarterly', 'quarterly'],
                ['Monthly', 'monthly']
              ], @health_insurance.premium_frequency),
              { prompt: 'Select Frequency' },
              { class: "form-control" } %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :status, "Status", class: "form-label" %>
          <%= form.select :status,
              options_for_select([
                ['Active', 'active'],
                ['Pending', 'pending'],
                ['Expired', 'expired'],
                ['Cancelled', 'cancelled']
              ], @health_insurance.status),
              { prompt: 'Select Status' },
              { class: "form-control" } %>
        </div>

        <div class="col-md-12 mb-3">
          <%= form.label :additional_details, "Additional Details", class: "form-label" %>
          <%= form.text_area :additional_details,
              class: "form-control",
              rows: 4,
              placeholder: "Enter any additional policy details, terms, or conditions..." %>
        </div>
      </div>
    </div>
  </div>

  <!-- Family/Employee Coverage Section -->
  <div class="card mb-4" id="family_coverage_section">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-people me-2 text-primary"></i>
        Family Coverage
      </h5>
    </div>
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0">Family Members</h6>
        <button type="button" id="add_family_member" class="btn btn-primary">
          <i class="bi bi-plus me-1"></i>Add Member
        </button>
      </div>

      <div id="family_members">
        <% unless @health_insurance.health_insurance_members.any? %>
          <div class="text-center py-4 text-muted" id="no_members_message">
            <i class="bi bi-people display-4 mb-3"></i>
            <p class="mb-0">No family members added yet.</p>
          </div>
        <% end %>

        <%= form.fields_for :health_insurance_members do |member_form| %>
          <div class="family-member-row border rounded p-3 mb-3 bg-light">
            <div class="row">
              <div class="col-md-3 mb-3">
                <%= member_form.label :member_name, "Member Name", class: "form-label" %>
                <%= member_form.text_field :member_name, class: "form-control", placeholder: "Full Name" %>
              </div>
              <div class="col-md-2 mb-3">
                <%= member_form.label :age, "Age", class: "form-label" %>
                <%= member_form.number_field :age, class: "form-control", min: 1, max: 120 %>
              </div>
              <div class="col-md-3 mb-3">
                <%= member_form.label :relationship, "Relationship", class: "form-label" %>
                <%= member_form.select :relationship,
                    options_for_select(HealthInsuranceMember::RELATIONSHIPS.map { |rel| [rel, rel] }, member_form.object.relationship),
                    { prompt: 'Select Relationship' },
                    { class: "form-select" } %>
              </div>
              <div class="col-md-3 mb-3">
                <%= member_form.label :sum_insured, "Sum Insured", class: "form-label" %>
                <%= member_form.number_field :sum_insured, class: "form-control", step: 0.01 %>
              </div>
              <div class="col-md-1 d-flex align-items-end mb-3">
                <button type="button" class="btn btn-outline-danger remove-member-btn">
                  <i class="bi bi-trash"></i>
                </button>
                <%= member_form.check_box :_destroy, style: "display: none;" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <% if @health_insurance.drwise_policy? %>
  <!-- Commission Calculation Table -->
  <div class="card mb-4 shadow-sm commission-table">
    <div class="card-header" style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0 text-dark fw-bold">
            <i class="bi bi-calculator me-2 text-primary"></i>
            Commission Calculation
          </h5>
        </div>
        <div class="text-end">
          <small class="text-muted fw-bold">Profit Formula:</small>
          <div class="badge bg-light text-dark border" style="font-size: 0.8rem;">
            Main Agent Commission - Total Distribution - Company Expenses
          </div>
        </div>
      </div>
    </div>
    <div class="card-body p-0">
      <!-- Commission Table -->
      <div class="table-responsive">
        <table class="table mb-0" style="font-size: 0.95rem;">
          <thead style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
            <tr>
              <th class="py-3 px-4 fw-bold text-dark border-0" style="width: 20%;">COMMISSION DETAILS</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 12%;">(%)</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 18%;">COMMISSION</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 12%;">TDS (%)</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 15%;">TDS AMOUNT</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 23%; background: #f8f9fa;">ACTUAL AMOUNT</th>
            </tr>
          </thead>
          <tbody>
            <!-- Main Agent -->
            <tr style="border-bottom: 1px solid #e9ecef;">
              <td class="py-3 px-4 fw-bold text-dark bg-light">Main Agent</td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :main_agent_commission_percentage,
                    class: "form-control border-1 text-center fw-bold shadow-sm",
                    value: @health_insurance.main_agent_commission_percentage || 0,
                    step: 0.01, id: "commission_percentage",
                    style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :commission_amount,
                    class: "form-control border-1 text-center",
                    value: @health_insurance.commission_amount || 0,
                    step: 0.01, readonly: true, id: "commission_amount",
                    style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :tds_percentage,
                    class: "form-control border-1 text-center",
                    value: @health_insurance.tds_percentage || 0,
                    step: 0.01, id: "tds_percentage",
                    style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :tds_amount,
                    class: "form-control border-1 text-center",
                    value: @health_insurance.tds_amount || 0,
                    step: 0.01, readonly: true, id: "tds_amount",
                    style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
                <%= form.number_field :after_tds_value,
                    class: "form-control border-1 text-center fw-bold fs-6",
                    value: @health_insurance.after_tds_value || 0,
                    step: 0.01, readonly: true, id: "after_tds_value",
                    style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
            </tr>
            <!-- Affiliate -->
            <tr style="border-bottom: 1px solid #e9ecef;">
              <td class="py-3 px-4 fw-bold text-dark">Affiliate</td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :sub_agent_commission_percentage,
                    class: "form-control border-1 text-center fw-bold shadow-sm sub-agent-commission-percentage",
                    value: @health_insurance.sub_agent_commission_percentage || 0,
                    step: 0.01, style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :sub_agent_commission_amount,
                    class: "form-control border-1 text-center sub-agent-commission-amount",
                    value: @health_insurance.sub_agent_commission_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :sub_agent_tds_percentage,
                    class: "form-control border-1 text-center sub-agent-tds-percentage",
                    value: @health_insurance.sub_agent_tds_percentage || 0,
                    step: 0.01, style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :sub_agent_tds_amount,
                    class: "form-control border-1 text-center sub-agent-tds-amount",
                    value: @health_insurance.sub_agent_tds_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
                <%= form.number_field :sub_agent_after_tds_value,
                    class: "form-control border-1 text-center fw-bold fs-6 sub-agent-after-tds-value",
                    value: @health_insurance.sub_agent_after_tds_value || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
            </tr>
            <!-- Investor -->
            <tr style="border-bottom: 1px solid #e9ecef;">
              <td class="py-3 px-4 fw-bold text-dark">Investor</td>
              <td class="py-2 px-1 text-center">
