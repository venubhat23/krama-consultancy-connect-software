              <td class="py-2 px-1 text-center">
                <%= form.number_field :investor_commission_amount,
                    class: "form-control border-1 text-center investor-commission-amount",
                    value: @health_insurance.investor_commission_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-3 text-center fw-bold text-muted">—</td>
              <td class="py-2 px-3 text-center fw-bold text-muted">—</td>
              <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
                <%= form.number_field :investor_commission_amount,
                    class: "form-control border-1 text-center fw-bold fs-6 investor-commission-amount-display",
                    value: @health_insurance.investor_commission_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
            </tr>
            <%= form.hidden_field :investor_tds_percentage, value: 0, class: "investor-tds-percentage" %>
            <!-- Ambassador -->
            <tr style="border-bottom: 1px solid #e9ecef;">
              <td class="py-3 px-4 fw-bold text-dark">Ambassador</td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :ambassador_commission_percentage,
                    class: "form-control border-1 text-center fw-bold shadow-sm ambassador-commission-percentage",
                    value: @health_insurance.ambassador_commission_percentage || 0,
                    step: 0.01, style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :ambassador_commission_amount,
                    class: "form-control border-1 text-center ambassador-commission-amount",
                    value: @health_insurance.ambassador_commission_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :ambassador_tds_percentage,
                    class: "form-control border-1 text-center ambassador-tds-percentage",
                    value: @health_insurance.ambassador_tds_percentage || 0,
                    step: 0.01, style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :ambassador_tds_amount,
                    class: "form-control border-1 text-center ambassador-tds-amount",
                    value: @health_insurance.ambassador_tds_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
                <%= form.number_field :ambassador_after_tds_value,
                    class: "form-control border-1 text-center fw-bold fs-6 ambassador-after-tds-value",
                    value: @health_insurance.ambassador_after_tds_value || 0,
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
            </tr>
            <!-- Company Expenses -->
            <tr style="border-bottom: 1px solid #e9ecef;">
              <td class="py-3 px-4 fw-bold text-dark">Company Expenses</td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :company_expenses_percentage,
                    class: "form-control border-1 text-center fw-bold shadow-sm company-expenses-percentage",
                    value: @health_insurance.company_expenses_percentage || 5.0,
                    step: 0.01, min: 0, max: 100, style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :company_expenses_amount,
                    class: "form-control border-1 text-center company-expenses-amount",
                    value: ((@health_insurance.net_premium || 0) * ((@health_insurance.company_expenses_percentage || 5) / 100)).round(2),
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-3 text-center fw-bold text-muted">—</td>
              <td class="py-2 px-3 text-center fw-bold text-muted">—</td>
              <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
                <%= form.number_field :company_expenses_amount,
                    class: "form-control border-1 text-center fw-bold fs-6 company-expenses-amount-display",
                    value: ((@health_insurance.net_premium || 0) * ((@health_insurance.company_expenses_percentage || 5) / 100)).round(2),
                    step: 0.01, readonly: true, style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
            </tr>
            <!-- Profit Row -->
            <tr style="border-bottom: 2px solid #198754; background: linear-gradient(135deg, #f0fff0 0%, #e8f5e8 100%);">
              <td class="py-3 px-4 fw-bold text-dark" style="background: #e8f5e8;">
                <i class="bi bi-currency-rupee me-1 text-success"></i>
                Profit
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :profit_percentage,
                    class: "form-control border-1 text-center fw-bold profit-percentage",
                    value: @health_insurance.profit_percentage || 0,
                    step: 0.01, readonly: true, style: "background: #f0fff0; border-color: #198754; color: #198754;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :profit_amount,
                    class: "form-control border-1 text-center fw-bold profit-amount",
                    value: @health_insurance.profit_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f0fff0; border-color: #198754; color: #198754;" %>
              </td>
              <td class="py-2 px-3 text-center fw-bold text-muted">—</td>
              <td class="py-2 px-3 text-center fw-bold text-muted">—</td>
              <td class="py-2 px-1 text-center" style="background: #f0fff0;">
                <%= form.number_field :profit_amount,
                    class: "form-control border-1 text-center fw-bold profit-amount-display",
                    value: @health_insurance.profit_amount || 0,
                    step: 0.01, readonly: true, style: "background: #f0fff0; border-color: #198754; color: #198754;" %>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Hidden fields for calculations -->
      <%= form.hidden_field :total_distribution_percentage, class: "total-distribution-percentage", value: @health_insurance.total_distribution_percentage || 0 %>
    </div>
  </div>
  <% end %>

  <!-- Nominee Information Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-person-check me-2 text-primary"></i>
        Nominee Details
      </h5>
    </div>
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0">Nominees</h6>
        <div>
          <button type="button" id="load_customer_nominees_btn" class="btn btn-outline-secondary me-2">
            <i class="bi bi-download me-1"></i>Load from Client
          </button>
          <button type="button" id="add_nominee" class="btn btn-primary">
            <i class="bi bi-plus me-1"></i>Add Nominee
          </button>
        </div>
      </div>

      <div id="nominees">
        <div class="text-center py-4 text-muted" id="no_nominees_message">
          <i class="bi bi-person-check display-4 mb-3"></i>
          <p class="mb-0">No nominees added yet.</p>
        </div>

        <%= form.fields_for :health_insurance_nominees do |nominee_form| %>
          <div class="nominee-row border rounded p-3 mb-3 bg-light">
            <div class="row">
              <div class="col-md-4 mb-3">
                <%= nominee_form.label :nominee_name, "Nominee Name", class: "form-label required" %>
                <%= nominee_form.text_field :nominee_name, class: "form-control", placeholder: "Full Name", required: true %>
              </div>
              <div class="col-md-3 mb-3">
                <%= nominee_form.label :relationship, "Relationship", class: "form-label required" %>
                <%= nominee_form.select :relationship,
                    options_for_select(HealthInsuranceNominee::RELATIONSHIPS.map { |rel| [rel.humanize, rel] }, nominee_form.object.relationship),
                    { prompt: 'Select Relationship' },
                    { class: "form-select", required: true } %>
              </div>
              <div class="col-md-2 mb-3">
                <%= nominee_form.label :age, "Age", class: "form-label required" %>
                <%= nominee_form.number_field :age, class: "form-control", min: 1, max: 120, required: true %>
              </div>
              <div class="col-md-2 mb-3">
                <%= nominee_form.label :share_percentage, "Share %", class: "form-label required" %>
                <%= nominee_form.number_field :share_percentage, class: "form-control", min: 0, max: 100, step: 0.01, placeholder: "100", required: true %>
              </div>
              <div class="col-md-1 d-flex align-items-end mb-3">
                <button type="button" class="btn btn-outline-danger remove-nominee-btn">
                  <i class="bi bi-trash"></i>
                </button>
                <%= nominee_form.check_box :_destroy, style: "display: none;" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>


  <!-- Policy Documents Manager Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-cloud-upload me-2 text-primary"></i>
        Policy Documents Manager
      </h5>
      <small class="text-muted">Upload, organize and manage all policy-related documents with secure storage</small>
    </div>
    <div class="card-body p-4">
      <!-- R2 Main Policy Document Upload -->
      <div class="row mb-4">
        <div class="col-md-12">
          <div class="border border-success border-2 rounded p-4" style="background-color: #f0fff0;">
            <%= form.label :main_policy_document, class: "form-label fw-bold" do %>
              <i class="bi bi-cloud-upload me-2 text-success"></i>
              Main Policy Document (R2 Storage)
            <% end %>

            <!-- Current R2 Document Display -->
            <% if @health_insurance.has_main_policy_r2_document? %>
              <div class="current-document mb-3 p-3 border rounded bg-white">
                <div class="row align-items-center">
                  <div class="col-auto">
                    <% if @health_insurance.main_policy_document_content_type&.start_with?('image/') %>
                      <%= image_tag @health_insurance.main_policy_r2_document_url, class: "img-thumbnail",
                          style: "width: 60px; height: 60px; object-fit: cover;" %>
                    <% elsif @health_insurance.main_policy_document_content_type == 'application/pdf' %>
                      <div class="bg-danger text-white rounded d-flex align-items-center justify-content-center"
                           style="width: 60px; height: 60px;">
                        <i class="bi bi-file-earmark-pdf fs-4"></i>
                      </div>
                    <% else %>
                      <div class="bg-secondary text-white rounded d-flex align-items-center justify-content-center"
                           style="width: 60px; height: 60px;">
                        <i class="bi bi-file-earmark fs-4"></i>
                      </div>
                    <% end %>
                  </div>
                  <div class="col">
                    <div class="fw-medium"><%= @health_insurance.main_policy_document_filename %></div>
                    <small class="text-muted">
                      <%= (@health_insurance.main_policy_document_size / 1024.0 / 1024.0).round(2) %> MB •
                      <%= @health_insurance.main_policy_document_content_type %>
                    </small>
                    <div>
                      <small class="text-success">
                        <i class="bi bi-cloud-check me-1"></i>
                        Stored in Cloudflare R2
                      </small>
                    </div>
                  </div>
                  <div class="col-auto">
                    <div class="d-flex gap-1">
                      <%= link_to @health_insurance.main_policy_r2_url, class: "btn btn-sm btn-outline-primary",
                          target: "_blank", title: "View" do %>
                        <i class="bi bi-eye"></i>
                      <% end %>
                      <button type="button" class="btn btn-sm btn-outline-danger"
                              onclick="deleteMainPolicyDocument()" title="Delete Document">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
              <div class="mb-2">
                <small class="text-muted">
                  <strong>Replace document:</strong> Upload a new file to replace the current document
                </small>
              </div>
            <% end %>

            <%= form.file_field :main_policy_document,
                class: "form-control",
                accept: "application/pdf,image/jpeg,image/jpg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" %>
            <div class="form-text mt-2">
              <i class="bi bi-info-circle me-1"></i>
              <strong>Secure R2 Storage:</strong> Supports PDF, JPEG, PNG, Word files (Max: 10MB) -
              <% if @health_insurance.has_main_policy_r2_document? %>
                upload new file to replace existing document
              <% else %>
                files stored securely in Cloudflare R2
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Additional Documents -->
      <div class="row">
        <div class="col-md-12 mb-4">
          <div class="border border-secondary border-2 rounded p-4" style="background-color: #f8f9fa;">
            <%= form.label :documents, class: "form-label fw-bold" do %>
              <i class="bi bi-file-earmark-plus me-2 text-secondary"></i>
              Additional Documents
              <span class="badge bg-secondary ms-2">Optional</span>
            <% end %>
            <%= form.file_field :documents,
                class: "form-control",
                multiple: true,
                accept: "application/pdf,image/jpeg,image/jpg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" %>
            <div class="form-text mt-2">
              <i class="bi bi-info-circle me-1"></i>
              Upload medical reports, identity proofs, or other supporting documents. Multiple files supported.
            </div>
          </div>
        </div>
      </div>

      <!-- Existing Documents Display -->
      <% if @health_insurance.persisted? %>
        <div class="row">
          <div class="col-md-12">
            <!-- R2 Policy Documents -->
            <% if @health_insurance.respond_to?(:policy_documents_records) && @health_insurance.policy_documents_records.any? %>
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent border-0">
                  <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-success">
                      <i class="bi bi-cloud-check me-2"></i>
                      R2 Policy Documents
                    </h5>
                    <span class="badge bg-success"><%= @health_insurance.policy_documents_records.count %> files</span>
                  </div>
                </div>
                <div class="card-body p-0">
                  <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                      <thead class="table-light">
                        <tr>
                          <th style="width: 50px;">Type</th>
                          <th>Title</th>
                          <th>Category</th>
                          <th style="width: 100px;">Size</th>
                          <th style="width: 120px;">Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% @health_insurance.policy_documents_records.each do |doc| %>
                          <tr>
                            <td class="text-center">
                              <% if doc.r2_content_type&.start_with?('image/') %>
                                <div class="bg-info text-white rounded d-flex align-items-center justify-content-center"
                                     style="width: 30px; height: 30px; margin: 0 auto;">
                                  <i class="bi bi-image"></i>
                                </div>
                              <% elsif doc.r2_content_type == 'application/pdf' %>
                                <div class="bg-danger text-white rounded d-flex align-items-center justify-content-center"
                                     style="width: 30px; height: 30px; margin: 0 auto;">
                                  <i class="bi bi-file-earmark-pdf"></i>
                                </div>
                              <% else %>
                                <div class="bg-secondary text-white rounded d-flex align-items-center justify-content-center"
                                     style="width: 30px; height: 30px; margin: 0 auto;">
                                  <i class="bi bi-file-earmark"></i>
                                </div>
                              <% end %>
                            </td>
                            <td>
                              <div class="fw-bold"><%= doc.title %></div>
                              <% if doc.description.present? %>
                                <small class="text-muted"><%= doc.description %></small>
                              <% end %>
                            </td>
                            <td><span class="badge bg-light text-dark"><%= doc.document_type %></span></td>
                            <td class="text-center">
                              <small class="text-muted"><%= (doc.r2_file_size / 1024.0 / 1024.0).round(2) %> MB</small>
                            </td>
                            <td class="text-center">
                              <div class="btn-group" role="group">
                                <%= link_to doc.document_url, class: "btn btn-outline-primary btn-sm",
                                    target: "_blank", title: "View Document" do %>
                                  <i class="bi bi-eye"></i>
                                <% end %>
                                <%= button_to [:admin, doc], method: :delete, class: "btn btn-outline-danger btn-sm",
                                    title: "Delete Document",
                                    data: {
                                      confirm: "Are you sure you want to delete this document? This action cannot be undone.",
                                      turbo_method: :delete
                                    } do %>
                                  <i class="bi bi-trash"></i>
                                <% end %>
                              </div>
                            </td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Health Insurance Documents (Document Management System) -->
      <% if @health_insurance.health_insurance_documents.any? %>
        <div class="border-top pt-4 mt-4">
          <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent border-0">
              <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-info">
                  <i class="bi bi-file-earmark-plus me-2"></i>
                  Health Insurance Documents
                </h5>
                <span class="badge bg-info"><%= @health_insurance.health_insurance_documents.count %> files</span>
              </div>
            </div>
            <div class="card-body p-0">
              <div class="list-group list-group-flush">
                <% @health_insurance.health_insurance_documents.each_with_index do |document, index| %>
                  <div class="list-group-item border-0 <%= 'border-bottom' unless index == @health_insurance.health_insurance_documents.count - 1 %>">
                    <div class="d-flex align-items-center py-2">
                      <div class="flex-shrink-0 me-4">
                        <div class="rounded-circle bg-info bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                          <i class="bi bi-file-earmark-text text-info fs-4"></i>
                        </div>
                      </div>
                      <div class="flex-grow-1">
                        <div class="d-flex justify-content-between align-items-start">
                          <div>
                            <h6 class="mb-1 fw-bold"><%= document.title %></h6>
                            <div class="mb-2">
                              <span class="badge bg-light text-dark me-2"><%= document.document_type %></span>
                              <% if document.r2_file_size %>
                                <span class="text-muted small">
                                  <i class="bi bi-file-earmark me-1"></i><%= number_to_human_size(document.r2_file_size) %>
                                </span>
                              <% end %>
                            </div>
                            <% if document.description.present? %>
                              <p class="text-muted mb-1 small"><%= truncate(document.description, length: 100) %></p>
                            <% end %>
                            <small class="text-info d-block">
                              <i class="bi bi-cloud-check me-1"></i>Stored in Cloudflare R2 • Uploaded on <%= document.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                            </small>
                          </div>
                          <div class="btn-group" role="group">
                            <% if document.r2_file_key.present? %>
                              <% r2_url = R2Service.public_url(document.r2_file_key) if document.r2_file_key %>
                              <% if r2_url %>
                                <%= link_to r2_url, class: "btn btn-outline-info btn-sm", target: "_blank", title: "View Document" do %>
                                  <i class="bi bi-eye me-1"></i>View
                                <% end %>
                                <%= link_to r2_url, class: "btn btn-outline-primary btn-sm", download: document.r2_filename, title: "Download Document" do %>
                                  <i class="bi bi-download me-1"></i>Download
                                <% end %>
                              <% end %>
                            <% end %>
                            <button type="button" class="btn btn-outline-danger btn-sm" onclick="deleteHealthInsuranceDocument(<%= document.id %>, '<%= document.title.gsub("'", "\\'") %>')" title="Delete Document">
                              <i class="bi bi-trash me-1"></i>Delete
                            </button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Document Management System -->
      <div class="border-top pt-4 mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h6 class="mb-0">Add More Documents</h6>
          <button type="button" class="btn btn-sm btn-primary" id="add_health_document">
            <i class="bi bi-plus-lg me-1"></i>
            Add Document
          </button>
        </div>

        <div id="health_documents_container">
          <!-- New document system will be added here -->
        </div>

        <p class="text-muted mb-0 mt-2">
          <small>Use this system to add organized documents with titles and types</small>
        </p>
      </div>
    </div>
  </div>

  <!-- Autopay Installment Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-calendar-event me-2 text-primary"></i>
        Autopay Installment
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :installment_autopay_start_date, "Installment Autopay Start Date", class: "form-label" %>
          <%= form.date_field :installment_autopay_start_date,
              class: "form-control",
              id: "autopay_start_date",
              value: @health_insurance.installment_autopay_start_date,
              min: "1900-01-01",
              max: "2099-12-31" %>
        </div>
        <div class="col-md-6 mb-3">
          <%= form.label :installment_autopay_end_date, "Installment Autopay End Date", class: "form-label" %>
          <%= form.date_field :installment_autopay_end_date,
              class: "form-control",
              id: "autopay_end_date",
              value: @health_insurance.installment_autopay_end_date,
              min: "1900-01-01",
              max: "2099-12-31" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="card mt-4">
    <div class="card-body">
      <div class="d-flex justify-content-between">
        <div>
          <%= link_to admin_health_insurances_path, class: "btn btn-outline-secondary btn-lg" do %>
            <i class="bi bi-x-lg me-2"></i>
            Cancel
          <% end %>
        </div>
        <div>
          <%= form.submit "Update Policy", class: "btn btn-primary btn-lg" %>
        </div>
      </div>
    </div>
  </div>

<% end %>

