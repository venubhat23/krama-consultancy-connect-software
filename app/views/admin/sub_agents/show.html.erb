      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Copy to clipboard functionality
  const copyButtons = document.querySelectorAll('.copy-btn');
  copyButtons.forEach(button => {
    button.addEventListener('click', function() {
      const textToCopy = this.getAttribute('data-copy');

      if (navigator.clipboard) {
        navigator.clipboard.writeText(textToCopy).then(() => {
          showCopyNotification(this, 'Copied!');
        }).catch(err => {
          fallbackCopyTextToClipboard(textToCopy, this);
        });
      } else {
        fallbackCopyTextToClipboard(textToCopy, this);
      }
    });
  });

  function fallbackCopyTextToClipboard(text, button) {
    const textArea = document.createElement("textarea");
    textArea.value = text;
    textArea.style.position = "fixed";
    textArea.style.top = "-1000px";
    textArea.style.left = "-1000px";
    document.body.appendChild(textArea);
    textArea.focus();
    textArea.select();

    try {
      const successful = document.execCommand('copy');
      if (successful) {
        showCopyNotification(button, 'Copied!');
      } else {
        showCopyNotification(button, 'Failed to copy', true);
      }
    } catch (err) {
      showCopyNotification(button, 'Failed to copy', true);
    }

    document.body.removeChild(textArea);
  }

  function showCopyNotification(button, message, isError = false) {
    const originalIcon = button.innerHTML;
    const originalClass = button.className;

    button.innerHTML = `<i class="bi bi-check"></i>`;
    button.className = isError ? 'btn btn-sm btn-outline-danger' : 'btn btn-sm btn-outline-success';

    setTimeout(() => {
      button.innerHTML = originalIcon;
      button.className = originalClass;
    }, 1000);
  }
});

// WhatsApp sharing function
function shareOnWhatsApp() {
  const username = document.getElementById('username_<%= @sub_agent.id %>').textContent;
  const password = document.getElementById('password_<%= @sub_agent.id %>').textContent;
  const agentName = '<%= @sub_agent.display_name %>';
  const mobile = '<%= @sub_agent.mobile %>';

  const message = `*Drwise Login Credentials*\n\n` +
                  `Name: ${agentName}\n` +
                  `Mobile: ${mobile}\n\n` +
                  `*Login Details:*\n` +
                  `Username: ${username}\n` +
                  `Password: ${password}\n\n` +
                  `Login URL: <%= request.base_url %>/login\n\n` +
                  `Please save these credentials securely.`;

  const whatsappUrl = 'https://wa.me/?text=' + encodeURIComponent(message);
  window.open(whatsappUrl, '_blank');
}
</script>