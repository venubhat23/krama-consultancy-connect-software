  color: rgba(255, 255, 255, 0.8);
  font-size: 14px;
}

.legend-value {
  color: white;
  font-weight: 600;
  font-size: 14px;
}

/* Performance Grid */
.performance-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 24px;
  margin-bottom: 40px;
}

/* KPI Grid */
.kpi-grid {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.kpi-item {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  transition: all 0.3s ease;
}

.kpi-item:hover {
