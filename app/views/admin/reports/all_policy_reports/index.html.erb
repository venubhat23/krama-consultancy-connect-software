<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <!-- Header Section -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2 class="mb-0">
            <i class="bi bi-file-text text-primary me-2"></i>
            All Policy Reports
          </h2>
          <p class="text-muted mb-0">Comprehensive policy analysis with advanced filtering</p>
        </div>
        <div>
          <button type="button" class="btn btn-success" id="exportBtn">
            <i class="bi bi-download me-2"></i>Export
          </button>
        </div>
      </div>

      <!-- Filters Section -->
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <h5 class="card-title mb-3">
            <i class="bi bi-funnel me-2"></i>Filters
          </h5>

          <%= form_with url: admin_reports_all_policy_reports_path, method: :get, class: "row g-3", id: "filtersForm", local: true do |form| %>
            <!-- Date Range -->
            <div class="col-md-3">
              <label class="form-label fw-bold">Start Date</label>
              <%= form.date_field :start_date, value: @start_date, class: "form-control" %>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">End Date</label>
              <%= form.date_field :end_date, value: @end_date, class: "form-control" %>
            </div>

            <!-- Policy Type -->
            <div class="col-md-3">
              <label class="form-label fw-bold">Policy Type</label>
              <%= form.select :policy_type, options_for_select([
                ['All Types', 'all'],
                ['Health Insurance', 'health'],
                ['Life Insurance', 'life'],
                ['Motor Insurance', 'motor'],
                ['Other Insurance', 'other']
              ], @policy_type), {}, { class: "form-select" } %>
            </div>

            <!-- Status -->
            <div class="col-md-3">
              <label class="form-label fw-bold">Status</label>
              <%= form.select :status, options_for_select([
                ['All Status', 'all'],
                ['Active', 'active'],
                ['Expired', 'expired'],
                ['Expiring Soon', 'expiring_soon']
              ], @status), {}, { class: "form-select" } %>
            </div>

            <!-- Insurance Company -->
            <div class="col-md-12">
              <label class="form-label fw-bold">Insurance Company</label>
              <%= form.text_field :insurance_company, value: @insurance_company, placeholder: "Company name...", class: "form-control" %>
            </div>

            <!-- Filter Actions -->
            <div class="col-12">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-2"></i>Apply Filters
              </button>
              <%= link_to "Clear Filters", admin_reports_all_policy_reports_path, class: "btn btn-outline-secondary ms-2" %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Summary Cards -->
      <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-3">
          <div class="card h-100 border-primary border-2 shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <h6 class="text-muted mb-2">Total Policies</h6>
                  <h3 class="mb-0 text-primary"><%= number_with_delimiter(@total_policies || 0) %></h3>
                </div>
                <div class="bg-primary bg-opacity-10 rounded p-3">
                  <i class="bi bi-shield-check fs-4 text-primary"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
          <div class="card h-100 border-success border-2 shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <h6 class="text-muted mb-2">Total Premium</h6>
                  <h3 class="mb-0 text-success"><%= indian_currency((@total_premium || 0).round(0)) %></h3>
                </div>
                <div class="bg-success bg-opacity-10 rounded p-3">
                  <i class="bi bi-currency-rupee fs-4 text-success"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
          <div class="card h-100 border-warning border-2 shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <h6 class="text-muted mb-2">Total Sum Insured</h6>
                  <h3 class="mb-0 text-warning"><%= indian_currency((@total_sum_insured || 0).round(0)) %></h3>
                </div>
                <div class="bg-warning bg-opacity-10 rounded p-3">
                  <i class="bi bi-shield-fill fs-4 text-warning"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
          <div class="card h-100 border-info border-2 shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <h6 class="text-muted mb-2">Policies This Page</h6>
                  <h3 class="mb-0 text-info"><%= number_with_delimiter(@policy_count || 0) %></h3>
                </div>
                <div class="bg-info bg-opacity-10 rounded p-3">
                  <i class="bi bi-list-ul fs-4 text-info"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Data Table -->
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">
            <i class="bi bi-table me-2"></i>Policy Data
            <small class="text-muted ms-2">(Latest records first)</small>
          </h5>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0" id="policyTable">
              <thead class="table-light">
                <tr>
                  <th scope="col">Policy Number / Type</th>
                  <th scope="col">Customer Name</th>
                  <th scope="col">Insurance Company</th>
                  <th scope="col">Policy Period</th>
                  <th scope="col">Premium</th>
                  <th scope="col">Sum Insured</th>
                  <th scope="col">Status</th>
                  <th scope="col">Affiliate</th>
                </tr>
              </thead>
              <tbody>
                <% if @policy_data.present? %>
                  <% @policy_data.each do |policy| %>
                    <tr>
                      <td>
                        <code><%= policy[:policy_number] %></code><br>
                        <span class="badge bg-<%= policy[:policy_type] == 'Health' ? 'success' : (policy[:policy_type] == 'Motor' ? 'warning' : (policy[:policy_type] == 'Life' ? 'info' : 'secondary')) %> mt-1">
                          <%= policy[:policy_type] %>
                        </span>
                      </td>
                      <td>
                        <strong><%= policy[:customer_name] %></strong>
                      </td>
                      <td>
                        <%= policy[:insurance_company] %>
                      </td>
                      <td>
                        <small><%= policy[:start_date]&.strftime('%d/%m/%Y') || '-' %></small><br>
                        <small class="text-muted">to <%= policy[:end_date]&.strftime('%d/%m/%Y') || '-' %></small>
                      </td>
                      <td class="text-end">
                        <strong class="text-success"><%= indian_currency((policy[:premium_amount] || 0).round(0)) %></strong>
                      </td>
                      <td class="text-end">
                        <span class="text-info"><%= indian_currency((policy[:sum_insured] || 0).round(0)) %></span>
                      </td>
                      <td>
                        <% case policy[:status]&.downcase %>
                        <% when 'active' %>
                          <span class="badge bg-success"><%= policy[:status] %></span>
                        <% when 'expired' %>
                          <span class="badge bg-danger"><%= policy[:status] %></span>
                        <% when 'expiring soon' %>
                          <span class="badge bg-warning"><%= policy[:status] %></span>
                        <% else %>
                          <span class="badge bg-secondary"><%= policy[:status] || 'Unknown' %></span>
                        <% end %>
                      </td>
                      <td>
                        <small><%= policy[:sub_agent_name] %></small>
                      </td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="8" class="text-center py-4">
                      <div class="text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No policy data found for the selected criteria.
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Pagination -->
        <% if @policy_data.respond_to?(:current_page) && @policy_data.total_pages > 1 %>
          <div class="card-footer">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <small class="text-muted">
                  Page <%= @policy_data.current_page %> of <%= @policy_data.total_pages %>
                  (<%= @policy_data.total_count %> total entries)
                </small>
              </div>
              <div>
                <%= paginate @policy_data, theme: 'twitter-bootstrap-4' %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exportModalLabel">
          <i class="bi bi-download me-2"></i>Export All Policy Report
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with url: "", method: :post, id: "exportForm", class: "needs-validation", novalidate: true do |form| %>
          <!-- Column Selection -->
          <div class="mb-4">
            <h6>Select Columns to Export</h6>
            <div class="row g-3">
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_number" id="col_policy_number" checked>
                  <label class="form-check-label" for="col_policy_number">Policy Number</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_type" id="col_policy_type" checked>
                  <label class="form-check-label" for="col_policy_type">Policy Type</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="customer_name" id="col_customer_name" checked>
                  <label class="form-check-label" for="col_customer_name">Customer Name</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="insurance_company" id="col_insurance_company" checked>
                  <label class="form-check-label" for="col_insurance_company">Insurance Company</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_holder" id="col_policy_holder" checked>
                  <label class="form-check-label" for="col_policy_holder">Policy Holder</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="start_date" id="col_start_date" checked>
                  <label class="form-check-label" for="col_start_date">Start Date</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="end_date" id="col_end_date" checked>
                  <label class="form-check-label" for="col_end_date">End Date</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="premium_amount" id="col_premium_amount" checked>
                  <label class="form-check-label" for="col_premium_amount">Premium Amount</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="sum_insured" id="col_sum_insured" checked>
                  <label class="form-check-label" for="col_sum_insured">Sum Insured</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="payment_mode" id="col_payment_mode">
                  <label class="form-check-label" for="col_payment_mode">Payment Mode</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="status" id="col_status" checked>
                  <label class="form-check-label" for="col_status">Status</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="sub_agent_name" id="col_sub_agent_name">
                  <label class="form-check-label" for="col_sub_agent_name">Affiliate Name</label>
                </div>
              </div>
            </div>
            <div class="mt-2">
              <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAllColumns()">Select All</button>
              <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deselectAllColumns()">Deselect All</button>
            </div>
          </div>
        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="performExport()">
          <i class="bi bi-download me-2"></i>Export
        </button>
      </div>
    </div>
  </div>
</div>

<!-- JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Export button click handler
  document.getElementById('exportBtn').addEventListener('click', function() {
    const exportModal = new bootstrap.Modal(document.getElementById('exportModal'));
    exportModal.show();
  });
});

function selectAllColumns() {
  const checkboxes = document.querySelectorAll('input[name="columns[]"]');
  checkboxes.forEach(checkbox => checkbox.checked = true);
}

function deselectAllColumns() {
  const checkboxes = document.querySelectorAll('input[name="columns[]"]');
  checkboxes.forEach(checkbox => checkbox.checked = false);
}

function performExport() {
  const form = document.getElementById('exportForm');
  const selectedColumns = document.querySelectorAll('input[name="columns[]"]:checked');
  const exportBtn = document.querySelector('#exportModal .btn-primary');

  // Check if at least one column is selected
  if (selectedColumns.length === 0) {
    alert('Please select at least one column to export.');
    return;
  }

  // Show loader
  const originalBtnText = exportBtn.innerHTML;
  exportBtn.disabled = true;
  exportBtn.innerHTML = '<i class="bi bi-arrow-clockwise me-2 spin"></i>Exporting...';

  function resetButton() {
    exportBtn.disabled = false;
    exportBtn.innerHTML = originalBtnText;
  }

  // Get current URL parameters to preserve filters
  const urlParams = new URLSearchParams(window.location.search);

  // Build export URL (PDF only)
  const exportUrl = '<%= export_pdf_admin_reports_all_policy_reports_path %>';

  // Create form data
  const formData = new FormData();

  // Add filter parameters
  urlParams.forEach((value, key) => {
    if (key !== 'page') { // Don't include page in export
      formData.append(key, value);
    }
  });

  // Add selected columns
  selectedColumns.forEach(checkbox => {
    formData.append('columns[]', checkbox.value);
  });

  // Add CSRF token
  const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
  formData.append('authenticity_token', csrfToken);

  // Submit form
  fetch(exportUrl, {
    method: 'POST',
    body: formData,
    headers: {
      'X-Requested-With': 'XMLHttpRequest'
    }
  })
  .then(response => {
    console.log('Response status:', response.status);
    console.log('Response headers:', Object.fromEntries(response.headers.entries()));

    if (response.ok) {
      return response.blob();
    }

    // Try to get error message from response
    return response.text().then(text => {
      throw new Error(`Export failed (${response.status}): ${text.substring(0, 200)}`);
    });
  })
  .then(blob => {
    // Download the file
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `All_Policies_Report_${new Date().toISOString().split('T')[0]}.pdf`;
    document.body.appendChild(a);
    a.click();
    window.URL.revokeObjectURL(url);
    document.body.removeChild(a);

    // Reset button and close modal
    resetButton();
    const exportModal = bootstrap.Modal.getInstance(document.getElementById('exportModal'));
    exportModal.hide();
  })
  .catch(error => {
    console.error('Export error:', error);
    alert('Export failed. Please try again.');
    resetButton();
  });
}
</script>

<style>
/* Spinning loader */
.spin {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
</style>