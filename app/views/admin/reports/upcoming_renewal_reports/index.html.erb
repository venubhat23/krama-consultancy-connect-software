<!-- Success/Error Messages -->
<% if flash[:success] %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle me-2"></i>
    <%= flash[:success] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>

<% if flash[:notice] %>
  <div class="alert alert-info alert-dismissible fade show" role="alert">
    <i class="bi bi-info-circle me-2"></i>
    <%= flash[:notice] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>

<% if flash[:alert] %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle me-2"></i>
    <%= flash[:alert] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Upcoming Renewals</h2>
    <p class="text-muted mb-0">Policies renewing in the next <strong><%= @renewal_days %> days</strong> — <%= @renewal_start.strftime('%d %b %Y') %> to <%= @renewal_end.strftime('%d %b %Y') %></p>
  </div>
  <div class="d-flex gap-2 align-items-center">
    <!-- Quick range switcher -->
    <% [15, 30, 60, 90].each do |d| %>
      <%= link_to admin_reports_upcoming_renewal_reports_path(renewal_days: d),
          class: "btn btn-sm #{ @renewal_days == d ? 'btn-primary' : 'btn-outline-secondary' }" do %>
        <%= d %>d
      <% end %>
    <% end %>
    <%= link_to generate_admin_reports_upcoming_renewal_reports_path, class: "btn btn-outline-primary ms-2" do %>
      <i class="bi bi-plus-lg me-1"></i>Generate Report
    <% end %>
    <button type="button" class="btn btn-success" id="exportBtn">
      <i class="bi bi-download me-1"></i>Export CSV
    </button>
  </div>
</div>

<!-- Summary KPI strip -->
<div class="row g-3 mb-4">
  <% due_soon  = @upcoming_policies.count { |p| p[:days_until_renewal] <= 7 } %>
  <% due_month = @upcoming_policies.count { |p| p[:days_until_renewal] > 7 && p[:days_until_renewal] <= 30 } %>
  <% total_prem = @upcoming_policies.sum { |p| p[:premium_amount].to_f } %>

  <div class="col-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="bg-danger bg-opacity-10 rounded p-3"><i class="bi bi-exclamation-circle text-danger fs-4"></i></div>
        <div>
          <div class="text-muted small">Due within 7 days</div>
          <div class="fw-bold fs-4 text-danger"><%= due_soon %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="bg-warning bg-opacity-10 rounded p-3"><i class="bi bi-clock text-warning fs-4"></i></div>
        <div>
          <div class="text-muted small">Next 8–30 days</div>
          <div class="fw-bold fs-4 text-warning"><%= due_month %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="bg-primary bg-opacity-10 rounded p-3"><i class="bi bi-file-earmark-check text-primary fs-4"></i></div>
        <div>
          <div class="text-muted small">Total Policies</div>
          <div class="fw-bold fs-4 text-primary"><%= @upcoming_policies.count %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="bg-success bg-opacity-10 rounded p-3"><i class="bi bi-currency-rupee text-success fs-4"></i></div>
        <div>
          <div class="text-muted small">Total Premium</div>
          <div class="fw-bold fs-5 text-success"><%= indian_currency(total_prem.round(0)) %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Live Upcoming Renewals Table -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between">
    <h5 class="mb-0"><i class="bi bi-arrow-repeat text-warning me-2"></i>Policies Renewing in Next <%= @renewal_days %> Days</h5>
    <span class="badge bg-warning text-dark"><%= @upcoming_policies.count %> policies</span>
  </div>
  <div class="card-body p-0">
    <% if @upcoming_policies.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0" id="renewalTable">
          <thead class="bg-light">
            <tr>
              <th class="border-0">Policy</th>
              <th class="border-0">Customer</th>
              <th class="border-0">Insurance Company</th>
              <th class="border-0">Renewal Date</th>
              <th class="border-0">Days Left</th>
              <th class="border-0 text-end">Premium</th>
              <th class="border-0">Affiliate</th>
            </tr>
          </thead>
          <tbody>
            <% @upcoming_policies.each do |p| %>
              <% days = p[:days_until_renewal] %>
              <% urgency_class = days <= 7 ? 'table-danger' : days <= 15 ? 'table-warning' : '' %>
              <tr class="<%= urgency_class %>">
                <td>
                  <div class="fw-semibold" style="font-size:13px;"><%= p[:policy_number] %></div>
                  <span class="badge rounded-pill <%= p[:policy_type] == 'health' ? 'bg-success' : p[:policy_type] == 'motor' ? 'bg-warning text-dark' : 'bg-primary' %>" style="font-size:10px;">
                    <%= p[:policy_type]&.capitalize %>
                  </span>
                </td>
                <td>
                  <div class="fw-semibold" style="font-size:13px;"><%= p[:customer_name] %></div>
                  <% if p[:customer_mobile].present? %>
                    <small class="text-muted"><i class="bi bi-telephone me-1"></i><%= p[:customer_mobile] %></small>
                  <% end %>
                </td>
                <td><small><%= p[:insurance_company] %></small></td>
                <td>
                  <div class="fw-semibold" style="font-size:13px;"><%= p[:policy_end_date]&.strftime('%d %b %Y') %></div>
                </td>
                <td>
                  <% if days <= 7 %>
                    <span class="badge bg-danger"><%= days %> days</span>
                  <% elsif days <= 15 %>
                    <span class="badge bg-warning text-dark"><%= days %> days</span>
                  <% else %>
                    <span class="badge bg-secondary"><%= days %> days</span>
                  <% end %>
                </td>
                <td class="text-end fw-semibold text-success"><%= indian_currency(p[:premium_amount].to_f.round(0)) %></td>
                <td><small class="text-muted"><%= p[:affiliate] %></small></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot class="bg-light">
            <tr>
              <td colspan="5" class="fw-bold text-end">Total Premium</td>
              <td class="text-end fw-bold text-success"><%= indian_currency(@upcoming_policies.sum { |p| p[:premium_amount].to_f }.round(0)) %></td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-calendar-check fs-1 text-muted d-block mb-3"></i>
        <h5 class="text-muted">No renewals in the next <%= @renewal_days %> days</h5>
        <p class="text-muted">All policies are up to date for this period.</p>
      </div>
    <% end %>
  </div>
</div>

<!-- Saved Reports List -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Saved Reports</h5>
  </div>
  <div class="card-body p-0">
    <% if @saved_reports && @saved_reports.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light">
            <tr>
              <th class="border-0">Report Name</th>
              <th class="border-0">Date Range</th>
              <th class="border-0">Created At</th>
              <th class="border-0">Created By</th>
              <th class="border-0">Total Premium</th>
              <th class="border-0 text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @saved_reports.each do |report| %>
              <tr>
                <td>
                  <div>
                    <h6 class="mb-1">
                      <i class="bi bi-file-earmark-text text-primary me-1"></i>
                      <%= report.name %>
                    </h6>
                    <% if report.filters %>
                      <div class="mt-1">
                        <% if report.filters['policy_type'].present? %>
                          <span class="badge bg-info me-1">
                            <i class="bi bi-tag-fill me-1"></i><%= report.filters['policy_type'].humanize %>
                          </span>
                        <% end %>
                        <% if report.filters['status'].present? %>
                          <span class="badge bg-warning">
                            <i class="bi bi-flag-fill me-1"></i><%= report.filters['status'].humanize %>
                          </span>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                </td>
                <td>
                  <% if report.filters && report.filters['start_date'] && report.filters['end_date'] %>
                    <div>
                      <i class="bi bi-calendar-range text-muted me-1"></i>
                      <small>
                        <%= Date.parse(report.filters['start_date'].to_s).strftime('%d %b %Y') %> -
                        <%= Date.parse(report.filters['end_date'].to_s).strftime('%d %b %Y') %>
                      </small>
                    </div>
                    <small class="text-muted">
                      <% days = (Date.parse(report.filters['end_date'].to_s) - Date.parse(report.filters['start_date'].to_s)).to_i + 1 %>
                      (<%= pluralize(days, 'day') %>)
                    </small>
                  <% else %>
                    <small class="text-muted">
                      <i class="bi bi-infinity me-1"></i>All Time
                    </small>
                  <% end %>
                </td>
                <td>
                  <small class="text-muted">
                    <i class="bi bi-clock me-1"></i>
                    <%= report.created_at.strftime('%d %b %Y') %>
                    <br>
                    <%= report.created_at.strftime('%I:%M %p') %>
                  </small>
                </td>
                <td>
                  <small class="text-muted">
                    <i class="bi bi-person-circle me-1"></i>
                    <%= report.created_by&.full_name || 'System' %>
                  </small>
                </td>
                <td>
                  <div class="text-end">
                    <strong class="text-success d-block">
                      <%= indian_currency((report.report_data&.dig('statistics', 'total_premium') || 0).to_f.round(2)) %>
                    </strong>
                    <% total_policies = report.report_data&.dig('statistics', 'total_policies') || 0 %>
                    <% if total_policies > 0 %>
                      <small class="text-muted">
                        <%= pluralize(total_policies, 'policy', 'policies') %>
                      </small>
                    <% end %>
                  </div>
                </td>
                <td>
                  <div class="d-flex gap-1 justify-content-center">
                    <%= link_to export_csv_admin_reports_upcoming_renewal_report_path(report),
                                class: "btn btn-sm btn-outline-success",
                                title: "Export CSV" do %>
                      <i class="bi bi-file-earmark-excel"></i>
                    <% end %>

                    <%= button_to destroy_saved_report_admin_reports_upcoming_renewal_report_path(report),
                                method: :delete,
                                data: { turbo_confirm: "Are you sure you want to delete this report?" },
                                class: "btn btn-sm btn-outline-danger",
                                title: "Delete Report",
                                form: { style: "display: inline-block;" } do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @saved_reports.respond_to?(:total_pages) && @saved_reports.total_pages > 1 %>
        <div class="card-footer bg-transparent border-0">
          <div class="d-flex justify-content-between align-items-center flex-wrap">
            <small class="text-muted mb-2 mb-md-0">
              Showing <%= @saved_reports.current_page == 1 ? 1 : ((@saved_reports.current_page - 1) * @saved_reports.limit_value + 1) %>
              to <%= [@saved_reports.current_page * @saved_reports.limit_value, @saved_reports.total_count].min %>
              of <%= number_with_delimiter(@saved_reports.total_count) %> reports
            </small>
            <div class="pagination-wrapper">
              <%= paginate @saved_reports %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-file-text fs-1 text-muted d-block mb-3"></i>
        <h5 class="text-muted">No reports generated yet</h5>
        <p class="text-muted mb-3">
          Generate your first upcoming renewal report to track policies due for renewal.
        </p>
      </div>
    <% end %>
  </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exportModalLabel">
          <i class="bi bi-download me-2"></i>Export Upcoming Renewal Report
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with url: "", method: :post, id: "exportForm", class: "needs-validation", novalidate: true do |form| %>
          <!-- Export Format -->
          <div class="mb-4">
            <h6>Export Format</h6>
            <div class="row g-3">
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="export_format" value="csv" id="format_csv" checked>
                  <label class="form-check-label" for="format_csv">
                    <i class="bi bi-file-earmark-spreadsheet text-success me-1"></i> CSV Spreadsheet
                  </label>
                </div>
              </div>
            </div>
          </div>

          <!-- Column Selection -->
          <div class="mb-4">
            <h6>Select Columns to Export</h6>
            <div class="row g-3">
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_number" id="col_policy_number" checked>
                  <label class="form-check-label" for="col_policy_number">Policy Number</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_type" id="col_policy_type" checked>
                  <label class="form-check-label" for="col_policy_type">Policy Type</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="customer_name" id="col_customer_name" checked>
                  <label class="form-check-label" for="col_customer_name">Customer Name</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="insurance_company" id="col_insurance_company" checked>
                  <label class="form-check-label" for="col_insurance_company">Insurance Company</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_holder" id="col_policy_holder">
                  <label class="form-check-label" for="col_policy_holder">Policy Holder</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="start_date" id="col_start_date">
                  <label class="form-check-label" for="col_start_date">Start Date</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="end_date" id="col_end_date" checked>
                  <label class="form-check-label" for="col_end_date">End Date</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="days_until_renewal" id="col_days_until_renewal" checked>
                  <label class="form-check-label" for="col_days_until_renewal">Days Until Renewal</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="premium_amount" id="col_premium_amount" checked>
                  <label class="form-check-label" for="col_premium_amount">Premium Amount</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="sum_insured" id="col_sum_insured" checked>
                  <label class="form-check-label" for="col_sum_insured">Sum Insured</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="payment_mode" id="col_payment_mode">
                  <label class="form-check-label" for="col_payment_mode">Payment Mode</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="sub_agent_name" id="col_sub_agent_name">
                  <label class="form-check-label" for="col_sub_agent_name">Sub Agent</label>
                </div>
              </div>
            </div>
            <div class="mt-2">
              <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAllColumns()">Select All</button>
              <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deselectAllColumns()">Deselect All</button>
            </div>
          </div>
        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="performExport()">
          <i class="bi bi-download me-2"></i>Export
        </button>
      </div>
    </div>
  </div>
</div>

<!-- JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Export button click handler
  document.getElementById('exportBtn').addEventListener('click', function() {
    const exportModal = new bootstrap.Modal(document.getElementById('exportModal'));
    exportModal.show();
  });
});

function selectAllColumns() {
  const checkboxes = document.querySelectorAll('input[name="columns[]"]');
  checkboxes.forEach(checkbox => checkbox.checked = true);
}

function deselectAllColumns() {
  const checkboxes = document.querySelectorAll('input[name="columns[]"]');
  checkboxes.forEach(checkbox => checkbox.checked = false);
}

function performExport() {
  const form = document.getElementById('exportForm');
  const selectedColumns = document.querySelectorAll('input[name="columns[]"]:checked');
  const exportBtn = document.querySelector('#exportModal .btn-primary');

  // Check if at least one column is selected
  if (selectedColumns.length === 0) {
    alert('Please select at least one column to export.');
    return;
  }

  // Show loader
  const originalBtnText = exportBtn.innerHTML;
  exportBtn.disabled = true;
  exportBtn.innerHTML = '<i class="bi bi-arrow-clockwise me-2 spin"></i>Exporting...';

  function resetButton() {
    exportBtn.disabled = false;
    exportBtn.innerHTML = originalBtnText;
  }

  // Create CSV content from current table
  let csvContent = 'Report Name,Date Range,Created At,Created By,Total Premium\n';

  const tableRows = document.querySelectorAll('table tbody tr');
  tableRows.forEach(row => {
    const cells = row.querySelectorAll('td');
    if (cells.length >= 5) {
      const reportName = cells[0].textContent.trim().split('\n')[0];
      const dateRange = cells[1].textContent.trim().replace(/\s+/g, ' ');
      const createdAt = cells[2].textContent.trim().replace(/\s+/g, ' ');
      const createdBy = cells[3].textContent.trim().replace(/\s+/g, ' ');
      const totalPremium = cells[4].textContent.trim().replace(/\s+/g, ' ');

      csvContent += `"${reportName}","${dateRange}","${createdAt}","${createdBy}","${totalPremium}"\n`;
    }
  });

  // Download CSV
  const blob = new Blob([csvContent], { type: 'text/csv' });
  const url = window.URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `Upcoming_Renewal_Reports_${new Date().toISOString().split('T')[0]}.csv`;
  document.body.appendChild(a);
  a.click();
  window.URL.revokeObjectURL(url);
  document.body.removeChild(a);

  // Reset button and close modal
  resetButton();
  const exportModal = bootstrap.Modal.getInstance(document.getElementById('exportModal'));
  exportModal.hide();
}
</script>

<style>
.min-width-250 { min-width: 250px; }

/* Spinning loader */
.spin {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
</style>