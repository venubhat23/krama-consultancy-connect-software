<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @report.name %></h2>
    <p class="text-muted mb-0">
      Generated on <%= @report.created_at.strftime('%d %b %Y at %I:%M %p') %>
      <% if @report.created_by %>
        by <%= @report.created_by.full_name %>
      <% end %>
    </p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to export_csv_admin_reports_lead_report_path(@report),
                class: "btn btn-success" do %>
      <i class="bi bi-file-earmark-excel me-1"></i>Export CSV
    <% end %>

    <%= link_to admin_reports_lead_reports_path,
                class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back to Reports
    <% end %>
  </div>
</div>

<!-- Report Filters Info -->
<% if @report.filters %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <h5 class="mb-3">Report Filters</h5>
      <div class="row">
        <div class="col-md-3">
          <small class="text-muted d-block">Date Range</small>
          <% if @report.filters['start_date'] && @report.filters['end_date'] %>
            <%= Date.parse(@report.filters['start_date'].to_s).strftime('%d %b %Y') %> -
            <%= Date.parse(@report.filters['end_date'].to_s).strftime('%d %b %Y') %>
          <% else %>
            All Time
          <% end %>
        </div>
        <% if @report.filters['current_stage'].present? %>
          <div class="col-md-3">
            <small class="text-muted d-block">Lead Stage</small>
            <%= @report.filters['current_stage'].humanize %>
          </div>
        <% end %>
        <% if @report.filters['product_category'].present? %>
          <div class="col-md-3">
            <small class="text-muted d-block">Product Category</small>
            <%= @report.filters['product_category'].humanize %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<!-- Report Content -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Report Details</h5>
  </div>
  <div class="card-body p-0">
    <% if @preview_data && @preview_data.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light">
            <tr>
              <th class="border-0">Lead Details</th>
              <th class="border-0">Contact Information</th>
              <th class="border-0">Referred By / Product Interest</th>
              <th class="border-0">Current Stage</th>
              <th class="border-0">Created Date</th>
            </tr>
          </thead>
          <tbody>
            <% @preview_data.each do |lead| %>
              <tr>
                <td>
                  <%= raw lead['lead_details'] %>
                </td>
                <td>
                  <%= raw lead['contact_information'] %>
                </td>
                <td>
                  <%= raw lead['referred_by_product_interest'] %>
                </td>
                <td>
                  <span class="badge bg-primary">
                    <%= lead['current_stage'] %>
                  </span>
                </td>
                <td>
                  <small class="text-muted">
                    <%= lead['created_date'] %>
                  </small>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
        <h5 class="text-muted">No lead data found</h5>
        <p class="text-muted mb-0">The report doesn't contain any lead data to display.</p>
      </div>
    <% end %>
  </div>
</div>