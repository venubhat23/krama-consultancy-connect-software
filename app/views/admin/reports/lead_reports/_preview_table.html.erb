<% if @preview_data && @preview_data.any? %>
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="bg-light">
        <tr>
          <th class="border-0">Lead Details</th>
          <th class="border-0">Contact Information</th>
          <th class="border-0">Referred By / Product Interest</th>
          <th class="border-0">Current Stage</th>
          <th class="border-0">Created Date</th>
        </tr>
      </thead>
      <tbody>
        <% @preview_data.each do |lead| %>
          <tr>
            <!-- Lead Details -->
            <td>
              <%= raw lead['lead_details'] %>
            </td>

            <!-- Contact Information -->
            <td>
              <%= raw lead['contact_information'] %>
            </td>

            <!-- Referred By / Product Interest -->
            <td>
              <%= raw lead['referred_by_product_interest'] %>
            </td>

            <!-- Current Stage -->
            <td>
              <span class="badge bg-primary">
                <%= lead['current_stage'] %>
              </span>
            </td>

            <!-- Created Date -->
            <td>
              <small class="text-muted">
                <%= lead['created_date'] %>
              </small>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Summary Statistics -->
  <div class="card-footer bg-light">
    <div class="row text-center">
      <div class="col-md-3">
        <h6 class="text-muted mb-1">Total Leads</h6>
        <h4 class="mb-0"><%= @preview_data.size %></h4>
      </div>
      <div class="col-md-3">
        <h6 class="text-muted mb-1">Lead Sources</h6>
        <h4 class="mb-0 text-primary">
          <%= @preview_data.map { |l| l['referred_by_product_interest']&.split('<br/>')&.first }.compact.uniq.count %>
        </h4>
      </div>
      <div class="col-md-3">
        <h6 class="text-muted mb-1">Unique Stages</h6>
        <h4 class="mb-0 text-success">
          <%= @preview_data.map { |l| l['current_stage'] }.compact.uniq.count %>
        </h4>
      </div>
      <div class="col-md-3">
        <h6 class="text-muted mb-1">Date Range</h6>
        <h4 class="mb-0 text-info">
          <%= @preview_data.size > 1 ?
              "#{@preview_data.last['created_date']} - #{@preview_data.first['created_date']}" :
              (@preview_data.first['created_date'] || 'N/A') %>
        </h4>
      </div>
    </div>
  </div>
<% else %>
  <div class="text-center py-5">
    <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
    <h5 class="text-muted">No data found</h5>
    <p class="text-muted mb-0">
      No lead data found for the selected filters.
    </p>
  </div>
<% end %>