<%# Profit Reports Index Page %>
<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <div>
            <h3 class="card-title mb-0">
              <i class="fas fa-chart-line"></i> Profit Reports
            </h3>
            <p class="text-muted mb-0">View all policies with profit information</p>
          </div>
          <div>
            <button type="button" class="btn btn-success" id="exportBtn">
              <i class="bi bi-download me-2"></i>Export
            </button>
          </div>
        </div>

        <!-- Filter Section -->
        <div class="card-body">
          <%= form_with url: admin_reports_profit_reports_path, method: :get, local: true, class: "row g-3 mb-4" do |f| %>
            <div class="col-md-3">
              <%= f.label :start_date, "Policy Start Date (From)", class: "form-label" %>
              <%= f.date_field :start_date, value: params[:start_date] || Date.current.beginning_of_year.strftime('%Y-%m-%d'), class: "form-control" %>
            </div>
            <div class="col-md-3">
              <%= f.label :end_date, "Policy Start Date (To)", class: "form-label" %>
              <%= f.date_field :end_date, value: params[:end_date] || Date.current.end_of_year.strftime('%Y-%m-%d'), class: "form-control" %>
            </div>
            <div class="col-md-2">
              <%= f.label :policy_type, "Policy Type", class: "form-label" %>
              <%= f.select :policy_type, options_from_collection_for_select(@policy_types.map { |pt| [pt.humanize, pt] }, :last, :first, params[:policy_type]),
                          { prompt: "All Types" }, { class: "form-select" } %>
            </div>
            <div class="col-md-3">
              <%= f.label :insurance_company, "Insurance Company", class: "form-label" %>
              <%= f.select :insurance_company, options_from_collection_for_select(@insurance_companies.map { |ic| [ic, ic] }, :last, :first, params[:insurance_company]),
                          { prompt: "All Companies" }, { class: "form-select" } %>
            </div>
            <div class="col-md-1 d-flex align-items-end">
              <%= f.submit "Filter", class: "btn btn-primary w-100" %>
            </div>
          <% end %>

          <!-- Summary Cards -->
          <div class="row mb-4">
            <div class="col-lg-3 col-md-6 mb-3">
              <div class="card h-100 border-0 shadow-sm bg-light">
                <div class="card-body">
                  <div class="d-flex justify-content-between">
                    <div>
                      <h6 class="text-muted mb-2">Total Policies</h6>
                      <h3 class="mb-0 text-dark"><%= number_with_delimiter(@total_policies || 0) %></h3>
                    </div>
                    <div class="bg-primary text-white rounded p-3">
                      <i class="fas fa-file-alt fs-4"></i>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-3">
              <div class="card h-100 border-0 shadow-sm bg-light">
                <div class="card-body">
                  <div class="d-flex justify-content-between">
                    <div>
                      <h6 class="text-muted mb-2">Total Profit</h6>
                      <h3 class="mb-0 text-dark"><%= indian_currency((@total_profit_amount || 0).round(2)) %></h3>
                    </div>
                    <div class="bg-success text-white rounded p-3">
                      <i class="fas fa-chart-line fs-4"></i>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-3">
              <div class="card h-100 border-0 shadow-sm bg-light">
                <div class="card-body">
                  <div class="d-flex justify-content-between">
                    <div>
                      <h6 class="text-muted mb-2">Total Premium</h6>
                      <h3 class="mb-0 text-dark"><%= indian_currency((@total_premium || 0).round(2)) %></h3>
                    </div>
                    <div class="bg-info text-white rounded p-3">
                      <i class="fas fa-money-bill-wave fs-4"></i>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-3">
              <div class="card h-100 border-0 shadow-sm bg-light">
                <div class="card-body">
                  <div class="d-flex justify-content-between">
                    <div>
                      <h6 class="text-muted mb-2">Avg. Profit %</h6>
                      <h3 class="mb-0 text-dark"><%= number_with_precision((@average_profit_percentage || 0), precision: 2) %>%</h3>
                    </div>
                    <div class="bg-warning text-white rounded p-3">
                      <i class="fas fa-percentage fs-4"></i>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Data Table -->
          <div class="table-responsive">
            <table class="table table-striped table-hover" id="profitReportsTable">
              <thead class="table-dark">
                <tr>
                  <th scope="col">Policy Number</th>
                  <th scope="col">Type</th>
                  <th scope="col">Customer</th>
                  <th scope="col">Insurance Company</th>
                  <th scope="col">Policy Holder</th>
                  <th scope="col">Start Date</th>
                  <th scope="col">End Date</th>
                  <th scope="col">Premium</th>
                  <th scope="col">Net Premium</th>
                  <th scope="col">Profit Amount</th>
                  <th scope="col">Profit %</th>
                  <th scope="col">Company Expenses</th>
                  <th scope="col">Sub Agent</th>
                  <th scope="col">Created</th>
                </tr>
              </thead>
              <tbody>
                <% if @policy_data.any? %>
                  <% @policy_data.each do |policy| %>
                    <tr>
                      <td>
                        <strong><%= policy[:policy_number] %></strong>
                        <% if policy[:lead_id].present? %>
                          <br><small class="text-muted">Lead: <%= policy[:lead_id] %></small>
                        <% end %>
                      </td>
                      <td>
                        <span class="badge
                          <%= case policy[:policy_type]
                              when 'Health' then 'bg-success'
                              when 'Life' then 'bg-primary'
                              when 'Motor' then 'bg-warning'
                              when 'Other' then 'bg-secondary'
                              else 'bg-light text-dark'
                              end %>">
                          <%= policy[:policy_type] %>
                        </span>
                      </td>
                      <td>
                        <%= policy[:customer_name] %>
                        <% if policy[:policy_holder] != policy[:customer_name] %>
                          <br><small class="text-muted">Holder: <%= policy[:policy_holder] %></small>
                        <% end %>
                      </td>
                      <td><%= policy[:insurance_company] %></td>
                      <td><%= policy[:policy_holder] %></td>
                      <td><%= policy[:start_date]&.strftime('%d/%m/%Y') %></td>
                      <td><%= policy[:end_date]&.strftime('%d/%m/%Y') %></td>
                      <td class="text-end">
                        <strong><%= indian_currency(policy[:premium_amount]) %></strong>
                      </td>
                      <td class="text-end">
                        <%= indian_currency(policy[:net_premium]) %>
                      </td>
                      <td class="text-end">
                        <strong class="text-success">
                          <%= indian_currency(policy[:profit_amount]) %>
                        </strong>
                      </td>
                      <td class="text-end">
                        <span class="badge
                          <%= if policy[:profit_percentage] > 10
                                'bg-success'
                              elsif policy[:profit_percentage] > 5
                                'bg-warning'
                              else
                                'bg-danger'
                              end %>">
                          <%= number_with_precision(policy[:profit_percentage], precision: 2) %>%
                        </span>
                      </td>
                      <td class="text-end">
                        <%= indian_currency(policy[:company_expenses]) %>
                      </td>
                      <td>
                        <span class="<%= policy[:sub_agent_name] == 'Direct' ? 'badge bg-info' : '' %>">
                          <%= policy[:sub_agent_name] %>
                        </span>
                      </td>
                      <td><%= policy[:created_at]&.strftime('%d/%m/%Y') %></td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="14" class="text-center py-4">
                      <div class="text-muted">
                        <i class="fas fa-search fa-3x mb-3"></i>
                        <p>No policies with profit found for the selected criteria.</p>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
          <% if @policy_data.respond_to?(:total_pages) && @policy_data.total_pages > 1 %>
            <div class="d-flex justify-content-between align-items-center mt-4">
              <div class="text-muted">
                Showing <%= (@policy_data.current_page - 1) * @policy_data.limit_value + 1 %> to
                <%= [@policy_data.current_page * @policy_data.limit_value, @policy_data.total_count].min %>
                of <%= @policy_data.total_count %> entries
              </div>
              <%= paginate @policy_data %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exportModalLabel">
          <i class="bi bi-download me-2"></i>Export Profit Report
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with url: "", method: :post, id: "exportForm", class: "needs-validation", novalidate: true do |form| %>
          <!-- Hidden field for default CSV format -->
          <input type="hidden" name="export_format" value="csv">

          <!-- Column Selection -->
          <div class="mb-4">
            <h6>Select Columns to Export</h6>
            <div class="mb-3">
              <button type="button" class="btn btn-sm btn-outline-primary me-2" onclick="selectAllColumns()">Select All</button>
              <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deselectAllColumns()">Deselect All</button>
            </div>
            <div class="row g-3">
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_number" id="col_policy_number" checked>
                  <label class="form-check-label" for="col_policy_number">Policy Number</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_type" id="col_policy_type" checked>
                  <label class="form-check-label" for="col_policy_type">Policy Type</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="customer_name" id="col_customer_name" checked>
                  <label class="form-check-label" for="col_customer_name">Customer Name</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="insurance_company" id="col_insurance_company" checked>
                  <label class="form-check-label" for="col_insurance_company">Insurance Company</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_holder" id="col_policy_holder">
                  <label class="form-check-label" for="col_policy_holder">Policy Holder</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="start_date" id="col_start_date">
                  <label class="form-check-label" for="col_start_date">Start Date</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="end_date" id="col_end_date">
                  <label class="form-check-label" for="col_end_date">End Date</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="premium_amount" id="col_premium_amount" checked>
                  <label class="form-check-label" for="col_premium_amount">Premium Amount</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="net_premium" id="col_net_premium" checked>
                  <label class="form-check-label" for="col_net_premium">Net Premium</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="profit_amount" id="col_profit_amount" checked>
                  <label class="form-check-label" for="col_profit_amount">Profit Amount</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="profit_percentage" id="col_profit_percentage" checked>
                  <label class="form-check-label" for="col_profit_percentage">Profit Percentage</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="company_expenses" id="col_company_expenses">
                  <label class="form-check-label" for="col_company_expenses">Company Expenses</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="sub_agent_name" id="col_sub_agent_name">
                  <label class="form-check-label" for="col_sub_agent_name">Sub Agent</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="created_at" id="col_created_at">
                  <label class="form-check-label" for="col_created_at">Created Date</label>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="performExport()">
          <i class="bi bi-download me-2"></i>Export Report
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Export Functionality -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Export button click handler
  document.getElementById('exportBtn').addEventListener('click', function() {
    const exportModal = new bootstrap.Modal(document.getElementById('exportModal'));
    exportModal.show();
  });
});

function selectAllColumns() {
  const checkboxes = document.querySelectorAll('input[name="columns[]"]');
  checkboxes.forEach(checkbox => checkbox.checked = true);
}

function deselectAllColumns() {
  const checkboxes = document.querySelectorAll('input[name="columns[]"]');
  checkboxes.forEach(checkbox => checkbox.checked = false);
}

function performExport() {
  const selectedColumns = document.querySelectorAll('input[name="columns[]"]:checked');

  // Check if at least one column is selected
  if (selectedColumns.length === 0) {
    alert('Please select at least one column to export.');
    return;
  }

  // Get current URL parameters to preserve filters
  const urlParams = new URLSearchParams(window.location.search);

  // Build export URL for CSV format (default)
  const exportUrl = '<%= export_csv_admin_reports_profit_reports_path %>';

  // Build URL with parameters for GET request
  const exportUrlWithParams = new URL(exportUrl, window.location.origin);

  // Add filter parameters
  urlParams.forEach((value, key) => {
    if (key !== 'page') { // Don't include page in export
      exportUrlWithParams.searchParams.append(key, value);
    }
  });

  // Add selected columns
  selectedColumns.forEach(checkbox => {
    exportUrlWithParams.searchParams.append('columns[]', checkbox.value);
  });

  // Perform the export by redirecting to the CSV download URL
  window.location.href = exportUrlWithParams.toString();

  // Close modal
  const exportModal = bootstrap.Modal.getInstance(document.getElementById('exportModal'));
  exportModal.hide();
}
</script>

<style>
.card {
  box-shadow: 0 0.15rem 1.75rem 0 rgba(33, 40, 50, 0.15);
}

.table th {
  border-top: none;
  font-weight: 600;
  font-size: 0.85rem;
}

.badge {
  font-size: 0.75rem;
}

.text-muted {
  font-size: 0.8rem;
}

@media (max-width: 768px) {
  .table-responsive {
    font-size: 0.8rem;
  }

  .card-body .row .col-md-3,
  .card-body .row .col-md-2,
  .card-body .row .col-md-1 {
    margin-bottom: 1rem;
  }
}

/* Spinning loader */
.spin {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
</style>