<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Profit Report</title>
</head>
<body>
  <div class="header">
    <h1>Profit Report</h1>
    <div class="subtitle">Generated on <%= Date.current.strftime('%B %d, %Y') %></div>
  </div>

  <div class="report-info">
    <div class="info-row">
      <span class="label">Report Date:</span> <%= Date.current.strftime('%d/%m/%Y') %>
    </div>
    <div class="info-row">
      <span class="label">Total Policies:</span> <%= @policy_data.length %>
    </div>
    <div class="info-row">
      <span class="label">Period:</span>
      <%= @start_date&.strftime('%d/%m/%Y') || '30 days ago' %> to
      <%= @end_date&.strftime('%d/%m/%Y') || Date.current.strftime('%d/%m/%Y') %>
    </div>
  </div>

  <% if @policy_data.any? %>
    <div class="summary-cards">
      <div class="summary-card">
        <span class="number"><%= @policy_data.length %></span>
        <span class="label">Total Policies</span>
      </div>
      <div class="summary-card">
        <span class="number"><%= indian_currency(@policy_data.sum { |p| p[:profit_amount] || 0 }) %></span>
        <span class="label">Total Profit</span>
      </div>
      <div class="summary-card">
        <span class="number"><%= indian_currency(@policy_data.sum { |p| p[:premium_amount] || 0 }) %></span>
        <span class="label">Total Premium</span>
      </div>
      <div class="summary-card">
        <span class="number"><%= number_with_precision(@policy_data.empty? ? 0 : (@policy_data.sum { |p| p[:profit_percentage] || 0 } / @policy_data.size), precision: 2) %>%</span>
        <span class="label">Average Profit %</span>
      </div>
    </div>

    <table class="table">
      <thead>
        <tr>
          <% (@selected_columns || %w[policy_number policy_type customer_name insurance_company premium_amount net_premium profit_amount profit_percentage company_expenses sub_agent_name created_at]).each do |column| %>
            <th>
              <%= case column
                  when 'policy_number' then 'Policy Number'
                  when 'policy_type' then 'Type'
                  when 'customer_name' then 'Customer'
                  when 'insurance_company' then 'Insurance Company'
                  when 'policy_holder' then 'Policy Holder'
                  when 'start_date' then 'Start Date'
                  when 'end_date' then 'End Date'
                  when 'premium_amount' then 'Premium (Rs.)'
                  when 'net_premium' then 'Net Premium (Rs.)'
                  when 'profit_amount' then 'Profit (Rs.)'
                  when 'profit_percentage' then 'Profit %'
                  when 'company_expenses' then 'Expenses (Rs.)'
                  when 'sub_agent_name' then 'Sub Agent'
                  when 'created_at' then 'Created Date'
                  else column.humanize
                  end %>
            </th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% @policy_data.each do |policy| %>
          <tr>
            <% (@selected_columns || %w[policy_number policy_type customer_name insurance_company premium_amount net_premium profit_amount profit_percentage company_expenses sub_agent_name created_at]).each do |column| %>
              <td class="<%= 'currency' if %w[premium_amount net_premium profit_amount company_expenses].include?(column) %>
                         <%= 'percentage' if column == 'profit_percentage' %>
                         <%= 'profit-amount' if column == 'profit_amount' && (policy[:profit_amount] || 0) > 0 %>
                         <%= 'profit-negative' if column == 'profit_amount' && (policy[:profit_amount] || 0) < 0 %>">
                <% case column %>
                <% when 'policy_type' %>
                  <span class="policy-type <%= policy[:policy_type].downcase %>">
                    <%= policy[:policy_type] %>
                  </span>
                <% when 'start_date', 'end_date' %>
                  <%= policy[column.to_sym]&.strftime('%d/%m/%Y') || 'N/A' %>
                <% when 'premium_amount', 'net_premium', 'profit_amount', 'company_expenses' %>
                  <%= indian_currency(policy[column.to_sym] || 0) %>
                <% when 'profit_percentage' %>
                  <%= number_with_precision(policy[:profit_percentage] || 0, precision: 2) %>%
                <% when 'sub_agent_name' %>
                  <%= policy[:sub_agent_name] == 'Direct' ? 'Direct' : policy[:sub_agent_name] %>
                <% when 'created_at' %>
                  <%= policy[:created_at]&.strftime('%d/%m/%Y') || 'N/A' %>
                <% else %>
                  <%= policy[column.to_sym] || 'N/A' %>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="no-data">
      <h3>No profit data available</h3>
      <p>There are no policies with profit data for the selected criteria.</p>
    </div>
  <% end %>

  <div class="footer">
    <p>This report was generated automatically by the DrWise Insurance Management System</p>
    <p>Report generated on <%= Time.current.strftime('%d/%m/%Y at %I:%M %p') %></p>
  </div>
</body>
</html>

<style>
  body {
    font-family: Arial, sans-serif;
    font-size: 12px;
    line-height: 1.3;
    margin: 0;
    padding: 20px;
    color: #333;
  }
  .header {
    text-align: center;
    margin-bottom: 30px;
    border-bottom: 2px solid #28a745;
    padding-bottom: 15px;
  }
  .header h1 {
    margin: 0;
    color: #28a745;
    font-size: 24px;
    font-weight: bold;
  }
  .header .subtitle {
    margin: 5px 0 0 0;
    color: #666;
    font-size: 14px;
  }
  .report-info {
    margin-bottom: 20px;
    background: #f8f9fa;
    padding: 15px;
    border-radius: 5px;
  }
  .report-info .info-row {
    display: inline-block;
    margin-right: 30px;
    margin-bottom: 5px;
  }
  .report-info .label {
    font-weight: bold;
    color: #495057;
  }
  .summary-cards {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20px;
    gap: 15px;
  }
  .summary-card {
    flex: 1;
    background: #f8f9fa;
    padding: 15px;
    border-radius: 5px;
    text-align: center;
    border-left: 4px solid #28a745;
  }
  .summary-card .number {
    font-size: 20px;
    font-weight: bold;
    color: #28a745;
    display: block;
    margin-bottom: 5px;
  }
  .summary-card .label {
    font-size: 12px;
    color: #666;
  }
  .table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
  }
  .table th {
    background-color: #28a745;
    color: white;
    padding: 12px 8px;
    text-align: left;
    font-weight: bold;
    border: 1px solid #ddd;
    font-size: 11px;
  }
  .table td {
    padding: 10px 8px;
    border: 1px solid #ddd;
    font-size: 11px;
    vertical-align: top;
  }
  .table tr:nth-child(even) {
    background-color: #f8f9fa;
  }
  .currency {
    text-align: right;
    font-weight: 500;
  }
  .profit-amount {
    color: #28a745;
    font-weight: bold;
  }
  .profit-negative {
    color: #dc3545;
    font-weight: bold;
  }
  .percentage {
    text-align: center;
    font-weight: 500;
  }
  .policy-type {
    display: inline-block;
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 10px;
    font-weight: bold;
    text-transform: uppercase;
  }
  .health { background: #e7f3ff; color: #0066cc; }
  .motor { background: #fff0e6; color: #cc6600; }
  .life { background: #e6ffe6; color: #006600; }
  .other { background: #f0f0f0; color: #666666; }
  .no-data {
    text-align: center;
    padding: 40px;
    color: #666;
    font-style: italic;
  }
  .footer {
    margin-top: 30px;
    text-align: center;
    font-size: 10px;
    color: #666;
    border-top: 1px solid #ddd;
    padding-top: 15px;
  }
</style>