<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Payment Due Report</h2>
    <p class="text-muted mb-0">Track outstanding payments and overdue accounts</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to admin_reports_payment_due_reports_path(format: :csv, **params.permit!),
                class: "btn btn-success" do %>
      <i class="bi bi-file-earmark-excel me-1"></i>Export CSV
    <% end %>
  </div>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Due Amount</h6>
            <h3 class="mb-0 text-warning"><%= indian_currency(@statistics[:total_due_amount] || 0) %></h3>
          </div>
          <div class="bg-warning bg-opacity-10 rounded p-3">
            <i class="bi bi-credit-card-fill text-warning fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Policies</h6>
            <h3 class="mb-0 text-primary"><%= number_with_delimiter(@statistics[:total_policies] || 0) %></h3>
          </div>
          <div class="bg-primary bg-opacity-10 rounded p-3">
            <i class="bi bi-list-check text-primary fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Overdue Count</h6>
            <h3 class="mb-0 text-danger"><%= @statistics[:overdue_count] || 0 %></h3>
          </div>
          <div class="bg-danger bg-opacity-10 rounded p-3">
            <i class="bi bi-clock text-danger fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Due in 7 Days</h6>
            <h3 class="mb-0 text-info"><%= @statistics[:due_ranges]['Due in 7 days'] || 0 %></h3>
          </div>
          <div class="bg-info bg-opacity-10 rounded p-3">
            <i class="bi bi-calendar-check text-info fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="text-center py-5">
  <i class="bi bi-credit-card-fill fs-1 text-muted d-block mb-3"></i>
  <h5 class="text-muted">Payment Due Report</h5>
  <p class="text-muted mb-3">Complete implementation with filters and data display coming soon!</p>
</div>