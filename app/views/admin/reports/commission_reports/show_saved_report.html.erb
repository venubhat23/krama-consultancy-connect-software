<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @report.name %></h2>
    <p class="text-muted mb-0">
      Generated on <%= @report.created_at.strftime('%d %b %Y at %I:%M %p') %>
      <% if @report.created_by %>
        by <%= @report.created_by.full_name %>
      <% end %>
    </p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to export_csv_admin_reports_commission_report_path(@report),
                class: "btn btn-success" do %>
      <i class="bi bi-file-earmark-excel me-1"></i>Export CSV
    <% end %>

    <%= link_to export_pdf_admin_reports_commission_report_path(@report),
                class: "btn btn-danger" do %>
      <i class="bi bi-file-earmark-pdf me-1"></i>Export PDF
    <% end %>

    <%= link_to admin_reports_commission_reports_path,
                class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back to Reports
    <% end %>
  </div>
</div>

<!-- Report Filters Info -->
<% if @report.filters %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <h5 class="mb-3">Report Filters</h5>
      <div class="row">
        <div class="col-md-3">
          <small class="text-muted d-block">Date Range</small>
          <% if @report.filters['start_date'] && @report.filters['end_date'] %>
            <%= Date.parse(@report.filters['start_date'].to_s).strftime('%d %b %Y') %> -
            <%= Date.parse(@report.filters['end_date'].to_s).strftime('%d %b %Y') %>
          <% else %>
            All Time
          <% end %>
        </div>
        <% if @report.filters['policy_type'].present? %>
          <div class="col-md-3">
            <small class="text-muted d-block">Policy Type</small>
            <%= @report.filters['policy_type'].humanize %>
          </div>
        <% end %>
        <% if @report.filters['payout_to'].present? %>
          <div class="col-md-3">
            <small class="text-muted d-block">Recipient Type</small>
            <%= @report.filters['payout_to'].humanize %>
          </div>
        <% end %>
        <% if @report.filters['status'].present? %>
          <div class="col-md-3">
            <small class="text-muted d-block">Payment Status</small>
            <%= @report.filters['status'].humanize %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<!-- Report Content -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Report Details</h5>
  </div>
  <div class="card-body p-0">
    <%= render partial: 'preview_table' %>
  </div>
</div>