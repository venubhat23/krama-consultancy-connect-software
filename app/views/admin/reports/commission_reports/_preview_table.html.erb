<% if @preview_data && @preview_data.any? %>
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="bg-light">
        <tr>
          <th class="border-0">Policy Details</th>
          <th class="border-0">Customer</th>
          <th class="border-0">Premium</th>
          <th class="border-0">Commission Generated</th>
          <th class="border-0">Main Agent Commission</th>
          <th class="border-0">Transfer Status</th>
          <th class="border-0">Commission Breakdown</th>
        </tr>
      </thead>
      <tbody>
        <% @preview_data.each do |policy| %>
          <tr>
            <!-- Policy Details -->
            <td>
              <div>
                <h6 class="mb-1"><%= policy[:policy_number] %></h6>
                <span class="badge bg-<%= policy[:policy_type] == 'health' ? 'success' : (policy[:policy_type] == 'motor' ? 'warning' : 'info') %>">
                  <%= policy[:policy_type]&.capitalize %>
                </span>
              </div>
            </td>

            <!-- Customer -->
            <td>
              <div>
                <h6 class="mb-1"><%= policy[:customer_name] %></h6>
                <small class="text-muted d-block">
                  <%= policy[:insurance_company] %>
                </small>
                <% if policy[:lead_id] %>
                  <small class="text-muted">
                    Lead: <%= policy[:lead_id] %>
                  </small>
                <% end %>
              </div>
            </td>

            <!-- Premium -->
            <td>
              <strong><%= indian_currency(policy[:premium_amount] || 0) %></strong>
            </td>

            <!-- Commission Generated -->
            <td>
              <strong class="text-success">
                <%= indian_currency(policy[:total_commission] || 0) %>
              </strong>
            </td>

            <!-- Main Agent Commission -->
            <td>
              <div>
                <div>Main Agent:
                  <strong><%= indian_currency(policy[:main_agent_amount] || 0) %></strong>
                  <small class="text-muted">(<%= policy[:main_agent_percentage] || 0 %>%)</small>
                </div>
                <% if policy[:main_agent_status] == 'pending' %>
                  <button class="btn btn-sm btn-outline-success mt-1">
                    Mark as Paid
                  </button>
                <% else %>
                  <span class="badge bg-success mt-1">Paid</span>
                <% end %>
              </div>
            </td>

            <!-- Transfer Status -->
            <td>
              <div>
                <div class="mb-1">
                  <span class="<%= policy[:paid_count] == policy[:total_recipients] ? 'text-success' : 'text-warning' %>">
                    Paid: <%= policy[:paid_count] || 0 %>/<%= policy[:total_recipients] || 0 %>
                  </span>
                </div>
                <div>
                  Amount: <strong><%= indian_currency(policy[:paid_amount] || 0) %></strong>
                </div>
              </div>
            </td>

            <!-- Commission Breakdown -->
            <td>
              <div class="small">
                <% if policy[:affiliate_amount] && policy[:affiliate_amount] > 0 %>
                  <div>Affiliate:
                    <strong><%= indian_currency(policy[:affiliate_amount]) %></strong>
                    <small class="text-muted">(<%= policy[:affiliate_percentage] %>%)</small>
                  </div>
                <% end %>
                <% if policy[:ambassador_amount] && policy[:ambassador_amount] > 0 %>
                  <div>Ambassador:
                    <strong><%= indian_currency(policy[:ambassador_amount]) %></strong>
                    <small class="text-muted">(<%= policy[:ambassador_percentage] %>%)</small>
                  </div>
                <% end %>
                <% if policy[:investor_amount] && policy[:investor_amount] > 0 %>
                  <div>Investor:
                    <strong><%= indian_currency(policy[:investor_amount]) %></strong>
                    <small class="text-muted">(<%= policy[:investor_percentage] %>%)</small>
                  </div>
                <% end %>
                <% if policy[:company_amount] && policy[:company_amount] > 0 %>
                  <div>Company:
                    <strong><%= indian_currency(policy[:company_amount]) %></strong>
                    <small class="text-muted">(<%= policy[:company_percentage] %>%)</small>
                  </div>
                <% end %>
                <% if policy[:distributor_amount] && policy[:distributor_amount] > 0 %>
                  <div>Distributor:
                    <strong><%= indian_currency(policy[:distributor_amount]) %></strong>
                    <small class="text-muted">(<%= policy[:distributor_percentage] %>%)</small>
                  </div>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Summary Statistics -->
  <div class="card-footer bg-light">
    <div class="row text-center">
      <div class="col-md-3">
        <h6 class="text-muted mb-1">Total Policies</h6>
        <h4 class="mb-0"><%= @preview_data.size %></h4>
      </div>
      <div class="col-md-3">
        <h6 class="text-muted mb-1">Total Premium</h6>
        <h4 class="mb-0 text-primary">
          <%= indian_currency(@preview_data.sum { |p| p[:premium_amount] || 0 }) %>
        </h4>
      </div>
      <div class="col-md-3">
        <h6 class="text-muted mb-1">Total Commission</h6>
        <h4 class="mb-0 text-success">
          <%= indian_currency(@preview_data.sum { |p| p[:total_commission] || 0 }) %>
        </h4>
      </div>
      <div class="col-md-3">
        <h6 class="text-muted mb-1">Total Paid</h6>
        <h4 class="mb-0 text-info">
          <%= indian_currency(@preview_data.sum { |p| p[:paid_amount] || 0 }) %>
        </h4>
      </div>
    </div>
  </div>
<% else %>
  <div class="text-center py-5">
    <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
    <h5 class="text-muted">No data found</h5>
    <p class="text-muted mb-0">
      No commission data found for the selected filters.
    </p>
  </div>
<% end %>