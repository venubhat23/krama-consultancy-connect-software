<!-- Lead Reports Redirect Notice -->
<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
        <div class="text-center">
          <div class="card border-0 shadow-sm" style="max-width: 500px;">
            <div class="card-body p-5">
              <i class="bi bi-arrow-right-circle text-primary fs-1 mb-3"></i>
              <h4 class="text-primary mb-3">Lead Reports Moved</h4>
              <p class="text-muted mb-4">
                The Lead Reports feature has been moved to a new location with enhanced functionality.
                Click below to access the new comprehensive Lead Reports system.
              </p>
              <%= link_to admin_reports_lead_reports_path, class: "btn btn-primary btn-lg" do %>
                <i class="bi bi-file-earmark-text me-2"></i>
                Go to Lead Reports
              <% end %>
              <div class="mt-3">
                <small class="text-muted">
                  New features: Advanced filtering, CSV export, saved reports, and more!
                </small>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Auto-redirect after 3 seconds
setTimeout(function() {
  window.location.href = '<%= admin_reports_lead_reports_path %>';
}, 3000);
</script>