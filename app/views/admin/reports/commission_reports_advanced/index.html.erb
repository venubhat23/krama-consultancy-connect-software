<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <!-- Header Section -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2 class="mb-0">
            <i class="bi bi-graph-up-arrow text-primary me-2"></i>
            Commission Reports
          </h2>
          <p class="text-muted mb-0">Comprehensive commission analysis with advanced filtering</p>
        </div>
        <div>
          <button type="button" class="btn btn-success" id="exportBtn">
            <i class="bi bi-download me-2"></i>Export
          </button>
        </div>
      </div>

      <!-- Filters Section -->
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <h5 class="card-title mb-3">
            <i class="bi bi-funnel me-2"></i>Filters
          </h5>

          <%= form_with url: admin_reports_commission_reports_advanced_index_path, method: :get, class: "row g-3", id: "filtersForm", local: true do |form| %>
            <!-- Date Range -->
            <div class="col-md-3">
              <label class="form-label fw-bold">Start Date</label>
              <%= form.date_field :start_date, value: @start_date, class: "form-control" %>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">End Date</label>
              <%= form.date_field :end_date, value: @end_date, class: "form-control" %>
            </div>

            <!-- Policy Type -->
            <div class="col-md-3">
              <label class="form-label fw-bold">Policy Type</label>
              <%= form.select :policy_type, options_for_select([
                ['All Types', 'all'],
                ['Health Insurance', 'health'],
                ['Life Insurance', 'life'],
                ['Motor Insurance', 'motor'],
                ['Other Insurance', 'other']
              ], @policy_type), {}, { class: "form-select" } %>
            </div>

            <!-- Status -->
            <div class="col-md-3">
              <label class="form-label fw-bold">Status</label>
              <%= form.select :status, options_for_select([
                ['All Status', 'all'],
                ['Pending', 'pending'],
                ['Paid', 'paid'],
                ['Processing', 'processing']
              ], @status), {}, { class: "form-select" } %>
            </div>

            <!-- Sub Agent -->
            <div class="col-md-4">
              <label class="form-label fw-bold">Affiliate</label>
              <%= form.select :sub_agent_id, options_from_collection_for_select(@sub_agents, :id, :full_name, @sub_agent_id),
                              { prompt: 'All Affiliates' }, { class: "form-select" } %>
            </div>

            <!-- Distributor -->
            <div class="col-md-4">
              <label class="form-label fw-bold">Ambassador</label>
              <%= form.select :distributor_id, options_from_collection_for_select(@distributors, :id, :full_name, @distributor_id),
                              { prompt: 'All Ambassadors' }, { class: "form-select" } %>
            </div>

            <!-- Insurance Company -->
            <div class="col-md-4">
              <label class="form-label fw-bold">Insurance Company</label>
              <%= form.text_field :insurance_company, value: @insurance_company, placeholder: "Company name...", class: "form-control" %>
            </div>

            <!-- Filter Actions -->
            <div class="col-12">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-2"></i>Apply Filters
              </button>
              <%= link_to "Clear Filters", admin_reports_commission_reports_advanced_index_path, class: "btn btn-outline-secondary ms-2" %>
            </div>
          <% end %>
        </div>
      </div>


      <!-- Data Table -->
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">
            <i class="bi bi-table me-2"></i>Commission Data
            <small class="text-muted ms-2">(Latest records first)</small>
          </h5>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0" id="commissionTable">
              <thead class="table-light">
                <tr>
                  <th scope="col">Customer Name</th>
                  <th scope="col">Policy Type</th>
                  <th scope="col">Policy Number</th>
                  <th scope="col">Insurance Company</th>
                  <th scope="col">Commission</th>
                  <th scope="col">TDS</th>
                  <th scope="col">Net Amount</th>
                  <th scope="col">Status</th>
                  <th scope="col">Date</th>
                  <th scope="col">Affiliate</th>
                  <th scope="col">Ambassador</th>
                </tr>
              </thead>
              <tbody>
                <% if @commission_data.present? %>
                  <% @commission_data.each do |commission| %>
                    <tr>
                      <td>
                        <strong><%= commission.customer_name %></strong>
                      </td>
                      <td>
                        <span class="badge bg-primary"><%= commission.policy_type&.titleize %></span>
                      </td>
                      <td>
                        <code><%= commission.policy_number || '-' %></code>
                      </td>
                      <td>
                        <%= commission.policy&.insurance_company_name || '-' %>
                      </td>
                      <td class="text-end">
                        <strong class="text-success"><%= indian_currency(commission.payout_amount.round(2)) %></strong>
                      </td>
                      <td class="text-end">
                        <span class="text-warning"><%= indian_currency((commission.tds_amount || 0).round(2)) %></span>
                      </td>
                      <td class="text-end">
                        <strong class="text-primary"><%= indian_currency(commission.net_amount.round(2)) %></strong>
                      </td>
                      <td>
                        <% case commission.status&.downcase %>
                        <% when 'paid' %>
                          <span class="badge bg-success"><%= commission.status.titleize %></span>
                        <% when 'pending' %>
                          <span class="badge bg-warning"><%= commission.status.titleize %></span>
                        <% when 'processing' %>
                          <span class="badge bg-info"><%= commission.status.titleize %></span>
                        <% else %>
                          <span class="badge bg-secondary"><%= commission.status&.titleize || 'Unknown' %></span>
                        <% end %>
                      </td>
                      <td>
                        <small><%= commission.created_at.strftime('%d/%m/%Y') %></small>
                      </td>
                      <td>
                        <small><%= get_sub_agent_name(commission) || '-' %></small>
                      </td>
                      <td>
                        <small><%= get_distributor_name(commission) || '-' %></small>
                      </td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="11" class="text-center py-4">
                      <div class="text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No commission data found for the selected criteria.
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Pagination -->
        <% if @commission_data.respond_to?(:current_page) && @commission_data.total_pages > 1 %>
          <div class="card-footer">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <small class="text-muted">
                  Page <%= @commission_data.current_page %> of <%= @commission_data.total_pages %>
                  (<%= @commission_data.total_count %> total entries)
                </small>
              </div>
              <div>
                <%= paginate @commission_data, theme: 'twitter-bootstrap-4' %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exportModalLabel">
          <i class="bi bi-download me-2"></i>Export Commission Report
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with url: "", method: :post, id: "exportForm", class: "needs-validation", novalidate: true do |form| %>
          <!-- Column Selection -->
          <div class="mb-4">
            <h6>Select Columns to Export</h6>
            <div class="row g-3">
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="customer_name" id="col_customer_name" checked>
                  <label class="form-check-label" for="col_customer_name">Customer Name</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_type" id="col_policy_type" checked>
                  <label class="form-check-label" for="col_policy_type">Policy Type</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_number" id="col_policy_number" checked>
                  <label class="form-check-label" for="col_policy_number">Policy Number</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="insurance_company" id="col_insurance_company" checked>
                  <label class="form-check-label" for="col_insurance_company">Insurance Company</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="payout_amount" id="col_payout_amount" checked>
                  <label class="form-check-label" for="col_payout_amount">Commission Amount</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="tds_amount" id="col_tds_amount" checked>
                  <label class="form-check-label" for="col_tds_amount">TDS Amount</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="net_amount" id="col_net_amount" checked>
                  <label class="form-check-label" for="col_net_amount">Net Amount</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="status" id="col_status" checked>
                  <label class="form-check-label" for="col_status">Status</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="created_at" id="col_created_at" checked>
                  <label class="form-check-label" for="col_created_at">Date</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="sub_agent_name" id="col_sub_agent_name">
                  <label class="form-check-label" for="col_sub_agent_name">Affiliate Name</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="distributor_name" id="col_distributor_name">
                  <label class="form-check-label" for="col_distributor_name">Ambassador Name</label>
                </div>
              </div>
            </div>
            <div class="mt-2">
              <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAllColumns()">Select All</button>
              <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deselectAllColumns()">Deselect All</button>
            </div>
          </div>
        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="performExport()">
          <i class="bi bi-download me-2"></i>Export
        </button>
      </div>
    </div>
  </div>
</div>

<!-- JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Export button click handler
  document.getElementById('exportBtn').addEventListener('click', function() {
    const exportModal = new bootstrap.Modal(document.getElementById('exportModal'));
    exportModal.show();
  });
});

function selectAllColumns() {
  const checkboxes = document.querySelectorAll('input[name="columns[]"]');
  checkboxes.forEach(checkbox => checkbox.checked = true);
}

function deselectAllColumns() {
  const checkboxes = document.querySelectorAll('input[name="columns[]"]');
  checkboxes.forEach(checkbox => checkbox.checked = false);
}

function performExport() {
  const form = document.getElementById('exportForm');
  const selectedColumns = document.querySelectorAll('input[name="columns[]"]:checked');
  const exportBtn = document.querySelector('#exportModal .btn-primary');

  // Check if at least one column is selected
  if (selectedColumns.length === 0) {
    alert('Please select at least one column to export.');
    return;
  }

  // Show loader
  const originalBtnText = exportBtn.innerHTML;
  exportBtn.disabled = true;
  exportBtn.innerHTML = '<i class="bi bi-arrow-clockwise me-2 spin"></i>Exporting...';

  function resetButton() {
    exportBtn.disabled = false;
    exportBtn.innerHTML = originalBtnText;
  }

  // Get current URL parameters to preserve filters
  const urlParams = new URLSearchParams(window.location.search);

  // Build export URL (CSV only)
  const exportUrl = '<%= export_csv_admin_reports_commission_reports_advanced_index_path %>';

  // Create form data
  const formData = new FormData();

  // Add filter parameters
  urlParams.forEach((value, key) => {
    if (key !== 'page') { // Don't include page in export
      formData.append(key, value);
    }
  });

  // Add selected columns
  selectedColumns.forEach(checkbox => {
    formData.append('columns[]', checkbox.value);
  });

  // Add CSRF token
  const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
  formData.append('authenticity_token', csrfToken);

  // Submit form
  fetch(exportUrl, {
    method: 'POST',
    body: formData,
    headers: {
      'X-Requested-With': 'XMLHttpRequest'
    }
  })
  .then(response => {
    console.log('Response status:', response.status);
    console.log('Response headers:', Object.fromEntries(response.headers.entries()));

    if (response.ok) {
      return response.blob();
    }

    // Try to get error message from response
    return response.text().then(text => {
      throw new Error(`Export failed (${response.status}): ${text.substring(0, 200)}`);
    });
  })
  .then(blob => {
    // Download the file
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `Commission_Report_${new Date().toISOString().split('T')[0]}.csv`;
    document.body.appendChild(a);
    a.click();
    window.URL.revokeObjectURL(url);
    document.body.removeChild(a);

    // Reset button and close modal
    resetButton();
    const exportModal = bootstrap.Modal.getInstance(document.getElementById('exportModal'));
    exportModal.hide();
  })
  .catch(error => {
    console.error('Export error:', error);
    alert('Export failed. Please try again.');
    resetButton();
  });
}
</script>

<style>
.bg-gradient-primary {
  background: linear-gradient(135deg, #007bff, #0056b3);
}
.bg-gradient-success {
  background: linear-gradient(135deg, #28a745, #1e7e34);
}
.bg-gradient-warning {
  background: linear-gradient(135deg, #ffc107, #d39e00);
}
.bg-gradient-info {
  background: linear-gradient(135deg, #17a2b8, #117a8b);
}

/* Spinning loader */
.spin {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
</style>