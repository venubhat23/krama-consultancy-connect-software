<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <!-- Header Section -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2 class="mb-0">
            <i class="bi bi-exclamation-triangle text-danger me-2"></i>
            Expired Insurance Reports
          </h2>
          <p class="text-muted mb-0">Comprehensive expired policy analysis with advanced filtering</p>
        </div>
        <div class="d-flex gap-2">
          <%= link_to generate_admin_reports_expired_insurance_reports_path, class: "btn btn-primary" do %>
            <i class="bi bi-plus-lg me-2"></i>Generate Report
          <% end %>
          <button type="button" class="btn btn-success" id="exportBtn">
            <i class="bi bi-download me-2"></i>Export CSV
          </button>
        </div>
      </div>

      <!-- Filters Section -->
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <h5 class="card-title mb-3">
            <i class="bi bi-funnel me-2"></i>Filters
          </h5>

          <%= form_with url: admin_reports_expired_insurance_reports_path, method: :get, class: "row g-3", id: "filtersForm", local: true do |form| %>
            <!-- Date Range -->
            <div class="col-md-3">
              <label class="form-label fw-bold">Start Date</label>
              <%= form.date_field :start_date, value: @start_date, class: "form-control" %>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">End Date</label>
              <%= form.date_field :end_date, value: @end_date, class: "form-control" %>
            </div>

            <!-- Policy Type -->
            <div class="col-md-3">
              <label class="form-label fw-bold">Policy Type</label>
              <%= form.select :policy_type, options_for_select([
                ['All Types', 'all'],
                ['Health Insurance', 'health'],
                ['Life Insurance', 'life'],
                ['Motor Insurance', 'motor'],
                ['Other Insurance', 'other']
              ], @policy_type), {}, { class: "form-select" } %>
            </div>

            <!-- Insurance Company -->
            <div class="col-md-3">
              <label class="form-label fw-bold">Insurance Company</label>
              <%= form.text_field :insurance_company, value: @insurance_company, placeholder: "Company name...", class: "form-control" %>
            </div>

            <!-- Filter Actions -->
            <div class="col-12">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-2"></i>Apply Filters
              </button>
              <%= link_to "Clear Filters", admin_reports_expired_insurance_reports_path, class: "btn btn-outline-secondary ms-2" %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Summary Cards -->
      <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-3">
          <div class="card h-100 border-0 shadow-sm bg-light">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <h6 class="text-muted mb-2">Total Expired</h6>
                  <h3 class="mb-0 text-dark"><%= number_with_delimiter(@total_expired || 0) %></h3>
                </div>
                <div class="bg-danger text-white rounded p-3">
                  <i class="bi bi-exclamation-triangle fs-4"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
          <div class="card h-100 border-0 shadow-sm bg-light">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <h6 class="text-muted mb-2">Premium Lost</h6>
                  <h3 class="mb-0 text-dark"><%= indian_currency((@total_premium_lost || 0).round(2)) %></h3>
                </div>
                <div class="bg-warning text-white rounded p-3">
                  <i class="bi bi-currency-rupee fs-4"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
          <div class="card h-100 border-0 shadow-sm bg-light">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <h6 class="text-muted mb-2">Sum Insured Lost</h6>
                  <h3 class="mb-0 text-dark"><%= indian_currency((@total_sum_insured_lost || 0).round(2)) %></h3>
                </div>
                <div class="bg-info text-white rounded p-3">
                  <i class="bi bi-shield-x fs-4"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
          <div class="card h-100 border-0 shadow-sm bg-light">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <h6 class="text-muted mb-2">Showing Results</h6>
                  <h3 class="mb-0 text-dark"><%= @policy_count || 0 %></h3>
                </div>
                <div class="bg-secondary text-white rounded p-3">
                  <i class="bi bi-list-ul fs-4"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Data Table -->
      <div class="card shadow-sm">
        <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Expired Policies</h5>
          <small class="text-muted">
            <% if @expired_data && @expired_data.respond_to?(:total_count) %>
              Showing <%= @expired_data.total_count %> expired policies
            <% end %>
          </small>
        </div>
        <div class="card-body p-0">
          <% if @expired_data && @expired_data.any? %>
            <div class="table-responsive">
              <table class="table table-hover mb-0" id="expiredPoliciesTable">
                <thead class="table-dark">
                  <tr>
                    <th scope="col">Policy Number</th>
                    <th scope="col">Type</th>
                    <th scope="col">Customer</th>
                    <th scope="col">Insurance Company</th>
                    <th scope="col">Policy Holder</th>
                    <th scope="col">Start Date</th>
                    <th scope="col">End Date</th>
                    <th scope="col">Days Expired</th>
                    <th scope="col">Premium Amount</th>
                    <th scope="col">Sum Insured</th>
                    <th scope="col">Payment Mode</th>
                    <th scope="col">Sub Agent</th>
                  </tr>
                </thead>
                <tbody>
                  <% @expired_data.each do |policy| %>
                    <tr>
                      <td>
                        <strong><%= policy[:policy_number] %></strong>
                        <% if policy[:lead_id].present? %>
                          <br><small class="text-muted">Lead: <%= policy[:lead_id] %></small>
                        <% end %>
                      </td>
                      <td>
                        <span class="badge
                          <%= case policy[:policy_type]
                              when 'Health' then 'bg-success'
                              when 'Life' then 'bg-primary'
                              when 'Motor' then 'bg-warning'
                              when 'Other' then 'bg-secondary'
                              else 'bg-light text-dark'
                              end %>">
                          <%= policy[:policy_type] %>
                        </span>
                      </td>
                      <td><%= policy[:customer_name] %></td>
                      <td><%= policy[:insurance_company] %></td>
                      <td><%= policy[:policy_holder] %></td>
                      <td><%= policy[:start_date]&.strftime('%d/%m/%Y') %></td>
                      <td>
                        <span class="text-danger">
                          <strong><%= policy[:end_date]&.strftime('%d/%m/%Y') %></strong>
                        </span>
                      </td>
                      <td>
                        <span class="badge <%= policy[:days_expired] > 90 ? 'bg-danger' : 'bg-warning text-dark' %>">
                          <%= pluralize(policy[:days_expired], 'day') %>
                        </span>
                      </td>
                      <td class="text-end">
                        <strong><%= indian_currency(policy[:premium_amount]) %></strong>
                      </td>
                      <td class="text-end">
                        <strong><%= indian_currency(policy[:sum_insured]) %></strong>
                      </td>
                      <td><%= policy[:payment_mode] %></td>
                      <td>
                        <span class="<%= policy[:sub_agent_name] == 'N/A' ? 'badge bg-info' : '' %>">
                          <%= policy[:sub_agent_name] == 'N/A' ? 'Direct' : policy[:sub_agent_name] %>
                        </span>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <!-- Pagination -->
            <% if @expired_data.respond_to?(:total_pages) && @expired_data.total_pages > 1 %>
              <div class="card-footer bg-transparent border-0">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                  <small class="text-muted mb-2 mb-md-0">
                    Showing <%= (@expired_data.current_page - 1) * @expired_data.limit_value + 1 %> to
                    <%= [@expired_data.current_page * @expired_data.limit_value, @expired_data.total_count].min %>
                    of <%= number_with_delimiter(@expired_data.total_count) %> expired policies
                  </small>
                  <div class="pagination-wrapper">
                    <%= paginate @expired_data %>
                  </div>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-5">
              <i class="bi bi-shield-check fs-1 text-success d-block mb-3"></i>
              <h5 class="text-success">No Expired Policies Found!</h5>
              <p class="text-muted mb-3">
                Great news! There are no expired insurance policies in the selected criteria.
              </p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exportModalLabel">
          <i class="bi bi-download me-2"></i>Export Expired Insurance Report
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with url: "", method: :post, id: "exportForm", class: "needs-validation", novalidate: true do |form| %>
          <!-- Export Info -->
          <div class="mb-4">
            <div class="alert alert-info d-flex align-items-center">
              <i class="bi bi-file-earmark-spreadsheet text-primary me-2"></i>
              <div>
                <strong>Export Format:</strong> CSV Spreadsheet - Ready for Excel and data analysis
              </div>
            </div>
          </div>

          <!-- Column Selection -->
          <div class="mb-4">
            <h6>Select Columns to Export</h6>
            <div class="row g-3">
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_number" id="col_policy_number" checked>
                  <label class="form-check-label" for="col_policy_number">Policy Number</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_type" id="col_policy_type" checked>
                  <label class="form-check-label" for="col_policy_type">Policy Type</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="customer_name" id="col_customer_name" checked>
                  <label class="form-check-label" for="col_customer_name">Customer Name</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="insurance_company" id="col_insurance_company" checked>
                  <label class="form-check-label" for="col_insurance_company">Insurance Company</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="policy_holder" id="col_policy_holder">
                  <label class="form-check-label" for="col_policy_holder">Policy Holder</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="start_date" id="col_start_date">
                  <label class="form-check-label" for="col_start_date">Start Date</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="lead_id" id="col_lead_id">
                  <label class="form-check-label" for="col_lead_id">Lead ID</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="end_date" id="col_end_date" checked>
                  <label class="form-check-label" for="col_end_date">End Date</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="days_expired" id="col_days_expired" checked>
                  <label class="form-check-label" for="col_days_expired">Days Expired</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="premium_amount" id="col_premium_amount" checked>
                  <label class="form-check-label" for="col_premium_amount">Premium Amount</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="sum_insured" id="col_sum_insured" checked>
                  <label class="form-check-label" for="col_sum_insured">Sum Insured</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="payment_mode" id="col_payment_mode">
                  <label class="form-check-label" for="col_payment_mode">Payment Mode</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="sub_agent_name" id="col_sub_agent_name">
                  <label class="form-check-label" for="col_sub_agent_name">Sub Agent</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="created_at" id="col_created_at">
                  <label class="form-check-label" for="col_created_at">Created Date</label>
                </div>
              </div>
            </div>
            <div class="mt-2">
              <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAllColumns()">Select All</button>
              <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deselectAllColumns()">Deselect All</button>
            </div>
          </div>
        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="performExport()">
          <i class="bi bi-download me-2"></i>Export
        </button>
      </div>
    </div>
  </div>
</div>

<!-- JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Export button click handler
  document.getElementById('exportBtn').addEventListener('click', function() {
    const exportModal = new bootstrap.Modal(document.getElementById('exportModal'));
    exportModal.show();
  });

  // Initialize DataTables if needed
  if ($('#expiredPoliciesTable').length) {
    $('#expiredPoliciesTable').DataTable({
      "paging": false,
      "ordering": false,
      "searching": false,
      "info": false,
      "responsive": true,
      "autoWidth": false
    });
  }
});

function selectAllColumns() {
  const checkboxes = document.querySelectorAll('input[name="columns[]"]');
  checkboxes.forEach(checkbox => checkbox.checked = true);
}

function deselectAllColumns() {
  const checkboxes = document.querySelectorAll('input[name="columns[]"]');
  checkboxes.forEach(checkbox => checkbox.checked = false);
}

function performExport() {
  const form = document.getElementById('exportForm');
  const selectedColumns = document.querySelectorAll('input[name="columns[]"]:checked');
  const exportBtn = document.querySelector('#exportModal .btn-primary');

  // Check if at least one column is selected
  if (selectedColumns.length === 0) {
    alert('Please select at least one column to export.');
    return;
  }

  // Show loader
  const originalBtnText = exportBtn.innerHTML;
  exportBtn.disabled = true;
  exportBtn.innerHTML = '<i class="bi bi-arrow-clockwise me-2 spin"></i>Exporting...';

  function resetButton() {
    exportBtn.disabled = false;
    exportBtn.innerHTML = originalBtnText;
  }

  // Get current URL parameters to preserve filters
  const urlParams = new URLSearchParams(window.location.search);

  // Always use CSV export URL
  const exportUrl = '<%= export_csv_admin_reports_expired_insurance_reports_path %>';

  // Build CSV URL with parameters
  let csvUrl = exportUrl + '?';
  urlParams.forEach((value, key) => {
    if (key !== 'page') { // Don't include page in export
      csvUrl += key + '=' + encodeURIComponent(value) + '&';
    }
  });
  selectedColumns.forEach(checkbox => {
    csvUrl += 'columns[]=' + encodeURIComponent(checkbox.value) + '&';
  });
  csvUrl = csvUrl.slice(0, -1); // Remove last &

  // Direct download for CSV
  window.location.href = csvUrl;
  resetButton();
  const exportModal = bootstrap.Modal.getInstance(document.getElementById('exportModal'));
  exportModal.hide();
}
</script>

<style>
.bg-gradient-primary {
  background: linear-gradient(135deg, #007bff, #0056b3);
}
.bg-gradient-success {
  background: linear-gradient(135deg, #28a745, #1e7e34);
}
.bg-gradient-warning {
  background: linear-gradient(135deg, #ffc107, #d39e00);
}
.bg-gradient-info {
  background: linear-gradient(135deg, #17a2b8, #117a8b);
}
.bg-gradient-danger {
  background: linear-gradient(135deg, #dc3545, #c82333);
}
.bg-gradient-secondary {
  background: linear-gradient(135deg, #6c757d, #545b62);
}

/* Spinning loader */
.spin {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.card {
  box-shadow: 0 0.15rem 1.75rem 0 rgba(33, 40, 50, 0.15);
}

.table th {
  border-top: none;
  font-weight: 600;
  font-size: 0.85rem;
}

.badge {
  font-size: 0.75rem;
}

@media (max-width: 768px) {
  .table-responsive {
    font-size: 0.8rem;
  }

  .card-body .row .col-md-3 {
    margin-bottom: 1rem;
  }
}
</style>