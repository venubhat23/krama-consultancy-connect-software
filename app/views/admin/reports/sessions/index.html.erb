<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Session Reports</h2>
    <p class="text-muted mb-0">Track user session activities and login/logout events</p>
  </div>
  <div>
    <button type="button" class="btn btn-success me-2" id="exportBtn">
      <i class="bi bi-download me-2"></i>Export
    </button>
    <button class="btn btn-primary" onclick="refreshData()">
      <i class="bi bi-arrow-clockwise me-1"></i>
      Refresh Data
    </button>
  </div>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Sessions</h6>
            <h3 class="mb-0 text-primary"><%= number_with_delimiter(@total_logins) %></h3>
          </div>
          <div class="bg-primary bg-opacity-10 rounded p-3">
            <i class="bi bi-activity text-primary fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm" style="cursor: pointer;" onclick="showUniqueUsersModal()">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Unique Users</h6>
            <h3 class="mb-0 text-info"><%= number_with_delimiter(@unique_users) %></h3>
          </div>
          <div class="bg-info bg-opacity-10 rounded p-3">
            <i class="bi bi-people text-info fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Today's Sessions</h6>
            <h3 class="mb-0 text-success" id="today-logins-count"><%= number_with_delimiter(@today_logins) %></h3>
          </div>
          <div class="bg-success bg-opacity-10 rounded p-3">
            <i class="bi bi-calendar-day text-success fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Last Activity</h6>
            <p class="mb-0 text-warning">
              <% if @recent_activities && @recent_activities.any? %>
                <% last_activity = @recent_activities.first %>
                <% occurred_time = last_activity.respond_to?(:occurred_at) ? last_activity.occurred_at : last_activity.started_at %>
                <%= time_ago_in_words(occurred_time) %> ago
              <% else %>
                Never
              <% end %>
            </p>
          </div>
          <div class="bg-warning bg-opacity-10 rounded p-3">
            <i class="bi bi-clock-history text-warning fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Filter Section -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Filter Options</h5>
  </div>
  <div class="card-body">
    <%= form_with url: admin_reports_sessions_path, method: :get, local: true, class: "row g-3 align-items-end" do |form| %>
      <div class="col-md-4">
        <%= form.label :date_range, "Time Period", class: "form-label fw-semibold" %>
        <%= form.select :date_range,
            options_for_select([
              ['Last 7 Days', '7_days'],
              ['Last 30 Days', '30_days'],
              ['Last 3 Months', '3_months'],
              ['Last 6 Months', '6_months'],
              ['Last Year', '1_year']
            ], @date_range),
            {},
            { class: "form-select" } %>
      </div>
      <div class="col-md-3">
        <%= form.submit "Apply Filter", class: "btn btn-primary" %>
        <button type="button" class="btn btn-outline-secondary" onclick="window.location.href='<%= admin_reports_sessions_path %>'">Clear</button>
      </div>
      <div class="col-md-5 text-end">
        <small class="text-muted">
          <i class="bi bi-info-circle me-1"></i>
          Showing session data for
          <strong><%= case @date_range
              when '7_days' then 'last 7 days'
              when '30_days' then 'last 30 days'
              when '3_months' then 'last 3 months'
              when '6_months' then 'last 6 months'
              when '1_year' then 'last year'
              else 'last 30 days'
              end %></strong>
        </small>
      </div>
    <% end %>
  </div>
</div>

<!-- Recent Session Events -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Session Activities</h5>
      <small class="text-muted" id="current-time">
        <i class="bi bi-clock me-1"></i>
        <%= Time.zone.now.strftime("%B %d, %Y %I:%M:%S %p IST") %>
      </small>
    </div>
  </div>
  <div class="card-body p-0">
    <% if @recent_activities && @recent_activities.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light">
            <tr>
              <th class="border-0">User</th>
              <th class="border-0">Role</th>
              <th class="border-0">Activity Type</th>
              <th class="border-0">Time</th>
              <th class="border-0">Status</th>
            </tr>
          </thead>
        <tbody>
          <% @recent_activities.each do |activity| %>
            <tr>
              <td>
                <div class="d-flex align-items-center">
                  <div class="avatar-sm bg-primary bg-opacity-10 rounded-circle me-2 d-flex align-items-center justify-content-center">
                    <i class="bi bi-person text-primary"></i>
                  </div>
                  <div>
                    <div class="fw-medium">
                      <%= activity.user ? "#{activity.user.first_name} #{activity.user.last_name}".strip.presence || activity.user.email : "Guest" %>
                    </div>
                    <small class="text-muted"><%= activity.user&.email %></small>
                  </div>
                </div>
              </td>
              <td>
                <% if activity.user %>
                  <%
                    role = activity.user.user_type
                    role_color = case role
                                when 'admin' then 'danger'
                                when 'agent' then 'primary'
                                when 'customer' then 'success'
                                when 'sub_agent' then 'info'
                                else 'secondary'
                                end
                  %>
                  <span class="badge bg-<%= role_color %>"><%= role.humanize %></span>
                <% else %>
                  <span class="badge bg-secondary">Guest</span>
                <% end %>
              </td>
              <td>
                <%
                  activity_type = activity.respond_to?(:activity_type) ? activity.activity_type : 'login'
                  is_login = activity_type == 'login'
                  badge_color = is_login ? 'success' : 'warning'
                  icon = is_login ? 'box-arrow-in-right' : 'box-arrow-right'
                  text = is_login ? 'Login' : 'Logout'
                %>
                <span class="badge bg-<%= badge_color %>">
                  <i class="bi bi-<%= icon %> me-1"></i><%= text %>
                </span>
              </td>
              <td>
                <% occurred_time = activity.respond_to?(:occurred_at) ? activity.occurred_at : activity.started_at %>
                <div>
                  <div class="fw-medium"><%= occurred_time.in_time_zone('Asia/Kolkata').strftime("%I:%M %p") %></div>
                  <small class="text-muted"><%= occurred_time.in_time_zone('Asia/Kolkata').strftime("%b %d, %Y") %></small>
                </div>
              </td>
              <td>
                <%
                  occurred_time = activity.respond_to?(:occurred_at) ? activity.occurred_at : activity.started_at
                  if activity_type == 'logout'
                %>
                  <span class="badge bg-secondary">
                    <i class="bi bi-check-circle me-1"></i>Completed
                  </span>
                <% else %>
                  <%
                    is_recent = occurred_time > 30.minutes.ago
                    status_class = is_recent ? 'success' : 'secondary'
                    status_text = is_recent ? 'Active' : 'Ended'
                    status_icon = is_recent ? 'circle-fill' : 'circle'
                  %>
                  <span class="badge bg-<%= status_class %>">
                    <i class="bi bi-<%= status_icon %> me-1"></i><%= status_text %>
                  </span>
                  <% if is_recent %>
                    <br><small class="text-success">Started <%= time_ago_in_words(occurred_time) %> ago</small>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-activity fs-1 text-muted mb-3 d-block"></i>
        <h5 class="text-muted">No session activities found</h5>
        <p class="text-muted mb-3">
          Session activities will appear here when users login/logout.
        </p>
      </div>
    <% end %>
  </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exportModalLabel">
          <i class="bi bi-download me-2"></i>Export Session Report
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with url: "", method: :post, id: "exportForm", class: "needs-validation", novalidate: true do |form| %>
          <!-- Export Format -->
          <div class="mb-4">
            <h6>Export Format</h6>
            <div class="row g-3">
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="export_format" value="csv" id="format_csv" checked>
                  <label class="form-check-label" for="format_csv">
                    <i class="bi bi-file-earmark-spreadsheet text-success me-1"></i> CSV Spreadsheet
                  </label>
                </div>
              </div>
            </div>
          </div>

          <!-- Column Selection -->
          <div class="mb-4">
            <h6>Select Columns to Export</h6>
            <div class="row g-3">
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="user_name" id="col_user_name" checked>
                  <label class="form-check-label" for="col_user_name">User Name</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="user_email" id="col_user_email" checked>
                  <label class="form-check-label" for="col_user_email">User Email</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="role" id="col_role" checked>
                  <label class="form-check-label" for="col_role">Role</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="activity_type" id="col_activity_type" checked>
                  <label class="form-check-label" for="col_activity_type">Activity Type</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="time" id="col_time" checked>
                  <label class="form-check-label" for="col_time">Time</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="columns[]" value="status" id="col_status" checked>
                  <label class="form-check-label" for="col_status">Status</label>
                </div>
              </div>
            </div>
            <div class="mt-2">
              <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAllColumns()">Select All</button>
              <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deselectAllColumns()">Deselect All</button>
            </div>
          </div>
        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="performExport()">
          <i class="bi bi-download me-2"></i>Export
        </button>
      </div>
    </div>
  </div>
</div>

<script>
// Export button click handler
document.addEventListener('DOMContentLoaded', function() {
  document.getElementById('exportBtn').addEventListener('click', function() {
    const exportModal = new bootstrap.Modal(document.getElementById('exportModal'));
    exportModal.show();
  });
});

function selectAllColumns() {
  const checkboxes = document.querySelectorAll('input[name="columns[]"]');
  checkboxes.forEach(checkbox => checkbox.checked = true);
}

function deselectAllColumns() {
  const checkboxes = document.querySelectorAll('input[name="columns[]"]');
  checkboxes.forEach(checkbox => checkbox.checked = false);
}

function performExport() {
  const form = document.getElementById('exportForm');
  const selectedColumns = document.querySelectorAll('input[name="columns[]"]:checked');
  const exportBtn = document.querySelector('#exportModal .btn-primary');

  // Check if at least one column is selected
  if (selectedColumns.length === 0) {
    alert('Please select at least one column to export.');
    return;
  }

  // Show loader
  const originalBtnText = exportBtn.innerHTML;
  exportBtn.disabled = true;
  exportBtn.innerHTML = '<i class="bi bi-arrow-clockwise me-2 spin"></i>Exporting...';

  function resetButton() {
    exportBtn.disabled = false;
    exportBtn.innerHTML = originalBtnText;
  }

  // Create CSV content from current table
  let csvContent = 'User Name,User Email,Role,Activity Type,Time,Status\n';

  const tableRows = document.querySelectorAll('table tbody tr');
  tableRows.forEach(row => {
    const cells = row.querySelectorAll('td');
    if (cells.length >= 5) {
      const userName = cells[0].textContent.trim().split('\n')[0];
      const userEmail = cells[0].textContent.trim().split('\n')[1] || '';
      const role = cells[1].textContent.trim();
      const activityType = cells[2].textContent.trim();
      const time = cells[3].textContent.trim().replace(/\s+/g, ' ');
      const status = cells[4].textContent.trim().replace(/\s+/g, ' ');

      csvContent += `"${userName}","${userEmail}","${role}","${activityType}","${time}","${status}"\n`;
    }
  });

  // Download CSV
  const blob = new Blob([csvContent], { type: 'text/csv' });
  const url = window.URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `Session_Report_${new Date().toISOString().split('T')[0]}.csv`;
  document.body.appendChild(a);
  a.click();
  window.URL.revokeObjectURL(url);
  document.body.removeChild(a);

  // Reset button and close modal
  resetButton();
  const exportModal = bootstrap.Modal.getInstance(document.getElementById('exportModal'));
  exportModal.hide();
}

// Simple data refresh
function refreshData() {
    fetch('<%= realtime_data_admin_reports_sessions_path %>', {
        headers: {
            'Accept': 'application/json'
        }
    })
    .then(response => response.json())
    .then(data => {
        // Update today's logins count
        const todayLoginsEl = document.getElementById('today-logins-count');
        if (todayLoginsEl) {
            todayLoginsEl.textContent = data.today_logins.toLocaleString();
        }

        // Update current time
        const currentTimeEl = document.getElementById('current-time');
        if (currentTimeEl) {
            currentTimeEl.innerHTML = '<i class="bi bi-clock me-1"></i>' + data.current_time;
        }
    })
    .catch(error => console.error('Error fetching real-time data:', error));
}

// Auto-refresh every 30 seconds
setInterval(refreshData, 30000);

// Unique Users Modal Function - Following Commission Report Pattern
function showUniqueUsersModal() {
    const modal = document.getElementById('uniqueUsersModal');
    modal.style.display = 'block';
    document.body.style.overflow = 'hidden'; // Prevent background scrolling
    loadUniqueUsersData();
}

function closeUniqueUsersModal() {
    const modal = document.getElementById('uniqueUsersModal');
    modal.style.display = 'none';
    document.body.style.overflow = ''; // Re-enable scrolling
}

function loadUniqueUsersData() {
    const tbody = document.getElementById('uniqueUsersTableBody');
    const loader = document.getElementById('uniqueUsersLoader');
    const content = document.getElementById('uniqueUsersContent');

    loader.classList.remove('d-none');
    content.classList.add('d-none');

    fetch('<%= admin_reports_sessions_path %>?format=json&unique_users=true')
        .then(response => response.json())
        .then(data => {
            loader.classList.add('d-none');
            content.classList.remove('d-none');

            tbody.innerHTML = '';

            if (data.unique_users && data.unique_users.length > 0) {
                data.unique_users.forEach((user, index) => {
                    const row = `
                        <tr style="border-bottom: 1px solid #e2e8f0;" onmouseover="this.style.background='rgba(102, 126, 234, 0.05)'" onmouseout="this.style.background=''">
                            <td style="padding: 1rem; vertical-align: middle;">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); font-weight: 600;">
                                        ${user.name.charAt(0).toUpperCase()}
                                    </div>
                                    <div>
                                        <div style="font-weight: 600; color: #2d3748; margin-bottom: 2px;">${user.name}</div>
                                        <small style="color: #718096;">${user.email}</small>
                                    </div>
                                </div>
                            </td>
                            <td style="padding: 1rem; vertical-align: middle;">
                                <span class="badge" style="background: linear-gradient(135deg,
                                    ${user.role_color === 'danger' ? '#ef4444, #dc2626' :
                                      user.role_color === 'primary' ? '#3b82f6, #2563eb' :
                                      user.role_color === 'success' ? '#10b981, #059669' :
                                      user.role_color === 'info' ? '#06b6d4, #0891b2' : '#6b7280, #4b5563'});
                                    color: white; padding: 0.5rem 1rem; border-radius: 8px; font-weight: 500;">
                                    ${user.role}
                                </span>
                            </td>
                            <td style="padding: 1rem; vertical-align: middle;">
                                <div style="font-weight: 700; font-size: 1.1rem; color: #2d3748;">${user.session_count}</div>
                                <small style="color: #718096;">Sessions</small>
                            </td>
                            <td style="padding: 1rem; vertical-align: middle;">
                                <div style="color: #2d3748; font-weight: 500;">${user.last_login}</div>
                            </td>
                        </tr>
                    `;
                    tbody.innerHTML += row;
                });
            } else {
                tbody.innerHTML = '<tr><td colspan="4" class="text-center py-5" style="color: #718096;">No unique users found</td></tr>';
            }
        })
        .catch(error => {
            console.error('Error loading unique users:', error);
            loader.classList.add('d-none');
            content.classList.remove('d-none');
            tbody.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-danger">Error loading data</td></tr>';
        });
}

// Export function for unique users data
function exportUniqueUsers() {
    // Get current data from the table
    const table = document.getElementById('uniqueUsersTableBody');
    if (!table || table.children.length === 0) {
        alert('No data to export. Please load the user data first.');
        return;
    }

    // Create CSV content
    let csvContent = 'User Name,Email,Role,Session Count,Last Login\n';

    for (let row of table.children) {
        const cells = row.children;
        if (cells.length >= 4) {
            const userName = cells[0].textContent.trim().split('\n')[0];
            const email = cells[0].textContent.trim().split('\n')[1] || '';
            const role = cells[1].textContent.trim();
            const sessionCount = cells[2].textContent.trim().split('\n')[0];
            const lastLogin = cells[3].textContent.trim();

            csvContent += `"${userName}","${email}","${role}","${sessionCount}","${lastLogin}"\n`;
        }
    }

    // Download CSV
    const blob = new Blob([csvContent], { type: 'text/csv' });
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `unique-users-session-report-${new Date().toISOString().slice(0,10)}.csv`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    window.URL.revokeObjectURL(url);
}

// Close modal on outside click
document.addEventListener('click', function(event) {
    const modal = document.getElementById('uniqueUsersModal');
    if (event.target === modal) {
        closeUniqueUsersModal();
    }
});

// Close modal on Escape key
document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
        const modal = document.getElementById('uniqueUsersModal');
        if (modal.style.display === 'block') {
            closeUniqueUsersModal();
        }
    }
});
</script>

<style>
/* Unique Users Card Hover Effect */
.card[onclick*="showUniqueUsersModal"]:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15) !important;
    transition: all 0.3s ease;
    cursor: pointer;
}

/* Enhanced table styling for consistency */
.table td {
    vertical-align: middle;
}

/* Modal animation */
#uniqueUsersModal {
    animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}

/* Custom scrollbar for modal content */
#uniqueUsersContent::-webkit-scrollbar {
    width: 6px;
}

#uniqueUsersContent::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 6px;
}

#uniqueUsersContent::-webkit-scrollbar-thumb {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 6px;
}

#uniqueUsersContent::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(135deg, #5a67d8 0%, #6b46c1 100%);
}

/* Spinning loader for export */
.spin {
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}
</style>

<!-- Unique Users Modal - Following Commission Report Pattern -->
<div id="uniqueUsersModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.5); z-index: 999999;">
  <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; border-radius: 15px; box-shadow: 0 20px 50px rgba(0,0,0,0.3); min-width: 800px; max-width: 90vw; max-height: 85vh; overflow: hidden;">
    <!-- Modal Header -->
    <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 1.5rem 2rem; border-radius: 15px 15px 0 0;">
      <div class="d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-white">
          <i class="bi bi-people me-2"></i>Unique Users - Session Details
        </h5>
        <button type="button" onclick="closeUniqueUsersModal()" class="btn-close btn-close-white" style="background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer;">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
    </div>

    <!-- Modal Body -->
    <div style="padding: 2rem; max-height: 60vh; overflow-y: auto;">
      <!-- Loader -->
      <div id="uniqueUsersLoader" class="text-center py-5">
        <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
        <h6 class="mb-2">Loading Unique Users...</h6>
        <p class="text-muted mb-0">Please wait while we fetch user session data</p>
      </div>

      <!-- Content -->
