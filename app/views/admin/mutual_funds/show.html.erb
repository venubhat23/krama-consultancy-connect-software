<!-- Header -->
<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h2 class="mb-1">
      <i class="bi bi-pie-chart-fill text-success me-2"></i>
      <%= @mutual_fund.fund_name.presence || "Mutual Fund" %>
    </h2>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><%= link_to "Mutual Funds", admin_mutual_funds_path %></li>
        <li class="breadcrumb-item active"><%= @mutual_fund.customer&.display_name %></li>
      </ol>
    </nav>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_mutual_fund_path(@mutual_fund), class: "btn btn-outline-primary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_mutual_funds_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<!-- Status badge -->
<div class="mb-3">
  <% if @mutual_fund.active %>
    <span class="badge bg-success fs-6">Active</span>
  <% else %>
    <span class="badge bg-secondary fs-6">Inactive</span>
  <% end %>
  <span class="badge bg-<%= @mutual_fund.investment_type == 'SIP' ? 'primary' : 'success' %> fs-6 ms-2">
    <%= @mutual_fund.investment_type %>
  </span>
</div>

<!-- Investment Details -->
<div class="card mb-4 shadow-sm">
  <div class="card-header">
    <h5 class="mb-0"><i class="bi bi-graph-up me-2 text-success"></i>Investment Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="text-muted small fw-bold">CLIENT NAME</label>
        <div class="fw-semibold"><%= @mutual_fund.customer&.display_name %></div>
      </div>
      <div class="col-md-6 mb-3">
        <label class="text-muted small fw-bold">AFFILIATE</label>
        <div class="fw-semibold"><%= @mutual_fund.sub_agent&.display_name || 'Self' %></div>
      </div>
      <div class="col-md-6 mb-3">
        <label class="text-muted small fw-bold">INVESTMENT TYPE</label>
        <div class="fw-semibold"><%= @mutual_fund.investment_type %></div>
      </div>
      <div class="col-md-6 mb-3">
        <label class="text-muted small fw-bold">AMOUNT</label>
        <div class="fw-semibold text-success fs-5"><%= indian_currency(@mutual_fund.amount) %></div>
      </div>
      <div class="col-md-6 mb-3">
        <label class="text-muted small fw-bold">FUND NAME / AMC</label>
        <div class="fw-semibold"><%= @mutual_fund.fund_name.presence || '—' %></div>
      </div>
      <div class="col-md-6 mb-3">
        <label class="text-muted small fw-bold">FOLIO NUMBER</label>
        <div><% if @mutual_fund.folio_number.present? %><code><%= @mutual_fund.folio_number %></code><% else %>—<% end %></div>
      </div>
      <div class="col-md-6 mb-3">
        <label class="text-muted small fw-bold">PLAN NAME</label>
        <div><%= @mutual_fund.plan_name.presence || '—' %></div>
      </div>
      <div class="col-md-3 mb-3">
        <label class="text-muted small fw-bold">START DATE</label>
        <div><%= @mutual_fund.start_date&.strftime("%d %b %Y") || '—' %></div>
      </div>
      <div class="col-md-3 mb-3">
        <label class="text-muted small fw-bold">MATURITY DATE</label>
        <div><%= @mutual_fund.maturity_date&.strftime("%d %b %Y") || '—' %></div>
      </div>
    </div>
  </div>
</div>

<!-- Commission Calculation -->
<% mf = @mutual_fund %>
<div class="card mb-4 shadow-sm">
  <div class="card-header" style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="mb-0 fw-bold"><i class="bi bi-calculator me-2 text-primary"></i>Commission Calculation</h5>
      <div class="badge bg-light text-dark border">
        Main Agent Commission - Total Distribution - Company Expenses
      </div>
    </div>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table mb-0" style="font-size: 0.9rem;">
        <thead style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
          <tr>
            <th class="py-3 px-4 border-0">COMMISSION DETAILS</th>
            <th class="py-3 px-3 border-0 text-center">(%)</th>
            <th class="py-3 px-3 border-0 text-center">COMMISSION</th>
            <th class="py-3 px-3 border-0 text-center">TDS (%)</th>
            <th class="py-3 px-3 border-0 text-center">TDS AMOUNT</th>
            <th class="py-3 px-3 border-0 text-center">ACTUAL AMOUNT</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-bottom">
            <td class="py-3 px-4 fw-bold bg-light">Main Agent</td>
            <td class="text-center py-2"><%= mf.main_agent_commission_percentage %>%</td>
            <td class="text-center py-2"><%= indian_currency(mf.commission_amount || 0) %></td>
            <td class="text-center py-2"><%= mf.tds_percentage %>%</td>
            <td class="text-center py-2"><%= indian_currency(mf.tds_amount || 0) %></td>
            <td class="text-center py-2 fw-bold"><%= indian_currency(mf.after_tds_value || 0) %></td>
          </tr>
          <tr class="border-bottom">
            <td class="py-3 px-4 fw-bold">Affiliate</td>
            <td class="text-center py-2"><%= mf.sub_agent_commission_percentage %>%</td>
            <td class="text-center py-2"><%= indian_currency(mf.sub_agent_commission_amount || 0) %></td>
            <td class="text-center py-2"><%= mf.sub_agent_tds_percentage %>%</td>
            <td class="text-center py-2"><%= indian_currency(mf.sub_agent_tds_amount || 0) %></td>
            <td class="text-center py-2 fw-bold"><%= indian_currency(mf.sub_agent_after_tds_value || 0) %></td>
          </tr>
          <tr class="border-bottom">
            <td class="py-3 px-4 fw-bold">Ambassador</td>
            <td class="text-center py-2"><%= mf.distributor_commission_percentage %>%</td>
            <td class="text-center py-2"><%= indian_currency(mf.distributor_commission_amount || 0) %></td>
            <td class="text-center py-2"><%= mf.distributor_tds_percentage %>%</td>
            <td class="text-center py-2"><%= indian_currency(mf.distributor_tds_amount || 0) %></td>
            <td class="text-center py-2 fw-bold"><%= indian_currency(mf.distributor_after_tds_value || 0) %></td>
          </tr>
          <tr class="border-bottom">
            <td class="py-3 px-4 fw-bold">Investor</td>
            <td class="text-center py-2"><%= mf.investor_commission_percentage %>%</td>
            <td class="text-center py-2"><%= indian_currency(mf.investor_commission_amount || 0) %></td>
            <td class="text-center py-2">—</td>
            <td class="text-center py-2">—</td>
            <td class="text-center py-2 fw-bold"><%= indian_currency(mf.investor_commission_amount || 0) %></td>
          </tr>
          <tr class="border-bottom">
            <td class="py-3 px-4 fw-bold">Company</td>
            <td class="text-center py-2"><%= mf.company_expenses_percentage %>%</td>
            <td class="text-center py-2"><%= indian_currency(mf.company_expenses_amount || 0) %></td>
            <td class="text-center py-2">—</td>
            <td class="text-center py-2">—</td>
            <td class="text-center py-2 fw-bold"><%= indian_currency(mf.company_expenses_amount || 0) %></td>
          </tr>
          <tr style="background: #f0fff4;">
            <td class="py-3 px-4 fw-bold text-success">Profit</td>
            <td class="text-center py-2 fw-bold text-success"><%= mf.profit_percentage %>%</td>
            <td class="text-center py-2 fw-bold text-success"><%= indian_currency(mf.profit_amount || 0) %></td>
            <td class="text-center py-2">—</td>
            <td class="text-center py-2">—</td>
            <td class="text-center py-2 fw-bold text-success"><%= indian_currency(mf.profit_amount || 0) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
