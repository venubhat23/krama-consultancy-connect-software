<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">
      <i class="bi bi-pie-chart-fill text-success me-2"></i>
      Mutual Funds
    </h2>
    <p class="text-muted mb-0">Manage all mutual fund investments</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to new_admin_mutual_fund_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i>
      Add Mutual Fund
    <% end %>
  </div>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Mutual Funds</h6>
            <h3 class="mb-0 text-primary"><%= number_with_delimiter((@drwise_count || 0) + (@non_drwise_count || 0)) %></h3>
            <div class="d-flex gap-2 mt-2">
              <small class="text-success"><i class="bi bi-check-circle me-1"></i>DrWise: <%= @drwise_count %></small>
              <small class="text-warning"><i class="bi bi-x-circle me-1"></i>Non-DrWise: <%= @non_drwise_count %></small>
            </div>
          </div>
          <div class="bg-primary bg-opacity-10 rounded p-3">
            <i class="bi bi-pie-chart-fill text-primary fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Investment</h6>
            <h3 class="mb-0 text-success"><%= indian_currency((@drwise_amount || 0) + (@non_drwise_amount || 0)) %></h3>
            <div class="mt-2">
              <small class="text-muted d-block">DrWise: <%= indian_currency(@drwise_amount || 0) %></small>
              <small class="text-muted d-block">Non-DrWise: <%= indian_currency(@non_drwise_amount || 0) %></small>
            </div>
          </div>
          <div class="bg-success bg-opacity-10 rounded p-3">
            <i class="bi bi-currency-rupee text-success fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">SIP Funds</h6>
            <h3 class="mb-0 text-info"><%= MutualFund.where(investment_type: 'SIP').count %></h3>
          </div>
          <div class="bg-info bg-opacity-10 rounded p-3">
            <i class="bi bi-arrow-repeat text-info fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Clients</h6>
            <h3 class="mb-0 text-warning"><%= @total_clients_count || 0 %></h3>
          </div>
          <div class="bg-warning bg-opacity-10 rounded p-3">
            <i class="bi bi-people-fill text-warning fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- DrWise / Non-DrWise Tabs -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white border-bottom">
    <ul class="nav nav-tabs card-header-tabs" id="mutualFundTabs">
      <li class="nav-item">
        <%= link_to admin_mutual_funds_path(tab: 'drwise', search: params[:search], investment_type: params[:investment_type]),
            class: "nav-link #{'active' if @current_tab == 'drwise'}" do %>
          <i class="bi bi-shield-check me-1 text-success"></i>
          DrWise
          <span class="badge bg-success ms-1"><%= @drwise_count %></span>
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to admin_mutual_funds_path(tab: 'non_drwise', search: params[:search], investment_type: params[:investment_type]),
            class: "nav-link #{'active' if @current_tab == 'non_drwise'}" do %>
          <i class="bi bi-person-fill me-1 text-warning"></i>
          Non-DrWise
          <span class="badge bg-warning ms-1"><%= @non_drwise_count %></span>
        <% end %>
      </li>
    </ul>
  </div>

  <!-- Filters -->
  <div class="card-body border-bottom bg-light py-3">
    <%= form_with url: admin_mutual_funds_path, method: :get, local: true, class: "row g-2 align-items-end" do |f| %>
      <%= f.hidden_field :tab, value: @current_tab %>

      <div class="col-md-5">
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <%= f.text_field :search, value: params[:search], placeholder: "Search by client, fund name, folio...", class: "form-control" %>
        </div>
      </div>

      <div class="col-md-3">
        <%= f.select :investment_type,
            options_for_select([['All Types', ''], ['SIP', 'SIP'], ['Lumpsum', 'Lumpsum']], params[:investment_type]),
            {},
            { class: "form-select" } %>
      </div>

      <div class="col-md-2">
        <%= f.submit "Filter", class: "btn btn-primary w-100" %>
      </div>

      <div class="col-md-2">
        <%= link_to admin_mutual_funds_path(tab: @current_tab), class: "btn btn-outline-secondary w-100" do %>
          <i class="bi bi-x-circle me-1"></i>Clear
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Table -->
  <div class="card-body p-0">
    <% if @mutual_funds.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="py-3 px-4">#</th>
              <th class="py-3">Client Name</th>
              <th class="py-3">Affiliate</th>
              <th class="py-3">Fund Name</th>
              <th class="py-3">Folio Number</th>
              <th class="py-3">Type</th>
              <th class="py-3">Amount</th>
              <th class="py-3">Start Date</th>
              <th class="py-3">Status</th>
              <th class="py-3 text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @mutual_funds.each_with_index do |mf, i| %>
              <tr>
                <td class="px-4 py-3 text-muted"><%= i + 1 %></td>
                <td class="py-3">
                  <div class="fw-semibold"><%= mf.customer&.display_name %></div>
                </td>
                <td class="py-3">
                  <% if mf.sub_agent.present? %>
                    <span class="badge bg-info text-dark"><%= mf.sub_agent.display_name %></span>
                  <% else %>
                    <span class="text-muted">Self</span>
                  <% end %>
                </td>
                <td class="py-3"><%= mf.fund_name.presence || '—' %></td>
                <td class="py-3">
                  <% if mf.folio_number.present? %>
                    <code><%= mf.folio_number %></code>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
                <td class="py-3">
                  <% badge_color = mf.investment_type == 'SIP' ? 'bg-primary' : 'bg-success' %>
                  <span class="badge <%= badge_color %>"><%= mf.investment_type %></span>
                </td>
                <td class="py-3 fw-semibold"><%= indian_currency(mf.amount) %></td>
                <td class="py-3"><%= mf.start_date&.strftime("%d %b %Y") || '—' %></td>
                <td class="py-3">
                  <% if mf.active %>
                    <span class="badge bg-success">Active</span>
                  <% else %>
                    <span class="badge bg-secondary">Inactive</span>
                  <% end %>
                </td>
                <td class="py-3 text-center">
                  <div class="btn-group btn-group-sm">
                    <%= link_to admin_mutual_fund_path(mf), class: "btn btn-outline-primary", title: "View" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to edit_admin_mutual_fund_path(mf), class: "btn btn-outline-secondary", title: "Edit" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <%= link_to admin_mutual_fund_path(mf), method: :delete,
                        data: { confirm: "Delete this mutual fund record?" },
                        class: "btn btn-outline-danger", title: "Delete" do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="card-footer bg-white">
        <%= render 'shared/pagination', collection: @mutual_funds %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-pie-chart text-muted" style="font-size: 4rem;"></i>
        <h5 class="text-muted mt-3">No mutual funds found</h5>
        <p class="text-muted">
          <% if params[:search].present? || params[:investment_type].present? %>
            Try adjusting your search filters.
          <% else %>
            Click "Add Mutual Fund" to create the first record.
          <% end %>
        </p>
        <%= link_to new_admin_mutual_fund_path, class: "btn btn-primary mt-2" do %>
          <i class="bi bi-plus-lg me-1"></i>Add Mutual Fund
        <% end %>
      </div>
    <% end %>
  </div>
</div>
