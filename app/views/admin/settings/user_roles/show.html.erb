<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= "#{@user.first_name} #{@user.last_name}" %></h2>
    <p class="text-muted mb-0">User details and permissions</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_settings_user_role_path(@user), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-1"></i>
      Edit User
    <% end %>
    <%= link_to admin_settings_user_roles_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>
      Back to Users
    <% end %>
  </div>
</div>

<div class="row">
  <div class="col-lg-8">
    <!-- Login Credentials (if recently created) -->
    <% if flash[:user_created] %>
      <div class="card border-primary shadow-sm mb-4">
        <div class="card-header bg-primary bg-opacity-10 border-0">
          <h5 class="mb-0 text-primary">
            <i class="bi bi-key me-2"></i>
            User Created Successfully
          </h5>
        </div>
        <div class="card-body">
          <div class="alert alert-success mb-3">
            <i class="bi bi-check-circle me-2"></i>
            <strong>User created successfully!</strong> The user can now login with their credentials.
          </div>

          <div class="row">
            <div class="col-12 mb-3">
              <label class="form-label text-muted">Username/Email</label>
              <div class="input-group">
                <input type="text" class="form-control fw-bold" value="<%= @user.email %>" readonly>
                <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('<%= @user.email %>')">
                  <i class="bi bi-copy"></i>
                </button>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="p-3 bg-light rounded">
                <h6 class="mb-2">Login Information:</h6>
                <div class="small">
                  <strong>Login URL:</strong> <%= request.base_url %>/users/sign_in<br>
                  <strong>Username:</strong> <%= @user.email %><br>
                  <strong>Note:</strong> <span class="text-primary">The user should use the password they provided during creation.</span>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-3">
            <div class="alert alert-info small mb-0">
              <i class="bi bi-info-circle me-2"></i>
              <strong>Note:</strong> Please inform the user to securely store their login credentials.
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Basic Information -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Basic Information</h5>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Full Name</label>
            <p class="fw-bold mb-0"><%= "#{@user.first_name} #{@user.last_name}" %></p>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Email Address</label>
            <p class="fw-bold mb-0"><%= @user.email %></p>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Phone Number</label>
            <p class="fw-bold mb-0"><%= @user.mobile || 'Not provided' %></p>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Role</label>
            <p class="fw-bold mb-0">
              <span class="badge bg-secondary-subtle text-secondary px-3 py-2">
                <%= @user.role_name || 'No Role Assigned' %>
              </span>
            </p>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">User Type</label>
            <p class="fw-bold mb-0">
              <span class="badge bg-<%= @user.user_type == 'admin' ? 'primary' : 'info' %>-subtle text-<%= @user.user_type == 'admin' ? 'primary' : 'info' %> px-3 py-2">
                <i class="bi bi-<%= @user.user_type == 'admin' ? 'shield-check' : 'person' %> me-1"></i>
                <%= @user.user_type.humanize %>
              </span>
            </p>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Status</label>
            <p class="fw-bold mb-0">
              <span class="badge bg-<%= @user.status? ? 'success' : 'secondary' %>-subtle text-<%= @user.status? ? 'success' : 'secondary' %> px-3 py-2">
                <i class="bi bi-<%= @user.status? ? 'check-circle' : 'pause-circle' %> me-1"></i>
                <%= @user.status? ? 'Active' : 'Inactive' %>
              </span>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Module Permissions -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Module Permissions</h5>
      </div>
      <%
        raw_sp = @user.sidebar_permissions
        user_permissions = begin
          raw_sp.present? ? JSON.parse(raw_sp) : {}
        rescue JSON::ParserError
          {}
        end
        user_permissions = {} unless user_permissions.is_a?(Hash)

        # Convert old array format to view-only hash
        if user_permissions.is_a?(Array)
          user_permissions = user_permissions.each_with_object({}) { |k, h| h[k] = { 'view' => true, 'create' => false, 'edit' => false, 'delete' => false } }
        end

        effective_permissions = user_permissions.select { |_k, v| v.is_a?(Hash) && (v['view'] || v['create'] || v['edit'] || v['delete']) }

        all_sidebar_options = {
          'Main Menu' => [
            { key: 'dashboard', name: 'Dashboard' },
            { key: 'analytics', name: 'Analytics' },
            { key: 'leads', name: 'Leads' },
            { key: 'appointments', name: 'Appointments' },
            { key: 'customers', name: 'Clients' },
            { key: 'sub_agents', name: 'Affiliates' },
            { key: 'distributors', name: 'Ambassadors' }
          ],
          'Services' => [
            { key: 'life_insurance', name: 'Life Insurance' },
            { key: 'health_insurance', name: 'Health Insurance' },
            { key: 'motor_insurance', name: 'Motor Insurance' },
            { key: 'other_insurance', name: 'General Insurance' },
            { key: 'investments', name: 'Investments' },
            { key: 'taxation', name: 'Taxation' },
            { key: 'loans', name: 'Loans' },
            { key: 'travel', name: 'Travel' },
            { key: 'credit_card', name: 'Credit Card' }
          ],
          'Vendor' => [
            { key: 'brokers', name: 'Broker' },
            { key: 'agency_codes', name: 'Agency Code' }
          ],
          'Payouts' => [
            { key: 'payouts', name: 'Commissions' },
            { key: 'affiliate_payouts', name: 'Affiliate Payout' },
            { key: 'distributor_payouts', name: 'Ambassador Payout' }
          ],
          'Transactions' => [
            { key: 'invoices', name: 'Invoices' }
          ],
          'Reports & Analytics' => [
            { key: 'reports', name: 'Commission Report' },
            { key: 'all_policy_reports', name: 'All Policy Reports' },
            { key: 'profit_reports', name: 'Profit Reports' },
            { key: 'expired_insurance_reports', name: 'Expired Insurance' },
            { key: 'upcoming_renewal_reports', name: 'Upcoming Renewal' },
            { key: 'lead_reports', name: 'Lead Reports' }
          ],
          'Management' => [
            { key: 'investors', name: 'Investors' },
            { key: 'client_requests', name: 'Client Request' },
            { key: 'user_roles', name: 'Users' },
            { key: 'banners', name: 'Banner Management' },
            { key: 'insurance_companies', name: 'Companies' },
            { key: 'management', name: 'Import Data' }
          ],
          'Settings' => [
            { key: 'settings', name: 'System Settings' }
          ]
        }
      %>

      <% if effective_permissions.any? %>
        <div class="table-responsive">
          <table class="table table-hover mb-0" style="font-size: 0.9rem;">
            <thead class="bg-light">
              <tr>
                <th class="border-0 ps-3">Module</th>
                <th class="border-0 text-center">View</th>
                <th class="border-0 text-center">Create</th>
                <th class="border-0 text-center">Edit</th>
                <th class="border-0 text-center">Delete</th>
                <th class="border-0 text-center">Access Type</th>
              </tr>
            </thead>
            <tbody>
              <% all_sidebar_options.each do |section_name, mods| %>
                <% section_mods = mods.select { |m| effective_permissions.key?(m[:key]) } %>
                <% next if section_mods.empty? %>
                <tr style="background: #f8fafc;">
                  <td colspan="6" class="py-2 ps-3 fw-bold text-primary small border-0">
                    <i class="bi bi-folder-fill me-1"></i><%= section_name %>
                  </td>
                </tr>
                <% section_mods.each do |mod| %>
                  <% p = effective_permissions[mod[:key]] %>
                  <% v = p['view'] == true %>
                  <% c = p['create'] == true %>
                  <% e = p['edit'] == true %>
                  <% d = p['delete'] == true %>
                  <% is_full = v && c && e && d %>
                  <% is_view_only = v && !c && !e && !d %>
                  <tr>
                    <td class="ps-4 border-0 fw-medium"><%= mod[:name] %></td>
                    <td class="text-center border-0">
                      <% if v %><i class="bi bi-check-circle-fill text-success"></i><% else %><i class="bi bi-dash-circle text-muted opacity-25"></i><% end %>
                    </td>
                    <td class="text-center border-0">
                      <% if c %><i class="bi bi-check-circle-fill text-success"></i><% else %><i class="bi bi-dash-circle text-muted opacity-25"></i><% end %>
                    </td>
                    <td class="text-center border-0">
                      <% if e %><i class="bi bi-check-circle-fill text-success"></i><% else %><i class="bi bi-dash-circle text-muted opacity-25"></i><% end %>
                    </td>
                    <td class="text-center border-0">
                      <% if d %><i class="bi bi-check-circle-fill text-success"></i><% else %><i class="bi bi-dash-circle text-muted opacity-25"></i><% end %>
                    </td>
                    <td class="text-center border-0">
                      <% if is_full %>
                        <span class="badge bg-success-subtle text-success px-2"><i class="bi bi-unlock me-1"></i>Full Access</span>
                      <% elsif is_view_only %>
                        <span class="badge bg-info-subtle text-info px-2"><i class="bi bi-eye me-1"></i>View Only</span>
                      <% else %>
                        <span class="badge bg-warning-subtle text-warning px-2"><i class="bi bi-sliders me-1"></i>Custom</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="card-body text-center py-4">
          <i class="bi bi-shield-x fs-1 text-muted d-block mb-3"></i>
          <h6 class="text-muted">No Permissions Assigned</h6>
          <p class="text-muted mb-3">This user has no module permissions configured.</p>
          <%= link_to edit_admin_settings_user_role_path(@user), class: "btn btn-primary btn-sm" do %>
            <i class="bi bi-pencil me-1"></i>Assign Permissions
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="col-lg-4">
    <!-- Account Summary -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h6 class="mb-0">Account Summary</h6>
      </div>
      <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <span class="text-muted">User ID:</span>
          <span class="fw-bold">#<%= @user.id %></span>
        </div>
        <div class="d-flex align-items-center justify-content-between mb-3">
          <span class="text-muted">Created:</span>
          <span class="fw-bold"><%= @user.created_at.strftime("%b %d, %Y") %></span>
        </div>
        <div class="d-flex align-items-center justify-content-between mb-3">
          <span class="text-muted">Last Updated:</span>
          <span class="fw-bold"><%= @user.updated_at.strftime("%b %d, %Y") %></span>
        </div>
        <div class="d-flex align-items-center justify-content-between">
          <span class="text-muted">Account Age:</span>
          <span class="fw-bold"><%= time_ago_in_words(@user.created_at) %></span>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h6 class="mb-0">Quick Actions</h6>
      </div>
      <div class="card-body">
        <div class="d-grid gap-2">
          <%= link_to toggle_status_admin_settings_user_role_path(@user),
              method: :patch,
              class: "btn btn-outline-#{@user.status? ? 'warning' : 'success'}",
              data: {
                confirm: "Are you sure you want to #{@user.status? ? 'deactivate' : 'activate'} this user?",
                turbo_method: :patch
              } do %>
            <i class="bi bi-#{@user.status? ? 'pause-circle' : 'play-circle'} me-1"></i>
            <%= @user.status? ? 'Deactivate User' : 'Activate User' %>
          <% end %>

          <%= button_to admin_settings_user_role_path(@user),
              method: :delete,
              class: "btn btn-outline-danger",
              data: {
                confirm: "Are you sure you want to delete this user? This action cannot be undone."
              } do %>
            <i class="bi bi-trash me-1"></i>
            Delete User
          <% end %>
        </div>
      </div>
    </div>

    <!-- Permission Summary -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h6 class="mb-0">Permission Summary</h6>
      </div>
      <div class="card-body">
        <%
          full_access_count = effective_permissions.count { |_k, v| v['view'] && v['create'] && v['edit'] && v['delete'] }
          view_only_count   = effective_permissions.count { |_k, v| v['view'] && !v['create'] && !v['edit'] && !v['delete'] }
          custom_count      = effective_permissions.count - full_access_count - view_only_count
        %>
        <div class="text-center mb-3">
          <h3 class="text-primary mb-1"><%= effective_permissions.count %></h3>
          <p class="text-muted mb-0">Modules Assigned</p>
        </div>
        <hr>
        <div class="d-flex flex-column gap-2 small">
          <div class="d-flex justify-content-between align-items-center">
            <span><i class="bi bi-unlock text-success me-1"></i>Full Access</span>
            <span class="badge bg-success-subtle text-success"><%= full_access_count %></span>
          </div>
          <div class="d-flex justify-content-between align-items-center">
            <span><i class="bi bi-eye text-info me-1"></i>View Only</span>
            <span class="badge bg-info-subtle text-info"><%= view_only_count %></span>
          </div>
          <% if custom_count > 0 %>
          <div class="d-flex justify-content-between align-items-center">
            <span><i class="bi bi-sliders text-warning me-1"></i>Custom</span>
            <span class="badge bg-warning-subtle text-warning"><%= custom_count %></span>
          </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function togglePassword() {
  const passwordField = document.getElementById('passwordField');
  const passwordToggleIcon = document.getElementById('passwordToggleIcon');

  if (passwordField.type === 'password') {
    passwordField.type = 'text';
    passwordToggleIcon.classList.remove('bi-eye');
    passwordToggleIcon.classList.add('bi-eye-slash');
  } else {
    passwordField.type = 'password';
    passwordToggleIcon.classList.remove('bi-eye-slash');
    passwordToggleIcon.classList.add('bi-eye');
  }
}

function copyToClipboard(text) {
  if (navigator.clipboard && window.isSecureContext) {
    navigator.clipboard.writeText(text).then(function() {
      showToast('Copied to clipboard!', 'success');
    }, function(err) {
      console.error('Could not copy text: ', err);
      showToast('Failed to copy to clipboard', 'error');
    });
  } else {
    // Fallback for older browsers
    const textArea = document.createElement('textarea');
    textArea.value = text;
    textArea.style.position = 'fixed';
    textArea.style.left = '-999999px';
    textArea.style.top = '-999999px';
    document.body.appendChild(textArea);
    textArea.focus();
    textArea.select();

    try {
      const successful = document.execCommand('copy');
      showToast(successful ? 'Copied to clipboard!' : 'Failed to copy to clipboard', successful ? 'success' : 'error');
    } catch (err) {
      console.error('Fallback: Oops, unable to copy', err);
      showToast('Failed to copy to clipboard', 'error');
    }

    document.body.removeChild(textArea);
  }
}

function showToast(message, type = 'success') {
  // Create toast element
  const toast = document.createElement('div');
  toast.className = `alert alert-${type === 'success' ? 'success' : 'danger'} position-fixed`;
  toast.style.cssText = 'top: 20px; right: 20px; z-index: 9999; opacity: 0; transition: opacity 0.3s ease;';
  toast.innerHTML = `
    <i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>
    ${message}
  `;

  document.body.appendChild(toast);

  // Fade in
  setTimeout(() => { toast.style.opacity = '1'; }, 10);

  // Auto remove after 3 seconds
  setTimeout(() => {
    toast.style.opacity = '0';
    setTimeout(() => {
      if (toast.parentNode) {
        document.body.removeChild(toast);
      }
    }, 300);
  }, 3000);
}
</script>