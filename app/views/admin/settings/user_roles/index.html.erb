<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-0">User Management</h2>
  </div>
  <div class="d-flex gap-2">
    <%= link_to new_admin_settings_user_role_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i>
      Create User
    <% end %>
  </div>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Users</h6>
            <h3 class="mb-0 text-primary"><%= number_with_delimiter(@users.count) %></h3>
          </div>
          <div class="bg-primary bg-opacity-10 rounded p-3">
            <i class="bi bi-people text-primary fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Active Users</h6>
            <h3 class="mb-0 text-success"><%= number_with_delimiter(@users.select(&:status).count) %></h3>
          </div>
          <div class="bg-success bg-opacity-10 rounded p-3">
            <i class="bi bi-check-circle text-success fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Admin Users</h6>
            <h3 class="mb-0 text-info"><%= number_with_delimiter(@users.select { |u| u.user_type == 'admin' }.count) %></h3>
          </div>
          <div class="bg-info bg-opacity-10 rounded p-3">
            <i class="bi bi-shield-check text-info fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Agent Users</h6>
            <h3 class="mb-0 text-warning"><%= number_with_delimiter(@users.select { |u| u.user_type == 'agent' }.count) %></h3>
          </div>
          <div class="bg-warning bg-opacity-10 rounded p-3">
            <i class="bi bi-person text-warning fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Filters and Search -->
<div class="card shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: admin_settings_user_roles_path, method: :get, local: true, class: "d-flex flex-wrap gap-3 align-items-end", id: "search_form" do |form| %>
      <!-- Search -->
      <div class="flex-grow-1 min-width-250">
        <%= form.text_field :search, placeholder: "Search by name or email...",
                           value: params[:search],
                           class: "form-control",
                           id: "search_input" %>
      </div>

      <!-- Actions -->
      <div class="d-flex gap-2">
        <%= link_to "Clear", admin_settings_user_roles_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<!-- Users List -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Users List</h5>
  </div>
  <div class="card-body p-0">
    <% if @users.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light">
            <tr>
              <th class="border-0">User Details</th>
              <th class="border-0">Login Credentials</th>
              <th class="border-0">Password</th>
              <th class="border-0">Role</th>
              <th class="border-0">User Type</th>
              <th class="border-0">Sidebar Permissions</th>
              <th class="border-0">Status</th>
              <th class="border-0">Created</th>
              <th class="border-0">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <tr>
                <td>
                  <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 rounded-circle p-2 me-3">
                      <i class="bi bi-person text-primary"></i>
                    </div>
                    <div>
                      <h6 class="mb-1"><%= "#{user.first_name} #{user.last_name}" %></h6>
                      <small class="text-muted">ID: <%= user.id %></small>
                    </div>
                  </div>
                </td>
                <td>
                  <div>
                    <div class="mb-2">
                      <span class="badge bg-light text-dark border">
                        <i class="bi bi-envelope me-1"></i>
                        <%= user.email %>
                      </span>
                    </div>
                    <div class="mb-1">
                      <small class="text-success">
                        <i class="bi bi-person-check me-1"></i>Username: <%= user.email %>
                      </small>
                    </div>
                    <div>
                      <small class="text-muted">
                        <i class="bi bi-telephone me-1"></i><%= user.mobile %>
                      </small>
                    </div>
                  </div>
                </td>
                <td>
                  <div>
                    <% if user.original_password.present? %>
                      <span class="badge bg-info-subtle text-info border">
                        <i class="bi bi-key me-1"></i>
                        <%= user.original_password %>
                      </span>
                      <div class="mt-1">
                        <small class="text-muted">
                          <i class="bi bi-shield-check me-1"></i>Original password
                        </small>
                      </div>
                    <% else %>
                      <span class="badge bg-secondary-subtle text-secondary">
                        <i class="bi bi-lock me-1"></i>
                        Encrypted
                      </span>
                      <div class="mt-1">
                        <small class="text-muted">Password hidden</small>
                      </div>
                    <% end %>
                  </div>
                </td>
                <td>
                  <span class="badge bg-secondary-subtle text-secondary">
                    <%= user.role_name || 'No Role' %>
                  </span>
                </td>
                <td>
                  <span class="badge bg-<%= user.user_type == 'admin' ? 'primary' : 'info' %>-subtle text-<%= user.user_type == 'admin' ? 'primary' : 'info' %>">
                    <i class="bi bi-<%= user.user_type == 'admin' ? 'shield-check' : 'person' %> me-1"></i>
                    <%= user.user_type.humanize %>
                  </span>
                </td>
                <td style="max-width: 220px;">
                  <% if user.email == 'admin@drwise.com' %>
                    <span class="badge bg-success-subtle text-success">
                      <i class="bi bi-infinity me-1"></i>Full Access
                    </span>
                  <% else %>
                    <%
                      perms_hash = user.sidebar_permissions_hash
                      granted = perms_hash.select { |_k, v| v.is_a?(Hash) && (v['view'] || v['create'] || v['edit'] || v['delete']) }
                      module_name_map = {
                        'dashboard' => 'Dashboard', 'analytics' => 'Analytics', 'leads' => 'Leads',
                        'appointments' => 'Appointments', 'customers' => 'Clients',
                        'sub_agents' => 'Affiliates', 'distributors' => 'Ambassadors',
                        'life_insurance' => 'Life Ins.', 'health_insurance' => 'Health Ins.',
                        'motor_insurance' => 'Motor Ins.', 'other_insurance' => 'General Ins.',
                        'investments' => 'Investments', 'taxation' => 'Taxation',
                        'loans' => 'Loans', 'travel' => 'Travel', 'credit_card' => 'Credit Card',
                        'brokers' => 'Broker', 'agency_codes' => 'Agency Code',
                        'payouts' => 'Commissions', 'affiliate_payouts' => 'Affiliate Payout',
                        'distributor_payouts' => 'Amb. Payout', 'invoices' => 'Invoices',
                        'reports' => 'Commission Rpt', 'all_policy_reports' => 'All Policy',
                        'profit_reports' => 'Profit Rpt', 'expired_insurance_reports' => 'Expired Ins.',
                        'upcoming_renewal_reports' => 'Renewals', 'lead_reports' => 'Lead Rpt',
                        'investors' => 'Investors', 'client_requests' => 'Client Req.',
                        'user_roles' => 'Users', 'banners' => 'Banners',
                        'insurance_companies' => 'Companies', 'management' => 'Import Data',
                        'settings' => 'Settings'
                      }
                    %>
                    <% if granted.empty? %>
                      <span class="badge bg-secondary-subtle text-secondary">
                        <i class="bi bi-slash-circle me-1"></i>No Access
                      </span>
                    <% else %>
                      <div class="d-flex flex-wrap gap-1">
                        <% granted.each do |key, v| %>
                          <%
                            is_full = v['view'] && v['create'] && v['edit'] && v['delete']
                            is_view = v['view'] && !v['create'] && !v['edit'] && !v['delete']
                            badge_class = is_full ? 'bg-success-subtle text-success' : (is_view ? 'bg-info-subtle text-info' : 'bg-warning-subtle text-warning')
                            icon = is_full ? 'bi-unlock' : (is_view ? 'bi-eye' : 'bi-sliders')
                            label = module_name_map[key] || key.humanize
                          %>
                          <span class="badge <%= badge_class %>" style="font-size: 0.7rem;"
                                title="<%= label %>: <%= is_full ? 'Full Access' : (is_view ? 'View Only' : 'Custom') %>">
                            <i class="bi <%= icon %> me-1"></i><%= label %>
                          </span>
                        <% end %>
                      </div>
                    <% end %>
                  <% end %>
                </td>
                <td>
                  <span class="badge bg-<%= user.status? ? 'success' : 'secondary' %>-subtle text-<%= user.status? ? 'success' : 'secondary' %>">
                    <i class="bi bi-<%= user.status? ? 'check-circle' : 'pause-circle' %> me-1"></i>
                    <%= user.status? ? 'Active' : 'Inactive' %>
                  </span>
                </td>
                <td>
                  <div>
                    <div><%= user.created_at.strftime("%b %d, %Y") %></div>
                    <small class="text-muted"><%= time_ago_in_words(user.created_at) %> ago</small>
                  </div>
                </td>
                <td>
                  <div class="d-flex gap-1">
                    <%= link_to admin_settings_user_role_path(user), class: "btn btn-sm btn-outline-primary", title: "View Details" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to edit_admin_settings_user_role_path(user), class: "btn btn-sm btn-outline-warning", title: "Edit User" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <%= link_to toggle_status_admin_settings_user_role_path(user),
                        method: :patch,
                        class: "btn btn-sm btn-outline-#{user.status? ? 'secondary' : 'success'}",
                        title: user.status? ? 'Deactivate' : 'Activate',
                        data: {
                          confirm: "Are you sure you want to #{user.status? ? 'deactivate' : 'activate'} this user?",
                          turbo_method: :patch
                        } do %>
                      <i class="bi bi-#{user.status? ? 'pause-circle' : 'play-circle'}"></i>
                    <% end %>
                    <%= button_to admin_settings_user_role_path(user),
                        method: :delete,
                        class: "btn btn-sm btn-outline-danger",
                        title: "Delete User",
                        data: {
                          confirm: "Are you sure you want to delete this user? This action cannot be undone."
                        },
                        form: { style: "display: inline;" } do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-people fs-1 text-muted d-block mb-3"></i>
        <h5 class="text-muted">No users found</h5>
        <p class="text-muted mb-3">
          <% if params[:search].present? %>
            No users match your search criteria.
            <%= link_to "View all users", admin_settings_user_roles_path, class: "text-decoration-none" %>.
          <% else %>
            Start by creating your first user to manage system access.
          <% end %>
        </p>
        <%= link_to new_admin_settings_user_role_path, class: "btn btn-primary" do %>
          <i class="bi bi-plus-lg me-1"></i>
          <%= params[:search].present? ? "Create User" : "Create First User" %>
        <% end %>
      </div>
    <% end %>

    <!-- Conditional Pagination -->
    <%= render 'shared/pagination', records: @users %>
  </div>
</div>

<style>
.min-width-250 {
  min-width: 250px;
}

.btn-xs {
  padding: 0.1rem 0.3rem;
  font-size: 0.7rem;
  line-height: 1.2;
  border-radius: 0.2rem;
}

</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('search_input');
  const searchForm = document.getElementById('search_form');
  let searchTimeout;

  if (searchInput) {
    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimeout);
      const searchValue = this.value;

      searchTimeout = setTimeout(() => {
        if (searchValue.length >= 3 || searchValue.length === 0) {
          searchForm.submit();
        }
      }, 500);
    });
  }

  // Initialize tooltips for sidebar permissions
  const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
  const tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
    return new bootstrap.Tooltip(tooltipTriggerEl);
  });

});
</script>