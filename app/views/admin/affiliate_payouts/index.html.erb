<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Affiliate Payouts</h2>
    <p class="text-muted mb-0">Manage affiliate commission payouts based on main agent commission payments (2% of net premium)</p>
  </div>
  <div>
    <button type="button" class="btn btn-primary me-2" onclick="openQuickPayoutModal()">
      <i class="bi bi-credit-card me-2"></i>Process Payout
    </button>
    <button type="button" class="btn btn-success" onclick="loadUnpaidAffiliatesModal()">
      <i class="bi bi-wallet2 me-2"></i>Bulk Payout Manager
    </button>
  </div>
</div>

<!-- Summary Cards -->
<div class="row mb-4">
  <div class="col-md-3">
    <div class="card border-info">
      <div class="card-body text-center">
        <h5 class="card-title text-info">Total Affiliates</h5>
        <h2 class="text-info"><%= @total_affiliates %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-success">
      <div class="card-body text-center">
        <h5 class="card-title text-success">Total Commission Earned</h5>
        <h2 class="text-success"><%= indian_currency(@total_commission_earned.round(2)) %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-warning">
      <div class="card-body text-center">
        <h5 class="card-title text-warning">Pending Amount</h5>
        <h2 class="text-warning"><%= indian_currency(@total_pending_amount.round(2)) %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-primary">
      <div class="card-body text-center">
        <h5 class="card-title text-primary">Paid Amount</h5>
        <h2 class="text-primary"><%= indian_currency(@total_paid_amount.round(2)) %></h2>
      </div>
    </div>
  </div>
</div>

<!-- Affiliate Payouts Table -->
<div class="card">
  <div class="card-header">
    <h5 class="card-title mb-0">Affiliate Commission Summary</h5>
  </div>
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead class="table-light">
          <tr>
            <th>Affiliate Name</th>
            <th>Lead IDs & Commission</th>
            <th>Total Amount (Rs.)</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if @affiliate_payouts.any? %>
            <% @affiliate_payouts.each do |affiliate_data| %>
              <tr>
                <td>
                  <div class="d-flex align-items-center">
                    <div class="avatar-sm bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3">
                      <i class="bi bi-person text-primary"></i>
                    </div>
                    <div>
                      <h6 class="mb-0"><%= affiliate_data[:affiliate].display_name %></h6>
                      <small class="text-muted"><%= affiliate_data[:affiliate].email %></small>
                    </div>
                  </div>
                </td>
                <td>
                  <button type="button"
                          class="btn btn-info btn-sm text-white mb-2"
                          onclick="showLeadsDetails('<%= affiliate_data[:affiliate].id %>')"
                          style="border-radius: 20px;">
                    <i class="bi bi-list-ul me-1"></i><%= affiliate_data[:leads].count %> leads
                  </button>
                  <br>
                  <small class="text-muted mt-1">
                    Total Commission: Rs. <%= affiliate_data[:leads].sum { |lead| lead[:commission] }.to_i.to_s.gsub(/\B(?=(\d{3})+(?!\d))/, ',') %>
                  </small>

                  <!-- Store affiliate data for JavaScript -->
                  <script type="application/json" id="affiliate-data-<%= affiliate_data[:affiliate].id %>">
                    {
                      "affiliate": {
                        "id": <%= affiliate_data[:affiliate].id %>,
                        "name": "<%= j(affiliate_data[:affiliate].display_name) %>",
                        "email": "<%= affiliate_data[:affiliate].email %>"
                      },
                      "leads": <%= affiliate_data[:leads].map do |lead_data|
                        {
                          lead: {
                            id: lead_data[:lead].try(:id),
                            lead_id: lead_data[:lead].try(:lead_id)
                          },
                          policy: {
                            id: lead_data[:policy].id,
                            policy_number: lead_data[:policy].policy_number,
                            policy_booking_date: lead_data[:policy].try(:policy_booking_date),
                            created_at: lead_data[:policy].created_at,
                            class_name: lead_data[:policy].class.name,
                            customer: {
                              id: lead_data[:policy].customer&.id,
                              first_name: lead_data[:policy].customer&.first_name,
                              last_name: lead_data[:policy].customer&.last_name,
                              display_name: lead_data[:policy].customer&.display_name,
                              email: lead_data[:policy].customer&.email
                            }
                          },
                          commission: lead_data[:commission],
                          paid: lead_data[:paid],
                          created_date: lead_data[:lead].try(:created_at)
                        }
                      end.to_json.html_safe %>
                    }
                  </script>
                </td>
                <td>
                  <span class="fw-bold text-dark">
                    <%= indian_currency(affiliate_data[:total_amount].to_i) %>
                  </span>
                  <br>
                  <small class="text-muted">
                    Paid: <%= indian_currency(affiliate_data[:paid_amount].to_i) %> |
                    Pending: <%= indian_currency(affiliate_data[:pending_amount].to_i) %>
                  </small>
                </td>
                <td>
                  <% if affiliate_data[:pending_amount] > 0 %>
                    <div class="d-flex align-items-center">
                      <span class="badge bg-warning me-2">
                        <i class="bi bi-clock me-1"></i>Pending Payment
                      </span>
                      <small class="text-muted">
                        <%= indian_currency(affiliate_data[:pending_amount].to_i) %> pending
                      </small>
                    </div>
                  <% else %>
                    <div class="d-flex align-items-center">
                      <span class="badge bg-success">
                        <i class="bi bi-check-circle me-1"></i>All Paid
                      </span>
                      <small class="text-success ms-2">Complete</small>
                    </div>
                  <% end %>
                </td>
                <td>
                  <% unpaid_leads = affiliate_data[:leads].select { |l| !l[:paid] } %>
                  <% if unpaid_leads.any? %>
                    <div class="d-flex gap-2">
                      <button type="button"
                              class="btn btn-sm btn-success"
                              onclick="openMarkAllModal(<%= affiliate_data[:affiliate].id %>, `<%= j(affiliate_data[:affiliate].display_name) %>`, <%= affiliate_data[:pending_amount].round(2) %>, <%= unpaid_leads.count %>, [<%= unpaid_leads.map { |l| "'#{l[:lead].lead_id}'" }.join(', ') %>])">
                        <i class="bi bi-check-circle me-1"></i>Mark All as Paid
                      </button>
                    </div>
                  <% else %>
                    <div class="d-flex align-items-center text-success">
                      <i class="bi bi-check-circle-fill me-2"></i>
                      <span class="fw-medium">All Paid</span>
                    </div>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="text-center py-4">
                <div class="text-center py-5">
                  <div class="mb-3">
                    <i class="bi bi-people display-1 text-muted"></i>
                  </div>
                  <h5 class="mb-3">No Affiliate Payouts Found</h5>
                  <p class="text-muted mb-4">
                    Affiliate payouts will appear here once main agent commissions are marked as received for policies with affiliates.
                  </p>
                  <p class="text-muted">
                    <strong>How it works:</strong><br>
                    1. Main agent commission must be marked as "received" for policies<br>
                    2. Policies must have an associated lead ID and affiliate<br>
                    3. Affiliate commission is calculated as 2% of net premium<br>
                    4. Payouts are grouped by affiliate showing all their lead commissions
                  </p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Help Information -->

