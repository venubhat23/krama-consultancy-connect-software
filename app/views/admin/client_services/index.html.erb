<%
  service_icon = case @service_category
    when 'taxation'    then 'bi-calculator'
    when 'loans'       then 'bi-cash-stack'
    when 'travel'      then 'bi-airplane'
    when 'credit_card' then 'bi-credit-card'
    else 'bi-briefcase'
  end
  icon_gradient = case @service_category
    when 'taxation'    then 'gradient-orange'
    when 'loans'       then 'gradient-pink'
    when 'travel'      then 'gradient-emerald'
    when 'credit_card' then 'gradient-teal'
    else 'gradient-blue'
  end
%>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">
      <i class="bi <%= service_icon %> me-2 text-primary"></i>
      <%= @page_title %>
    </h2>
    <p class="text-muted mb-0">Manage <%= @page_title %> service records</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to new_admin_client_service_path(service_type: @service_type), class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i>
      Add Record
    <% end %>
  </div>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Records</h6>
            <h3 class="mb-0 text-primary"><%= number_with_delimiter(@total_count || 0) %></h3>
            <div class="d-flex gap-2 mt-2">
              <small class="text-success"><i class="bi bi-check-circle me-1"></i>DrWise: <%= @drwise_count || 0 %></small>
              <small class="text-warning"><i class="bi bi-x-circle me-1"></i>Non-DrWise: <%= @non_drwise_count || 0 %></small>
            </div>
          </div>
          <div class="bg-primary bg-opacity-10 rounded p-3">
            <i class="bi <%= service_icon %> text-primary fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Amount</h6>
            <h3 class="mb-0 text-success"><%= indian_currency(@total_amount || 0) %></h3>
            <div class="mt-2">
              <small class="text-muted d-block">DrWise: <%= indian_currency(@drwise_amount || 0) %></small>
              <small class="text-muted d-block">Non-DrWise: <%= indian_currency(@non_drwise_amount || 0) %></small>
            </div>
          </div>
          <div class="bg-success bg-opacity-10 rounded p-3">
            <i class="bi bi-currency-rupee text-success fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Pending</h6>
            <h3 class="mb-0 text-warning"><%= @pending_count || 0 %></h3>
          </div>
          <div class="bg-warning bg-opacity-10 rounded p-3">
            <i class="bi bi-clock text-warning fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Completed</h6>
            <h3 class="mb-0 text-info"><%= @completed_count || 0 %></h3>
          </div>
          <div class="bg-info bg-opacity-10 rounded p-3">
            <i class="bi bi-check-circle text-info fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- DrWise / Non-DrWise Tabs -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body p-0">
    <ul class="nav nav-tabs border-0" role="tablist">
      <li class="nav-item" role="presentation">
        <%= link_to admin_client_services_path(params.permit!.to_h.merge(tab: 'drwise')),
            class: "nav-link #{'active' if @current_tab == 'drwise'}",
            role: "tab" do %>
          <i class="bi bi-check-circle me-2"></i>
          DrWise Records
          <span class="badge bg-success ms-2"><%= @drwise_count || 0 %></span>
        <% end %>
      </li>
      <li class="nav-item" role="presentation">
        <%= link_to admin_client_services_path(params.permit!.to_h.merge(tab: 'non_drwise')),
            class: "nav-link #{'active' if @current_tab == 'non_drwise'}",
            role: "tab" do %>
          <i class="bi bi-x-circle me-2"></i>
          Non-DrWise Records
          <span class="badge bg-warning ms-2"><%= @non_drwise_count || 0 %></span>
        <% end %>
      </li>
    </ul>
  </div>
</div>

<!-- Table Card -->
<div class="card border-0 shadow-sm">
  <!-- Filters -->
  <div class="card-body border-bottom bg-light py-3">
    <%= form_with url: admin_client_services_path, method: :get, local: true, class: "row g-2 align-items-end" do |f| %>
      <%= f.hidden_field :service_type, value: @service_type %>
      <%= f.hidden_field :tab, value: @current_tab %>

      <div class="col-md-5">
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <%= f.text_field :search, value: params[:search], placeholder: "Search by client or reference...", class: "form-control" %>
        </div>
      </div>

      <div class="col-md-3">
        <%= f.select :status,
            options_for_select([['All Status', ''], ['Pending', 'pending'], ['In Progress', 'in_progress'], ['Completed', 'completed'], ['Cancelled', 'cancelled']], params[:status]),
            {},
            { class: "form-select" } %>
      </div>

      <div class="col-md-2">
        <%= f.submit "Filter", class: "btn btn-primary w-100" %>
      </div>

      <div class="col-md-2">
        <%= link_to admin_client_services_path(service_type: @service_type), class: "btn btn-outline-secondary w-100" do %>
          <i class="bi bi-x-circle me-1"></i>Clear
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Table -->
  <div class="card-body p-0">
    <% if @client_services.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="py-3 px-4">#</th>
              <th class="py-3">Client Name</th>
              <th class="py-3">Service</th>
              <th class="py-3">Source</th>
              <th class="py-3">Affiliate</th>
              <th class="py-3">Amount</th>
              <th class="py-3">Status</th>
              <th class="py-3">Date</th>
              <th class="py-3">Ref #</th>
              <th class="py-3 text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @client_services.each_with_index do |cs, i| %>
              <tr>
                <td class="px-4 py-3 text-muted"><%= i + 1 %></td>
                <td class="py-3">
                  <div class="fw-semibold"><%= cs.customer&.display_name %></div>
                </td>
                <td class="py-3">
                  <span class="badge bg-primary bg-opacity-10 text-primary"><%= cs.service_type_label %></span>
                </td>
                <td class="py-3">
                  <% if cs.is_admin_added? %>
                    <span class="badge bg-success">DrWise</span>
                  <% else %>
                    <span class="badge bg-warning text-dark">Non-DrWise</span>
                  <% end %>
                </td>
                <td class="py-3">
                  <% if cs.sub_agent.present? %>
                    <span class="badge bg-info text-dark"><%= cs.sub_agent.display_name %></span>
                  <% else %>
                    <span class="text-muted">Self</span>
                  <% end %>
                </td>
                <td class="py-3 fw-semibold"><%= indian_currency(cs.amount) %></td>
                <td class="py-3">
                  <span class="badge <%= cs.status_badge_class %>"><%= cs.status.humanize %></span>
                </td>
                <td class="py-3"><%= cs.start_date&.strftime("%d %b %Y") || '—' %></td>
                <td class="py-3">
                  <% if cs.reference_number.present? %>
                    <code><%= cs.reference_number %></code>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
                <td class="py-3 text-center">
                  <div class="btn-group btn-group-sm">
                    <%= link_to admin_client_service_path(cs), class: "btn btn-outline-primary", title: "View" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to edit_admin_client_service_path(cs), class: "btn btn-outline-secondary", title: "Edit" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <%= button_to admin_client_service_path(cs),
                        method: :delete,
                        data: { confirm: "Delete this record?" },
                        class: "btn btn-outline-danger",
                        title: "Delete",
                        form: { style: "display: inline;" } do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="card-footer bg-white">
        <%= render 'shared/pagination', collection: @client_services %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi <%= service_icon %> text-muted" style="font-size: 4rem;"></i>
        <h5 class="text-muted mt-3">No records found</h5>
        <p class="text-muted">
          <% if params[:search].present? || params[:status].present? %>
            Try adjusting your search filters.
          <% else %>
            Click "Add Record" to create the first entry.
          <% end %>
        </p>
        <%= link_to new_admin_client_service_path(service_type: @service_type), class: "btn btn-primary mt-2" do %>
          <i class="bi bi-plus-lg me-1"></i>Add Record
        <% end %>
      </div>
    <% end %>
  </div>
</div>
