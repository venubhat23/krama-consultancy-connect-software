<%
  service_label = ClientService::SERVICE_TYPES[@client_service.service_type] || @client_service.service_type&.humanize || 'New Service'
%>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">
      <i class="bi bi-plus-circle me-2 text-primary"></i>
      New <%= service_label %> Record
    </h2>
    <p class="text-muted mb-0">Create a new <%= service_label.downcase %> record for a client</p>
  </div>
  <%= link_to admin_client_services_path(service_type: @client_service.service_type), class: "btn btn-outline-secondary" do %>
    <i class="bi bi-arrow-left me-1"></i>Back
  <% end %>
</div>

<%= render 'form' %>
