<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">
      <i class="bi bi-briefcase me-2 text-primary"></i>
      <%= @client_service.service_type_label %>
    </h2>
    <p class="text-muted mb-0"><%= @client_service.customer&.display_name %></p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_client_service_path(@client_service), class: "btn btn-outline-secondary" do %>
      <i class="bi bi-pencil me-1"></i>Edit
    <% end %>
    <%= link_to admin_client_services_path(service_type: @client_service.service_type), class: "btn btn-outline-primary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back
    <% end %>
  </div>
</div>

<!-- Summary Cards -->
<div class="row mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm text-center p-3">
      <div class="text-muted small mb-1">Status</div>
      <span class="badge <%= @client_service.status_badge_class %> fs-6"><%= @client_service.status.humanize %></span>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm text-center p-3">
      <div class="text-muted small mb-1">Amount</div>
      <div class="fw-bold text-success fs-5"><%= indian_currency(@client_service.amount) %></div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm text-center p-3">
      <div class="text-muted small mb-1">Affiliate</div>
      <div class="fw-semibold"><%= @client_service.sub_agent&.display_name || 'Self' %></div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm text-center p-3">
      <div class="text-muted small mb-1">Start Date</div>
      <div class="fw-semibold"><%= @client_service.start_date&.strftime('%d %b %Y') || '—' %></div>
    </div>
  </div>
</div>

<!-- Details Card -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white">
    <h5 class="mb-0"><i class="bi bi-info-circle me-2 text-primary"></i>Service Details</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="text-muted small">Client</label>
        <div class="fw-semibold"><%= @client_service.customer&.display_name %></div>
      </div>
      <div class="col-md-6 mb-3">
        <label class="text-muted small">Service Type</label>
        <div class="fw-semibold"><%= @client_service.service_type_label %></div>
      </div>
      <div class="col-md-6 mb-3">
        <label class="text-muted small">Reference Number</label>
        <div class="fw-semibold"><%= @client_service.reference_number.presence || '—' %></div>
      </div>
      <div class="col-md-6 mb-3">
        <label class="text-muted small">Category</label>
        <div class="fw-semibold"><%= @client_service.category_label %></div>
      </div>
      <% if @client_service.notes.present? %>
        <div class="col-12 mb-3">
          <label class="text-muted small">Notes</label>
          <div class="fw-semibold"><%= @client_service.notes %></div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Commission Summary -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white">
    <h5 class="mb-0"><i class="bi bi-calculator me-2 text-primary"></i>Commission Summary</h5>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table mb-0">
        <thead class="table-light">
          <tr>
            <th>Commission Details</th>
            <th class="text-center">%</th>
            <th class="text-center">Amount</th>
            <th class="text-center">TDS %</th>
            <th class="text-center">TDS Amount</th>
            <th class="text-center">Actual Amount</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="fw-bold bg-light">Main Agent</td>
            <td class="text-center"><%= @client_service.main_agent_commission_percentage %>%</td>
            <td class="text-center"><%= indian_currency(@client_service.commission_amount) %></td>
            <td class="text-center"><%= @client_service.tds_percentage %>%</td>
            <td class="text-center"><%= indian_currency(@client_service.tds_amount) %></td>
            <td class="text-center fw-bold text-success"><%= indian_currency(@client_service.after_tds_value) %></td>
          </tr>
          <tr>
            <td class="fw-bold">Affiliate</td>
            <td class="text-center"><%= @client_service.sub_agent_commission_percentage %>%</td>
            <td class="text-center"><%= indian_currency(@client_service.sub_agent_commission_amount) %></td>
            <td class="text-center"><%= @client_service.sub_agent_tds_percentage %>%</td>
            <td class="text-center"><%= indian_currency(@client_service.sub_agent_tds_amount) %></td>
            <td class="text-center fw-bold text-primary"><%= indian_currency(@client_service.sub_agent_after_tds_value) %></td>
          </tr>
          <tr>
            <td class="fw-bold">Ambassador</td>
            <td class="text-center"><%= @client_service.distributor_commission_percentage %>%</td>
            <td class="text-center"><%= indian_currency(@client_service.distributor_commission_amount) %></td>
            <td class="text-center"><%= @client_service.distributor_tds_percentage %>%</td>
            <td class="text-center"><%= indian_currency(@client_service.distributor_tds_amount) %></td>
            <td class="text-center fw-bold text-warning"><%= indian_currency(@client_service.distributor_after_tds_value) %></td>
          </tr>
          <tr>
            <td class="fw-bold">Investor</td>
            <td class="text-center"><%= @client_service.investor_commission_percentage %>%</td>
            <td class="text-center"><%= indian_currency(@client_service.investor_commission_amount) %></td>
            <td class="text-center text-muted">—</td>
            <td class="text-center text-muted">—</td>
            <td class="text-center fw-bold"><%= indian_currency(@client_service.investor_commission_amount) %></td>
          </tr>
          <tr>
            <td class="fw-bold">Company</td>
            <td class="text-center"><%= @client_service.company_expenses_percentage %>%</td>
            <td class="text-center"><%= indian_currency(@client_service.company_expenses_amount) %></td>
            <td class="text-center text-muted">—</td>
            <td class="text-center text-muted">—</td>
            <td class="text-center fw-bold"><%= indian_currency(@client_service.company_expenses_amount) %></td>
          </tr>
          <tr class="table-success">
            <td class="fw-bold">Profit</td>
            <td class="text-center fw-bold"><%= @client_service.profit_percentage %>%</td>
            <td class="text-center fw-bold"><%= indian_currency(@client_service.profit_amount) %></td>
            <td class="text-center text-muted">—</td>
            <td class="text-center text-muted">—</td>
            <td class="text-center fw-bold text-success"><%= indian_currency(@client_service.profit_amount) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
