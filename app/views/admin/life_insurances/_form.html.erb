  // Function to setup preview functionality for dynamically added documents
  function setupDocumentPreview(index) {
    const fileInput = document.getElementById(`doc_file_${index}`);
    const previewContainer = document.getElementById(`doc_preview_${index}`);

    if (!fileInput || !previewContainer) return;

    fileInput.addEventListener('change', function(e) {
      const file = e.target.files[0];

      if (!file) {
        previewContainer.style.display = 'none';
        return;
      }

      // Validate file size (10MB limit)
      if (file.size > 10 * 1024 * 1024) {
        showError(fileInput, 'File size exceeds 10MB limit');
        fileInput.value = '';
        previewContainer.style.display = 'none';
        return;
      }

      showDocumentPreview(file, previewContainer);
    });

    // Remove file button
    previewContainer.querySelector('.remove-file')?.addEventListener('click', function() {
      fileInput.value = '';
      previewContainer.style.display = 'none';
    });
  }

  function showDocumentPreview(file, previewContainer) {
    const imagePreview = previewContainer.querySelector('.image-preview');
    const documentPreview = previewContainer.querySelector('.document-preview');
    const fileNameElement = previewContainer.querySelector('.file-name-detail');
    const fileSizeElement = previewContainer.querySelector('.file-size-detail');

    // Hide both previews initially
    imagePreview.style.display = 'none';
    documentPreview.style.display = 'none';

    // Show preview container
    previewContainer.style.display = 'block';

    // Update file details
    if (fileNameElement) fileNameElement.textContent = file.name;
    if (fileSizeElement) fileSizeElement.textContent = formatFileSize(file.size);

    // Check if file is an image
    if (file.type && file.type.startsWith('image/')) {
      showImagePreview(file, imagePreview);
    } else {
      showDocPreview(file, documentPreview);
    }

    // Add smooth animation
    previewContainer.style.opacity = '0';
    setTimeout(() => {
      previewContainer.style.transition = 'opacity 0.3s ease';
      previewContainer.style.opacity = '1';
    }, 10);
  }

  function showImagePreview(file, container) {
    const reader = new FileReader();
    reader.onload = function(e) {
      const img = container.querySelector('.preview-image');
      img.src = e.target.result;
      container.style.display = 'block';
    };
    reader.readAsDataURL(file);
  }

  function showDocPreview(file, container) {
    const fileIcon = container.querySelector('.file-icon');
    const fileName = container.querySelector('.file-name');
    const fileType = container.querySelector('.file-type');

    fileName.textContent = file.name;
    fileType.textContent = file.type || 'Unknown type';

    // Set appropriate icon
    fileIcon.className = 'file-icon bi fs-3 me-2 ' + getFileIcon(file.type || file.name);

    container.style.display = 'block';
  }

  function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }

  function getFileIcon(fileType) {
    if (fileType.includes('pdf')) return 'bi-file-earmark-pdf text-danger';
    if (fileType.includes('word') || fileType.includes('document')) return 'bi-file-earmark-word text-primary';
    if (fileType.includes('excel') || fileType.includes('spreadsheet')) return 'bi-file-earmark-excel text-success';
    if (fileType.includes('image')) return 'bi-file-earmark-image text-info';
    return 'bi-file-earmark text-muted';
  }

  // R2 Main Policy Document Delete Function
  function deleteMainPolicyDocument() {
    if (confirm('Are you sure you want to delete this main policy document from R2 storage?')) {
      const form = document.createElement('form');
      form.method = 'PATCH';
      form.action = '<%= admin_life_insurance_path(@life_insurance) if @life_insurance.persisted? %>';
      form.style.display = 'none';

      const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
      const csrfInput = document.createElement('input');
      csrfInput.type = 'hidden';
      csrfInput.name = 'authenticity_token';
      csrfInput.value = csrfToken;

      const deleteInput = document.createElement('input');
      deleteInput.type = 'hidden';
      deleteInput.name = 'delete_main_policy_document';
      deleteInput.value = 'true';

      form.appendChild(csrfInput);
      form.appendChild(deleteInput);
      document.body.appendChild(form);
      form.submit();
    }
  }

