<script>
document.addEventListener('DOMContentLoaded', function() {

  // Insurance Company Name to Code mapping
  const companyCodeMapping = {
    <% InsuranceCompany.all.each do |company| %>
      '<%= company.name %>': '<%= company.code %>',
    <% end %>
  };

  // Handle insurance company selection to auto-populate code
  const companySelect = document.getElementById('life_insurance_insurance_company_name');
  const companyCodeField = document.getElementById('life_insurance_insurance_company_code');

  if (companySelect && companyCodeField) {
    companySelect.addEventListener('change', function() {
      const selectedCompany = this.value;
      const companyCode = companyCodeMapping[selectedCompany] || '';
      companyCodeField.value = companyCode;
      console.log('Selected company:', selectedCompany, '-> Code:', companyCode);
    });

    // Set initial value if company is already selected
    if (companySelect.value) {
      const companyCode = companyCodeMapping[companySelect.value] || '';
      companyCodeField.value = companyCode;
    }
  }


  // Function to load policy holder options when customer changes
  function loadPolicyHolderOptions() {
    const customerId = $('#customer_select').val();
    console.log('🔄 Loading policy holder options for customer:', customerId);

    const policyHolderSelect = $('#policy_holder_select');

    if (!customerId) {
      // Reset to just 'Self' option if no customer selected
      policyHolderSelect.empty();
      policyHolderSelect.append('<option value="">Select Policy Holder</option>');
      policyHolderSelect.append('<option value="Self">Self</option>');
      policyHolderSelect.trigger('change.select2'); // Refresh Select2
      return;
    }

    // Make AJAX call to get customer family members
    $.ajax({
      url: '<%= customer_family_members_admin_life_insurances_path %>',
      method: 'GET',
      data: { customer_id: customerId },
      dataType: 'json',
      beforeSend: function() {
        policyHolderSelect.prop('disabled', true);
        policyHolderSelect.empty();
        policyHolderSelect.append('<option value="">Loading...</option>');
        policyHolderSelect.trigger('change.select2');
      },
      success: function(response) {
        console.log('✅ Policy holder options loaded:', response);
        policyHolderSelect.empty();

        // Always add Self option first
        policyHolderSelect.append('<option value="Self">Self</option>');

        if (response.success && response.options) {
          response.options.forEach(function(option) {
            // Skip the Self option if it's in the response (we already added it)
            if (option.value !== 'Self') {
              policyHolderSelect.append(`<option value="${option.value}">${option.text}</option>`);
            }
          });
        }

        policyHolderSelect.prop('disabled', false);
        policyHolderSelect.trigger('change.select2'); // Refresh Select2

        // Set default to Self if nothing was previously selected
        if (!policyHolderSelect.val()) {
          policyHolderSelect.val('Self').trigger('change.select2');
        }
      },
      error: function(xhr, status, error) {
        console.error('❌ Error loading policy holder options:', error);
        policyHolderSelect.empty();
        policyHolderSelect.append('<option value="">Select Policy Holder</option>');
        policyHolderSelect.append('<option value="Self">Self</option>');
        policyHolderSelect.prop('disabled', false);
        policyHolderSelect.trigger('change.select2');
      }
    });
  }

  // Initialize tooltips if Bootstrap is available
  if (typeof bootstrap !== 'undefined' && bootstrap.Tooltip) {
    const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-toggle="tooltip"]'));
    tooltipTriggerList.map(function (tooltipTriggerEl) {
      return new bootstrap.Tooltip(tooltipTriggerEl);
    });
  }
  // Initialize Select2 for searchable dropdown
  $('#customer_select').select2({
    theme: 'bootstrap-5',
    placeholder: 'Search and select client...',
    allowClear: true,
    width: '100%',
    dropdownParent: $('body'),
    dropdownCssClass: 'select2-dropdown-large',
    minimumResultsForSearch: 0,
    closeOnSelect: true,
    templateResult: function(option) {
      if (!option.id || option.element.value === '') {
        return option.text;
      }

      // Generate avatar with initials
      var initials = option.text.split(' ').map(function(name) {
        return name.charAt(0).toUpperCase();
      }).join('').substring(0, 2);

      // Custom template for dropdown options with avatar
      var $option = $(
        '<div class="client-option">' +
          '<div class="client-option-avatar">' + initials + '</div>' +
          '<div class="client-option-details">' +
            '<div class="client-option-name">' + option.text + '</div>' +
            '<div class="client-option-id">Client ID: #' + option.id + '</div>' +
          '</div>' +
