      calculateProfitAndExpenses();
      console.log('✅ All commission calculations completed successfully');
    } catch (error) {
      console.error('❌ Error in calculateAllCommissions:', error);
    }
  }

  // Auto-calculate autopay end date based on payment mode
  function calculateAutopayEndDate() {
    const paymentMode = document.getElementById('payment_mode_select').value;
    const startDate = document.getElementById('autopay_start_date').value;

    if (startDate && paymentMode) {
      const start = new Date(startDate);
      const end = new Date(start);

      // Calculate end date based on payment mode
      switch (paymentMode) {
        case 'Yearly':
          end.setFullYear(end.getFullYear() + 1);
          end.setDate(end.getDate() - 1); // Subtract 1 day to make it end on the day before anniversary
          break;
        case 'Half-Yearly':
          end.setMonth(end.getMonth() + 6);
          end.setDate(end.getDate() - 1);
          break;
        case 'Quarterly':
          end.setMonth(end.getMonth() + 3);
          end.setDate(end.getDate() - 1);
          break;
        case 'Monthly':
          end.setMonth(end.getMonth() + 1);
          end.setDate(end.getDate() - 1);
          break;
        case 'Single':
          // For single payment, autopay end date is the same as start date
          end.setTime(start.getTime());
          break;
        default:
          // Default to yearly if no mode selected
          end.setFullYear(end.getFullYear() + 1);
          end.setDate(end.getDate() - 1);
          break;
      }

      document.getElementById('autopay_end_date').value = end.toISOString().split('T')[0];
    }
  }

  // Update autopay start date when policy start date changes
  function updateAutopayStartDate() {
    const policyStartDate = document.getElementById('start_date').value;
    if (policyStartDate) {
      document.getElementById('autopay_start_date').value = policyStartDate;
      calculateAutopayEndDate(); // Recalculate end date
    }
  }

  // Auto-calculate end date based on start date and default to 1 year
  function calculateEndDate() {
    const startDate = document.getElementById('start_date').value;

    if (startDate) {
      const start = new Date(startDate);
      const end = new Date(start);

      // Default to 1 year policy term
      end.setFullYear(end.getFullYear() + 1);

      // Set end date to one day before the renewal date
      end.setDate(end.getDate() - 1);

      document.getElementById('end_date').value = end.toISOString().split('T')[0];
    }
  }

  // Load customer family members for policy holder options
  function loadCustomerFamilyMembers(customerId) {
    const policyHolderSelect = document.getElementById('policy_holder_select');
    if (!policyHolderSelect || !customerId) return;

    console.log(`🔄 Loading family members for customer ID: ${customerId}`);
    // Show loading state
    policyHolderSelect.innerHTML = '<option value="">Loading family members...</option>';

    // Get CSRF token for authenticated request
    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');

    fetch(`/admin/insurance/life/customer_family_members?customer_id=${customerId}`, {
      method: 'GET',
      headers: {
        'Accept': 'application/json',
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': csrfToken
      },
      credentials: 'same-origin'
    })
      .then(response => {
        console.log(`📡 Response status: ${response.status}`);
        return response.json();
      })
      .then(data => {
        console.log('📡 Response data:', data);
        if (data.success) {
          // Clear existing options
          policyHolderSelect.innerHTML = '<option value="">Select Policy Holder</option>';

          // Add new options
          data.options.forEach(option => {
            const optionElement = document.createElement('option');
            optionElement.value = option.value;
            optionElement.textContent = option.text;
            policyHolderSelect.add(optionElement);
            console.log(`✅ Added option: ${option.text}`);
          });

          console.log(`✅ Loaded ${data.options.length} policy holder options for ${data.customer_name}`);
        } else {
          console.error('❌ Failed to load family members:', data.message);
          // Fallback to Self only
          policyHolderSelect.innerHTML = '<option value="">Select Policy Holder</option><option value="Self">Self</option>';
        }
      })
      .catch(error => {
        console.error('❌ Error loading family members:', error);
        // Fallback to Self only
        policyHolderSelect.innerHTML = '<option value="">Select Policy Holder</option><option value="Self">Self</option>';
      });
  }

