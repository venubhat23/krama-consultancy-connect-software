                <div class="card-header bg-transparent border-0">
                  <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-success">
                      <i class="bi bi-cloud-check me-2"></i>
                      R2 Policy Documents
                    </h5>
                    <span class="badge bg-success"><%= @life_insurance.policy_documents_records.count %> files</span>
                  </div>
                </div>
                <div class="card-body p-0">
                  <div class="list-group list-group-flush">
                    <% @life_insurance.policy_documents_records.each_with_index do |document, index| %>
                      <div class="list-group-item border-0 <%= 'border-bottom' unless index == @life_insurance.policy_documents_records.count - 1 %>">
                        <div class="d-flex align-items-center py-2">
                          <div class="flex-shrink-0 me-4">
                            <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                              <i class="bi bi-file-earmark-pdf text-success fs-4"></i>
                            </div>
                          </div>
                          <div class="flex-grow-1">
