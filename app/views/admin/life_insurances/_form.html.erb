  // Function to manually load nominees from customer
  window.loadNomineesFromCustomer = function() {
    const customerSelect = document.getElementById('customer_select');
    const customerId = customerSelect ? customerSelect.value : null;

    if (!customerId) {
      alert('Please select a client first');
      return;
    }

    // Show loading state on button
    const btn = document.getElementById('load_customer_nominees_btn');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Loading...';
    btn.disabled = true;

    $.ajax({
      url: '<%= load_customer_nominees_admin_life_insurances_path %>',
      method: 'GET',
      data: { customer_id: customerId },
      success: function(response) {
        if (response.success && response.nominees && response.nominees.length > 0) {
          clearNominees();
          response.nominees.forEach(function(nominee) {
            addNomineeFromFamilyMember(nominee);
          });
          toggleNoNomineesMessage();
          alert(`Successfully loaded ${response.nominees.length} nominee(s) from client's family members.`);
        } else {
          // Enhanced error message with debug information
          let debugMessage = 'No family members found for this client.';
          if (response.debug) {
            debugMessage += `\n\nDebug Info:`;
            debugMessage += `\n- Total family members: ${response.debug.total_family_members}`;
            debugMessage += `\n- Valid nominees: ${response.debug.valid_nominees}`;

            if (response.debug.family_members_debug && response.debug.family_members_debug.length > 0) {
              debugMessage += `\n\nFamily Members Analysis:`;
              response.debug.family_members_debug.forEach((member, index) => {
                debugMessage += `\n${index + 1}. Name: "${member.name}" (Valid: ${member.name_present && member.name_length > 0 && !member.is_number})`;
                debugMessage += `\n   - Name present: ${member.name_present}`;
                debugMessage += `\n   - Name length: ${member.name_length}`;
                debugMessage += `\n   - Is number: ${member.is_number}`;
                debugMessage += `\n   - Relationship: ${member.relationship}`;
                debugMessage += `\n   - Age: ${member.age}`;
              });
            }
          }
          console.log('Load nominees debug:', response);
          alert(debugMessage);
        }

        // Restore button state
        btn.innerHTML = originalText;
        btn.disabled = false;
      },
      error: function(xhr, status, error) {
        console.error('Error loading customer nominees:', error);
        alert('Error loading nominees. Please try again.');

        // Restore button state
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    });
  }

