          <div class="col-md-4 mb-3">
            <label class="form-label">Nominee Name <span class="text-danger">*</span></label>
            <input class="form-control" placeholder="Enter nominee name" required="required" type="text" name="life_insurance[life_insurance_nominees_attributes][${index}][nominee_name]" id="life_insurance_life_insurance_nominees_attributes_${index}_nominee_name">
          </div>
          <div class="col-md-3 mb-3">
            <label class="form-label">Relationship <span class="text-danger">*</span></label>
            <select class="form-control" required="required" name="life_insurance[life_insurance_nominees_attributes][${index}][relationship]" id="life_insurance_life_insurance_nominees_attributes_${index}_relationship">
              <option value="">Select Relationship</option>
              <option value="spouse">Spouse</option>
              <option value="son">Son</option>
              <option value="daughter">Daughter</option>
              <option value="father">Father</option>
              <option value="mother">Mother</option>
              <option value="brother">Brother</option>
              <option value="sister">Sister</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="col-md-2 mb-3">
            <label class="form-label">Age <span class="text-danger">*</span></label>
            <input class="form-control" placeholder="Age" required="required" min="0" max="120" type="number" name="life_insurance[life_insurance_nominees_attributes][${index}][age]" id="life_insurance_life_insurance_nominees_attributes_${index}_age">
          </div>
          <div class="col-md-2 mb-3">
            <label class="form-label">Share (%)</label>
            <input class="form-control" placeholder="100" min="0" max="100" step="0.01" type="number" name="life_insurance[life_insurance_nominees_attributes][${index}][share_percentage]" id="life_insurance_life_insurance_nominees_attributes_${index}_share_percentage">
          </div>
          <div class="col-md-1 mb-3 d-flex align-items-end">
            <button type="button" class="btn btn-danger btn-sm" onclick="removeNominee(this)" title="Remove nominee">
              <i class="bi bi-trash"></i>
            </button>
          </div>
        </div>
        <input value="false" class="destroy-flag" type="hidden" name="life_insurance[life_insurance_nominees_attributes][${index}][_destroy]" id="life_insurance_life_insurance_nominees_attributes_${index}__destroy">
      </div>
    `;

    document.getElementById('nominees-container').insertAdjacentHTML('beforeend', nomineeHtml);
    toggleNoNomineesMessage();
  }

  // Function to remove nominee
  window.removeNominee = function(button) {
    const nomineeRow = button.closest('.nominee-row');
    const destroyField = nomineeRow.querySelector('.destroy-flag');

    if (destroyField && destroyField.value === 'false') {
      destroyField.value = 'true';
      nomineeRow.style.display = 'none';
    } else {
      nomineeRow.remove();
    }

    toggleNoNomineesMessage();
  }

  // Initial call to set correct message state
  toggleNoNomineesMessage();

});
</script>

