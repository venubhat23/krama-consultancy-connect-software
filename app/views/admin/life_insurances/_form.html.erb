            <!-- Company -->
            <tr class="border-bottom">
              <td class="py-3 px-4 fw-bold text-dark">Company</td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :company_expenses_percentage,
                    class: "form-control border-1 text-center fw-bold shadow-sm company-expenses-percentage",
                    value: @life_insurance.company_expenses_percentage || 0,
                    step: 0.01, min: 0, max: 100, style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <input type="number" class="form-control border-1 text-center company-expenses-amount"
                       value="0.00" step="0.01" readonly style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
              </td>
              <td class="py-2 px-3 text-center fw-bold text-muted">—</td>
              <td class="py-2 px-3 text-center fw-bold text-muted">—</td>
              <td class="py-2 px-1 text-center" style="background: #f8f9fa;">
                <input type="number" class="form-control border-1 text-center fw-bold fs-6 company-expenses-amount-display"
                       value="0.00" step="0.01" readonly style="background: #f8f9fa; border-color: #dee2e6; color: #495057;">
              </td>
            </tr>

            <!-- Profit -->
            <tr class="border-bottom" style="background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 50%);">
              <td class="py-3 px-4 fw-bold text-dark bg-warning bg-opacity-25">Profit</td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :profit_percentage,
                    class: "form-control border-1 text-center fw-bold shadow-sm profit-percentage",
                    value: @life_insurance.profit_percentage || 0,
                    step: 0.01, readonly: true, style: "background: #fff3cd; border-color: #ffc107; color: #856404;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :profit_amount,
                    class: "form-control border-1 text-center fw-bold profit-amount",
                    value: @life_insurance.profit_amount || 0,
                    step: 0.01, readonly: true, style: "background: #fff3cd; border-color: #ffc107; color: #856404;" %>
              </td>
              <td class="py-2 px-3 text-center fw-bold text-muted">—</td>
              <td class="py-2 px-3 text-center fw-bold text-muted">—</td>
              <td class="py-2 px-1 text-center" style="background: #fff3cd;">
                <%= form.number_field :profit_amount,
                    class: "form-control border-1 text-center fw-bold fs-6 profit-amount-display",
                    value: @life_insurance.profit_amount || 0,
                    step: 0.01, readonly: true, style: "background: #fff3cd; border-color: #ffc107; color: #856404;" %>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Hidden fields for compatibility -->
      <%= form.hidden_field :total_distribution_percentage, class: "total-distribution-percentage" %>
      <%= form.hidden_field :investor_tds_percentage, value: 0, class: "investor-tds-percentage" %>
    </div>
  </div>
  <% end %>

  <!-- Policy Upload Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-cloud-upload me-2 text-primary"></i>
        Policy Documents Manager
      </h5>
      <small class="text-muted">Upload, organize and manage all policy-related documents with secure storage</small>
    </div>
    <div class="card-body p-4">
      <!-- R2 Main Policy Document Upload -->
      <div class="row mb-4">
        <div class="col-md-12">
          <div class="border border-success border-2 rounded p-4" style="background-color: #f0fff0;">
            <%= form.label :main_policy_document, class: "form-label fw-bold" do %>
              <i class="bi bi-cloud-upload me-2 text-success"></i>
              Main Policy Document (R2 Storage)
            <% end %>

            <!-- Current R2 Document Display -->
            <% if @life_insurance.has_main_policy_r2_document? %>
              <div class="current-document mb-3 p-3 border rounded bg-white">
                <div class="row align-items-center">
                  <div class="col-auto">
                    <% if @life_insurance.main_policy_document_content_type&.start_with?('image/') %>
                      <%= image_tag @life_insurance.main_policy_r2_document_url, class: "img-thumbnail",
                          style: "width: 60px; height: 60px; object-fit: cover;" %>
                    <% elsif @life_insurance.main_policy_document_content_type == 'application/pdf' %>
                      <div class="bg-danger text-white rounded d-flex align-items-center justify-content-center"
                           style="width: 60px; height: 60px;">
                        <i class="bi bi-file-earmark-pdf fs-4"></i>
                      </div>
                    <% else %>
                      <div class="bg-secondary text-white rounded d-flex align-items-center justify-content-center"
                           style="width: 60px; height: 60px;">
                        <i class="bi bi-file-earmark fs-4"></i>
                      </div>
                    <% end %>
                  </div>
                  <div class="col">
                    <div class="fw-medium"><%= @life_insurance.main_policy_document_filename %></div>
                    <small class="text-muted">
                      <%= (@life_insurance.main_policy_document_size / 1024.0 / 1024.0).round(2) %> MB •
                      <%= @life_insurance.main_policy_document_content_type %>
                    </small>
                    <div>
                      <small class="text-success">
                        <i class="bi bi-cloud-check me-1"></i>
                        Stored in Cloudflare R2
                      </small>
                    </div>
                  </div>
                  <div class="col-auto">
                    <div class="d-flex gap-1">
                      <%= link_to @life_insurance.main_policy_r2_url, class: "btn btn-sm btn-outline-primary",
                          target: "_blank", title: "View" do %>
                        <i class="bi bi-eye"></i>
                      <% end %>
                      <button type="button" class="btn btn-sm btn-outline-danger"
                              onclick="deleteMainPolicyDocument()" title="Delete Document">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
              <div class="mb-2">
                <small class="text-muted">
                  <strong>Replace document:</strong> Upload a new file to replace the current document
                </small>
              </div>
            <% end %>

            <%= form.file_field :main_policy_document,
                class: "form-control",
                accept: "application/pdf,image/jpeg,image/jpg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" %>
            <div class="form-text mt-2">
              <i class="bi bi-info-circle me-1"></i>
              <strong>Secure R2 Storage:</strong> Supports PDF, JPEG, PNG, Word files (Max: 10MB) -
              <% if @life_insurance.has_main_policy_r2_document? %>
                upload new file to replace existing document
              <% else %>
                files stored securely in Cloudflare R2
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-md-12 mb-4">
          <div class="border border-secondary border-2 rounded p-4" style="background-color: #f8f9fa;">
            <%= form.label :documents, class: "form-label fw-bold" do %>
              <i class="bi bi-file-earmark-plus me-2 text-secondary"></i>
              Additional Documents
              <span class="badge bg-secondary ms-2">Optional</span>
            <% end %>
            <%= form.file_field :documents,
                class: "form-control",
                multiple: true,
                id: "additional_documents_upload",
                accept: "application/pdf,image/jpeg,image/jpg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" %>
            <div class="form-text mt-2">
              <i class="bi bi-info-circle me-1"></i>
              Supports PDF, Images, Word files - Identity proofs, Medical reports, etc.
            </div>
          </div>

          <!-- Additional Documents Preview -->
          <%= render 'shared/file_upload_preview',
                     field_id: 'additional_documents_upload',
                     preview_id: 'additional_documents_preview',
                     accept: 'application/pdf,image/jpeg,image/jpg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document',
                     show_file_info: true,
                     max_file_size: '10MB' %>
        </div>
      </div>

      <!-- Existing Documents (Edit Mode) -->
      <% if @life_insurance.persisted? %>
        <%
          total_documents = @life_insurance.uploaded_documents.count +
                           @life_insurance.policy_documents_records.count +
                           @life_insurance.life_insurance_documents.count

          total_size = 0
          total_size += @life_insurance.uploaded_documents.sum { |doc| doc.file&.byte_size || 0 }
          total_size += @life_insurance.policy_documents_records.sum { |doc| doc.r2_file_size || 0 }
          total_size += @life_insurance.life_insurance_documents.sum { |doc| doc.r2_file_size || 0 }

          document_types = []
          document_types += @life_insurance.uploaded_documents.pluck(:document_type).compact.uniq
          document_types += ['Policy Document'] if @life_insurance.policy_documents_records.any?
          document_types += ['Life Insurance Document'] if @life_insurance.life_insurance_documents.any?
          document_types = document_types.uniq

          recent_docs = @life_insurance.uploaded_documents.where('created_at > ?', 7.days.ago).count
        %>

        <% if total_documents > 0 %>
          <div class="border-top pt-4 mt-4">
            <!-- Document Overview Statistics -->
            <div class="row mb-4">
              <div class="col-xl-3 col-md-6 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                  <div class="card-body">
                    <div class="d-flex justify-content-between">
                      <div>
                        <h6 class="text-muted mb-2">Total Documents</h6>
                        <h3 class="mb-0 text-primary"><%= total_documents %></h3>
                      </div>
                      <div class="bg-primary bg-opacity-10 rounded p-3">
                        <i class="bi bi-files text-primary fs-4"></i>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="col-xl-3 col-md-6 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                  <div class="card-body">
                    <div class="d-flex justify-content-between">
                      <div>
                        <h6 class="text-muted mb-2">Document Types</h6>
                        <h3 class="mb-0 text-info"><%= document_types.count %></h3>
                      </div>
                      <div class="bg-info bg-opacity-10 rounded p-3">
                        <i class="bi bi-collection text-info fs-4"></i>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="col-xl-3 col-md-6 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                  <div class="card-body">
                    <div class="d-flex justify-content-between">
                      <div>
                        <h6 class="text-muted mb-2">Total Size</h6>
                        <h3 class="mb-0 text-success"><%= number_to_human_size(total_size) %></h3>
                      </div>
                      <div class="bg-success bg-opacity-10 rounded p-3">
                        <i class="bi bi-hdd-stack text-success fs-4"></i>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="col-xl-3 col-md-6 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                  <div class="card-body">
                    <div class="d-flex justify-content-between">
                      <div>
                        <h6 class="text-muted mb-2">Recent (7 days)</h6>
                        <h3 class="mb-0 text-warning"><%= recent_docs %></h3>
                      </div>
                      <div class="bg-warning bg-opacity-10 rounded p-3">
                        <i class="bi bi-clock text-warning fs-4"></i>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Main Document System -->
            <% if @life_insurance.uploaded_documents.any? || @life_insurance.policy_documents_records.any? || @life_insurance.life_insurance_documents.any? %>
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent border-0">
                  <h5 class="mb-0 text-primary">
                    <i class="bi bi-folder2-open me-2"></i>
                    Policy Documents
                  </h5>
                </div>
                <div class="card-body p-0">
                  <!-- List View -->
                  <div class="documents-list-view">
                    <div class="list-group list-group-flush">
                      <% @life_insurance.uploaded_documents.each_with_index do |document, index| %>
                        <div class="list-group-item border-0 <%= 'border-bottom' unless index == @life_insurance.uploaded_documents.count - 1 %>">
                          <div class="d-flex align-items-center py-2">
                            <!-- Document Icon -->
                            <div class="flex-shrink-0 me-4">
                              <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                <i class="bi bi-<%= document.file_icon %> text-primary fs-4"></i>
                              </div>
                            </div>

                            <!-- Document Details -->
                            <div class="flex-grow-1">
                              <div class="d-flex justify-content-between align-items-start">
                                <div>
                                  <h6 class="mb-1 fw-bold"><%= document.title %></h6>
                                  <div class="mb-2">
                                    <span class="badge bg-light text-dark me-2"><%= document.human_document_type %></span>
                                    <% if document.file&.byte_size %>
                                      <span class="text-muted small">
                                        <i class="bi bi-file-earmark me-1"></i><%= number_to_human_size(document.file.byte_size) %>
                                      </span>
                                    <% end %>
                                  </div>
                                  <% if document.description.present? %>
                                    <p class="text-muted mb-1 small"><%= truncate(document.description, length: 100) %></p>
                                  <% end %>
                                  <small class="text-success d-block">
                                    <i class="bi bi-calendar-check me-1"></i>Uploaded by <%= document.uploaded_by || "Admin User" %> on <%= document.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                                  </small>
                                </div>

                                <!-- Actions -->
                                <div class="btn-group" role="group">
                                  <% if document.file.present? %>
                                    <%= link_to document.document_url,
                                        class: "btn btn-outline-primary btn-sm",
                                        target: "_blank",
                                        title: "Preview Document" do %>
                                      <i class="bi bi-eye me-1"></i>Preview
                                    <% end %>
                                    <%= link_to document.download_url,
                                        class: "btn btn-outline-success btn-sm",
                                        title: "Download Document" do %>
                                      <i class="bi bi-download me-1"></i>Download
                                    <% end %>
                                    <%= link_to admin_document_path(document),
                                        method: :delete,
                                        class: "btn btn-outline-danger btn-sm",
                                        title: "Delete Document",
                                        data: {
                                          confirm: "Are you sure you want to delete this document? This action cannot be undone."
                                        } do %>
                                      <i class="bi bi-trash me-1"></i>Delete
                                    <% end %>
                                  <% end %>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  </div>

                </div>
              </div>
            <% end %>

            <!-- R2 Policy Documents -->
            <% if @life_insurance.policy_documents_records.any? %>
