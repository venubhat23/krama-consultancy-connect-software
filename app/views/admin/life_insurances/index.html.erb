<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Life Insurance Policies</h2>
  </div>
  <div class="d-flex gap-2">
    <div class="dropdown download-dropdown">
      <button class="btn btn-success dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-download me-1"></i> Download
      </button>
      <ul class="dropdown-menu dropdown-menu-end">
        <li>
          <a class="dropdown-item" data-turbo="false" href="<%= download_admin_life_insurances_path(request.query_parameters.merge(format_type: 'csv')) %>">
            <i class="bi bi-filetype-csv text-success me-2"></i>CSV
          </a>
        </li>
        <li>
          <a class="dropdown-item" data-turbo="false" href="<%= download_admin_life_insurances_path(request.query_parameters.merge(format_type: 'excel')) %>">
            <i class="bi bi-file-earmark-excel text-success me-2"></i>Excel
          </a>
        </li>
      </ul>
    </div>
    <%= link_to new_admin_life_insurance_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i>
      Add New Life Policy
    <% end %>
  </div>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Life Policies</h6>
            <h3 class="mb-0 text-primary" data-stat="total-policies"><%= number_with_delimiter((@drwise_count || 0) + (@non_drwise_count || 0)) %></h3>
            <div class="d-flex gap-2 mt-2">
              <small class="text-success">
                <i class="bi bi-check-circle me-1"></i>DrWise: <%= @drwise_count %>
              </small>
              <small class="text-warning">
                <i class="bi bi-x-circle me-1"></i>Non-DrWise: <%= @non_drwise_count %>
              </small>
            </div>
          </div>
          <div class="bg-primary bg-opacity-10 rounded p-3">
            <i class="bi bi-heart text-primary fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Premium</h6>
            <h3 class="mb-0 text-success" data-stat="total-premium"><%= indian_currency((@drwise_premium || 0) + (@non_drwise_premium || 0)) %></h3>
            <div class="mt-2">
              <small class="text-muted d-block">DrWise: <%= indian_currency(@drwise_premium || 0) %></small>
              <small class="text-muted d-block">Non-DrWise: <%= indian_currency(@non_drwise_premium || 0) %></small>
            </div>
          </div>
          <div class="bg-success bg-opacity-10 rounded p-3">
            <i class="bi bi-currency-rupee text-success fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Coverage</h6>
            <h3 class="mb-0 text-info" data-stat="total-coverage"><%= indian_currency((@drwise_coverage || 0) + (@non_drwise_coverage || 0)) %></h3>
            <div class="mt-2">
              <small class="text-muted d-block">DrWise: <%= indian_currency(@drwise_coverage || 0) %></small>
              <small class="text-muted d-block">Non-DrWise: <%= indian_currency(@non_drwise_coverage || 0) %></small>
            </div>
          </div>
          <div class="bg-info bg-opacity-10 rounded p-3">
            <i class="bi bi-shield-check text-info fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Covered Lives</h6>
            <%
              total_lives = LifeInsurance.joins(:customer).distinct.count('customers.id')
              drwise_lives = LifeInsurance.where(
                is_admin_added: true, is_customer_added: false, is_agent_added: false
              ).joins(:customer).distinct.count('customers.id')
              non_drwise_lives = total_lives - drwise_lives
            %>
            <h3 class="mb-0 text-warning" data-stat="covered-lives"><%= number_with_delimiter(total_lives) %></h3>
            <div class="d-flex gap-2 mt-2">
              <small class="text-success">
                <i class="bi bi-check-circle me-1"></i>DrWise: <%= drwise_lives %>
              </small>
              <small class="text-warning">
                <i class="bi bi-x-circle me-1"></i>Non-DrWise: <%= non_drwise_lives %>
              </small>
            </div>
          </div>
          <div class="bg-warning bg-opacity-10 rounded p-3">
            <i class="bi bi-people text-warning fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Tabs for DrWise vs Non-DrWise -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body p-0">
    <ul class="nav nav-tabs border-0" role="tablist">
      <li class="nav-item" role="presentation">
        <%= link_to admin_life_insurances_path(params.permit!.to_h.merge(tab: 'drwise')),
            class: "nav-link #{'active' if @current_tab == 'drwise'}",
            role: "tab" do %>
          <i class="bi bi-check-circle me-2"></i>
          DrWise Policies
          <span class="badge bg-success ms-2"><%= @drwise_count %></span>
        <% end %>
      </li>
      <li class="nav-item" role="presentation">
        <%= link_to admin_life_insurances_path(params.permit!.to_h.merge(tab: 'non_drwise')),
            class: "nav-link #{'active' if @current_tab == 'non_drwise'}",
            role: "tab" do %>
          <i class="bi bi-x-circle me-2"></i>
          Non-DrWise Policies
          <span class="badge bg-warning ms-2"><%= @non_drwise_count %></span>
        <% end %>
      </li>
    </ul>
  </div>
</div>

<!-- Search and Filters -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: admin_life_insurances_path, method: :get, local: true, id: "life-filter-form" do |form| %>
      <%= form.hidden_field :tab, value: params[:tab] %>

      <!-- Basic filter row -->
      <div class="row g-2 align-items-end mb-2">
        <div class="col-md-4">
          <%= form.text_field :search, placeholder: "Search by policy no., customer, company…",
              value: params[:search], class: "form-control" %>
        </div>
        <div class="col-md-2">
          <%= form.select :status, options_for_select([
            ['All Statuses', ''],
            ['Active', 'active'],
            ['Expiring Soon', 'expiring_soon'],
            ['Expired', 'expired']
          ], params[:status]), {}, { class: "form-select" } %>
        </div>
        <div class="col-md-2">
          <%= form.submit "Search", class: "btn btn-primary w-100" %>
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-outline-secondary w-100" id="toggle-adv-filter">
            <i class="bi bi-funnel me-1"></i>Advanced
            <% adv_active = [params[:company], params[:sub_agent_id], params[:policy_type], params[:payment_mode], params[:from_date], params[:to_date]].any?(&:present?) %>
            <% if adv_active %>
              <span class="badge bg-primary ms-1" id="adv-active-dot">●</span>
            <% else %>
              <span class="badge bg-secondary ms-1 d-none" id="adv-active-dot">●</span>
            <% end %>
          </button>
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-outline-secondary w-100" id="col-config-btn" title="Configure visible columns">
            <i class="bi bi-layout-three-columns me-1"></i>Columns
          </button>
        </div>
      </div>

      <!-- Advanced filter panel -->
      <div id="adv-filter-panel" class="border rounded p-3 mt-2 bg-light" style="display: <%= adv_active ? 'block' : 'none' %>;">
        <div class="row g-3">
          <!-- Company Name -->
          <div class="col-md-4">
            <label class="form-label fw-semibold small text-muted">Company Name</label>
            <select name="company" id="adv_company" class="form-select adv-select2">
              <option value="">All Companies</option>
              <% @filter_companies.each do |co| %>
                <option value="<%= co %>" <%= 'selected' if params[:company] == co %>><%= co %></option>
              <% end %>
            </select>
          </div>

          <!-- Affiliate (Sub Agent) -->
          <div class="col-md-4">
            <label class="form-label fw-semibold small text-muted">Affiliate</label>
            <select name="sub_agent_id" id="adv_sub_agent" class="form-select adv-select2">
              <option value="">All Affiliates</option>
              <% @filter_sub_agents.each do |sa| %>
                <option value="<%= sa.id %>" <%= 'selected' if params[:sub_agent_id].to_s == sa.id.to_s %>><%= sa.display_name %></option>
              <% end %>
            </select>
          </div>

          <!-- Policy Type -->
          <div class="col-md-4">
            <label class="form-label fw-semibold small text-muted">Policy Type</label>
            <select name="policy_type" id="adv_policy_type" class="form-select adv-select2">
              <option value="">All Types</option>
              <% @filter_policy_types.each do |pt| %>
                <option value="<%= pt %>" <%= 'selected' if params[:policy_type] == pt %>><%= pt %></option>
              <% end %>
            </select>
          </div>

          <!-- From Date -->
          <div class="col-md-3">
            <label class="form-label fw-semibold small text-muted">Policy Start — From</label>
            <div class="input-group">
              <span class="input-group-text bg-primary text-white border-0"><i class="bi bi-calendar3"></i></span>
              <%= form.date_field :from_date, value: params[:from_date], class: "form-control",
                  placeholder: "DD-MM-YYYY" %>
            </div>
          </div>

          <!-- To Date -->
          <div class="col-md-3">
            <label class="form-label fw-semibold small text-muted">Policy Start — To</label>
            <div class="input-group">
              <span class="input-group-text bg-primary text-white border-0"><i class="bi bi-calendar3"></i></span>
              <%= form.date_field :to_date, value: params[:to_date], class: "form-control",
                  placeholder: "DD-MM-YYYY" %>
            </div>
          </div>

          <!-- Payment Mode -->
          <div class="col-md-3">
            <label class="form-label fw-semibold small text-muted">Payment Mode</label>
            <select name="payment_mode" id="adv_payment_mode" class="form-select adv-select2">
              <option value="">All Modes</option>
              <% @filter_payment_modes.each do |pm| %>
                <option value="<%= pm %>" <%= 'selected' if params[:payment_mode] == pm %>><%= pm %></option>
              <% end %>
            </select>
          </div>

          <!-- Actions -->
          <div class="col-md-3 d-flex align-items-end gap-2">
            <%= form.submit "Apply Filter", class: "btn btn-primary flex-fill" %>
            <%= link_to "Reset", admin_life_insurances_path(tab: params[:tab]),
                class: "btn btn-outline-secondary flex-fill" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Select2 for advanced filter -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet"/>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<!-- Life Insurance Policies List -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">
      <% if @current_tab == 'drwise' %>
        <i class="bi bi-check-circle text-success me-2"></i>DrWise Life Insurance Policies
      <% else %>
        <i class="bi bi-x-circle text-warning me-2"></i>Non-DrWise Life Insurance Policies
      <% end %>
    </h5>
  </div>
  <div class="card-body p-0">
    <% if @life_insurances.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0" id="life-insurance-table">
          <thead class="bg-light">
            <tr>
              <th class="border-0" data-col="policy">Policy</th>
              <th class="border-0" data-col="customer">Customer</th>
              <th class="border-0" data-col="company">Company</th>
              <th class="border-0" data-col="source-type">Source &amp; Type</th>
              <th class="border-0" data-col="coverage">Coverage</th>
              <th class="border-0" data-col="premium">Premium</th>
              <th class="border-0" data-col="status">Status</th>
              <th class="border-0" data-col="policy-holder">Policy Holder</th>
              <th class="border-0" data-col="plan-name">Plan Name</th>
              <th class="border-0" data-col="start-date">Start Date</th>
              <th class="border-0" data-col="end-date">End Date</th>
              <th class="border-0" data-col="net-premium">Net Premium</th>
              <th class="border-0" data-col="payment-mode">Payment Mode</th>
              <th class="border-0" data-col="policy-term">Policy Term</th>
              <th class="border-0" data-col="agent">Agent</th>
              <th class="border-0" data-col="broker">Broker</th>
              <th class="border-0" data-col="booking-date">Booking Date</th>
              <th class="border-0" data-col="actions">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @life_insurances.each do |policy| %>
              <tr>
                <td data-col="policy">
                  <div>
                    <h6 class="mb-1"><%= policy.policy_number %></h6>
                    <small class="text-muted"><%= policy.policy_type&.humanize %></small>
                    <br>
                    <% doc_count = policy.total_documents_count %>
                    <small class="<%= doc_count > 0 ? 'text-success' : 'text-danger' %>">
                      <i class="bi bi-file-earmark-<%= doc_count > 0 ? 'check' : 'x' %> me-1"></i>
                      <%= doc_count %> doc<%= doc_count == 1 ? '' : 's' %>
                    </small>
                  </div>
                </td>
                <td data-col="customer">
                  <div>
                    <h6 class="mb-1"><%= policy.customer&.display_name %></h6>
                    <small class="text-muted"><%= policy.customer&.mobile %></small>
                  </div>
                </td>
                <td data-col="company">
                  <div>
                    <% if policy.insurance_company_code.present? %>
                      <h6 class="mb-1"><%= policy.insurance_company_code %></h6>
                      <small class="text-muted"><%= policy.insurance_company_name %></small>
                    <% else %>
                      <h6 class="mb-1"><%= policy.insurance_company_name %></h6>
                    <% end %>
                  </div>
                </td>
                <td data-col="source-type">
                  <div class="d-flex flex-column gap-1">
                    <div>
                      <% if policy.is_customer_added? %>
                        <span class="badge bg-info-subtle text-info">
                          <i class="bi bi-person-check me-1"></i>Customer
                        </span>
                      <% elsif policy.is_agent_added? %>
                        <span class="badge bg-success-subtle text-success">
                          <i class="bi bi-person-badge me-1"></i>Agent
                        </span>
                      <% elsif policy.is_admin_added? %>
                        <span class="badge bg-primary-subtle text-primary">
                          <i class="bi bi-shield-check me-1"></i>Admin
                        </span>
                      <% else %>
                        <span class="badge bg-secondary-subtle text-secondary">
                          <i class="bi bi-question-circle me-1"></i>Unknown
                        </span>
                      <% end %>
                    </div>
                    <div>
                      <span class="badge <%= policy.policy_classification_badge_class %>">
                        <% if policy.drwise_policy? %>
                          <i class="bi bi-check-circle me-1"></i>
                        <% elsif policy.non_drwise_policy? %>
                          <i class="bi bi-x-circle me-1"></i>
                        <% else %>
                          <i class="bi bi-question-circle me-1"></i>
                        <% end %>
                        <%= policy.policy_classification %>
                      </span>
                    </div>
                  </div>
                </td>
                <td data-col="coverage">
                  <div>
                    <small class="text-muted d-block" style="font-size: 0.75rem;">Sum Assured</small>
                    <div class="fw-bold text-primary" style="font-size: 1rem;"
                         title="<%= indian_currency(policy.sum_insured) %>" data-bs-toggle="tooltip">
                      <%= amount_in_words(policy.sum_insured) %>
                    </div>
                  </div>
                </td>
                <td data-col="premium">
                  <div>
                    <small class="text-muted d-block" style="font-size: 0.75rem;"><%= policy.payment_mode&.humanize || 'Yearly' %></small>
                    <div class="fw-bold text-success" style="font-size: 1rem;"><%= indian_currency(policy.total_premium) %></div>
                  </div>
                </td>
                <td data-col="status">
                  <% if policy.has_been_renewed? && policy.expired? %>
                    <span class="badge" style="background-color:#6f42c1;">Renewed</span>
                  <% elsif policy.status == 'active' %>
                    <span class="badge bg-success">Active</span>
                  <% elsif policy.status == 'expiring_soon' %>
                    <span class="badge bg-warning">Expiring Soon</span>
                  <% elsif policy.status == 'expired' %>
                    <span class="badge bg-danger">Expired</span>
                  <% else %>
                    <span class="badge bg-warning"><%= policy.status&.humanize || 'Pending' %></span>
                  <% end %>
                </td>
                <td data-col="policy-holder">
                  <span class="text-muted"><%= policy.policy_holder.presence || '-' %></span>
                </td>
                <td data-col="plan-name">
                  <span class="text-muted"><%= policy.plan_name.presence || '-' %></span>
                </td>
                <td data-col="start-date">
                  <span class="text-muted"><%= policy.policy_start_date&.strftime('%d %b %Y') || '-' %></span>
                </td>
                <td data-col="end-date">
                  <span class="text-muted"><%= policy.policy_end_date&.strftime('%d %b %Y') || '-' %></span>
                </td>
                <td data-col="net-premium">
                  <span class="fw-semibold text-secondary"><%= indian_currency(policy.net_premium) %></span>
                </td>
                <td data-col="payment-mode">
                  <span class="text-muted"><%= policy.payment_mode&.humanize || '-' %></span>
                </td>
                <td data-col="policy-term">
                  <span class="text-muted"><%= policy.policy_term ? "#{policy.policy_term} yr#{ policy.policy_term.to_i == 1 ? '' : 's'}" : '-' %></span>
                </td>
                <td data-col="agent">
                  <span class="text-muted"><%= policy.sub_agent&.display_name || '-' %></span>
                </td>
                <td data-col="broker">
                  <span class="text-muted"><%= policy.broker&.name || '-' %></span>
                </td>
                <td data-col="booking-date">
                  <span class="text-muted"><%= policy.policy_booking_date&.strftime('%d %b %Y') || '-' %></span>
                </td>
                <td data-col="actions">
                  <div class="d-flex gap-1">
                    <%= link_to admin_life_insurance_path(policy), class: "btn btn-sm btn-outline-primary", title: "View" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to commission_details_admin_life_insurance_path(policy), class: "btn btn-sm btn-outline-info", title: "Commission Details" do %>
                      <i class="bi bi-percent"></i>
                    <% end %>

                    <% if policy.has_been_renewed? %>
                      <%= link_to admin_life_insurance_path(policy.renewal_policy),
                          class: "btn btn-sm btn-success",
                          title: "View Renewal Policy: #{policy.renewal_policy.policy_number}" do %>
                        <i class="bi bi-check-circle"></i>
                        <span class="d-none d-md-inline ms-1">Renewed</span>
                      <% end %>
                    <% elsif policy.can_be_renewed? %>
                      <% days_to_expiry = (policy.policy_end_date - Date.current).to_i %>
                      <%= link_to renew_admin_life_insurance_path(policy),
                          class: "btn btn-sm #{'btn-warning' if days_to_expiry <= 30}#{'btn-info' if days_to_expiry > 30}",
                          title: "Renew Policy (#{days_to_expiry} days to expiry)" do %>
                        <i class="bi bi-arrow-clockwise"></i>
                        <span class="d-none d-md-inline ms-1">Renew</span>
                      <% end %>
                    <% elsif policy.is_renewal? %>
                      <span class="btn btn-sm btn-outline-secondary disabled" title="This is a renewal policy">
                        <i class="bi bi-arrow-clockwise"></i>
                        <span class="d-none d-md-inline ms-1">Renewal</span>
                      </span>
                    <% end %>

                    <%= link_to edit_admin_life_insurance_path(policy), class: "btn btn-sm btn-outline-warning", title: "Edit" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <%= link_to admin_life_insurance_path(policy),
                        class: "btn btn-sm btn-outline-danger delete-policy-btn",
                        title: "Delete Policy & All Data",
                        method: :delete,
                        data: {
                          policy_number: policy.policy_number,
                          customer_name: policy.customer&.display_name,
                          company_name: policy.insurance_company_name,
                          premium_amount: number_to_currency(policy.total_premium, unit: 'Rs. ', precision: 0),
                          turbo_method: :delete,
                          turbo_confirm: false
                        },
                        onclick: "return confirmLifePolicyDeletion(this, event);" do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @life_insurances.respond_to?(:current_page) %>
        <div class="card-footer bg-transparent border-0">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="d-flex align-items-center gap-3">
              <% if @life_insurances.respond_to?(:total_count) %>
                <small class="text-muted">
                  Showing <strong><%= @life_insurances.offset_value + 1 %></strong>–<strong><%= [@life_insurances.offset_value + @life_insurances.limit_value, @life_insurances.total_count].min %></strong> of <strong><%= number_with_delimiter(@life_insurances.total_count) %></strong>
                </small>
              <% end %>
              <%= render 'shared/per_page_selector' %>
            </div>
            <% if @life_insurances.respond_to?(:total_pages) && @life_insurances.total_pages > 1 %>
              <%= paginate @life_insurances %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-5">
        <% if @current_tab == 'drwise' %>
          <i class="bi bi-check-circle fs-1 text-success d-block mb-3"></i>
          <h5 class="text-muted">No DrWise life insurance policies found</h5>
        <% else %>
          <i class="bi bi-x-circle fs-1 text-warning d-block mb-3"></i>
          <h5 class="text-muted">No Non-DrWise life insurance policies found</h5>
        <% end %>
        <p class="text-muted mb-3">
          <% if [params[:search], params[:status], params[:company], params[:sub_agent_id], params[:policy_type], params[:payment_mode], params[:from_date], params[:to_date]].any?(&:present?) %>
            Try adjusting your search criteria or
            <%= link_to "view all #{@current_tab} policies", admin_life_insurances_path(tab: @current_tab), class: "text-decoration-none" %>.
          <% else %>
            <% if @current_tab == 'drwise' %>
              DrWise policies are created from the admin panel.
            <% else %>
              Non-DrWise policies are added by customers or agents.
            <% end %>
          <% end %>
        </p>
        <% if @current_tab == 'drwise' %>
          <%= link_to new_admin_life_insurance_path, class: "btn btn-primary" do %>
            <i class="bi bi-plus-lg me-1"></i>
            Add DrWise Life Policy
          <% end %>
        <% else %>
          <div class="text-muted small">
            Non-DrWise policies are typically added through customer or agent portals.
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<!-- Column Configuration Modal -->
<div class="modal fade" id="colConfigModal" tabindex="-1" aria-labelledby="colConfigModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-semibold" id="colConfigModalLabel">
          <i class="bi bi-layout-three-columns me-2 text-primary"></i>Customize Columns
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-3">
        <div class="border rounded p-3" style="background:#f8fbff;">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="fw-semibold text-primary">Select Columns</span>
            <div class="form-check mb-0">
              <input type="checkbox" class="form-check-input" id="col-check-all">
              <label class="form-check-label fw-semibold" for="col-check-all">Check All</label>
            </div>
          </div>
          <div class="row g-2" id="col-checkboxes">
            <!-- Populated by JS -->
          </div>
          <div class="mt-3 text-muted small">
            <i class="bi bi-info-circle me-1"></i>
            Maximum <strong>9 columns</strong> can be selected. <strong>Actions</strong> is always visible.
          </div>
          <div id="col-validation-msg" class="alert alert-danger mt-2 mb-0 py-2 d-none">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>
            <span id="col-validation-text">You can select a maximum of 9 columns.</span>
          </div>
        </div>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary px-4" id="apply-col-changes">
          <i class="bi bi-check-lg me-1"></i>Apply Changes
        </button>
      </div>
    </div>
  </div>
</div>

