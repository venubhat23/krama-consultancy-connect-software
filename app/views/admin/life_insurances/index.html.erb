<script>
const LIFE_COL_CONFIG = [
  { key: 'policy',        label: 'Policy',         defaultOn: true  },
  { key: 'customer',      label: 'Customer',        defaultOn: true  },
  { key: 'company',       label: 'Company',         defaultOn: true  },
  { key: 'source-type',   label: 'Source & Type',   defaultOn: true  },
  { key: 'coverage',      label: 'Coverage',        defaultOn: true  },
  { key: 'premium',       label: 'Premium',         defaultOn: true  },
  { key: 'status',        label: 'Status',          defaultOn: true  },
  { key: 'policy-holder', label: 'Policy Holder',   defaultOn: false },
  { key: 'plan-name',     label: 'Plan Name',       defaultOn: false },
  { key: 'start-date',    label: 'Start Date',      defaultOn: false },
  { key: 'end-date',      label: 'End Date',        defaultOn: false },
  { key: 'net-premium',   label: 'Net Premium',     defaultOn: false },
  { key: 'payment-mode',  label: 'Payment Mode',    defaultOn: false },
  { key: 'policy-term',   label: 'Policy Term',     defaultOn: false },
  { key: 'agent',         label: 'Agent/Affiliate', defaultOn: false },
  { key: 'broker',        label: 'Broker',          defaultOn: false },
  { key: 'booking-date',  label: 'Booking Date',    defaultOn: false },
];

const LIFE_COL_MAX    = 9;
const LIFE_COL_KEY    = 'life_insurance_columns_v1';

function lifeGetSelectedCols() {
  try {
    const saved = localStorage.getItem(LIFE_COL_KEY);
    if (saved) return JSON.parse(saved);
  } catch(e) {}
  return LIFE_COL_CONFIG.filter(c => c.defaultOn).map(c => c.key);
}

function lifeSaveCols(cols) {
  localStorage.setItem(LIFE_COL_KEY, JSON.stringify(cols));
}

function lifeApplyCols(selectedCols) {
  LIFE_COL_CONFIG.forEach(function(col) {
    const show = selectedCols.includes(col.key);
    document.querySelectorAll('[data-col="' + col.key + '"]').forEach(function(el) {
      el.style.display = show ? '' : 'none';
    });
  });
}

function lifeBuildCheckboxes(selectedCols) {
  const container = document.getElementById('col-checkboxes');
  container.innerHTML = '';
  LIFE_COL_CONFIG.forEach(function(col) {
    const checked = selectedCols.includes(col.key);
    const div = document.createElement('div');
    div.className = 'col-md-4';
    div.innerHTML =
      '<div class="form-check">' +
        '<input class="form-check-input life-col-cb" type="checkbox" ' +
               'id="life-col-cb-' + col.key + '" value="' + col.key + '"' + (checked ? ' checked' : '') + '>' +
        '<label class="form-check-label" for="life-col-cb-' + col.key + '">' + col.label + '</label>' +
      '</div>';
    container.appendChild(div);
  });
}

function lifeUpdateCheckAll() {
  const cbs = document.querySelectorAll('.life-col-cb');
  const all = Array.from(cbs).every(function(cb) { return cb.checked; });
  document.getElementById('col-check-all').checked = all;
  document.getElementById('col-check-all').indeterminate = !all && Array.from(cbs).some(function(cb) { return cb.checked; });
}

function lifeShowValidation(msg) {
  const el = document.getElementById('col-validation-msg');
  document.getElementById('col-validation-text').textContent = msg;
  el.classList.remove('d-none');
}

function lifeHideValidation() {
  document.getElementById('col-validation-msg').classList.add('d-none');
}

document.addEventListener('DOMContentLoaded', function() {
  // Apply saved column visibility immediately
  lifeApplyCols(lifeGetSelectedCols());

  // Open modal
  var colConfigBtn = document.getElementById('col-config-btn');
  if (colConfigBtn) {
    colConfigBtn.addEventListener('click', function() {
      lifeBuildCheckboxes(lifeGetSelectedCols());
      lifeUpdateCheckAll();
      lifeHideValidation();
      new bootstrap.Modal(document.getElementById('colConfigModal')).show();
    });
  }

  // Check All
  document.getElementById('col-check-all').addEventListener('change', function() {
    var cbs = document.querySelectorAll('.life-col-cb');
    if (this.checked && cbs.length > LIFE_COL_MAX) {
      lifeShowValidation('Cannot select all — maximum is ' + LIFE_COL_MAX + ' columns. Please choose up to ' + LIFE_COL_MAX + '.');
      this.checked = false;
      return;
    }
    lifeHideValidation();
    cbs.forEach(function(cb) { cb.checked = true; });
    if (!this.checked) {
      cbs.forEach(function(cb) { cb.checked = false; });
    }
    lifeUpdateCheckAll();
  });

  // Individual checkbox — enforce max limit
  document.getElementById('col-checkboxes').addEventListener('change', function(e) {
    if (!e.target.classList.contains('life-col-cb')) return;
    var cbs = document.querySelectorAll('.life-col-cb');
    var count = Array.from(cbs).filter(function(cb) { return cb.checked; }).length;
    if (count > LIFE_COL_MAX) {
      e.target.checked = false;
      lifeShowValidation('Maximum ' + LIFE_COL_MAX + ' columns allowed. Deselect one before adding another.');
    } else {
      lifeHideValidation();
    }
    lifeUpdateCheckAll();
  });

  // Apply Changes
  document.getElementById('apply-col-changes').addEventListener('click', function() {
    var cbs = document.querySelectorAll('.life-col-cb');
    var selected = Array.from(cbs).filter(function(cb) { return cb.checked; }).map(function(cb) { return cb.value; });

    if (selected.length === 0) {
      lifeShowValidation('Please select at least 1 column.');
      return;
    }
    if (selected.length > LIFE_COL_MAX) {
      lifeShowValidation('Maximum ' + LIFE_COL_MAX + ' columns allowed. You have ' + selected.length + ' selected.');
      return;
    }

    lifeSaveCols(selected);
    lifeApplyCols(selected);
    bootstrap.Modal.getInstance(document.getElementById('colConfigModal')).hide();
  });

  // Advanced filter toggle
  var toggleBtn = document.getElementById('toggle-adv-filter');
  var panel     = document.getElementById('adv-filter-panel');
  var dot       = document.getElementById('adv-active-dot');

  if (toggleBtn) {
    toggleBtn.addEventListener('click', function() {
      var open = panel.style.display !== 'none';
      panel.style.display = open ? 'none' : 'block';
      toggleBtn.classList.toggle('btn-outline-secondary', open);
      toggleBtn.classList.toggle('btn-secondary', !open);
      if (!open) initSelect2();
    });
  }

  function initSelect2() {
    if (typeof $ === 'undefined') return;
    $('.adv-select2').each(function() {
      if ($(this).data('select2')) return;
      $(this).select2({
        theme: 'bootstrap-5',
        width: '100%',
        allowClear: true,
        placeholder: $(this).find('option:first').text()
      });
    });
  }

  if (panel && panel.style.display !== 'none') initSelect2();

  if (panel) {
    var advFields = panel.querySelectorAll('select, input[type=date]');
    advFields.forEach(function(el) {
      el.addEventListener('change', function() {
        var anyFilled = Array.from(advFields).some(function(f) { return f.value !== ''; });
        dot.classList.toggle('d-none', !anyFilled);
      });
    });
  }
});

function confirmLifePolicyDeletion(element, event) {
  event.preventDefault();

  var policyNumber  = element.dataset.policyNumber;
  var customerName  = element.dataset.customerName;
  var companyName   = element.dataset.companyName;
  var premiumAmount = element.dataset.premiumAmount;

  var confirmMessage = "⚠️ PERMANENT DELETION WARNING ⚠️\n\n" +
    "You are about to permanently delete:\n\n" +
    "📋 Policy: " + policyNumber + "\n" +
    "👤 Customer: " + customerName + "\n" +
    "🏢 Company: " + companyName + "\n" +
    "💰 Premium: " + premiumAmount + "\n\n" +
    "🗑️ This will also delete ALL associated data:\n" +
    "• Policy nominees and bank details\n" +
    "• Commission payouts and invoices\n" +
    "• Related lead records\n" +
    "• All uploaded documents (R2 storage)\n" +
    "• Renewal policy relationships\n\n" +
    "❌ THIS CANNOT BE UNDONE!\n\n" +
    "Are you absolutely sure you want to proceed?";

  if (confirm(confirmMessage)) {
    var form = document.createElement('form');
    form.method = 'POST';
    form.action = element.href;
    form.style.display = 'none';

    var csrfToken = document.querySelector('meta[name="csrf-token"]');
    if (csrfToken) {
      var csrfInput = document.createElement('input');
      csrfInput.type = 'hidden';
      csrfInput.name = 'authenticity_token';
      csrfInput.value = csrfToken.getAttribute('content');
      form.appendChild(csrfInput);
    }

    var methodInput = document.createElement('input');
    methodInput.type = 'hidden';
    methodInput.name = '_method';
    methodInput.value = 'delete';
    form.appendChild(methodInput);

    document.body.appendChild(form);
    form.submit();
  }

  return false;
}
</script>
