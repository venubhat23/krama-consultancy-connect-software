<script>
// Enhanced cleanup function for life insurance page
function aggressiveCleanup() {
  console.log('🧹 Running life insurance page cleanup...');

  // Find last actual section (Additional Information)
  const lastSection = document.querySelector('.info-section-card:last-of-type');

  if (lastSection) {
    console.log('📍 Last section found:', lastSection.querySelector('.section-title')?.textContent);

    // Remove ALL elements after the last section until we hit STYLE/SCRIPT
    let nextElement = lastSection.nextElementSibling;
    let removedCount = 0;

    while (nextElement &&
           nextElement.tagName !== 'STYLE' &&
           nextElement.tagName !== 'SCRIPT') {
      const toRemove = nextElement;
      nextElement = nextElement.nextElementSibling;

      console.log('🗑️ Removing element after last section:', toRemove.tagName, toRemove.className);
      toRemove.remove();
      removedCount++;
    }

    console.log(`✅ Removed ${removedCount} elements after last section`);
  }

  // Remove any empty info-section-cards
  const allSections = document.querySelectorAll('.info-section-card');
  allSections.forEach(section => {
    const sectionBody = section.querySelector('.section-body');
    if (sectionBody) {
      const textContent = sectionBody.textContent.trim();
      const hasInputs = sectionBody.querySelectorAll('input, textarea, select').length;

      // Only remove if truly empty (no inputs and no text)
      if (!hasInputs && textContent === '') {
        console.log('🗑️ Removing empty section:', section);
        section.remove();
      }
    }
  });

  // Remove empty divs that might be causing spacing issues
  const allDivs = document.querySelectorAll('div');
  allDivs.forEach(div => {
    if (div.children.length === 0 &&
        div.textContent.trim() === '' &&
        !div.classList.contains('section-icon') &&
        !div.classList.contains('collapse-icon') &&
        !div.classList.contains('collapse') &&
        !div.id.includes('Collapse')) {
      console.log('🗑️ Removing empty div:', div);
      div.remove();
    }
  });

  console.log('✅ Life insurance page cleanup completed');
}

// Run cleanup with multiple triggers
document.addEventListener('DOMContentLoaded', aggressiveCleanup);
window.addEventListener('load', aggressiveCleanup);
setTimeout(aggressiveCleanup, 100);
setTimeout(aggressiveCleanup, 500);
setTimeout(aggressiveCleanup, 1000);
</script>