<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">
      <i class="bi bi-arrow-clockwise me-2 text-warning"></i>
      Renew Life Insurance Policy
    </h2>
    <p class="text-muted mb-0">
      Creating renewal policy for: <strong><%= @original_policy.policy_number %></strong>
      <span class="badge bg-warning text-dark ms-2">
        Expires: <%= @original_policy.policy_end_date&.strftime('%B %d, %Y') %>
      </span>
    </p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to admin_life_insurance_path(@original_policy), class: "btn btn-outline-info" do %>
      <i class="bi bi-eye me-1"></i>
      View Original Policy
    <% end %>
    <%= link_to admin_life_insurances_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>
      Back to Policies
    <% end %>
  </div>
</div>

<!-- Original vs Renewal Comparison -->
<div class="alert alert-info d-flex align-items-center mb-4">
  <i class="bi bi-info-circle me-3 fs-4"></i>
  <div>
    <h6 class="alert-heading mb-1">Policy Renewal Information</h6>
    <p class="mb-0">
      This form is pre-filled with data from the original policy. Please review and update any changes needed for the renewal.
      The new policy will start from <strong><%= @renewed_policy.policy_start_date&.strftime('%B %d, %Y') %></strong>
      and expire on <strong><%= @renewed_policy.policy_end_date&.strftime('%B %d, %Y') %></strong>.
    </p>
  </div>
</div>

<!-- Complete Renewal Form (Same as Create Form) -->
<%= form_with model: [:admin, @renewed_policy], url: create_renewal_admin_life_insurance_path(@original_policy), method: :post, local: true, class: "needs-validation", novalidate: true do |form| %>

  <!-- Client & Agent Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-person me-2 text-primary"></i>
        Client & Agent Details
      </h5>
    </div>
    <div class="card-body">
      <% if @renewed_policy.errors.any? %>
        <div class="alert alert-danger alert-dismissible fade show">
          <i class="bi bi-exclamation-triangle me-2"></i>
          <strong>Please correct the following errors:</strong>
          <ul class="mb-0 mt-2">
            <% @renewed_policy.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :customer_id, "Client Name*", class: "form-label" %>
          <%= form.select :customer_id,
              options_for_select(@customers.map { |c| [c.display_name, c.id] }, @renewed_policy.customer_id),
              { prompt: 'Search and select client...' },
              { class: "form-control #{'is-invalid' if @renewed_policy.errors[:customer_id].any?}", required: true, id: "customer_select", data: { placeholder: "Type to search clients..." } } %>
          <% if @renewed_policy.errors[:customer_id].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:customer_id].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_holder, "Policy Holder", class: "form-label" %>
          <%
            policy_holder_options = [['Self', 'Self']]
            if @customer_family_members&.any?
              @customer_family_members.each do |member|
                policy_holder_options << ["#{member.name} (#{member.relationship.humanize})", "#{member.name}"]
              end
            end
          %>
          <%= form.select :policy_holder,
              options_for_select(policy_holder_options, @renewed_policy.policy_holder),
              { prompt: 'Select Policy Holder' },
              { class: "form-control", id: "policy_holder_select" } %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :sub_agent_id, "Affiliate", class: "form-label" %>
          <%= form.select :sub_agent_id,
              options_for_select([['Self', '']] + @sub_agents.map { |a| [a.display_name, a.id] }, @renewed_policy.sub_agent_id),
              { prompt: 'Search and select affiliate...' },
              { class: "form-control", id: "affiliate_select", data: { placeholder: "Type to search affiliates..." } } %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :insured_name, "Insured Name", class: "form-label" %>
          <%= form.text_field :insured_name,
              class: "form-control",
              placeholder: "Enter insured name" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Policy Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-file-text me-2 text-primary"></i>
        Policy Details
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <!-- 1st: Broker Code dropdown with Direct/Broking options -->
        <div class="col-md-4 mb-3">
          <%= form.label :broker_code_type, "Broker Code", class: "form-label" %>
          <%= form.select :broker_code_type,
              options_for_select([
                ['Direct', 'direct'],
                ['Broking', 'broking']
              ], @renewed_policy.broker_code_type),
              { prompt: 'Select Broker Code' },
              { class: "form-control", id: "life_insurance_broker_code_type" } %>
        </div>

        <!-- 2nd: Agency Code (shows Agents when Direct selected, Brokers when Broking selected) -->
        <div class="col-md-4 mb-3">
          <%= form.label :agency_code_id, "Agency Code (All Agents)*", class: "form-label" %>
          <span class="agency-code-label-extra" id="agency_code_label_text">
            <%= @renewed_policy.broker_code_type == 'broking' ? ' (All Brokers)' : ' (All Agents)' %>
          </span>
          <%
            if @renewed_policy.broker_code_type == 'direct'
              agency_options = @agency_codes.map { |ac| ["#{ac.agent_name} (#{ac.code})", ac.id, { 'data-agent-name' => ac.agent_name, 'data-agent-code' => ac.code, 'data-company-name' => ac.insurance_company_name.to_s }] }
              selected_agency = @renewed_policy.agency_code_id
              agency_prompt = 'Select Agency Code'
            elsif @renewed_policy.broker_code_type == 'broking'
              agency_options = @brokers.map { |b| [b.name, "broker_#{b.id}", { 'data-broker-id' => b.id }] }
              selected_agency = @renewed_policy.broker_id.present? ? "broker_#{@renewed_policy.broker_id}" : nil
              agency_prompt = 'Select Broker'
            else
              agency_options = []
              selected_agency = nil
              agency_prompt = 'Select Agency Code'
            end
          %>
          <%= form.select :agency_code_id,
              options_for_select(agency_options, selected_agency),
              { prompt: agency_prompt },
              { class: "form-control", id: "life_insurance_agency_code_id", required: false } %>
          <%= form.hidden_field :broker_id, id: "broker_id_hidden", value: @renewed_policy.broker_id %>
          <%= form.hidden_field :distributor_id, id: "distributor_id_hidden" %>
        </div>

        <!-- 3rd: Insurance Company (depends on selected agent/broker) -->
        <div class="col-md-4 mb-3">
          <%= form.label :insurance_company_name, "Insurance Company*", class: "form-label" %>
          <%= form.select :insurance_company_name,
              options_for_select(@insurance_companies.map { |company| [company, company] }, @renewed_policy.insurance_company_name),
              { prompt: 'Select Company' },
              { class: "form-control #{'is-invalid' if @renewed_policy.errors[:insurance_company_name].any?}", required: true, id: "life_insurance_insurance_company_name" } %>
          <% if @renewed_policy.errors[:insurance_company_name].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:insurance_company_name].first %></div>
          <% end %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :policy_type, "Policy Type*", class: "form-label" %>
          <%= form.select :policy_type,
              options_for_select(@policy_types.map { |type| [type, type] }, @renewed_policy.policy_type),
              { prompt: 'Select Policy Type' },
              { class: "form-control #{'is-invalid' if @renewed_policy.errors[:policy_type].any?}", required: true, readonly: true } %>
          <% if @renewed_policy.errors[:policy_type].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:policy_type].first %></div>
          <% end %>
          <div class="form-text text-muted">Policy type is set to "Renewal" for this renewal policy.</div>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :payment_mode, "Payment Mode*", class: "form-label" %>
          <%= form.select :payment_mode,
              options_for_select(@payment_modes.map { |mode| [mode, mode] }, @renewed_policy.payment_mode),
              { prompt: 'Select Payment Mode' },
              { class: "form-control #{'is-invalid' if @renewed_policy.errors[:payment_mode].any?}", required: true, id: "payment_mode_select" } %>
          <% if @renewed_policy.errors[:payment_mode].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:payment_mode].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_number, "Policy Number*", class: "form-label" %>
          <%= form.text_field :policy_number,
              class: "form-control #{'is-invalid' if @renewed_policy.errors[:policy_number].any?}",
              placeholder: "Enter new policy number for renewal",
              required: true %>
          <% if @renewed_policy.errors[:policy_number].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:policy_number].first %></div>
          <% end %>
          <div class="form-text text-muted">Original Policy: <%= @original_policy.policy_number %></div>
        </div>
      </div>

      <!-- Policy Dates -->
      <div class="row">
        <div class="col-md-3 mb-3">
          <%= form.label :policy_booking_date, "Policy Booking Date*", class: "form-label" %>
          <%= form.date_field :policy_booking_date,
              class: "form-control #{'is-invalid' if @renewed_policy.errors[:policy_booking_date].any?}",
              required: true %>
          <% if @renewed_policy.errors[:policy_booking_date].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:policy_booking_date].first %></div>
          <% end %>
        </div>

        <div class="col-md-3 mb-3">
          <%= form.label :policy_start_date, "Policy Start Date*", class: "form-label" %>
          <%= form.date_field :policy_start_date,
              class: "form-control #{'is-invalid' if @renewed_policy.errors[:policy_start_date].any?}",
              required: true, id: "start_date" %>
          <% if @renewed_policy.errors[:policy_start_date].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:policy_start_date].first %></div>
          <% end %>
          <div class="form-text text-muted">Original expires: <%= @original_policy.policy_end_date&.strftime('%d/%m/%Y') %></div>
        </div>

        <div class="col-md-3 mb-3">
          <%= form.label :policy_end_date, "Policy End Date*", class: "form-label" %>
          <%= form.date_field :policy_end_date,
              class: "form-control #{'is-invalid' if @renewed_policy.errors[:policy_end_date].any?}",
              required: true, id: "end_date" %>
          <% if @renewed_policy.errors[:policy_end_date].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:policy_end_date].first %></div>
          <% end %>
        </div>

        <div class="col-md-3 mb-3">
          <%= form.label :risk_start_date, "Risk Start Date", class: "form-label" %>
          <%= form.date_field :risk_start_date, class: "form-control" %>
        </div>
      </div>

      <!-- Policy Terms -->
      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :policy_term, "Policy Term (Years)*", class: "form-label" %>
          <%= form.number_field :policy_term,
              class: "form-control #{'is-invalid' if @renewed_policy.errors[:policy_term].any?}",
              placeholder: "Enter policy term in years",
              min: 1,
              max: 50,
              required: true %>
          <% if @renewed_policy.errors[:policy_term].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:policy_term].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :premium_payment_term, "Premium Payment Term (Years)*", class: "form-label" %>
          <%= form.number_field :premium_payment_term,
              class: "form-control #{'is-invalid' if @renewed_policy.errors[:premium_payment_term].any?}",
              placeholder: "Enter premium payment term",
              min: 1,
              max: 50,
              required: true %>
          <% if @renewed_policy.errors[:premium_payment_term].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:premium_payment_term].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :plan_name, "Plan Name*", class: "form-label" %>
          <%= form.text_field :plan_name,
              class: "form-control #{'is-invalid' if @renewed_policy.errors[:plan_name].any?}",
              placeholder: "Enter plan name",
              required: true %>
          <% if @renewed_policy.errors[:plan_name].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:plan_name].first %></div>
          <% end %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :sum_insured, "Sum Insured", class: "form-label" %>
          <%= form.select :sum_insured,
              options_for_select([
                ['Rs. 5 Lakhs', 500000],
                ['Rs. 10 Lakhs', 1000000],
                ['Rs. 15 Lakhs', 1500000],
                ['Rs. 20 Lakhs', 2000000],
                ['Rs. 25 Lakhs', 2500000],
                ['Rs. 50 Lakhs', 5000000],
                ['Rs. 75 Lakhs', 7500000],
                ['Rs. 1 Crore', 10000000],
                ['Rs. 1.5 Crore', 15000000],
                ['Rs. 2 Crore', 20000000],
                ['Rs. 5 Crore', 50000000]
              ], @renewed_policy.sum_insured),
              { prompt: 'Select Sum Insured' },
              { class: "form-control #{'is-invalid' if @renewed_policy.errors[:sum_insured].any?}", required: true, id: "life_insurance_sum_insured" } %>
          <% if @renewed_policy.errors[:sum_insured].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:sum_insured].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :net_premium, "Net Premium*", class: "form-label" %>
          <%= form.number_field :net_premium,
              class: "form-control #{'is-invalid' if @renewed_policy.errors[:net_premium].any?}",
              placeholder: "0", step: 0.01, required: true, id: "net_premium" %>
          <% if @renewed_policy.errors[:net_premium].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:net_premium].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :first_year_gst_percentage, "1st Year GST %", class: "form-label" %>
          <%= form.number_field :first_year_gst_percentage,
              class: "form-control",
              value: @renewed_policy.first_year_gst_percentage || 18,
              step: 0.01, min: 0, id: "first_year_gst" %>
        </div>


        <div class="col-md-4 mb-3">
          <%= form.label :total_premium, "Total Premium*", class: "form-label" %>
          <%= form.number_field :total_premium,
              class: "form-control #{'is-invalid' if @renewed_policy.errors[:total_premium].any?}",
              placeholder: "0", step: 0.01, required: true, readonly: true, id: "total_premium" %>
          <% if @renewed_policy.errors[:total_premium].any? %>
            <div class="invalid-feedback"><%= @renewed_policy.errors[:total_premium].first %></div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Nominee Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-people me-2 text-primary"></i>
        Nominee Details
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-3 mb-3">
          <%= form.label :nominee_name, "Nominee Name", class: "form-label" %>
          <%= form.text_field :nominee_name,
              class: "form-control",
              id: "renew_nominee_name",
              placeholder: "Nominee Name" %>
        </div>
        <div class="col-md-3 mb-3">
          <%= form.label :nominee_relationship, "Relationship", class: "form-label" %>
          <%= form.select :nominee_relationship,
              options_for_select(@relationships.map { |r| [r, r] }, @renewed_policy.nominee_relationship),
              { prompt: 'Select Relationship' },
              { class: "form-control", id: "nominee_relationship_select" } %>
        </div>
        <div class="col-md-3 mb-3">
          <%= form.label :nominee_age, "Age", class: "form-label" %>
          <%= form.number_field :nominee_age,
              class: "form-control",
              id: "renew_nominee_age",
              placeholder: "Nominee Age" %>
        </div>
        <div class="col-md-3 mb-3">
          <label class="form-label">Share (%)</label>
          <input type="number" class="form-control" id="renew_nominee_share" placeholder="100" min="0" max="100" step="0.01" value="100" disabled>
          <small class="text-muted">Display only</small>
        </div>
      </div>
    </div>
  </div>

  <!-- Bank Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-bank me-2 text-primary"></i>
        Bank Details
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :bank_name, "Bank Name", class: "form-label" %>
          <%= form.text_field :bank_name,
              class: "form-control",
              placeholder: "Bank Name" %>
        </div>
        <div class="col-md-4 mb-3">
          <%= form.label :account_type, "Account Type", class: "form-label" %>
          <%= form.select :account_type,
              options_for_select(@account_types.map { |t| [t, t] }, @renewed_policy.account_type),
              { prompt: 'Account Type' },
              { class: "form-control", id: "account_type_select" } %>
        </div>
        <div class="col-md-4 mb-3">
          <%= form.label :account_number, "Account Number", class: "form-label" %>
          <%= form.text_field :account_number,
              class: "form-control",
              placeholder: "Account Number" %>
        </div>
        <div class="col-md-6 mb-3">
          <%= form.label :ifsc_code, "IFSC CODE", class: "form-label" %>
          <%= form.text_field :ifsc_code,
              class: "form-control",
              placeholder: "IFSC CODE" %>
        </div>
        <div class="col-md-6 mb-3">
          <%= form.label :account_holder_name, "Account Holder Name", class: "form-label" %>
          <%= form.text_field :account_holder_name,
              class: "form-control",
              placeholder: "Holder Name" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Other Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-info-circle me-2 text-primary"></i>
        Other Details
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :reference_by_name, "Reference By Name", class: "form-label" %>
          <%= form.text_field :reference_by_name,
              class: "form-control",
              placeholder: "Enter reference name" %>
        </div>
        <div class="col-md-6 mb-3">
          <%= form.label :broker_name, "Broker Name", class: "form-label" %>
          <%= form.text_field :broker_name,
              class: "form-control",
              placeholder: "Broker Name" %>
        </div>
        <div class="col-md-6 mb-3">
          <%= form.label :bonus, "Bonus", class: "form-label" %>
          <%= form.number_field :bonus,
              class: "form-control",
              value: @renewed_policy.bonus || 0,
              step: 0.01 %>
        </div>
        <div class="col-md-6 mb-3">
          <%= form.label :fund, "Fund", class: "form-label" %>
          <%= form.number_field :fund,
              class: "form-control",
              value: @renewed_policy.fund || 0,
              step: 0.01 %>
        </div>
        <div class="col-12 mb-3">
          <%= form.label :extra_note, "Extra Note", class: "form-label" %>
          <%= form.text_area :extra_note,
              class: "form-control",
              rows: 4,
              placeholder: "Enter additional notes or comments..." %>
        </div>
      </div>
    </div>
  </div>

  <!-- Commission Calculation Table -->
  <div class="card mb-4 shadow-sm commission-table">
    <div class="card-header" style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0 text-dark fw-bold">
            <i class="bi bi-calculator me-2 text-primary"></i>
            Commission Calculation
          </h5>
        </div>
        <div class="text-end">
          <small class="text-muted fw-bold">Profit Formula:</small>
          <div class="badge bg-light text-dark border" style="font-size: 0.8rem;">
            Main Agent Commission - Total Distribution - Company Expenses
          </div>
        </div>
      </div>
    </div>
    <div class="card-body p-0">
      <!-- Commission Table -->
      <div class="table-responsive">
        <table class="table mb-0" style="font-size: 0.95rem;">
          <thead style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
            <tr>
              <th class="py-3 px-4 fw-bold text-dark border-0" style="width: 20%;">COMMISSION DETAILS</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 12%;">(%)</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 18%;">COMMISSION</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 12%;">TDS (%)</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 15%;">TDS AMOUNT</th>
              <th class="py-3 px-3 fw-bold text-dark border-0 text-center" style="width: 23%; background: #f8f9fa;">ACTUAL AMOUNT</th>
            </tr>
          </thead>
          <tbody>
            <!-- Main Agent -->
            <tr class="border-bottom">
              <td class="py-3 px-4 fw-bold text-dark bg-light">Main Agent Commission</td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :main_agent_commission_percentage,
                    class: "form-control border-1 text-center fw-bold shadow-sm",
                    value: @renewed_policy.main_agent_commission_percentage || 0,
                    step: 0.01, id: "commission_percentage",
                    style: "background: #fff; border-color: #dee2e6;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :commission_amount,
                    class: "form-control border-1 text-center",
                    value: @renewed_policy.commission_amount || 0,
                    step: 0.01, readonly: true, id: "commission_amount",
                    style: "background: #f8f9fa; border-color: #dee2e6; color: #495057;" %>
              </td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :tds_percentage,
