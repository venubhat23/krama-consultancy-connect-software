        return;
      }

      const brokerCodeType = brokerCodeTypeSelect ? brokerCodeTypeSelect.value : null;

      if (brokerCodeType === 'direct') {
        // Get company name directly from the selected agency code
        const companyName = selectedOption.getAttribute('data-company-name');
        const agentName = selectedOption.getAttribute('data-agent-name');

        console.log('Direct mode - Loading company for agency code:', companyName);

        if (companyName && insuranceCompanySelect) {
          // Destroy Select2 if initialized
          if ($(insuranceCompanySelect).hasClass('select2-hidden-accessible')) {
            $(insuranceCompanySelect).select2('destroy');
          }

          // Clear and set only the specific company for this agency code
          insuranceCompanySelect.innerHTML = '';

          const defaultOption = document.createElement('option');
          defaultOption.value = '';
          defaultOption.textContent = 'Select Company';
          insuranceCompanySelect.appendChild(defaultOption);

          const option = document.createElement('option');
          option.value = companyName;
          option.textContent = companyName;
          option.selected = true; // Auto-select the company
          insuranceCompanySelect.appendChild(option);

          // Reinitialize Select2 with the new option
          $(insuranceCompanySelect).select2({
            theme: 'bootstrap-5',
            placeholder: 'Select Insurance Company...',
            allowClear: true,
            width: '100%'
          });

          // Trigger change to update the value
          $(insuranceCompanySelect).val(companyName).trigger('change');

          console.log(`Set company to '${companyName}' for agency code from agent '${agentName}'`);
        }

        currentSelectedAgentName = agentName;
        // Clear broker ID for direct
        if (brokerIdHidden) brokerIdHidden.value = '';
      } else if (brokerCodeType === 'broking') {
        // Get broker ID from data attribute
        const brokerId = selectedOption.getAttribute('data-broker-id');
        if (brokerId) {
          currentSelectedBrokerId = brokerId;
          // In Broking mode, ALL companies are already loaded regardless of broker selection
          // Set broker ID in hidden field
          if (brokerIdHidden) brokerIdHidden.value = brokerId;
        }
      }
    });

    // Also handle clear event
    $(agencyCodeSelect).on('select2:clear', function(e) {
      console.log('Agency code cleared');
      // Clear company dropdown
      if (insuranceCompanySelect) {
        if ($(insuranceCompanySelect).hasClass('select2-hidden-accessible')) {
          $(insuranceCompanySelect).select2('destroy');
        }
        insuranceCompanySelect.innerHTML = '<option value="">Select Company</option>';
        $(insuranceCompanySelect).select2({
          theme: 'bootstrap-5',
          placeholder: 'Select Insurance Company...',
          allowClear: true,
          width: '100%'
        });
      }
    });
  }

  // Initialize functionality on page load - check existing values and pre-select from original policy
  if (brokerCodeTypeSelect && agencyCodeSelect && insuranceCompanySelect) {
    const currentBrokerCodeType = brokerCodeTypeSelect.value;
    const originalAgencyCodeId = '<%= j(@renewed_policy.agency_code_id.to_s) %>';
    const originalBrokerId = '<%= j(@renewed_policy.broker_id.to_s) %>';
    const originalInsuranceCompany = '<%= j(@renewed_policy.insurance_company_name.to_s) %>';

    console.log('Initializing with original values:');
    console.log('Broker Code Type:', currentBrokerCodeType);
    console.log('Agency Code ID:', originalAgencyCodeId);
    console.log('Broker ID:', originalBrokerId);
    console.log('Insurance Company:', originalInsuranceCompany);

    // If no broker code type is set but we have agency code or broker ID, trigger the change
    if (!currentBrokerCodeType && (originalAgencyCodeId || originalBrokerId)) {
      console.log('No broker code type set, but we have agency/broker data. Triggering change event.');
      setTimeout(() => {
        // Trigger the change event to load the appropriate dropdown options
        $(brokerCodeTypeSelect).trigger('change');
      }, 500);
    }

    if (currentBrokerCodeType === 'direct') {
      loadAllAgentsForDirect().then(() => {
        // After agents are loaded, pre-select the original agency code
        if (originalAgencyCodeId) {
          console.log('Pre-selecting agency code:', originalAgencyCodeId);

          // Use Select2 to set the value and trigger change
          $(agencyCodeSelect).val(originalAgencyCodeId).trigger('change');

          // This will automatically trigger the change event which loads the company
          console.log('Triggered change event for agency code');
        }
      }).catch(error => {
        console.error('Error loading agents for Direct mode:', error);
      });
    } else if (currentBrokerCodeType === 'broking') {
      Promise.all([
        loadAllBrokersForBroking(),
        loadAllCompaniesForBroking()
      ]).then(() => {
        // After brokers and companies are loaded, pre-select the original broker
        if (originalBrokerId) {
          console.log('Pre-selecting broker:', originalBrokerId);
          const brokerOption = agencyCodeSelect.querySelector(`option[data-broker-id="${originalBrokerId}"]`);
          if (brokerOption) {
            // Use Select2 to set the value
            $(agencyCodeSelect).val(brokerOption.value).trigger('change');
            if (brokerIdHidden) brokerIdHidden.value = originalBrokerId;
          }
        }

        // Pre-select insurance company using Select2
        if (originalInsuranceCompany) {
          console.log('Pre-selecting insurance company:', originalInsuranceCompany);
          $(insuranceCompanySelect).val(originalInsuranceCompany).trigger('change');
        }
      }).catch(error => {
        console.error('Error loading brokers/companies for Broking mode:', error);
      });
    }
  } else {
    console.warn('Some dropdown elements not found during initialization');
  }

  // Additional initialization after Select2 is loaded
  setTimeout(() => {
    // Initialize Select2 on broker code type and trigger change if needed
    $('#life_insurance_broker_code_type').select2({
      theme: 'bootstrap-5',
      placeholder: 'Select Broker Code...',
      allowClear: true,
      width: '100%',
      dropdownParent: $('body'),
      minimumResultsForSearch: 0,
      closeOnSelect: true
    });

    // Check if broker code type should be auto-selected
    const currentBrokerCodeType = document.getElementById('life_insurance_broker_code_type')?.value;
    const originalAgencyCodeId = '<%= j(@renewed_policy.agency_code_id.to_s) %>';
    const originalBrokerId = '<%= j(@renewed_policy.broker_id.to_s) %>';

    console.log('Post-init check - Broker Code Type:', currentBrokerCodeType);
    console.log('Post-init check - Agency Code ID:', originalAgencyCodeId);
    console.log('Post-init check - Broker ID:', originalBrokerId);

    // Auto-detect broker code type if not set
    if (!currentBrokerCodeType && (originalAgencyCodeId || originalBrokerId)) {
      let detectedType = null;

      if (originalAgencyCodeId && !originalBrokerId) {
        detectedType = 'direct';
        console.log('Auto-detected broker type as "direct" based on agency_code_id');
      } else if (originalBrokerId && !originalAgencyCodeId) {
        detectedType = 'broking';
        console.log('Auto-detected broker type as "broking" based on broker_id');
      }

      if (detectedType) {
        // Set the broker code type and trigger change
        $('#life_insurance_broker_code_type').val(detectedType);
        console.log('Set broker code type to:', detectedType);
      }
    }

    // Only trigger change if broker type was NOT already pre-set from the original policy
    // (if it was pre-set, the init block above already loaded agents/brokers)
    const finalBrokerCodeType = document.getElementById('life_insurance_broker_code_type')?.value;
    const preSetBrokerCodeType = '<%= @renewed_policy.broker_code_type %>';
    if (finalBrokerCodeType && !preSetBrokerCodeType) {
      console.log('Triggering broker code type change for auto-detected type:', finalBrokerCodeType);
      $('#life_insurance_broker_code_type').trigger('change');
    }
  }, 1000);

  // Helper function to force refresh affiliate dropdown
  function refreshAffiliateDropdown() {
    var selectedCustomerId = $('#customer_select').val();
    console.log('Refreshing affiliate dropdown for customer:', selectedCustomerId);

    // Clear the affiliate dropdown
    $('#affiliate_select').val(null);

    // Destroy and recreate the affiliate Select2 to force refresh
    $('#affiliate_select').select2('destroy');

    // Reinitialize with the same configuration
    $('#affiliate_select').select2({
      theme: 'bootstrap-5',
      placeholder: 'Search and select affiliate...',
      allowClear: true,
      width: '100%',
      dropdownParent: $('body'),
      dropdownCssClass: 'select2-dropdown-large',
      minimumInputLength: 0,
      ajax: {
        url: '/api/v1/public/search_sub_agents',
        dataType: 'json',
        delay: 250,
        timeout: 10000,
        data: function (params) {
          console.log('Refreshing with params:', {
            q: params.term || '',
            customer_id: selectedCustomerId,
            limit: params.term ? 20 : 10
          });

          return {
            q: params.term || '',
            customer_id: selectedCustomerId,
            limit: params.term ? 20 : 10
          };
        },
        processResults: function (data) {
          console.log('Refreshed affiliates response:', data);

          // Handle both array and object responses
          var results = [];
          if (data && Array.isArray(data.results)) {
            results = data.results;
          } else if (data && Array.isArray(data)) {
            results = data;
          } else {
            console.warn('Unexpected refresh API response format:', data);
            results = [];
          }

          console.log('Processed refresh results:', results);
          return {
            results: results
          };
        },
        error: function(xhr, status, error) {
          console.error('Refresh affiliates AJAX error:', {
            status: status,
            error: error,
            responseText: xhr.responseText,
            statusCode: xhr.status
          });

          // Show more helpful error message
          var errorMessage = 'Error refreshing affiliates';
          if (xhr.status === 0) {
            errorMessage = 'Network error - please check your connection';
          } else if (xhr.status === 500) {
            errorMessage = 'Server error - please try again';
          } else if (xhr.status === 404) {
            errorMessage = 'Affiliate search endpoint not found';
          }

          return {
            results: [{id: '', text: errorMessage}]
          };
        },
        cache: false
      },
      templateResult: function(option) {
        if (option.loading) return option.text;
        if (!option.id || option.id === '') {
          return option.text;
        }

        var initials = option.text.split(' ').map(function(name) {
          return name.charAt(0).toUpperCase();
        }).join('').substring(0, 2);

        var $option = $(
          '<div class="affiliate-option">' +
            '<div class="affiliate-option-avatar">' + initials + '</div>' +
            '<div class="affiliate-option-details">' +
              '<div class="affiliate-option-name">' + option.text + '</div>' +
              '<div class="affiliate-option-id">Affiliate ID: #' + option.id + '</div>' +
            '</div>' +
          '</div>'
        );
        return $option;
      },
      templateSelection: function(option) {
        return option.text || 'Search and select affiliate...';
      },
      escapeMarkup: function(markup) {
        return markup;
      }
    });
  }

  // Customer selection change event listeners
  $('#customer_select').on('select2:select', function(e) {
    var selectedCustomerId = this.value;
    console.log('Customer selected, filtering affiliates for customer ID:', selectedCustomerId);

    // Refresh the affiliate dropdown with the new customer filter
    setTimeout(function() {
      refreshAffiliateDropdown();
    }, 500);
  });

  // Handle customer clearing
  $('#customer_select').on('select2:clear', function(e) {
    // Clear affiliate dropdown when customer is cleared
    $('#affiliate_select').val(null).trigger('change');
    // Also clear distributor when customer is cleared
    $('#distributor_id_hidden').val('');
    console.log('Customer cleared, showing all affiliates and clearing distributor');
    // Clear nominee fields
    $('#renew_nominee_name').val('');
    $('#nominee_relationship_select').val('').trigger('change');
    $('#renew_nominee_age').val('');
    $('#renew_nominee_share').val('');
  });

  // Auto-load nominees for the pre-selected customer on renew page
  function loadRenewNominees(customerId) {
    if (!customerId) return;
    $.ajax({
      url: '<%= load_customer_nominees_admin_life_insurances_path %>',
      method: 'GET',
      data: { customer_id: customerId },
      success: function(response) {
        if (response.success && response.nominees && response.nominees.length > 0) {
          var n = response.nominees[0];
          $('#renew_nominee_name').val(n.nominee_name || '');
          var rel = (n.relationship || '').toLowerCase();
          // Try to match to the available relationship options
          var matchedRel = '';
          $('#nominee_relationship_select option').each(function() {
            if ($(this).val().toLowerCase() === rel || $(this).text().toLowerCase() === rel) {
              matchedRel = $(this).val();
            }
          });
          if (matchedRel) {
            $('#nominee_relationship_select').val(matchedRel).trigger('change');
          }
          $('#renew_nominee_age').val(n.age || '');
          $('#renew_nominee_share').val(100);
          console.log('Nominee auto-loaded for customer:', customerId, n);
        }
      },
      error: function(xhr, status, error) {
        console.error('Error loading nominees for renew:', error);
      }
    });
  }

  // Load nominees on page load for pre-selected customer
  setTimeout(function() {
    var preSelectedCustomer = $('#customer_select').val();
    if (preSelectedCustomer) {
      loadRenewNominees(preSelectedCustomer);
    }
  }, 600);

  // Also load nominees when customer is manually changed
  $('#customer_select').on('select2:select', function(e) {
    loadRenewNominees(e.params.data.id);
  });

  // Check for customer-specific affiliate loading after a delay
  setTimeout(function() {
    var selectedCustomerId = $('#customer_select').val();
    var currentAffiliateValue = $('#affiliate_select').val();

    console.log('Checking affiliate dropdown status for customer:', selectedCustomerId);
    console.log('Current affiliate value:', currentAffiliateValue);

    // Only refresh if customer is selected but affiliate is not yet set
    if (selectedCustomerId && !currentAffiliateValue) {
      console.log('Customer is pre-selected but no affiliate selected, may need to refresh affiliate dropdown');

      // Optional: Force refresh the affiliate dropdown for the specific customer
      // This is usually not needed since we pre-select the affiliate above
      // refreshAffiliateDropdown();
    } else if (currentAffiliateValue) {
      console.log('Affiliate already pre-selected:', currentAffiliateValue);
    } else if (!selectedCustomerId) {
      console.log('No customer pre-selected, affiliate dropdown will show all affiliates');
    }
  }, 2000); // Delay to ensure both Select2 dropdowns are initialized

  // Initialize calculations on page load
  setTimeout(() => {
    console.log('=== Commission Values Check ===');
    console.log('Main Agent Commission %:', document.getElementById('commission_percentage')?.value);
    console.log('Sub Agent Commission %:', document.querySelector('.sub-agent-commission-percentage')?.value);
    console.log('Ambassador Commission %:', document.querySelector('.ambassador-commission-percentage')?.value);
    console.log('Investor Commission %:', document.querySelector('.investor-commission-percentage')?.value);
    console.log('Company Expenses %:', document.querySelector('.company-expenses-percentage')?.value);
    console.log('================================');

    calculateAllCommissions();
    calculateTotalPremium();
    calculateEndDate();
  }, 2000);

  // Image preview functionality
  function handleFileSelect(event, previewContainerId) {
    const files = event.target.files;
    const previewContainer = document.getElementById(previewContainerId);

    // Clear existing previews only if new files are selected
    if (files.length > 0) {
      previewContainer.innerHTML = '';
    }

    Array.from(files).forEach((file, index) => {
      const reader = new FileReader();

      if (file.type.match('image.*')) {
        // Handle image files
        reader.onload = function(e) {
          const container = document.createElement('div');
          container.className = 'image-preview-container';
          container.setAttribute('data-file-index', index);

          const img = document.createElement('img');
          img.className = 'image-preview';
          img.src = e.target.result;
          img.alt = file.name;
          img.title = file.name;
          img.onclick = function() {
            showImageModal(e.target.result, file.name);
          };

          const removeBtn = document.createElement('button');
          removeBtn.className = 'remove-preview';
          removeBtn.innerHTML = '×';
          removeBtn.onclick = function() {
            removeFile(event.target, index, container);
          };

          container.appendChild(img);
          container.appendChild(removeBtn);
          previewContainer.appendChild(container);
        };
        reader.readAsDataURL(file);
      } else {
        // Handle non-image files
        const container = document.createElement('div');
        container.className = 'file-preview-container';
        container.setAttribute('data-file-index', index);

        const icon = document.createElement('div');
        icon.className = 'file-icon';

        // Set icon based on file type
        if (file.type.includes('pdf')) {
          icon.innerHTML = '<i class="bi bi-file-earmark-pdf-fill text-danger"></i>';
        } else if (file.type.includes('word') || file.name.endsWith('.doc') || file.name.endsWith('.docx')) {
          icon.innerHTML = '<i class="bi bi-file-earmark-word-fill text-primary"></i>';
        } else {
          icon.innerHTML = '<i class="bi bi-file-earmark-fill text-secondary"></i>';
        }

        const fileName = document.createElement('div');
        fileName.className = 'file-name';
        fileName.textContent = file.name.length > 20 ? file.name.substring(0, 17) + '...' : file.name;
        fileName.title = file.name;

        const removeBtn = document.createElement('button');
        removeBtn.className = 'remove-preview';
        removeBtn.innerHTML = '×';
        removeBtn.onclick = function() {
          removeFile(event.target, index, container);
        };

        container.appendChild(icon);
        container.appendChild(fileName);
        container.appendChild(removeBtn);
        previewContainer.appendChild(container);
      }
    });
  }

  // Remove file from input
  function removeFile(input, index, containerElement) {
    const dt = new DataTransfer();
    const files = input.files;

    for (let i = 0; i < files.length; i++) {
      if (i !== index) {
        dt.items.add(files[i]);
      }
    }

    input.files = dt.files;
    containerElement.remove();

    // If no files left, trigger change event to clear input
    if (input.files.length === 0) {
      $(input).val('').trigger('change');
    }
  }

  // Show full-size image modal
  function showImageModal(src, alt) {
    // Create modal if it doesn't exist
    let modal = document.getElementById('imageModal');
    if (!modal) {
      modal = document.createElement('div');
      modal.id = 'imageModal';
      modal.className = 'image-modal';
      modal.innerHTML = `
        <span class="image-modal-close">&times;</span>
        <img class="image-modal-content" id="modalImage">
      `;
      document.body.appendChild(modal);

      // Close modal when clicking on X or outside the image
      modal.onclick = function(e) {
        if (e.target === modal || e.target.className === 'image-modal-close') {
          modal.style.display = 'none';
        }
      };
    }

    // Set image and show modal
    document.getElementById('modalImage').src = src;
    document.getElementById('modalImage').alt = alt;
    modal.style.display = 'block';
  }

  // Attach file input listeners
  document.getElementById('policy_documents_upload').addEventListener('change', function(e) {
    handleFileSelect(e, 'policy_documents_preview');
  });

  document.getElementById('additional_documents_upload').addEventListener('change', function(e) {
    handleFileSelect(e, 'additional_documents_preview');
  });

  // Close modal on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      const modal = document.getElementById('imageModal');
      if (modal && modal.style.display === 'block') {
        modal.style.display = 'none';
      }
    }
  });
});
</script>