  function calculateAllCommissions() {
    calculateCommission();
    calculateSubAgentCommission();
    calculateAmbassadorCommission();
    calculateInvestorCommission();
    calculateCompanyExpenses();
    calculateProfitAndExpenses();
  }

  // Auto-calculate end date when start date changes (1 year policy)
  function calculateEndDate() {
    const startDate = document.getElementById('start_date')?.value;
    if (startDate) {
      const endDateObj = new Date(startDate);
      endDateObj.setFullYear(endDateObj.getFullYear() + 1);
      endDateObj.setDate(endDateObj.getDate() - 1); // One day before next year

      document.getElementById('end_date').value = endDateObj.toISOString().split('T')[0];
    }
  }

