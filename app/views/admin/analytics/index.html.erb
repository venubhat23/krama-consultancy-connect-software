            '#5b21b6'
          ]
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        indexAxis: 'y',
        scales: {
          x: {
            beginAtZero: true,
            grid: {
              color: '#f1f5f9',
              drawOnChartArea: true
            },
            ticks: {
              color: '#6b7280'
            }
          },
          y: {
            grid: {
              color: '#f1f5f9',
              drawOnChartArea: false
            },
            ticks: {
