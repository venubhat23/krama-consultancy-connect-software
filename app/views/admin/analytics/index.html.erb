        data: policyPerformanceValues,
        backgroundColor: [
          '#3b82f6',
          '#10b981',
          '#f59e0b',
          '#ec4899'
        ],
        borderRadius: 8,
        borderSkipped: false,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: '#f1f5f9' }
        },
        x: {
          grid: { display: false }
        }
      },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(0, 0, 0, 0.8)',
          titleColor: '#ffffff',
          bodyColor: '#ffffff'
        }
      }
    }
  });
    console.log('✅ Policy Performance Chart initialized successfully');

  } catch (error) {
    console.error('❌ Error initializing Policy Performance Chart:', error);
  }

  try {
    // Operations Overview Chart
    console.log('🔧 Initializing Operations Chart...');
    const operationsCtx = document.getElementById('operationsChart');
    if (!operationsCtx) {
      console.error('❌ operationsChart canvas not found!');
      return;
    }
    const operationsChart = new Chart(operationsCtx.getContext('2d'), {
    type: 'polarArea',
    plugins: [ChartDataLabels],
    data: {
      labels: ['Documents Pending', 'Support Tickets', 'Claims Processing', 'Client Requests'],
      datasets: [{
        data: [
          <%= (@docs_pending || 0) %>,
          <%= (@support_tickets || 0) %>,
          <%= (@claims_processing || 0) %>,
          <%= (@client_requests_count || 0) %>
        ],
        backgroundColor: [
          'rgba(239, 68, 68, 0.7)',
          'rgba(245, 158, 11, 0.7)',
          'rgba(139, 92, 246, 0.7)',
          'rgba(6, 182, 212, 0.7)'
        ],
        borderColor: [
          '#ef4444',
          '#f59e0b',
          '#8b5cf6',
          '#06b6d4'
        ],
        borderWidth: 2
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom',
          labels: {
            padding: 15,
            usePointStyle: true,
            font: { size: 11 }
          }
        },
        datalabels: {
          display: false  // Disable for polar area charts
        }
      },
      scales: {
        r: {
          beginAtZero: true,
          grid: { color: '#f1f5f9' }
        }
      }
    }
  });
    console.log('✅ Operations Chart initialized successfully');

  } catch (error) {
    console.error('❌ Error initializing Operations Chart:', error);
  }

  try {
    // Quick Insights Chart
    console.log('📈 Initializing Quick Insights Chart...');
    const quickInsightsCtx = document.getElementById('quickInsightsChart');
    if (!quickInsightsCtx) {
      console.error('❌ quickInsightsChart canvas not found!');
      return;
    }
    const quickInsightsChart = new Chart(quickInsightsCtx.getContext('2d'), {
    type: 'radar',
    plugins: [ChartDataLabels],
    data: {
      labels: ['Active Customers', 'Converted Leads', 'New Leads', 'Support Tickets'],
      datasets: [{
        label: 'Business Metrics',
        data: [
          <%= (@active_customers || 0) %>,
          <%= (@converted_leads || 0) %>,
          <%= (@new_leads || 0) %>,
          <%= (@support_tickets || 0) %>
        ],
        borderColor: '#3b82f6',
        backgroundColor: 'rgba(59, 130, 246, 0.2)',
        pointBackgroundColor: '#3b82f6',
        pointBorderColor: '#ffffff',
        pointBorderWidth: 2,
        borderWidth: 2,
        tension: 0.1
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        datalabels: {
          display: false  // Disable for radar charts
        }
      },
      scales: {
        r: {
          beginAtZero: true,
          grid: { color: '#f1f5f9' },
          angleLines: { color: '#e2e8f0' },
          ticks: {
            display: false
          }
        }
      }
    }
  });
    console.log('✅ Quick Insights Chart initialized successfully');

  } catch (error) {
    console.error('❌ Error initializing Quick Insights Chart:', error);
  }

  console.log('🎉 All analytics charts initialization completed!');

  // Enhanced Chart Interaction Functions

  // Store chart instances globally for manipulation
  window.chartInstances = {};

  // Function to toggle chart types
  window.toggleChartType = function(chartId, currentType, newType) {
    const chart = Chart.getChart(chartId);
    if (chart) {
      const currentTypeActual = chart.config.type;
      const targetType = currentTypeActual === currentType ? newType : currentType;

      // Show loading
      showChartLoading(chartId);

      setTimeout(() => {
        chart.config.type = targetType;

        // Adjust options based on chart type
        if (targetType === 'bar' && currentTypeActual === 'line') {
          chart.config.options.scales.y.beginAtZero = true;
          chart.config.data.datasets.forEach(dataset => {
            dataset.fill = false;
            dataset.tension = 0;
          });
        } else if (targetType === 'line' && currentTypeActual === 'bar') {
          chart.config.data.datasets.forEach(dataset => {
            dataset.fill = true;
            dataset.tension = 0.4;
          });
        }

        chart.update('active');
        hideChartLoading(chartId);
      }, 300);
    }
  };

  // Function to refresh individual charts with real data
  window.refreshChart = function(chartName) {
    const chartCard = document.querySelector(`[data-chart="${chartName}"]`);
    if (chartCard) {
      showChartLoading(chartCard.querySelector('canvas').id);

      // Preserve current filter params so chart refresh uses the same date range
      const currentParams = new URLSearchParams(window.location.search);
      currentParams.set('refresh', 'true');
      currentParams.set('chart', chartName);

      fetch('/admin/analytics?' + currentParams.toString(), {
        headers: {
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        }
      })
      .then(response => response.json())
      .then(data => {
        console.log(`✅ Fresh data received for ${chartName}:`, data);

        // Update chart with fresh data based on chart type
        updateChartData(chartName, data);

        hideChartLoading(chartCard.querySelector('canvas').id);

        // Success animation
        chartCard.style.borderColor = '#10b981';
        chartCard.style.transform = 'scale(0.98)';
        setTimeout(() => {
          chartCard.style.transform = 'scale(1)';
          chartCard.style.borderColor = '#e2e8f0';
        }, 150);

        // Show success notification
        showNotification(`${chartName} updated successfully`, 'success');
      })
      .catch(error => {
        console.error(`❌ Error refreshing ${chartName}:`, error);
        hideChartLoading(chartCard.querySelector('canvas').id);

        // Error animation
        chartCard.style.borderColor = '#ef4444';
        setTimeout(() => {
          chartCard.style.borderColor = '#e2e8f0';
        }, 2000);

        // Show error notification
        showNotification(`Failed to update ${chartName}`, 'error');
      });
    }
  };

  // Function to update chart data dynamically
  function updateChartData(chartName, newData) {
    const chartMapping = {
      'policyDistribution': 'policyDistributionChart',
      'monthlyTrends': 'monthlyTrendsChart',
      'leadStage': 'leadStageChart',
      'policyPerformance': 'policyPerformanceChart',
      'premiumRevenue': 'premiumRevenueTrendChart'
    };

    const chartId = chartMapping[chartName];
    const chart = Chart.getChart(chartId);

    if (chart && newData) {
      // Update chart data with smooth animation
      chart.data.labels = newData.labels || chart.data.labels;

      if (chart.data.datasets && newData.data) {
        chart.data.datasets.forEach((dataset, index) => {
          dataset.data = Array.isArray(newData.data) ? newData.data : newData.data[index] || dataset.data;
        });
      }

      chart.update('active');
      console.log(`🔄 Updated ${chartName} with fresh data`);
    }
  }

  // Notification system functions
  function showNotification(message, type = 'success') {
    const indicator = document.getElementById('updateIndicator');
    const text = document.getElementById('indicatorText');
    const icon = indicator.querySelector('i');

    // Update content
    text.textContent = message;

    // Update styling based on type
    if (type === 'error') {
      indicator.className = 'update-indicator error show';
      icon.className = 'bi bi-exclamation-triangle me-2';
    } else if (type === 'loading') {
      indicator.className = 'update-indicator show';
      icon.className = 'bi bi-arrow-repeat me-2';
      icon.style.animation = 'spin 1s linear infinite';
    } else {
      indicator.className = 'update-indicator show';
      icon.className = 'bi bi-check-circle me-2';
      icon.style.animation = '';
    }

    // Hide after 3 seconds (except for loading)
    if (type !== 'loading') {
      setTimeout(() => {
        indicator.classList.remove('show');
      }, 3000);
    }
  }

  function showLoadingNotification(message) {
    const indicator = document.getElementById('updateIndicator');
    const text = document.getElementById('indicatorText');
    const icon = indicator.querySelector('i');

    text.textContent = message;
    indicator.className = 'update-indicator show';
    icon.className = 'bi bi-arrow-repeat me-2';
    icon.style.animation = 'spin 1s linear infinite';

    return () => {
      icon.style.animation = '';
      indicator.classList.remove('show');
    };
  }

  // Function to show loading state
  function showChartLoading(chartId) {
    const canvas = document.getElementById(chartId);
    if (canvas) {
      const loadingElement = canvas.parentElement.querySelector('.chart-loading');
      if (loadingElement) {
        loadingElement.style.display = 'block';
      }
    }
  }

  // Function to hide loading state
  function hideChartLoading(chartId) {
    const canvas = document.getElementById(chartId);
    if (canvas) {
      const loadingElement = canvas.parentElement.querySelector('.chart-loading');
      if (loadingElement) {
        loadingElement.style.display = 'none';
      }
    }
  }

  // Enhanced chart animations and interactions
  Chart.defaults.animation = {
    duration: 1000,
    easing: 'easeInOutQuart'
  };

  Chart.defaults.interaction = {
    mode: 'index',
    intersect: false
  };

  // Global chart hover effects
  Chart.defaults.onHover = function(event, activeElements) {
    event.native.target.style.cursor = activeElements.length > 0 ? 'pointer' : 'default';
  };

  // Auto-refresh charts every 5 minutes (optional)
  setInterval(() => {
    const currentTime = new Date().toLocaleTimeString();
    console.log(`Auto-refreshing analytics charts at ${currentTime}`);

    // Show loading notification
    const hideLoading = showLoadingNotification('Auto-refreshing charts...');

    // Add pulse effect to indicate auto-refresh
    document.querySelectorAll('.chart-card').forEach(card => {
      card.classList.add('pulse');
      setTimeout(() => {
        card.classList.remove('pulse');
      }, 1000);
    });

    // Refresh page data (simplified approach)
    setTimeout(() => {
      hideLoading();
      showNotification('Charts auto-refreshed', 'success');
    }, 2000);
  }, 300000); // 5 minutes

  // Add keyboard shortcuts for chart interactions
  document.addEventListener('keydown', (event) => {
    if (event.ctrlKey && event.key === 'r') {
      event.preventDefault();
      // Refresh all charts
      document.querySelectorAll('[data-chart]').forEach(card => {
        const chartName = card.dataset.chart;
        refreshChart(chartName);
      });
    }
  });

  // ---- Investor Analytics Charts ----
  const investorAmbassadorData = <%= (@top_investors_by_ambassadors || {}).to_json.html_safe %>;

  try {
    // Top Investors by Ambassador Count (horizontal bar)
    const invAmbCtx = document.getElementById('investorAmbassadorChart');
    if (invAmbCtx && Object.keys(investorAmbassadorData).length > 0) {
      new Chart(invAmbCtx.getContext('2d'), {
        type: 'bar',
        plugins: [ChartDataLabels],
        data: {
          labels: Object.keys(investorAmbassadorData),
          datasets: [{
            label: 'Ambassadors',
            data: Object.values(investorAmbassadorData),
            backgroundColor: [
              '#8b5cf6','#7c3aed','#a78bfa','#6d28d9','#ddd6fe',
              '#4c1d95','#c4b5fd','#5b21b6','#ede9fe','#4338ca'
            ],
            borderRadius: 6,
            borderSkipped: false
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          indexAxis: 'y',
          scales: {
            x: { beginAtZero: true, grid: { color: '#f1f5f9' } },
            y: { grid: { display: false }, ticks: { font: { weight: 'bold' } } }
          },
          plugins: {
            legend: { display: false },
            datalabels: {
              color: '#fff', font: { size: 11, weight: 'bold' },
              formatter: (v) => v,
              anchor: 'end', align: 'start', offset: 4
            }
          }
        }
      });
    } else if (invAmbCtx) {
      const ctx2d = invAmbCtx.getContext('2d');
      ctx2d.font = '14px sans-serif';
      ctx2d.fillStyle = '#9ca3af';
      ctx2d.textAlign = 'center';
      ctx2d.fillText('No ambassador data available', invAmbCtx.width / 2, invAmbCtx.height / 2);
    }
  } catch(e) { console.error('Investor ambassador chart error:', e); }


  // Final initialization summary
  console.log('🎯 ===== ANALYTICS CHARTS INITIALIZATION COMPLETE =====');
  console.log('✅ All charts should now be visible and interactive');
  console.log('📊 Charts initialized:', Chart.instances.length, 'total instances');
  console.log('🎨 Enhanced analytics charts loaded with interactive features!');
  console.log('💡 Features available:');
  console.log('   - Click chart type buttons to toggle between chart types');
  console.log('   - Click refresh buttons to reload chart data');
  console.log('   - Hover effects and animations on all charts');
  console.log('   - Auto-refresh every 5 minutes');
  console.log('   - Keyboard shortcut: Ctrl+R to refresh all charts');
  console.log('🔗 If charts are still empty, check:');
  console.log('   1. Data availability in controller');
  console.log('   2. Canvas elements exist in HTML');
  console.log('   3. Chart.js library loaded correctly');

  // Unified period dropdown handler
  function applyPeriod(val) {
    const yearHidden  = document.getElementById('year_hidden');
    const fyHidden    = document.getElementById('fy_hidden');
    const startField  = document.getElementById('start_date_field');
    const endField    = document.getElementById('end_date_field');
    const monthSelect = document.getElementById('month_filter');

    if (!val) return;
    if (val.startsWith('cal_')) {
      const yr = parseInt(val.replace('cal_', ''));
      if (yearHidden) yearHidden.value = yr;
      if (fyHidden)   fyHidden.value   = '';
      if (startField) startField.value = yr + '-01-01';
      if (endField)   endField.value   = yr + '-12-31';
      if (monthSelect) monthSelect.value = '';
    } else if (val.startsWith('fy_')) {
      const fy = parseInt(val.replace('fy_', ''));
      if (fyHidden)   fyHidden.value   = fy;
      if (yearHidden) yearHidden.value = '';
      if (startField) startField.value = (fy - 1) + '-04-01';
      if (endField)   endField.value   = fy       + '-03-31';
      if (monthSelect) monthSelect.value = '';
    }
  }

  const periodSelect = document.getElementById('period_select');
  if (periodSelect) {
    periodSelect.addEventListener('change', function() {
      applyPeriod(this.value);
      const form = this.closest('form');
      if (form) form.submit();
    });
  }

  const monthSelectEl = document.getElementById('month_filter');
  if (monthSelectEl) {
    monthSelectEl.addEventListener('change', function() {
      const form = this.closest('form');
      if (form) form.submit();
    });
  }

  function refreshAnalytics() {
    const currentUrl = new URL(window.location);
    currentUrl.searchParams.set('refresh', 'true');
    window.location.href = currentUrl.toString();
  }

  // Add keyboard shortcut for refresh (Ctrl+R or Cmd+R)
  document.addEventListener('keydown', function(e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 'r') {
      e.preventDefault();
      refreshAnalytics();
    }
  });

  console.log('✅ Analytics filter functionality initialized');

});
</script>