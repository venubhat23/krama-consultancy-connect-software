    const monthlyChart = new Chart(trendsCtx.getContext('2d'), {
    type: 'line',
    plugins: [ChartDataLabels],
    data: {
      labels: monthlyLabels,
      datasets: [
        {
          label: 'Customers',
          data: customerData,
          borderColor: '#3b82f6',
