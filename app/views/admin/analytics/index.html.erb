</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  console.log('🎯 Analytics Charts Initialization Started...');

  // Register the datalabels plugin globally
  Chart.register(ChartDataLabels);

  // Set global defaults for data labels
  Chart.defaults.plugins.datalabels = {
    display: true,
    color: '#fff',
    font: {
      size: 11,
      weight: 'bold'
    },
    formatter: (value) => value,
    anchor: 'center',
    align: 'center'
  };

  // Refresh Affiliates Data function
  window.refreshAffiliatesData = function() {
    const card = document.querySelector('.kpi-card[style*="--card-color: #ec4899"]');
    const valueElement = document.getElementById('affiliates-value');
    const changeElement = document.getElementById('affiliates-change');
    const refreshBtn = event.currentTarget;

    if (!card || !valueElement || !changeElement) return;

    // Start loading state
    refreshBtn.innerHTML = '<i class="bi bi-arrow-clockwise" style="font-size: 0.75rem; animation: spin 1s linear infinite;"></i>';

    // Add visual feedback
    card.style.transform = 'scale(0.98)';
    card.style.transition = 'transform 0.2s ease';
    card.style.boxShadow = '0 0 0 2px rgba(236, 72, 153, 0.2)';

    // Show notification
    showNotification('Refreshing affiliates data...', 'loading');

    // Simulate data refresh (in a real app, this would be an AJAX call)
    setTimeout(() => {
      // Success animation
      card.style.transform = 'scale(1)';
      card.style.boxShadow = '';

      // Reset button
      refreshBtn.innerHTML = '<i class="bi bi-arrow-clockwise" style="font-size: 0.75rem;"></i>';

      // Add a subtle flash effect to show update
      valueElement.style.background = 'rgba(236, 72, 153, 0.1)';
      setTimeout(() => {
        valueElement.style.background = '';
      }, 300);

      showNotification('Affiliates data refreshed', 'success');
    }, 800);
  };

  // Debug data with fallbacks
  const policyDistributionData = <%= (@policy_distribution || {}).to_json.html_safe %>;
  const commissionSummaryData = <%= (@commission_summary || {}).to_json.html_safe %>;
  const leadFunnelData = <%= (@lead_conversion_funnel || {}).to_json.html_safe %>;
  const monthlyTrendsData = <%= (@monthly_trends || {}).to_json.html_safe %>;
  const leadStageData = <%= (@lead_stage_distribution || {}).to_json.html_safe %>;
  const renewalAnalyticsData = <%= (@renewal_analytics || {}).to_json.html_safe %>;
  const customerLocationData = <%= (@customer_location || {}).to_json.html_safe %>;
  const customerAcquisitionData = <%= (@customer_acquisition_trend || {}).to_json.html_safe %>;
  const premiumRevenueData = <%= (@premium_revenue_trend || {}).to_json.html_safe %>;

  console.log('Policy Distribution Data:', policyDistributionData);
  console.log('Commission Summary Data:', commissionSummaryData);
  console.log('Lead Funnel Data:', leadFunnelData);
  console.log('Monthly Trends Data:', monthlyTrendsData);
  console.log('Lead Stage Data:', leadStageData);
  console.log('Renewal Analytics Data:', renewalAnalyticsData);

  try {
    // Premium Revenue Trend Chart - Clean Line Graph
    console.log('💰 Initializing Premium Revenue Trend Chart...');
    const premiumTrendCtx = document.getElementById('premiumRevenueTrendChart');
    if (!premiumTrendCtx) {
      console.error('❌ premiumRevenueTrendChart canvas not found!');
    } else {
      const premiumLabels = Object.keys(premiumRevenueData);
      const premiumValues = Object.values(premiumRevenueData);

      if (premiumLabels.length === 0) {
        console.warn('No premium revenue data available');
      } else {

      // Create gradient for the line
      const gradientPremium = premiumTrendCtx.getContext('2d').createLinearGradient(0, 0, 0, 300);
      gradientPremium.addColorStop(0, 'rgba(16, 185, 129, 0.3)');
      gradientPremium.addColorStop(1, 'rgba(16, 185, 129, 0.01)');

      const premiumRevenueTrendChart = new Chart(premiumTrendCtx.getContext('2d'), {
        type: 'line',
        plugins: [ChartDataLabels],
        data: {
          labels: premiumLabels,
          datasets: [{
            label: 'Premium Revenue (Rs.)',
            data: premiumValues,
            borderColor: '#10b981',
            backgroundColor: gradientPremium,
            borderWidth: 3,
            tension: 0.4,
            fill: true,
            pointRadius: 4,
            pointBackgroundColor: '#10b981',
            pointBorderColor: '#ffffff',
