          beginAtZero: true,
          grid: { color: '#f1f5f9' }
        }
      },
      plugins: {
        legend: { display: false },
        datalabels: {
          color: '#fff',
          font: {
            size: 12,
            weight: 'bold'
          },
          formatter: (value) => {
            if (value >= 1000) {
              return 'Rs. ' + (value / 1000).toFixed(1) + 'K';
            }
            return 'Rs. ' + value;
          },
          anchor: 'center',
          align: 'center'
        }
      }
    }
    });
    console.log('✅ Commission Chart initialized successfully');

  } catch (error) {
    console.error('❌ Error initializing Commission Chart:', error);
  }

  try {
    // Renewal Analytics Chart
