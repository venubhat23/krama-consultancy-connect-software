      <div style="margin-top: 1rem;">
        <%
          commissions_due_safe  = (@commissions_due.to_f rescue 0)
          commissions_paid_safe = ((@commission_summary.is_a?(Hash) ? (@commission_summary['total_commission_paid'] || @commission_summary[:total_commission_paid]) : 0).to_f rescue 0)
          total_policies_safe   = (@total_policies.to_i rescue 0)
          total_commission      = commissions_due_safe + commissions_paid_safe
          commission_paid_rate  = total_commission > 0 ? ((commissions_paid_safe / total_commission) * 100).round(1) : 0

          commission_stats = {
            'Total Commission Due'      => { value: commissions_due_safe, format: 'currency', color: '#ef4444' },
            'Total Commission Paid'     => { value: commissions_paid_safe, format: 'currency', color: '#10b981' },
            'Avg Commission per Policy' => { value: total_policies_safe > 0 ? (commissions_due_safe / total_policies_safe.to_f).round(0) : 0, format: 'currency', color: '#3b82f6' },
            'Commission Paid Rate'      => { value: commission_paid_rate, format: 'percentage', color: '#8b5cf6' }
          }
        %>
        <% commission_stats.each do |label, data| %>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid #f1f5f9;">
