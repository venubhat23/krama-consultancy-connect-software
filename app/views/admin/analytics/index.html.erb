            },
            datalabels: {
              backgroundColor: '#10b981',
              borderColor: 'white',
              borderRadius: 4,
              borderWidth: 2,
              color: 'white',
              font: {
                size: 10,
                weight: 'bold'
              },
              formatter: (value) => 'Rs. ' + (value / 1000).toFixed(0) + 'K',
              padding: 4,
              anchor: 'end',
              align: 'top',
              display: 'auto'
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: {
                color: '#f1f5f9',
                drawBorder: false
              },
              ticks: {
                color: '#6b7280',
                font: {
                  size: 11
                },
                callback: function(value) {
                  return 'Rs. ' + (value / 1000) + 'K';
                }
              }
            },
            x: {
              grid: {
                display: false
              },
              ticks: {
                color: '#6b7280',
                font: {
                  size: 11
                },
                maxRotation: 45,
                minRotation: 45
              }
            }
          },
          animation: {
            duration: 1500,
            easing: 'easeInOutQuart'
          }
        }
      });
      console.log('✅ Premium Revenue Trend Chart initialized successfully');
      } // end else (premiumLabels.length > 0)
    }
  } catch (error) {
    console.error('❌ Error initializing Premium Revenue Trend Chart:', error);
  }

  try {
    // Policy Distribution Chart
    console.log('📊 Initializing Policy Distribution Chart...');
    const policyCtx = document.getElementById('policyDistributionChart');
    if (!policyCtx) {
      console.error('❌ policyDistributionChart canvas not found!');
      throw new Error('policyDistributionChart canvas not found');
