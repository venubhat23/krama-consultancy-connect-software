                <%= indian_currency(data[:value] || 0) %>
              <% elsif data[:format] == 'percentage' %>
                <%= data[:value] %>%
              <% else %>
                <%= data[:value] %>
              <% end %>
            </span>
          </div>
        <% end %>
      </div>
