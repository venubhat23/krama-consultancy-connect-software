    const gradient4 = ctx.createLinearGradient(0, 0, 150, 0);
    gradient4.addColorStop(0, '#ec4899');
    gradient4.addColorStop(1, '#be185d');

    const gradient5 = ctx.createLinearGradient(0, 0, 100, 0);
    gradient5.addColorStop(0, '#8b5cf6');
