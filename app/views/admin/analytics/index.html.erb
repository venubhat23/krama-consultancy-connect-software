      datasets: [{
        data: [
          renewalAnalyticsData.expiring_soon || 0,
          renewalAnalyticsData.expiring_later || 0,
          renewalAnalyticsData.expired || 0,
          renewalAnalyticsData.renewal_rate || 0
        ],
        backgroundColor: [
          '#f59e0b',
          '#8b5cf6',
          '#ef4444',
          '#10b981'
        ],
        borderRadius: 6,
        borderSkipped: false,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: '#f1f5f9' }
        }
      },
      plugins: {
        legend: { display: false },
        datalabels: {
          color: '#fff',
          font: {
            size: 12,
            weight: 'bold'
          },
          formatter: (value, context) => {
            const label = context.chart.data.labels[context.dataIndex];
            if (label.includes('%')) {
              return value + '%';
            }
            return value;
          },
          anchor: 'center',
          align: 'center'
        }
      }
    }
    });
    console.log('✅ Renewal Analytics Chart initialized successfully');

  } catch (error) {
    console.error('❌ Error initializing Renewal Analytics Chart:', error);
  }

  try {
    // Lead Funnel Chart - Enhanced with gradient and animations
    console.log('🎯 Initializing Lead Funnel Chart...');
    const leadFunnelCtx = document.getElementById('leadFunnelChart');
    if (!leadFunnelCtx) {
      console.error('❌ leadFunnelChart canvas not found!');
      throw new Error('leadFunnelChart canvas not found');
    }

    // Create gradient colors for funnel effect
