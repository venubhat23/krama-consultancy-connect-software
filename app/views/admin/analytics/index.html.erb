    console.log('✅ Policy Distribution Chart initialized successfully');

  } catch (error) {
    console.error('❌ Error initializing Policy Distribution Chart:', error);
  }

  try {
    // Monthly Trends Chart
    console.log('📈 Initializing Monthly Trends Chart...');
