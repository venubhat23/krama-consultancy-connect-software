<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Ambassador Payouts</h2>
    <p class="text-muted mb-0">Manage ambassador commission payouts based on main agent commission payments (3% of net premium)</p>
  </div>
  <div>
    <button type="button" class="btn btn-primary me-2" onclick="openQuickPayoutModal()">
      <i class="bi bi-credit-card me-2"></i>Process Payout
    </button>
    <button type="button" class="btn btn-success" onclick="loadUnpaidDistributorsModal()">
      <i class="bi bi-wallet2 me-2"></i>Bulk Payout Manager
    </button>
  </div>
</div>

<!-- Summary Cards -->
<div class="row mb-4">
  <div class="col-md-3">
    <div class="card border-info">
      <div class="card-body text-center">
        <h5 class="card-title text-info">Total Ambassadors</h5>
        <h2 class="text-info"><%= @total_distributors %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-success">
      <div class="card-body text-center">
        <h5 class="card-title text-success">Total Commission Earned</h5>
        <h2 class="text-success"><%= indian_currency(@total_commission_earned.round(2)) %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-warning">
      <div class="card-body text-center">
        <h5 class="card-title text-warning">Pending Amount</h5>
        <h2 class="text-warning"><%= indian_currency(@total_pending_amount.round(2)) %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-primary">
      <div class="card-body text-center">
        <h5 class="card-title text-primary">Paid Amount</h5>
        <h2 class="text-primary"><%= indian_currency(@total_paid_amount.round(2)) %></h2>
      </div>
    </div>
  </div>
</div>

<!-- Ambassador Payouts Table -->
<div class="card">
  <div class="card-header">
    <h5 class="card-title mb-0">Ambassador Commission Summary</h5>
  </div>
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead class="table-light">
          <tr>
            <th>Ambassador Name</th>
            <th>Lead IDs & Commission</th>
            <th>Total Amount (Rs.)</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if @distributor_payouts.any? %>
            <% @distributor_payouts.each do |distributor_data| %>
              <tr>
                <td>
                  <div class="d-flex align-items-center">
                    <div class="avatar-sm bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3">
                      <i class="bi bi-building text-primary"></i>
                    </div>
                    <div>
                      <h6 class="mb-0"><%= distributor_data[:distributor].display_name %></h6>
                      <small class="text-muted"><%= distributor_data[:distributor].email %></small>
                    </div>
                  </div>
                </td>
                <td>
                  <button type="button"
                          class="btn btn-info btn-sm text-white mb-2"
                          onclick="showLeadsDetails('<%= distributor_data[:distributor].id %>')"
                          style="border-radius: 20px;">
                    <i class="bi bi-list-ul me-1"></i><%= distributor_data[:leads].count %> leads
                  </button>
                  <br>
                  <small class="text-muted mt-1">
                    Total Commission: Rs. <%= distributor_data[:leads].sum { |lead| lead[:commission] }.to_i.to_s.gsub(/\B(?=(\d{3})+(?!\d))/, ',') %>
                  </small>

                  <!-- Store distributor data for JavaScript -->
                  <script type="application/json" id="distributor-data-<%= distributor_data[:distributor].id %>">
                    {
                      "distributor": {
                        "id": <%= distributor_data[:distributor].id %>,
                        "name": "<%= j(distributor_data[:distributor].display_name) %>",
                        "email": "<%= distributor_data[:distributor].email %>"
                      },
                      "leads": <%= distributor_data[:leads].map do |lead_data|
                        {
                          lead: {
                            id: lead_data[:lead].try(:id),
                            lead_id: lead_data[:lead].try(:lead_id)
                          },
                          policy: {
                            id: lead_data[:policy].id,
                            policy_number: lead_data[:policy].policy_number,
                            policy_booking_date: lead_data[:policy].try(:policy_booking_date),
                            created_at: lead_data[:policy].created_at,
                            class_name: lead_data[:policy].class.name,
                            customer: {
                              id: lead_data[:policy].customer&.id,
                              first_name: lead_data[:policy].customer&.first_name,
                              last_name: lead_data[:policy].customer&.last_name,
                              display_name: lead_data[:policy].customer&.display_name,
                              email: lead_data[:policy].customer&.email
                            }
                          },
                          commission: lead_data[:commission],
                          paid: lead_data[:paid],
                          created_date: lead_data[:lead].try(:created_at)
                        }
                      end.to_json.html_safe %>
                    }
                  </script>
                </td>
                <td>
                  <span class="fw-bold text-dark">
                    <%= indian_currency(distributor_data[:total_amount].round) %>
                  </span>
                  <br>
                  <small class="text-muted">
                    Paid: <%= indian_currency(distributor_data[:paid_amount].round) %> |
                    Pending: <%= indian_currency(distributor_data[:pending_amount].round) %>
                  </small>
                </td>
                <td>
                  <% if distributor_data[:pending_amount] > 0 %>
                    <div class="d-flex align-items-center">
                      <span class="badge bg-warning me-2">
                        <i class="bi bi-clock me-1"></i>Pending Payment
                      </span>
                      <small class="text-muted">
                        <%= indian_currency(distributor_data[:pending_amount].round) %> pending
                      </small>
                    </div>
                  <% else %>
                    <div class="d-flex align-items-center">
                      <span class="badge bg-success">
                        <i class="bi bi-check-circle me-1"></i>All Paid
                      </span>
                      <small class="text-success ms-2">Complete</small>
                    </div>
                  <% end %>
                </td>
                <td>
                  <% unpaid_leads = distributor_data[:leads].select { |l| !l[:paid] } %>
                  <% if unpaid_leads.any? %>
                    <div class="d-flex gap-2">
                      <button type="button"
                              class="btn btn-sm btn-success"
                              onclick="openMarkAllModal(<%= distributor_data[:distributor].id %>, '<%= distributor_data[:distributor].display_name.html_safe %>', <%= distributor_data[:pending_amount].round(2) %>, <%= unpaid_leads.count %>, [<%= unpaid_leads.map { |l| "'#{l[:lead].lead_id}'" }.join(', ') %>])">
                        <i class="bi bi-check-circle me-1"></i>Mark All as Paid
                      </button>
                    </div>
                  <% else %>
                    <div class="d-flex align-items-center text-success">
                      <i class="bi bi-check-circle-fill me-2"></i>
                      <span class="fw-medium">All Paid</span>
                    </div>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="5" class="text-center py-4">
                <div class="text-center py-5">
                  <div class="mb-3">
                    <i class="bi bi-building display-1 text-muted"></i>
                  </div>
                  <h5 class="mb-3">No Ambassador Payouts Found</h5>
                  <p class="text-muted mb-4">
                    Ambassador payouts will appear here once main agent commissions are marked as received for policies with ambassadors.
                  </p>
                  <p class="text-muted">
                    <strong>How it works:</strong><br>
                    1. Main agent commission must be marked as "received" for policies<br>
                    2. Policies must have an associated lead ID and ambassador<br>
                    3. Ambassador commission is calculated as 3% of net premium<br>
                    4. Payouts are grouped by ambassador showing all their lead commissions
                  </p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Ambassador Commission Records -->
<%
  # Get ambassador commission records that were paid
  ambassador_commission_records = CommissionPayout.where(payout_to: 'ambassador_display', status: 'paid')
                                                 .includes(:payout)
                                                 .order(processed_at: :desc)
                                                 .limit(50)
%>

<% if ambassador_commission_records.any? %>
<div class="card mt-4">
  <div class="card-header bg-light">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="card-title mb-0">
        <i class="bi bi-trophy me-2 text-warning"></i>
        Ambassador Commission Records (Recent Payouts)
      </h5>
      <small class="text-muted">Showing last 50 paid commissions</small>
    </div>
    <small class="text-muted">These records show ambassador commissions that were paid after main agent commission was received</small>
  </div>
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-sm">
        <thead class="table-light">
          <tr>
            <th>Lead ID</th>
            <th>Policy Details</th>
            <th>Ambassador</th>
            <th>Commission Amount</th>
            <th>Transaction ID</th>
            <th>Payment Date</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% ambassador_commission_records.each do |record| %>
            <%
              policy = case record.policy_type
                      when 'health' then HealthInsurance.find_by(id: record.policy_id)
                      when 'life' then LifeInsurance.find_by(id: record.policy_id)
                      when 'motor' then MotorInsurance.find_by(id: record.policy_id)
                      when 'other' then OtherInsurance.find_by(id: record.policy_id) if defined?(OtherInsurance)
                      end

              distributor = policy&.respond_to?(:distributor_id) && policy.distributor_id.present? ?
                           Distributor.find_by(id: policy.distributor_id) : nil
            %>
            <% if policy && distributor %>
              <tr>
                <td>
                  <span class="badge bg-primary">
                    <%= record.lead_id %>
                  </span>
                </td>
                <td>
                  <div>
                    <small class="fw-medium"><%= policy.policy_number || 'N/A' %></small>
                    <br>
                    <small class="text-muted">
                      <%= record.policy_type.humanize %> |
                      <%= policy.customer&.display_name || 'Unknown' %>
                    </small>
                  </div>
                </td>
                <td>
                  <div>
                    <small class="fw-medium"><%= distributor.display_name %></small>
                    <br>
                    <small class="text-muted"><%= distributor.email %></small>
                  </div>
                </td>
                <td>
                  <span class="fw-bold text-success">
                    <%= indian_currency(record.payout_amount.round) %>
                  </span>
                </td>
                <td>
                  <small class="text-monospace"><%= record.transaction_id || 'N/A' %></small>
                </td>
                <td>
                  <small>
                    <%= record.payout_date&.strftime('%d %b %Y') || 'N/A' %>
                  </small>
                </td>
                <td>
                  <span class="badge bg-success">
                    <i class="bi bi-check-circle me-1"></i>Paid
                  </span>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="text-muted mt-3">
      <small>
        <i class="bi bi-info-circle me-1"></i>
        Ambassador commission records are automatically created when distributor payouts are marked as paid.
        These show the commission flow from main agent to distributors (ambassadors).
      </small>
    </div>
  </div>
</div>
<% end %>

<!-- Help Information -->
