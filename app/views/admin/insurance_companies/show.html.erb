}

.col-lg-4 .card:last-child {
  margin-bottom: 0;
}

/* Better button spacing */
.d-grid gap-2 > .btn {
  margin-bottom: 0.5rem;
}

.d-grid gap-2 > .btn:last-child {
  margin-bottom: 0;
}

/* Improved alert styling */
.alert-sm.alert-success {
