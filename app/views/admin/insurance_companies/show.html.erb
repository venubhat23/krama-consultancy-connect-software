  }
}

/* Progress bars styling */
.progress {
  border-radius: 10px;
  background-color: rgba(0,0,0,0.1);
}

.progress-bar {
  border-radius: 10px;
  transition: width 1s ease-in-out;
}

/* Enhanced sidebar cards */
