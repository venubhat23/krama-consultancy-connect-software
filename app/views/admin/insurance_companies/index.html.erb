<!-- Enhanced Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-0 text-primary">
      <i class="bi bi-building me-2"></i>Insurance Companies
    </h2>
    <p class="text-muted mb-0">Manage insurance company partnerships and policies</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to new_admin_insurance_company_path, class: "btn btn-primary shadow-sm" do %>
      <i class="bi bi-plus-lg me-1"></i>
      Add Insurance Company
    <% end %>
  </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm <%= 'border-primary' if @current_tab == 'all' %>">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Total Companies</h6>
            <h4 class="mb-0" data-stat="total"><%= @total_companies %></h4>
          </div>
          <div class="text-primary">
            <i class="bi bi-building fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm <%= 'border-success' if @current_tab == 'life' %>">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Life Insurance Companies</h6>
            <h4 class="mb-0" data-stat="life"><%= @life_companies %></h4>
          </div>
          <div class="text-success">
            <i class="bi bi-heart-pulse fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm <%= 'border-info' if @current_tab == 'health' %>">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Health Insurance Companies</h6>
            <h4 class="mb-0" data-stat="health"><%= @health_companies %></h4>
          </div>
          <div class="text-info">
            <i class="bi bi-shield-plus fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm <%= 'border-warning' if @current_tab == 'general' %>">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">General Insurance Companies</h6>
            <h4 class="mb-0" data-stat="motor"><%= @general_companies %></h4>
          </div>
          <div class="text-warning">
            <i class="bi bi-shield-check fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Tab Navigation and Table -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="mb-0">Insurance Companies List</h5>
      <div class="d-flex gap-2">
        <%= form_with url: admin_insurance_companies_path, method: :get, local: true, class: "d-flex gap-2", data: { turbo: false } do |f| %>
          <%= f.hidden_field :tab, value: @current_tab %>
          <div class="position-relative">
            <%= f.text_field :search, value: @search_query, placeholder: "Search companies...", class: "form-control", id: "searchInput" %>
            <i class="bi bi-search position-absolute top-50 end-0 translate-middle-y me-3"></i>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs border-0">
      <li class="nav-item">
        <%= link_to admin_insurance_companies_path(tab: 'all', search: @search_query),
            class: "nav-link #{'active' if @current_tab == 'all'}" do %>
          <i class="bi bi-grid me-1"></i>
          All Companies
          <span class="badge bg-primary-subtle text-primary ms-1"><%= @total_companies %></span>
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to admin_insurance_companies_path(tab: 'life', search: @search_query),
            class: "nav-link #{'active' if @current_tab == 'life'}" do %>
          <i class="bi bi-heart-pulse me-1"></i>
          Life Insurance
          <span class="badge bg-success-subtle text-success ms-1"><%= @life_companies %></span>
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to admin_insurance_companies_path(tab: 'health', search: @search_query),
            class: "nav-link #{'active' if @current_tab == 'health'}" do %>
          <i class="bi bi-shield-plus me-1"></i>
          Health Insurance
          <span class="badge bg-info-subtle text-info ms-1"><%= @health_companies %></span>
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to admin_insurance_companies_path(tab: 'general', search: @search_query),
            class: "nav-link #{'active' if @current_tab == 'general'}" do %>
          <i class="bi bi-shield-check me-1"></i>
          General Insurance
          <span class="badge bg-warning-subtle text-warning ms-1"><%= @general_companies %></span>
        <% end %>
      </li>
    </ul>
  </div>
  <div class="card-body p-0">
    <% if @insurance_companies.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 fw-semibold">Company Name</th>
              <th class="border-0 fw-semibold">Type</th>
              <th class="border-0 fw-semibold">Short Name</th>
              <th class="border-0 fw-semibold">Status</th>
              <th class="border-0 fw-semibold">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @insurance_companies.each do |company| %>
              <tr>
                <td class="align-middle">
                  <div class="d-flex align-items-center">
                    <div class="avatar-sm bg-primary-subtle rounded-circle d-flex align-items-center justify-content-center me-3">
                      <i class="bi bi-building text-primary"></i>
                    </div>
                    <div>
                      <h6 class="mb-0"><%= company.name %></h6>
                    </div>
                  </div>
                </td>
                <td class="align-middle">
                  <% case company.insurance_type %>
                  <% when 'life' %>
                    Life Insurance
                  <% when 'health' %>
                    Health Insurance
                  <% when 'motor_other' %>
                    General Insurance
                  <% else %>
                    Not Specified
                  <% end %>
                </td>
                <td class="align-middle">
                  <span class="badge bg-secondary-subtle text-secondary"><%= company.code || 'N/A' %></span>
                </td>
                <td class="align-middle">
                  <% if company.status %>
                    <span class="badge bg-success-subtle text-success">
                      <i class="bi bi-check-circle me-1"></i>
                      Active
                    </span>
                  <% else %>
                    <span class="badge bg-danger-subtle text-danger">
                      <i class="bi bi-x-circle me-1"></i>
                      Inactive
                    </span>
                  <% end %>
                </td>
                <td class="align-middle">
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                      <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu">
                      <li>
                        <%= link_to admin_insurance_company_path(company), class: "dropdown-item" do %>
                          <i class="bi bi-eye me-2"></i>
                          View Details
                        <% end %>
                      </li>
                      <li>
                        <%= link_to edit_admin_insurance_company_path(company), class: "dropdown-item" do %>
                          <i class="bi bi-pencil me-2"></i>
                          Edit Company
                        <% end %>
                      </li>
                      <li><hr class="dropdown-divider"></li>
                      <li>
                        <button type="button"
                            class="dropdown-item text-danger delete-company"
                            data-url="<%= admin_insurance_company_path(company) %>"
                            data-company-name="<%= company.name %>"
                            data-confirm="Are you sure you want to delete <%= company.name %>? This action cannot be undone.">
                          <i class="bi bi-trash me-2"></i>
                          Delete Company
                        </button>
                      </li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if respond_to?(:paginate) %>
        <div class="card-footer bg-transparent border-0">
          <%= paginate @insurance_companies, params: { tab: @current_tab, search: @search_query } %>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-5">
        <div class="mb-3">
          <i class="bi bi-building fs-1 text-muted"></i>
        </div>
        <h5 class="text-muted mb-3">No Insurance Companies Found</h5>
        <p class="text-muted mb-4">Start by adding your first insurance company to manage partnerships and policies.</p>
        <%= link_to "Add Insurance Company", new_admin_insurance_company_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

<!-- Set body data attributes for optimized JavaScript -->
<script>
  document.body.dataset.controller = 'insurance_companies';
  document.body.dataset.action = 'index';
</script>


<!-- Fallback JavaScript for browsers without module support -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Only run fallback if optimized version didn't load
  if (window.InsuranceCompaniesOptimized) return;

  console.warn('Loading fallback JavaScript for Insurance Companies');

  // Basic search functionality fallback
  const searchInput = document.getElementById('searchInput');
  const searchForm = searchInput?.closest('form');

  if (searchInput && searchForm) {
    let searchTimeout;

    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        searchForm.submit();
      }, 500);
    });

    searchInput.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        clearTimeout(searchTimeout);
        searchForm.submit();
      }
    });
  }

  // Basic delete functionality fallback
  document.addEventListener('click', function(e) {
    if (e.target.closest('.delete-company')) {
      e.preventDefault();

      const button = e.target.closest('.delete-company');
      const url = button.dataset.url;
      const companyName = button.dataset.companyName;
      const confirmMessage = button.dataset.confirm;

      if (confirm(confirmMessage)) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = url;
        form.style.display = 'none';

        const csrfToken = document.querySelector('meta[name="csrf-token"]');
        if (csrfToken) {
          const csrfInput = document.createElement('input');
          csrfInput.type = 'hidden';
          csrfInput.name = 'authenticity_token';
          csrfInput.value = csrfToken.content;
          form.appendChild(csrfInput);
        }

        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'DELETE';
        form.appendChild(methodInput);

        document.body.appendChild(form);
        form.submit();
      }
    }
  });
});
</script>