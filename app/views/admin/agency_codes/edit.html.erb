<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Edit Agency Code</h2>
    <p class="text-muted mb-0">Update the agency code information</p>
  </div>
  <div>
    <%= link_to admin_agency_codes_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>
      Back to Agency Codes
    <% end %>
  </div>
</div>

<!-- Error Display -->
<% if @agency_code.errors.any? %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <div class="d-flex align-items-center">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
      <div>
        <h6 class="mb-1"><%= pluralize(@agency_code.errors.count, "error") %> prohibited this agency code from being saved:</h6>
        <ul class="mb-0">
          <% @agency_code.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>

<%= form_with model: [:admin, @agency_code], local: true, class: "needs-validation", novalidate: true, data: { turbo: false } do |form| %>

  <!-- Agency Code Information -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-transparent border-0 d-flex align-items-center">
      <i class="bi bi-building me-2 text-primary"></i>
      <h5 class="mb-0">Agency Code Information</h5>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <%= form.label :insurance_type, "Insurance Type", class: "form-label" do %>
            <i class="bi bi-shield-check me-2 text-primary"></i>
            Insurance Type <span class="text-danger">*</span>
          <% end %>
          <%= form.select :insurance_type,
              options_for_select(@insurance_types.map { |type| [type, type] }, @agency_code.insurance_type),
              { prompt: 'Select Insurance Type' },
              { class: "form-select form-select-lg searchable-select", required: true, data: { placeholder: "Search and select type..." } } %>
          <small class="form-text text-muted">
            <i class="bi bi-info-circle me-1"></i>
            Select the type of insurance coverage
          </small>
          <div class="invalid-feedback">
            Please select an insurance type.
          </div>
        </div>

        <div class="col-md-6">
          <%= form.label :company_name, "Company Name", class: "form-label" do %>
            <i class="bi bi-building me-2 text-primary"></i>
            Company Name <span class="text-danger">*</span>
          <% end %>
          <%= form.select :company_name,
              options_for_select(@insurance_companies.map { |company| [company, company] }, @agency_code.company_name),
              { prompt: 'Select Insurance Company' },
              { class: "form-select form-select-lg searchable-select", required: true, data: { placeholder: "Search and select company..." } } %>
          <small class="form-text text-muted">
            <i class="bi bi-info-circle me-1"></i>
            Choose the insurance company
          </small>
          <div class="invalid-feedback">
            Please select a company name.
          </div>
        </div>

        <div class="col-md-6">
          <%= form.label :agent_name, "Agent Name", class: "form-label" do %>
            <i class="bi bi-person me-2 text-primary"></i>
            Agent Name <span class="text-danger">*</span>
          <% end %>
          <%= form.text_field :agent_name,
              class: "form-control form-control-lg",
              placeholder: "Enter agent name",
              required: true %>
          <small class="form-text text-muted">
            <i class="bi bi-info-circle me-1"></i>
            Full name of the insurance agent
          </small>
          <div class="invalid-feedback">
            Please provide an agent name.
          </div>
        </div>


        <div class="col-md-6">
          <%= form.label :code, "Agency Code", class: "form-label" do %>
            <i class="bi bi-hash me-2 text-primary"></i>
            Agency Code <span class="text-danger">*</span>
          <% end %>
          <%= form.text_field :code,
              class: "form-control form-control-lg",
              placeholder: "Enter agency code",
              required: true %>
          <small class="form-text text-muted">
            <i class="bi bi-info-circle me-1"></i>
            Unique code assigned to this agency
          </small>
          <div class="invalid-feedback">
            Please provide an agency code.
          </div>
        </div>
      </div>

      <!-- Information Alert -->
      <div class="alert alert-info mt-3" role="alert">
        <div class="d-flex">
          <i class="bi bi-lightbulb-fill me-2 text-info"></i>
          <div>
            <strong>Note:</strong> Changes to this agency code will affect all associated policies and records.
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <small class="text-muted">
            <i class="bi bi-info-circle me-1"></i>
            All fields marked with <span class="text-danger">*</span> are required
          </small>
        </div>
        <div class="d-flex gap-2">
          <%= link_to admin_agency_codes_path, class: "btn btn-outline-secondary" do %>
            <i class="bi bi-x-lg me-1"></i>
            Cancel
          <% end %>
          <%= form.submit "Update Agency Code", class: "btn btn-primary px-4" %>
        </div>
      </div>
    </div>
  </div>

<% end %>

<style>
.form-control-lg, .form-select-lg {
  border-radius: 12px;
  border: 2px solid #e9ecef;
  padding: 12px 16px;
  font-size: 16px;
}

.form-control-lg:focus, .form-select-lg:focus {
  border-color: #0d6efd;
  box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.1);
}

.card {
  border-radius: 16px;
}

.card-header {
  border-radius: 16px 16px 0 0 !important;
}

.btn {
  border-radius: 10px;
  font-weight: 500;
}

.alert {
  border-radius: 12px;
  border: none;
}

.form-label {
  font-weight: 600;
  color: #495057;
  margin-bottom: 8px;
}

.form-text {
  font-size: 13px;
}

.invalid-feedback {
  font-size: 13px;
  margin-top: 4px;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Bootstrap form validation
  const forms = document.querySelectorAll('.needs-validation');

  Array.from(forms).forEach(function(form) {
    form.addEventListener('submit', function(event) {
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }
      form.classList.add('was-validated');
    });
  });

  // Focus on first input
  const firstInput = document.querySelector('select, input[type="text"]');
  if (firstInput) {
    firstInput.focus();
  }

  // Initialize Select2 for searchable dropdowns
  if (typeof $ !== 'undefined' && $.fn.select2) {
    $('.searchable-select').each(function() {
      const $element = $(this);
      const placeholder = $element.data('placeholder') || 'Search and select...';

      $element.select2({
        theme: 'bootstrap-5',
        placeholder: placeholder,
        allowClear: true,
        width: '100%',
        minimumResultsForSearch: 0,
        dropdownParent: $('body')
      });
    });
  }

  // Dynamic company filtering based on insurance type
  const insuranceTypeSelect = document.getElementById('agency_code_insurance_type');
  const companySelect = document.getElementById('agency_code_company_name');

  if (insuranceTypeSelect && companySelect) {
    // Function to load companies based on insurance type
    function loadCompaniesByType(insuranceType) {
      if (!insuranceType) {
        // Reset to all companies if no type selected
        companySelect.innerHTML = '<option value="">Select Insurance Company</option>';
        if ($(companySelect).hasClass('select2-hidden-accessible')) {
          $(companySelect).val(null).trigger('change');
        }
        return;
      }

      // Fetch companies for the selected insurance type
      const agencyCodeId = '<%= @agency_code.id %>';
      fetch(`/admin/agency_codes/companies_by_type?insurance_type=${encodeURIComponent(insuranceType)}&agency_code_id=${agencyCodeId}`, {
        method: 'GET',
        headers: {
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Store current value (could be from dropdown or from server-side rendering)
          const currentValue = companySelect.value || '<%= @agency_code.company_name %>';

          // Clear existing options
          companySelect.innerHTML = '<option value="">Select Insurance Company</option>';

          // Add new options
          let hasCurrentValue = false;
          data.companies.forEach(company => {
            const option = document.createElement('option');
            option.value = company;
            option.textContent = company;
            // Restore selection if it exists in the new list
            if (company === currentValue) {
              option.selected = true;
              hasCurrentValue = true;
            }
            companySelect.appendChild(option);
          });

          // If the current value wasn't found in the list, add it anyway (for existing data)
          if (currentValue && !hasCurrentValue && currentValue !== '') {
            const option = document.createElement('option');
            option.value = currentValue;
            option.textContent = currentValue;
            option.selected = true;
            companySelect.appendChild(option);
            console.log('Added missing company option:', currentValue);
          }

          // Update Select2 if it's initialized
          if ($(companySelect).hasClass('select2-hidden-accessible')) {
            $(companySelect).val(currentValue).trigger('change');
          }

          console.log(`Loaded ${data.companies.length} companies for ${insuranceType} insurance`);
          if (currentValue) {
            console.log('Preserved company selection:', currentValue);
          }
        } else {
          console.error('Failed to load companies:', data.message);
        }
      })
      .catch(error => {
        console.error('Error loading companies:', error);
      });
    }

    // Handle insurance type change
    insuranceTypeSelect.addEventListener('change', function() {
      const selectedType = this.value;
      console.log('Insurance type changed to:', selectedType);
      loadCompaniesByType(selectedType);
    });

    // Handle Select2 change event for insurance type
    $('#agency_code_insurance_type').on('select2:select', function(e) {
      const selectedType = e.params.data.id;
      console.log('Insurance type changed via Select2 to:', selectedType);
      loadCompaniesByType(selectedType);
    });

    // Clear company when insurance type is cleared
    $('#agency_code_insurance_type').on('select2:clear', function() {
      console.log('Insurance type cleared');
      loadCompaniesByType(null);
    });

    // Load companies on page load if insurance type is already selected
    const initialInsuranceType = insuranceTypeSelect.value;
    const initialCompanyName = companySelect.value || '<%= @agency_code.company_name %>';

    if (initialInsuranceType) {
      console.log('Loading companies for initial type:', initialInsuranceType);
      console.log('Initial company name:', initialCompanyName);

      // Delay the company loading slightly to ensure Select2 is fully initialized
      setTimeout(() => {
        loadCompaniesByType(initialInsuranceType);

        // After loading companies, set the initial value
        setTimeout(() => {
          if (initialCompanyName) {
            companySelect.value = initialCompanyName;

            // If Select2 is initialized, trigger change to update the display
            if ($(companySelect).hasClass('select2-hidden-accessible')) {
              $(companySelect).val(initialCompanyName).trigger('change');
            }

            console.log('Restored company selection to:', initialCompanyName);
          }
        }, 100);
      }, 200);
    }
  }
});
</script>

<!-- Add Select2 CSS and JS -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>