  border: none;
  font-weight: 600;
  color: #495057;
  font-size: 0.875rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 1rem 0.75rem;
}

.table td {
  border: none;
  border-bottom: 1px solid #f1f3f4;
  padding: 1rem 0.75rem;
  vertical-align: middle;
}

.table tbody tr:hover {
  background-color: #f8f9fa;
}

.badge {
  font-weight: 500;
  font-size: 0.75rem;
  padding: 0.375rem 0.75rem;
}

.btn-sm {
  padding: 0.25rem 0.5rem;
  font-size: 0.75rem;
}

.company-badge {
  background: linear-gradient(45deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 500;
}

.type-badge-health { background-color: #d4edda; color: #155724; }
.type-badge-motor { background-color: #fff3cd; color: #856404; }
.type-badge-life { background-color: #cce7ff; color: #004085; }
.type-badge-general { background-color: #f8d7da; color: #721c24; }
.type-badge-other { background-color: #e2e3e5; color: #383d41; }

/* Pagination styling */
.pagination-wrapper .pagination {
  margin-bottom: 0;
}

.pagination-wrapper .pagination .page-link {
  border-radius: 6px;
  margin: 0 2px;
  border: 1px solid #dee2e6;
  color: #6c757d;
  font-size: 0.875rem;
}

.pagination-wrapper .pagination .page-item.active .page-link {
  background-color: #0d6efd;
  border-color: #0d6efd;
}

.pagination-wrapper .pagination .page-link:hover {
  background-color: #f8f9fa;
  border-color: #dee2e6;
  color: #0d6efd;
}

@media (max-width: 576px) {
  .pagination-wrapper .pagination {
    justify-content: center;
    font-size: 0.8rem;
  }

  .card-footer .d-flex {
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('search_input');
  const insuranceTypeFilter = document.getElementById('insurance_type_filter');
  const companyFilter = document.getElementById('company_filter');
  const searchForm = document.getElementById('search_form');
  let searchTimeout;

  // Auto-search on typing after 3 characters
  searchInput.addEventListener('input', function() {
    clearTimeout(searchTimeout);
    const searchValue = this.value;

    searchTimeout = setTimeout(() => {
      if (searchValue.length >= 3 || searchValue.length === 0) {
        searchForm.submit();
      }
    }, 500); // 500ms delay after typing stops
  });

  // Auto-submit on insurance type filter change
  insuranceTypeFilter.addEventListener('change', function() {
    searchForm.submit();
  });

  // Auto-submit on company filter change
  companyFilter.addEventListener('change', function() {
    searchForm.submit();
  });

});
</script>

<!-- jQuery and Select2 for searchable company dropdown -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>
$(document).ready(function() {
  // Initialize Select2 for company dropdown
  $('.searchable-company-select').select2({
    theme: 'bootstrap-5',
    placeholder: 'Search and select company...',
    allowClear: true,
    width: '100%',
    minimumResultsForSearch: 0, // Show search box always
    dropdownParent: $('body'),
    matcher: function(params, data) {
      // If there are no search terms, return all data
      if ($.trim(params.term) === '') {
        return data;
      }

      // Skip if there is no 'children' property
      if (typeof data.children === 'undefined') {
        // Check if the text contains the term (case insensitive)
        if (data.text.toLowerCase().indexOf(params.term.toLowerCase()) > -1) {
          return data;
        }
      }

      // Return null if the term should not be displayed
      return null;
    }
  });

  // Handle Select2 change event for company filter
  $('.searchable-company-select').on('select2:select select2:clear', function() {
    // Trigger form submission when company is selected or cleared
    setTimeout(() => {
      $('#search_form').submit();
    }, 100);
  });
});
</script>

<style>
/* Select2 Bootstrap 5 styling for company dropdown */
.select2-container--bootstrap-5 .select2-selection--single:focus-within {
  border-color: #86b7fe;
  box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
}

.select2-container--bootstrap-5 .select2-selection__rendered {
  color: #212529;
}

.select2-container--bootstrap-5 .select2-results__option {
  padding: 6px 12px;
  font-size: 1rem;
}

.select2-container--bootstrap-5 .select2-results__option--highlighted {
  background-color: #0d6efd;
  color: white;
}

.select2-dropdown {
  border: 1px solid #ced4da;
  border-radius: 6px;
  box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
}

.select2-results__options {
  max-height: 300px !important;
  overflow-y: auto;
}

.select2-search__field {
  border: 1px solid #ced4da;
  border-radius: 4px;
  padding: 4px 8px;
  font-size: 1rem;
}

.select2-search__field:focus {
  border-color: #86b7fe;
  box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
  outline: 0;
}
</style>