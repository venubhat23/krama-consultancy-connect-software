<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Agency Code Management</h2>
  </div>
  <div class="d-flex gap-2">
    <%= link_to new_admin_agency_code_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i>
      Add New Agency Code
    <% end %>
  </div>
</div>


<!-- Statistics Cards -->
<div class="row mb-4">
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Agency Codes</h6>
            <h3 class="mb-0 text-primary"><%= number_with_delimiter(@total_codes) %></h3>
          </div>
          <div class="bg-primary bg-opacity-10 rounded p-3">
            <i class="bi bi-collection text-primary fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Health Insurance</h6>
            <h3 class="mb-0 text-success"><%= number_with_delimiter(@health_codes) %></h3>
          </div>
          <div class="bg-success bg-opacity-10 rounded p-3">
            <i class="bi bi-heart-pulse text-success fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Motor Insurance</h6>
            <h3 class="mb-0 text-warning"><%= number_with_delimiter(@motor_codes) %></h3>
          </div>
          <div class="bg-warning bg-opacity-10 rounded p-3">
            <i class="bi bi-car-front text-warning fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Life Insurance</h6>
            <h3 class="mb-0 text-info"><%= number_with_delimiter(@life_codes) %></h3>
          </div>
          <div class="bg-info bg-opacity-10 rounded p-3">
            <i class="bi bi-life-preserver text-info fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Filters and Search -->
<div class="card shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: admin_agency_codes_path, method: :get, local: true, class: "d-flex flex-wrap gap-3 align-items-end", id: "search_form" do |form| %>
      <!-- Search -->
      <div class="flex-grow-1 min-width-250">
        <%= form.text_field :search, placeholder: "Search by company, agent name, or code... (min 3 characters)",
                           value: params[:search],
                           class: "form-control",
                           id: "search_input",
                           data: { min_length: 3 } %>
      </div>

      <!-- Insurance Type Filter -->
      <div class="filter-type-small">
        <%= form.select :insurance_type,
                       options_for_select([
                         ['All Types', ''],
                         ['Health Insurance', 'Health Insurance'],
                         ['Life Insurance', 'Life Insurance'],
                         ['Motor and Other Insurance', 'Motor and Other Insurance']
                       ], params[:insurance_type]),
                       {},
                       { class: "form-select", id: "insurance_type_filter" } %>
      </div>

      <!-- Company Filter -->
      <div class="filter-company-large">
        <%= form.select :company,
                       options_for_select([['All Companies', '']] + @insurance_companies.map { |company| [company, company] }, params[:company]),
                       {},
                       { class: "form-select searchable-company-select", id: "company_filter", data: { placeholder: "Search companies..." } } %>
      </div>


      <!-- Actions -->
      <div class="d-flex gap-2">
        <%= link_to "Clear", admin_agency_codes_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<style>
.min-width-250 {
  min-width: 250px;
}

/* Filter spacing adjustments */
.filter-type-small {
  min-width: 180px;
  max-width: 200px;
}

.filter-company-large {
  min-width: 280px;
  flex: 1;
}

/* Ensure consistent heights for ALL filter elements */
#search_input,
.filter-type-small .form-select,
.filter-company-large .form-select,
.select2-container--bootstrap-5 .select2-selection--single {
  height: 38px !important;
  line-height: 1.5 !important;
  padding: 6px 12px !important;
  font-size: 1rem !important;
  border: 1px solid #ced4da !important;
  border-radius: 6px !important;
  box-sizing: border-box !important;
}

/* Fix Select2 specific styling to match form-select */
.select2-container--bootstrap-5 .select2-selection__rendered {
  line-height: 26px !important;
  padding-left: 12px !important;
  padding-right: 20px !important;
}

/* Ensure search input matches exactly */
#search_input {
  min-height: 38px !important;
  max-height: 38px !important;
}

/* Responsive adjustments */
@media (max-width: 768px) {
  .filter-type-small,
  .filter-company-large {
    min-width: unset;
    max-width: unset;
    width: 100%;
    margin-bottom: 0.5rem;
  }
}
</style>

<!-- Agency Codes Table -->
<div id="agency-codes-table">
  <%= render 'agency_codes_table', agency_codes: @agency_codes, total_filtered_count: @total_filtered_count %>
</div>


<style>
.table-responsive {
