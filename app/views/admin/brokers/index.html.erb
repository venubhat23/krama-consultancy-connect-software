<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Broker Management</h2>
    <p class="text-muted mb-0">Manage and track all brokers in the system</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to new_admin_broker_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i>
      Add New Broker
    <% end %>
    <%= link_to new_admin_broker_code_path, class: "btn btn-success ms-2" do %>
      <i class="bi bi-code-square me-1"></i>
      ADD Broker CODE
    <% end %>
  </div>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
  <div class="col-xl-4 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Total Brokers</h6>
            <h3 class="mb-0 text-primary"><%= number_with_delimiter(@total_brokers) %></h3>
          </div>
          <div class="bg-primary bg-opacity-10 rounded p-3">
            <i class="bi bi-briefcase text-primary fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-4 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Active Brokers</h6>
            <h3 class="mb-0 text-success"><%= number_with_delimiter(@active_brokers) %></h3>
          </div>
          <div class="bg-success bg-opacity-10 rounded p-3">
            <i class="bi bi-check-circle text-success fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-4 col-md-6 mb-3">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h6 class="text-muted mb-2">Broker Codes</h6>
            <h3 class="mb-0 text-info"><%= number_with_delimiter(BrokerCode.count) %></h3>
          </div>
          <div class="bg-info bg-opacity-10 rounded p-3">
            <i class="bi bi-code-square text-info fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Tab Navigation -->
<div class="card shadow-sm mb-4">
  <div class="card-header bg-transparent border-0 pt-3">
    <ul class="nav nav-tabs card-header-tabs" id="brokerTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= 'active' if @active_tab == 'broker-list' %>" id="broker-list-tab" data-bs-toggle="tab" data-bs-target="#broker-list" type="button" role="tab" aria-controls="broker-list" aria-selected="<%= @active_tab == 'broker-list' ? 'true' : 'false' %>">
          <i class="bi bi-briefcase me-2"></i>
          Broker List
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= 'active' if @active_tab == 'broker-code' %>" id="broker-code-tab" data-bs-toggle="tab" data-bs-target="#broker-code" type="button" role="tab" aria-controls="broker-code" aria-selected="<%= @active_tab == 'broker-code' ? 'true' : 'false' %>">
          <i class="bi bi-code-square me-2"></i>
          Broker Code
        </button>
      </li>
    </ul>
  </div>
</div>


<!-- Tab Content -->
<div class="tab-content" id="brokerTabsContent">
  <!-- Broker List Tab -->
  <div class="tab-pane fade <%= 'show active' if @active_tab == 'broker-list' %>" id="broker-list" role="tabpanel" aria-labelledby="broker-list-tab">
    <!-- Search and Filters for Brokers -->
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <%= form_with url: admin_brokers_path, method: :get, local: true, class: "d-flex flex-wrap gap-3 align-items-end", id: "search_form" do |form| %>
          <!-- Search -->
          <div class="flex-grow-1 min-width-250">
            <%= form.text_field :search, placeholder: "Search by broker name... (min 3 characters)",
                               value: params[:search],
                               class: "form-control",
                               id: "search_input",
                               data: { min_length: 3 } %>
          </div>

          <!-- Actions -->
          <div class="d-flex gap-2">
            <%= link_to "Clear", admin_brokers_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Brokers Table -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Brokers List</h5>
      </div>
      <div class="card-body p-0">
        <% if @brokers.any? %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="bg-light">
                <tr>
                  <th class="border-0">Broker Name</th>
                  <th class="border-0">Status</th>
                  <th class="border-0">Created At</th>
                  <th class="border-0">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @brokers.each do |broker| %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 rounded-circle p-2 me-3">
                          <i class="fas fa-briefcase text-primary"></i>
                        </div>
                        <div>
                          <h6 class="mb-0 fw-medium"><%= broker.name %></h6>
                          <small class="text-muted">Broker ID: #<%= broker.id %></small>
                        </div>
                      </div>
                    </td>
                    <td>
                      <% if broker.active? %>
                        <span class="badge bg-success">
                          <i class="bi bi-check-circle me-1"></i>
                          Active
                        </span>
                      <% else %>
                        <span class="badge bg-warning">
                          <i class="bi bi-x-circle me-1"></i>
                          Inactive
                        </span>
                      <% end %>
                    </td>
                    <td>
                      <span class="fw-medium text-dark"><%= broker.created_at.strftime("%b %d, %Y") %></span>
                      <br>
                      <small class="text-muted"><%= broker.created_at.strftime("%I:%M %p") %></small>
                    </td>
                    <td>
                      <div class="d-flex gap-1">
                        <%= link_to edit_admin_broker_path(broker),
                            class: "btn btn-sm btn-outline-primary",
                            title: "Edit" do %>
                          <i class="bi bi-pencil"></i>
                        <% end %>

                        <button type="button"
                            class="btn btn-sm btn-outline-danger delete-broker"
                            data-url="<%= admin_broker_path(broker) %>"
                            data-confirm="Are you sure you want to delete <%= broker.name %>?"
                            title="Delete">
                          <i class="bi bi-trash"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <!-- Pagination for Brokers -->
          <div class="card-footer bg-transparent border-0">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
              <small class="text-muted mb-2 mb-md-0">
                <% if defined?(@total_filtered_count) && @total_filtered_count.present? %>
                  Showing <%= @brokers.current_page == 1 ? 1 : ((@brokers.current_page - 1) * @brokers.limit_value + 1) %>
                  to <%= [@brokers.current_page * @brokers.limit_value, @total_filtered_count].min %>
                  of <%= number_with_delimiter(@total_filtered_count) %> brokers
                <% elsif @brokers.respond_to?(:total_count) %>
                  Showing <%= @brokers.current_page == 1 ? 1 : ((@brokers.current_page - 1) * @brokers.limit_value + 1) %>
                  to <%= [@brokers.current_page * @brokers.limit_value, @brokers.total_count].min %>
                  of <%= number_with_delimiter(@brokers.total_count) %> brokers
                <% else %>
                  Showing <%= @brokers.count %> brokers
                <% end %>
              </small>

              <% if @brokers.respond_to?(:total_pages) && @brokers.total_pages > 1 %>
                <div class="pagination-wrapper">
                  <%= paginate @brokers %>
                </div>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="text-center py-5">
            <i class="bi bi-briefcase fs-1 text-muted d-block mb-3"></i>
            <h5 class="text-muted">No brokers found</h5>
            <p class="text-muted mb-3">
              <% if params[:search].present? %>
                No brokers match your search criteria.
                <%= link_to "Clear search", admin_brokers_path, class: "text-decoration-none" %>
              <% else %>
                Start by creating your first broker.
              <% end %>
            </p>
            <% unless params[:search].present? %>
              <%= link_to new_admin_broker_path, class: "btn btn-primary" do %>
                <i class="bi bi-plus-lg me-1"></i>
                Add Your First Broker
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Broker Code Tab -->
  <div class="tab-pane fade <%= 'show active' if @active_tab == 'broker-code' %>" id="broker-code" role="tabpanel" aria-labelledby="broker-code-tab">
    <!-- Search and Filters for Broker Codes -->
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <%= form_with url: admin_brokers_path, method: :get, local: true, class: "d-flex flex-wrap gap-3 align-items-end", id: "broker_code_search_form" do |form| %>
          <!-- Search -->
          <div class="flex-grow-1 min-width-250">
            <%= form.text_field :search, placeholder: "Search by broker name or broker code... (min 3 characters)",
                               value: params[:search],
                               class: "form-control",
                               id: "broker_code_search_input",
                               data: { min_length: 3 } %>
          </div>

          <!-- Actions -->
          <div class="d-flex gap-2">
            <%= link_to "Clear", admin_brokers_path + "#broker-code", class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Broker Codes Table -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Broker Codes List</h5>
      </div>
      <div class="card-body p-0">
        <% if defined?(@broker_codes) && @broker_codes&.any? %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="bg-light">
                <tr>
                  <th class="border-0">Broker Name</th>
                  <th class="border-0">Agency Name</th>
                  <th class="border-0">Broker Code</th>
                  <th class="border-0">Status</th>
                  <th class="border-0">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @broker_codes.each do |broker_code| %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center">
                        <div class="bg-info bg-opacity-10 rounded-circle p-2 me-3">
                          <i class="bi bi-code-square text-info"></i>
                        </div>
                        <div>
                          <h6 class="mb-0 fw-medium">
                            <%= broker_code.broker.name %>
                          </h6>
                          <small class="text-muted">
                            ID: #<%= broker_code.broker.id %>
                          </small>
                        </div>
                      </div>
                    </td>
                    <td>
                      <span class="<%= broker_code.agent_name.present? ? 'fw-medium text-dark' : 'text-muted' %>">
                        <%= broker_code.agent_name.present? ? broker_code.agent_name : '-' %>
                      </span>
                    </td>
                    <td>
                      <span class="fw-bold text-dark">
                        <%= broker_code.broker_code %>
                      </span>
                    </td>
                    <td>
                      <span class="badge bg-<%= broker_code.status_color %>-subtle text-<%= broker_code.status_color %>">
                        <i class="bi bi-<%= broker_code.status? ? 'check-circle' : 'pause-circle' %> me-1"></i>
                        <%= broker_code.status_badge %>
                      </span>
                    </td>
                    <td>
                      <div class="d-flex gap-1">
                        <%= link_to edit_admin_broker_code_path(broker_code),
                            class: "btn btn-sm btn-outline-primary",
                            title: "Edit" do %>
                          <i class="bi bi-pencil"></i>
                        <% end %>

                        <button type="button"
                            class="btn btn-sm btn-outline-danger delete-broker-code"
                            data-url="<%= admin_broker_code_path(broker_code) %>"
                            data-confirm="Are you sure you want to delete this broker code?"
                            title="Delete">
                          <i class="bi bi-trash"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <!-- Pagination for Broker Codes -->
          <div class="card-footer bg-transparent border-0">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
              <small class="text-muted mb-2 mb-md-0">
                <% if defined?(@broker_codes) && @broker_codes.respond_to?(:total_count) %>
                  Showing <%= @broker_codes.current_page == 1 ? 1 : ((@broker_codes.current_page - 1) * @broker_codes.limit_value + 1) %>
                  to <%= [@broker_codes.current_page * @broker_codes.limit_value, @broker_codes.total_count].min %>
                  of <%= number_with_delimiter(@broker_codes.total_count) %> broker codes
                <% elsif defined?(@broker_codes) %>
                  Showing <%= @broker_codes.count %> broker codes
                <% else %>
                  Showing 0 broker codes
                <% end %>
              </small>

              <% if defined?(@broker_codes) && @broker_codes.respond_to?(:total_pages) && @broker_codes.total_pages > 1 %>
                <div class="pagination-wrapper">
                  <%= paginate @broker_codes %>
                </div>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="text-center py-5">
            <i class="bi bi-code-square fs-1 text-muted d-block mb-3"></i>
            <h5 class="text-muted">No broker codes found</h5>
            <p class="text-muted mb-3">
              <% if params[:search].present? %>
                No broker codes match your search criteria.
                <%= link_to "Clear search", admin_brokers_path + "#broker-code", class: "text-decoration-none" %>
              <% else %>
                Start by creating your first broker code.
              <% end %>
            </p>
            <% unless params[:search].present? %>
              <%= link_to new_admin_broker_code_path, class: "btn btn-primary" do %>
                <i class="bi bi-plus-lg me-1"></i>
                Add Your First Broker Code
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
.min-width-250 {
  min-width: 250px;
}
</style>

<style>
.table-responsive {
  border-radius: 8px;
  overflow: hidden;
}

.table th {
  background-color: #f8f9fa;
  border: none;
  font-weight: 600;
  color: #495057;
  font-size: 0.875rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 1rem 0.75rem;
}

.table td {
  border: none;
  border-bottom: 1px solid #f1f3f4;
  padding: 1rem 0.75rem;
  vertical-align: middle;
}

.table tbody tr:hover {
  background-color: #f8f9fa;
}

.badge {
  font-weight: 500;
  font-size: 0.75rem;
  padding: 0.375rem 0.75rem;
}

.btn-sm {
  padding: 0.25rem 0.5rem;
  font-size: 0.75rem;
}

/* Pagination styling */
.pagination-wrapper .pagination {
  margin-bottom: 0;
}

.pagination-wrapper .pagination .page-link {
  border-radius: 6px;
  margin: 0 2px;
  border: 1px solid #dee2e6;
  color: #6c757d;
  font-size: 0.875rem;
}

.pagination-wrapper .pagination .page-item.active .page-link {
  background-color: #0d6efd;
  border-color: #0d6efd;
}

.pagination-wrapper .pagination .page-link:hover {
  background-color: #f8f9fa;
  border-color: #dee2e6;
  color: #0d6efd;
}

@media (max-width: 576px) {
  .pagination-wrapper .pagination {
    justify-content: center;
    font-size: 0.8rem;
  }

  .card-footer .d-flex {
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('search_input');
  const searchForm = document.getElementById('search_form');
  const brokerCodeSearchInput = document.getElementById('broker_code_search_input');
  const brokerCodeSearchForm = document.getElementById('broker_code_search_form');
  let searchTimeout;

  // Auto-search on typing after 3 characters for broker list
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimeout);
      const searchValue = this.value;

      searchTimeout = setTimeout(() => {
        if (searchValue.length >= 3 || searchValue.length === 0) {
          searchForm.submit();
        }
      }, 500); // 500ms delay after typing stops
    });
  }

  // Auto-search on typing after 3 characters for broker codes
  if (brokerCodeSearchInput) {
    brokerCodeSearchInput.addEventListener('input', function() {
      clearTimeout(searchTimeout);
      const searchValue = this.value;

      searchTimeout = setTimeout(() => {
        if (searchValue.length >= 3 || searchValue.length === 0) {
          // Add a hidden field to maintain the broker-code tab active
          const hiddenField = document.createElement('input');
          hiddenField.type = 'hidden';
          hiddenField.name = 'tab';
          hiddenField.value = 'broker-code';
          brokerCodeSearchForm.appendChild(hiddenField);

          brokerCodeSearchForm.submit();
        }
      }, 500); // 500ms delay after typing stops
    });
  }

  // Handle delete buttons for both brokers and agency codes
  document.addEventListener('click', function(e) {
    // Handle broker delete buttons
    if (e.target.closest('.delete-broker')) {
      e.preventDefault();

      const button = e.target.closest('.delete-broker');
      const url = button.dataset.url;
      const confirmMessage = button.dataset.confirm;

      if (confirm(confirmMessage)) {
        // Create and submit a form for DELETE request
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = url;
        form.style.display = 'none';

        // Add CSRF token
        const csrfToken = document.querySelector('meta[name="csrf-token"]');
        if (csrfToken) {
          const csrfInput = document.createElement('input');
          csrfInput.type = 'hidden';
          csrfInput.name = 'authenticity_token';
          csrfInput.value = csrfToken.content;
          form.appendChild(csrfInput);
        }

        // Add method override for DELETE
        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'DELETE';
        form.appendChild(methodInput);

        document.body.appendChild(form);
        form.submit();
      }
    }

    // Handle broker code delete buttons
    if (e.target.closest('.delete-broker-code')) {
      e.preventDefault();

      const button = e.target.closest('.delete-broker-code');
      const url = button.dataset.url;
      const confirmMessage = button.dataset.confirm;

      if (confirm(confirmMessage)) {
        // Create and submit a form for DELETE request
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = url;
        form.style.display = 'none';

        // Add CSRF token
        const csrfToken = document.querySelector('meta[name="csrf-token"]');
        if (csrfToken) {
          const csrfInput = document.createElement('input');
          csrfInput.type = 'hidden';
          csrfInput.name = 'authenticity_token';
          csrfInput.value = csrfToken.content;
          form.appendChild(csrfInput);
        }

        // Add method override for DELETE
        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'DELETE';
        form.appendChild(methodInput);

        document.body.appendChild(form);
        form.submit();
      }
    }
  });

  // Handle tab switching based on URL hash or active tab
  function activateTab() {
    const hash = window.location.hash;
    const activeTab = '<%= @active_tab %>';

    if (hash === '#broker-code' || activeTab === 'broker-code') {
      const brokerCodeTab = document.getElementById('broker-code-tab');
      if (brokerCodeTab) {
        brokerCodeTab.click();
      }
    } else {
      const brokerListTab = document.getElementById('broker-list-tab');
      if (brokerListTab) {
        brokerListTab.click();
      }
    }
  }

  // Activate the correct tab on page load
  activateTab();

  // Update URL hash when tab is clicked
  document.getElementById('broker-code-tab').addEventListener('click', function() {
    window.location.hash = '#broker-code';
  });

  document.getElementById('broker-list-tab').addEventListener('click', function() {
    window.location.hash = '#broker-list';
  });
});
</script>

