<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">
      <i class="fas fa-edit me-2 text-primary"></i>
      Edit Profile
    </h2>
    <p class="text-muted mb-0">Update your account information</p>
  </div>
  <div>
    <%= link_to admin_profile_path, class: "btn btn-outline-secondary" do %>
      <i class="fas fa-arrow-left me-1"></i>
      Back to Profile
    <% end %>
  </div>
</div>

<%= form_with model: @current_user, url: admin_profile_path, method: :patch, local: true, class: "needs-validation", novalidate: true do |form| %>
  <% if @current_user.errors.any? %>
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
      <h6>Please correct the following errors:</h6>
      <ul class="mb-0">
        <% @current_user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% end %>

  <!-- Basic Information -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-transparent border-0">
      <h5 class="mb-0">
        <i class="fas fa-user me-2 text-primary"></i>
        Basic Information
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :first_name, class: "form-label" do %>
            First Name <span class="text-danger">*</span>
          <% end %>
          <%= form.text_field :first_name, class: "form-control #{'is-invalid' if @current_user.errors[:first_name].any?}", placeholder: "Enter first name", required: true %>
          <% if @current_user.errors[:first_name].any? %>
            <div class="invalid-feedback"><%= @current_user.errors[:first_name].first %></div>
          <% end %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :last_name, class: "form-label" do %>
            Last Name <span class="text-danger">*</span>
          <% end %>
          <%= form.text_field :last_name, class: "form-control #{'is-invalid' if @current_user.errors[:last_name].any?}", placeholder: "Enter last name", required: true %>
          <% if @current_user.errors[:last_name].any? %>
            <div class="invalid-feedback"><%= @current_user.errors[:last_name].first %></div>
          <% end %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :email, class: "form-label" do %>
            Email Address <span class="text-danger">*</span>
          <% end %>
          <%= form.email_field :email, class: "form-control #{'is-invalid' if @current_user.errors[:email].any?}", placeholder: "Enter email address", required: true %>
          <% if @current_user.errors[:email].any? %>
            <div class="invalid-feedback"><%= @current_user.errors[:email].first %></div>
          <% end %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :mobile, class: "form-label" do %>
            Mobile Number
          <% end %>
          <%= form.telephone_field :mobile, class: "form-control #{'is-invalid' if @current_user.errors[:mobile].any?}", placeholder: "Enter mobile number" %>
          <% if @current_user.errors[:mobile].any? %>
            <div class="invalid-feedback"><%= @current_user.errors[:mobile].first %></div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Password Section -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
      <h5 class="mb-0">
        <i class="fas fa-key me-2 text-warning"></i>
        Change Password
      </h5>
      <small class="text-muted">(Leave blank to keep current password)</small>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :password, "New Password", class: "form-label" %>
          <%= form.password_field :password, class: "form-control #{'is-invalid' if @current_user.errors[:password].any?}", placeholder: "Enter new password" %>
          <% if @current_user.errors[:password].any? %>
            <div class="invalid-feedback"><%= @current_user.errors[:password].first %></div>
          <% else %>
            <div class="form-text">Password should be at least 6 characters long</div>
          <% end %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :password_confirmation, "Confirm New Password", class: "form-label" %>
          <%= form.password_field :password_confirmation, class: "form-control #{'is-invalid' if @current_user.errors[:password_confirmation].any?}", placeholder: "Confirm new password" %>
          <% if @current_user.errors[:password_confirmation].any? %>
            <div class="invalid-feedback"><%= @current_user.errors[:password_confirmation].first %></div>
          <% end %>
        </div>
      </div>

      <div class="alert alert-info d-flex align-items-center">
        <i class="fas fa-info-circle me-2"></i>
        <div>
          <strong>Security Note:</strong> If you change your password, you will need to log in again with your new password.
        </div>
      </div>
    </div>
  </div>

  <!-- Account Information (Read-only) -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-transparent border-0">
      <h5 class="mb-0">
        <i class="fas fa-info-circle me-2 text-info"></i>
        Account Information
        <small class="text-muted ms-2">(Read-only)</small>
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label text-muted">User Type</label>
          <div class="form-control-plaintext">
            <span class="badge bg-primary">
              <%= @current_user.user_type.presence&.humanize || 'Admin' %>
            </span>
          </div>
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label text-muted">Role</label>
          <div class="form-control-plaintext">
            <span class="badge bg-info">
              <%= @current_user.role.presence || 'Administrator' %>
            </span>
          </div>
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label text-muted">Account Created</label>
          <div class="form-control-plaintext text-muted">
            <%= @current_user.created_at.strftime('%B %d, %Y at %I:%M %p') %>
          </div>
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label text-muted">User ID</label>
          <div class="form-control-plaintext text-muted font-monospace">
            #<%= @current_user.id %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <%= link_to "Cancel", admin_profile_path, class: "btn btn-outline-secondary" %>
        </div>
        <div>
          <%= form.submit "Update Profile", class: "btn btn-success" %>
        </div>
      </div>
    </div>
  </div>

<% end %>

<!-- Custom CSS -->
<style>
.form-control-plaintext {
  padding: 0.375rem 0;
}

.font-monospace {
  font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
}

.badge {
  font-weight: 500;
}

.card {
  transition: transform 0.2s ease-in-out;
}

.card:hover {
  transform: translateY(-2px);
}
</style>

<!-- Form Validation Script -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Bootstrap form validation
  const forms = document.querySelectorAll('.needs-validation');
  Array.from(forms).forEach(form => {
    form.addEventListener('submit', event => {
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }
      form.classList.add('was-validated');
    }, false);
  });

  // Password confirmation validation
  const password = document.querySelector('#user_password');
  const confirmPassword = document.querySelector('#user_password_confirmation');

  if (password && confirmPassword) {
    function validatePassword() {
      if (password.value !== confirmPassword.value) {
        confirmPassword.setCustomValidity("Passwords don't match");
      } else {
        confirmPassword.setCustomValidity('');
      }
    }

    password.addEventListener('change', validatePassword);
    confirmPassword.addEventListener('keyup', validatePassword);
  }
});
</script>