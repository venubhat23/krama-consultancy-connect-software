<script>
// Define callMotorBrokingAPI function at the very top to prevent "not defined" errors
function callMotorBrokingAPI() {
  console.log('🌐 Calling Motor Broking API using broker_codes endpoint (TOP DEFINITION)...');

  const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
  const brokersHeaders = {
    'Accept': 'application/json',
    'X-Requested-With': 'XMLHttpRequest',
    'Content-Type': 'application/json'
  };
  if (csrfToken) {
    brokersHeaders['X-CSRF-Token'] = csrfToken;
  }

  fetch('/admin/broker_codes.json', {
    headers: brokersHeaders,
    credentials: 'same-origin'
  })
  .then(response => {
    console.log('Broker Codes API response status:', response.status);
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }
    return response.json();
  })
  .then(data => {
    console.log('✅ Motor Broker Codes API Success:', data);
    if (data && data.success && data.broker_codes && data.broker_codes.length > 0) {
      const brokersData = data.broker_codes.map(brokerCode => ({
        id: `broker_${brokerCode.id}`,
        text: brokerCode.display_name,
        broker_name: brokerCode.broker_name,
        code: brokerCode.broker_code,
        broker_id: brokerCode.broker_id
      }));

      console.log('📦 Transformed broker data for motor:', brokersData);
      populateMotorAgencyDropdown(brokersData, 'Select Broker...');
      console.log('✅ Motor Broking dropdown updated successfully');
    } else {
      console.error('❌ Motor Broker Codes API returned no data');
      populateMotorAgencyDropdown([], 'Select Broker...');
    }
  })
  .catch(error => {
    console.error('❌ Motor Broker Codes API Error:', error);
    populateMotorAgencyDropdown([], 'Select Broker...');
  });

  // Also get insurance companies
  fetch('/admin/insurance/motor/insurance_companies_for_type', {
    method: 'GET',
    headers: {
      'Accept': 'application/json',
      'Content-Type': 'application/json',
      'X-Requested-With': 'XMLHttpRequest'
    }
  })
  .then(response => {
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }
    return response.json();
  })
  .then(data => {
    console.log('📊 Motor Insurance Companies Data:', data);
    if (data.success && data.data) {
      populateMotorCompanyDropdown(data.data);
    }
  })
  .catch(error => {
    console.error('❌ Motor Company API Error:', error);
  });
}

// Force enable scrolling and prevent conflicts
try {
  // Ensure document body can scroll
  if (document.body) {
    document.body.style.overflow = 'auto';
    document.body.style.overflowY = 'auto';
    document.body.style.overflowX = 'hidden';
    document.body.style.position = 'relative';
    document.body.style.height = 'auto';
  }

  if (document.documentElement) {
    document.documentElement.style.overflow = 'auto';
    document.documentElement.style.overflowY = 'auto';
    document.documentElement.style.overflowX = 'hidden';
    document.documentElement.style.height = 'auto';
  }

  // Remove any scroll-blocking classes
  document.body.classList.remove('modal-open', 'no-scroll');

  console.log('✅ Scroll fix applied successfully');
} catch (error) {
  console.warn('⚠️  Scroll fix error:', error);
}

// Error handling wrapper
function safeExecute(fn, name) {
  try {
    return fn();
  } catch (error) {
    console.warn(`⚠️  ${name} error:`, error);
    return null;
  }
}

document.addEventListener('DOMContentLoaded', function() {
  // Auto-calculation functions
  function calculateTotalPremium() {
    const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
    const gstPercentage = parseFloat(document.getElementById('gst_percentage').value) || 0;

    const gstAmount = netPremium * (gstPercentage / 100);
    const totalPremium = netPremium + gstAmount;

    document.getElementById('total_premium').value = totalPremium.toFixed(2);
  }

  function calculateTotalIDV() {
    const vehicleIDV = parseFloat(document.getElementById('vehicle_idv').value) || 0;
    const cngIDV = parseFloat(document.getElementById('cng_idv').value) || 0;
    const totalIDV = vehicleIDV + cngIDV;

    document.getElementById('total_idv').value = totalIDV.toFixed(2);
  }

  // Event listeners for auto-calculations
  document.getElementById('net_premium').addEventListener('input', calculateTotalPremium);
  document.getElementById('net_premium').addEventListener('input', calculateAllCommissions);
  document.getElementById('gst_percentage').addEventListener('input', calculateTotalPremium);
  document.getElementById('vehicle_idv').addEventListener('input', calculateTotalIDV);
  document.getElementById('cng_idv').addEventListener('input', calculateTotalIDV);


  // Customer selection and policy holder options
  const customerSelect = document.getElementById('customer_select');
  if (customerSelect) {
    customerSelect.addEventListener('change', function() {
      const customerId = this.value;
      const policyHolderSelect = document.getElementById('policy_holder_select');

      // Clear existing options except first one
      policyHolderSelect.innerHTML = '<option value="">Select Policy Holder</option><option value="Self">Self</option>';

      if (customerId) {
        // Fetch policy holder options
        fetch(`/admin/insurance/motor/policy_holder_options?customer_id=${customerId}`)
          .then(response => response.json())
          .then(data => {
            data.options.forEach(option => {
              if (option[1] !== 'Self') {
                const optionElement = document.createElement('option');
                optionElement.value = option[1];
                optionElement.textContent = option[0];
                policyHolderSelect.appendChild(optionElement);
              }
            });
          })
          .catch(error => console.error('Error fetching policy holder options:', error));

        // Fetch and auto-select affiliate based on customer's branch/lead
        fetch(`/admin/insurance/motor/customer_affiliate_info?customer_id=${customerId}`)
          .then(response => response.json())
          .then(data => {
            if (data.affiliate_id) {
              // Auto-select the affiliate in the dropdown
              const affiliateSelect = document.getElementById('affiliate_select');
              if (affiliateSelect) {
                // If using Select2, set the value and trigger change
                if ($(affiliateSelect).data('select2')) {
                  $(affiliateSelect).val(data.affiliate_id).trigger('change');
                } else {
                  affiliateSelect.value = data.affiliate_id;
                }
                console.log(`Auto-selected affiliate: ${data.affiliate_name} (ID: ${data.affiliate_id})`);
              }
            }
          })
          .catch(error => console.error('Error fetching customer affiliate info:', error));
      }
    });
  }

  // Auto-set policy end date based on start date (default 1 year)
  const policyStartDate = document.getElementById('policy_start_date');
  if (policyStartDate) {
    policyStartDate.addEventListener('change', function() {
      const startDate = new Date(this.value);
      const endDate = new Date(startDate);
      endDate.setFullYear(endDate.getFullYear() + 1);
      endDate.setDate(endDate.getDate() - 1); // End date is one day before renewal

      document.getElementById('policy_end_date').value = endDate.toISOString().split('T')[0];
    });
  }

  // Auto-calculate commission amounts (matching Life Insurance)
  function calculateCommission() {
    console.log('🔧 calculateCommission() called');

    const netPremiumField = document.getElementById('net_premium');
    const commissionPercentageField = document.getElementById('commission_percentage');
    const tdsPercentageField = document.getElementById('tds_percentage');
    const commissionAmountField = document.getElementById('commission_amount');
    const tdsAmountField = document.getElementById('tds_amount');
    const afterTdsValueField = document.getElementById('after_tds_value');

    if (!netPremiumField || !commissionPercentageField || !tdsPercentageField) {
      console.error('❌ Missing required fields for commission calculation');
      return;
    }

    const netPremium = parseFloat(netPremiumField.value) || 0;
    const commissionPercentage = parseFloat(commissionPercentageField.value) || 0;
    const tdsPercentage = parseFloat(tdsPercentageField.value) || 0;

    console.log(`📊 Net Premium: Rs. ${netPremium}, Commission %: ${commissionPercentage}%, TDS %: ${tdsPercentage}%`);

    const commissionAmount = netPremium * (commissionPercentage / 100);
    const tdsAmount = commissionAmount * (tdsPercentage / 100);
    const afterTdsValue = commissionAmount - tdsAmount;

    console.log(`💰 Calculated - Commission: Rs. ${commissionAmount.toFixed(2)}, TDS: Rs. ${tdsAmount.toFixed(2)}, After TDS: Rs. ${afterTdsValue.toFixed(2)}`);

    if (commissionAmountField) commissionAmountField.value = commissionAmount.toFixed(2);
    if (tdsAmountField) tdsAmountField.value = tdsAmount.toFixed(2);
    if (afterTdsValueField) afterTdsValueField.value = afterTdsValue.toFixed(2);

    console.log('✅ Main commission calculation completed');
  }

  // Auto-calculate sub-agent commission
  function calculateSubAgentCommission() {
    const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
    const commissionPercentage = parseFloat(document.querySelector('.sub-agent-commission-percentage').value) || 2.0;
    const tdsPercentage = parseFloat(document.querySelector('.sub-agent-tds-percentage').value) || 0;

    const commissionAmount = netPremium * (commissionPercentage / 100);
    const tdsAmount = commissionAmount * (tdsPercentage / 100);
    const afterTdsValue = commissionAmount - tdsAmount;

    document.querySelector('.sub-agent-commission-amount').value = commissionAmount.toFixed(2);
    document.querySelector('.sub-agent-tds-amount').value = tdsAmount.toFixed(2);
    document.querySelector('.sub-agent-after-tds-value').value = afterTdsValue.toFixed(2);
  }

  // Auto-calculate investor commission
  function calculateInvestorCommission() {
    const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
    const commissionPercentage = parseFloat(document.querySelector('.investor-commission-percentage').value) || 2.0;
    const tdsPercentage = parseFloat(document.querySelector('.investor-tds-percentage').value) || 0;

    const commissionAmount = netPremium * (commissionPercentage / 100);
    const tdsAmount = commissionAmount * (tdsPercentage / 100);
    const afterTdsValue = commissionAmount - tdsAmount;

    document.querySelector('.investor-commission-amount').value = commissionAmount.toFixed(2);
  }

  // Auto-calculate ambassador commission
  function calculateAmbassadorCommission() {
    const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
    const commissionPercentage = parseFloat(document.querySelector('.ambassador-commission-percentage').value) || 2.0;
    const tdsPercentage = parseFloat(document.querySelector('.ambassador-tds-percentage').value) || 0;

    const commissionAmount = netPremium * (commissionPercentage / 100);
    const tdsAmount = commissionAmount * (tdsPercentage / 100);
    const afterTdsValue = commissionAmount - tdsAmount;

    document.querySelector('.ambassador-commission-amount').value = commissionAmount.toFixed(2);
    document.querySelector('.ambassador-tds-amount').value = tdsAmount.toFixed(2);
    document.querySelector('.ambassador-after-tds-value').value = afterTdsValue.toFixed(2);
  }

  // Calculate company expenses and profit
  function calculateProfitAndExpenses() {
    const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
    const mainAgentCommissionPercentage = parseFloat(document.getElementById('commission_percentage').value) || 0;

    // Get commission percentages (removed ambassador)
    const subAgentPercentage = parseFloat(document.querySelector('.sub-agent-commission-percentage').value) || 2.0;
    const investorPercentage = parseFloat(document.querySelector('.investor-commission-percentage').value) || 2.0;
    const companyExpensesPercentage = parseFloat(document.querySelector('.company-expenses-percentage').value) || 2.0;

    // Calculate company expenses amount
    const companyExpensesAmount = netPremium * (companyExpensesPercentage / 100);

    // Calculate total distribution (including ambassador)
    const ambassadorPercentage = parseFloat(document.querySelector('.ambassador-commission-percentage').value) || 2.0;
    const totalDistributionPercentage = subAgentPercentage + investorPercentage + ambassadorPercentage;

    // Calculate profit: Main Agent Commission - Affiliate Commission - Investor Portion - Company Expenses
    const profitPercentage = mainAgentCommissionPercentage - totalDistributionPercentage - companyExpensesPercentage;
    const profitAmount = netPremium * (profitPercentage / 100);

    // Update fields
    document.querySelector('.total-distribution-percentage').value = totalDistributionPercentage.toFixed(2);
    document.querySelector('.profit-percentage').value = profitPercentage.toFixed(2);
    document.querySelector('.profit-amount').value = profitAmount.toFixed(2);

    // Update company expenses amount fields
    const companyExpensesAmountField = document.querySelector('.company-expenses-amount');
    if (companyExpensesAmountField) {
      companyExpensesAmountField.value = companyExpensesAmount.toFixed(2);
    }
    // Company expenses has no TDS, so after TDS value equals the commission amount
    const companyExpensesAfterTdsValue = document.querySelector('.company-expenses-after-tds-value');
    if (companyExpensesAfterTdsValue) {
      companyExpensesAfterTdsValue.value = companyExpensesAmount.toFixed(2);
    }

    // Update profit amount in table display
    const profitAmountDisplay = document.querySelector('.profit-amount-display');
    if (profitAmountDisplay) {
      profitAmountDisplay.value = profitAmount.toFixed(2);
    }

    // Update investor display fields (since they don't have TDS)
    const investorDisplayField = document.querySelector('.investor-commission-amount-display');
    const investorCommissionAmount = netPremium * (investorPercentage / 100);
    if (investorDisplayField) {
      investorDisplayField.value = investorCommissionAmount.toFixed(2);
    }
  }


  // Calculate all commissions when net premium changes
  function calculateAllCommissions() {
    console.log('🚀 calculateAllCommissions() called - Running all commission calculations');
    try {
      calculateCommission();
      calculateSubAgentCommission();
      calculateInvestorCommission();
      calculateAmbassadorCommission();
      calculateProfitAndExpenses();
      console.log('✅ All commission calculations completed successfully');
    } catch (error) {
      console.error('❌ Error in calculateAllCommissions:', error);
    }
  }

  // Alias for backward compatibility
  const calculateCommissions = calculateAllCommissions;


  // Autopay date calculations
  function calculateAutopayEndDate() {
    const paymentMode = document.getElementById('payment_mode_select').value;
    const startDate = document.getElementById('autopay_start_date').value;

    if (startDate && paymentMode) {
      const start = new Date(startDate);
      let end = new Date(start);

      // Calculate end date based on payment mode
      switch (paymentMode) {
        case 'Yearly':
          end.setFullYear(end.getFullYear() + 1);
          end.setDate(end.getDate() - 1); // Subtract 1 day to make it end on the day before anniversary
          break;
        case 'Monthly':
          end.setMonth(end.getMonth() + 1);
          end.setDate(end.getDate() - 1);
          break;
        default:
          // Default to yearly if no mode selected
          end.setFullYear(end.getFullYear() + 1);
          end.setDate(end.getDate() - 1);
          break;
      }

      document.getElementById('autopay_end_date').value = end.toISOString().split('T')[0];
    }
  }

  // Update autopay start date when policy start date changes
  function updateAutopayStartDate() {
    const policyStartDate = document.getElementById('policy_start_date').value;
    if (policyStartDate) {
      document.getElementById('autopay_start_date').value = policyStartDate;
      calculateAutopayEndDate(); // Recalculate end date
    }
  }

  // Autopay event listeners
  const paymentModeField = document.getElementById('payment_mode_select');
  if (paymentModeField) {
    paymentModeField.addEventListener('change', calculateAutopayEndDate);
  }

  const autopayStartDateField = document.getElementById('autopay_start_date');
  if (autopayStartDateField) {
    autopayStartDateField.addEventListener('change', calculateAutopayEndDate);
  }

  // Update policy start date listener to also trigger autopay update
  const policyStartDateField = document.getElementById('policy_start_date');
  if (policyStartDateField) {
    // Keep existing listener
    const existingListener = policyStartDateField.onchange;
    policyStartDateField.addEventListener('change', function() {
      updateAutopayStartDate();
    });
  }

  // Initial calculations
  calculateTotalPremium();
  calculateTotalIDV();
  calculateCommissions();

  // Calculate autopay on load if values exist
  if (document.getElementById('autopay_start_date').value && document.getElementById('payment_mode_select').value) {
    calculateAutopayEndDate();
  }

  // Commission percentage event listeners (moved from duplicate DOMContentLoaded)
  const commissionPercentageField = document.getElementById('commission_percentage');
  if (commissionPercentageField) {
    commissionPercentageField.addEventListener('input', function() {
      console.log('Commission percentage changed:', this.value);
      calculateCommission();
      calculateProfitAndExpenses();
    });
  }

  // TDS percentage event listeners (moved from duplicate DOMContentLoaded)
  const tdsPercentageField = document.getElementById('tds_percentage');
  if (tdsPercentageField) {
    tdsPercentageField.addEventListener('input', calculateCommission);
  }

  // Sub-agent commission fields
  const subAgentFields = document.querySelectorAll('.sub-agent-commission-percentage, .sub-agent-tds-percentage');
  subAgentFields.forEach(field => {
    field.addEventListener('input', calculateAllCommissions);
    field.addEventListener('change', calculateAllCommissions);
  });

  // Investor commission fields
  const investorFields = document.querySelectorAll('.investor-commission-percentage');
  investorFields.forEach(field => {
    field.addEventListener('input', calculateAllCommissions);
    field.addEventListener('change', calculateAllCommissions);
  });

  // Ambassador commission fields
  const ambassadorFields = document.querySelectorAll('.ambassador-commission-percentage, .ambassador-tds-percentage');
  ambassadorFields.forEach(field => {
    field.addEventListener('input', calculateAllCommissions);
    field.addEventListener('change', calculateAllCommissions);
  });

  // Company expenses field
  const companyExpensesField = document.querySelector('.company-expenses-percentage');
  if (companyExpensesField) {
    companyExpensesField.addEventListener('input', calculateAllCommissions);
    companyExpensesField.addEventListener('change', calculateAllCommissions);
  }

  // Broker Code Type Dynamic Dropdown Functionality
  const brokerCodeSelect = document.getElementById('motor_insurance_broker_code_type');
  const agencyCodeSelect = document.getElementById('motor_insurance_agency_code_id');
  const insuranceCompanySelect = document.getElementById('motor_insurance_insurance_company_name');

  if (brokerCodeSelect) {
    // Enable Insurance Company dropdown on click
    brokerCodeSelect.addEventListener('click', function() {
      if (insuranceCompanySelect && insuranceCompanySelect.disabled) {
        insuranceCompanySelect.disabled = false;
        console.log('✅ Insurance Company Name dropdown enabled');
      }
    });

    brokerCodeSelect.addEventListener('change', function() {
      const brokerType = this.value;
      console.log('🔥 MOTOR BROKER CODE CHANGED! Value:', brokerType);

      // Enable Insurance Company dropdown when any option is selected
      if (insuranceCompanySelect && insuranceCompanySelect.disabled) {
        insuranceCompanySelect.disabled = false;
        console.log('✅ Insurance Company Name dropdown enabled on selection');
      }

      // Clear dependent dropdowns
      if (agencyCodeSelect) {
        agencyCodeSelect.innerHTML = '<option value="">Loading...</option>';
      }
      if (insuranceCompanySelect) {
        insuranceCompanySelect.innerHTML = '<option value="">Loading...</option>';
        insuranceCompanySelect.disabled = false;
      }

      // Load agency codes based on broker type
      if (brokerType === 'direct') {
        callMotorDirectAPI();
      } else if (brokerType === 'broking') {
        callMotorBrokingAPI();
      }
    });
  }

  // Old callDirectModeAPI function removed - now using callMotorDirectAPI()

  // Old functions removed - now using callMotorBrokingAPI() and populateMotorAgencyDropdown()

  // Agency Code change listener for direct mode
  if (agencyCodeSelect) {
    agencyCodeSelect.addEventListener('change', function() {
      const agentId = this.value;
      const brokerType = brokerCodeSelect ? brokerCodeSelect.value : '';

      if (brokerType === 'direct' && agentId) {
        console.log('🌐 Fetching company for agent ID:', agentId);

        // Show loading state
        if (insuranceCompanySelect) {
          insuranceCompanySelect.innerHTML = '<option value="">Loading company...</option>';
          insuranceCompanySelect.disabled = true;
        }

        // Call the company name API
        fetch(`/admin/insurance/motor/company_name_by_agent?agency_code_id=${agentId}`)
          .then(response => {
            console.log(`📡 API Response: ${response.status} ${response.statusText}`);
            return response.json();
          })
          .then(data => {
            if (data.success && data.data) {
              if (data.data.multiple_companies && data.data.company_names) {
                // Multiple companies - show all options
                const companyNames = data.data.company_names;
                const agentName = data.data.agent_name;
                console.log(`✅ Found ${companyNames.length} companies for agent ${agentName}: ${companyNames.join(', ')}`);

                insuranceCompanySelect.innerHTML = '<option value="">Select company...</option>';
                companyNames.forEach(companyName => {
                  const option = document.createElement('option');
                  option.value = companyName;
                  option.textContent = companyName;
                  insuranceCompanySelect.appendChild(option);
                });
                insuranceCompanySelect.disabled = false;
              } else if (data.data.company_name) {
                // Single company - auto-fill
                const companyName = data.data.company_name;
                const agentName = data.data.agent_name;
                console.log(`✅ Auto-filling company for agent ${agentName}: ${companyName}`);

                insuranceCompanySelect.innerHTML = `<option value="${companyName}" selected>${companyName}</option>`;
                insuranceCompanySelect.disabled = false;
              }
            } else {
              console.log('⚠️ No company data found for this agent');
              insuranceCompanySelect.innerHTML = '<option value="">No company found for this agent</option>';
              insuranceCompanySelect.disabled = false;
            }
          })
          .catch(error => {
            console.error('❌ Company API Error:', error);
            insuranceCompanySelect.innerHTML = '<option value="">Error loading company</option>';
            insuranceCompanySelect.disabled = false;
          });
      } else if (brokerType === 'direct' && !agentId) {
        // Clear company dropdown when no agent selected
        if (insuranceCompanySelect) {
          insuranceCompanySelect.innerHTML = '<option value="">Select Agent First...</option>';
        }
      }
    });
  }
});
</script>

