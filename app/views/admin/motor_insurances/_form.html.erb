          $('#motor_insurance_insurance_company_name').prop('disabled', false);
        }
      }
    });

    $(brokerCodeSelect).on('change.motorBroker', function() {
      const brokerType = this.value;
      console.log('🔥 MOTOR BROKER CODE CHANGED! Value:', brokerType);

      // Enable Insurance Company dropdown when any option is selected
      if (insuranceCompanySelect && insuranceCompanySelect.disabled) {
        insuranceCompanySelect.disabled = false;
        console.log('✅ Motor Insurance Company Name dropdown enabled on selection');

        // Also enable it for Select2 if initialized
        if (window.jQuery && $('#motor_insurance_insurance_company_name').hasClass('select2-hidden-accessible')) {
          $('#motor_insurance_insurance_company_name').prop('disabled', false);
        }
      }

      if (!brokerType) {
