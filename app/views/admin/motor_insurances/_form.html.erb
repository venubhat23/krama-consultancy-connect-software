    console.log('- Agency Code:', agencyCodeSelect ? '✅' : '❌');
    console.log('- Insurance Company:', insuranceCompanySelect ? '✅' : '❌');

    if (!brokerCodeSelect) {
      console.error('❌ Motor broker code select not found!');
      return;
    }

    // Clear any existing event listeners and add new one
    $(brokerCodeSelect).off('change.motorBroker');

    // Enable Insurance Company dropdown on click
    $(brokerCodeSelect).off('click.motorBrokerEnable');
    $(brokerCodeSelect).on('click.motorBrokerEnable', function() {
