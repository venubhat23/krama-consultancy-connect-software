      const labelSpan = document.getElementById('agency_code_label_text');
      if (labelSpan) {
        labelSpan.textContent = brokerType === 'direct' ? '' : ' (All Brokers)';
      }

      // Call appropriate API
      if (brokerType === 'direct') {
        callMotorDirectAPI();
      } else if (brokerType === 'broking') {
        callMotorBrokingAPI();
      }
    });

    console.log('✅ Motor broker code change listener attached');
