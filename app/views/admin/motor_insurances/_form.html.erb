function removeNominee(button) {
  const nomineeRow = button.closest('.nominee-row');
  const destroyField = nomineeRow.querySelector('.destroy-flag');

  if (destroyField.value === 'false') {
    destroyField.value = 'true';
    nomineeRow.style.display = 'none';
  } else {
    nomineeRow.remove();
  }

  toggleNoNomineesMessage();
}

function toggleNoNomineesMessage() {
  const nomineeRows = document.querySelectorAll('.nominee-row');
  const noNomineesMsg = document.getElementById('no_nominees_message');

  const visibleRows = Array.from(nomineeRows).filter(row => row.style.display !== 'none');

  if (visibleRows.length === 0) {
    noNomineesMsg.style.display = 'block';
  } else {
    noNomineesMsg.style.display = 'none';
  }
}

  // Document Upload System removed - using the one below
  // Policy Documents Manager JavaScript
  // Motor Insurance Policy Documents Manager (matching health insurance implementation)
  let motorPolicyDocumentIndex = <%= @motor_insurance.motor_insurance_documents.any? ? @motor_insurance.motor_insurance_documents.size : 0 %>;
  const addMotorPolicyDocumentBtn = document.getElementById('add_motor_policy_document');
  const motorPolicyDocumentsContainer = document.getElementById('motor_policy_documents_container');

  if (addMotorPolicyDocumentBtn && motorPolicyDocumentsContainer) {
    addMotorPolicyDocumentBtn.addEventListener('click', function() {
      const documentHtml = `
        <div class="document-entry p-3 mb-3 border rounded position-relative" data-index="${motorPolicyDocumentIndex}" style="background: #f8f9fa;">
          <button type="button" class="btn btn-sm btn-outline-danger position-absolute" style="top: 10px; right: 10px;" onclick="removeMotorDocument(this)">
            <i class="bi bi-x-lg"></i>
          </button>
          <div class="row">
            <div class="col-md-4">
              <label class="form-label">Document Title <span class="text-danger">*</span></label>
              <input type="text" name="motor_insurance[motor_insurance_documents_attributes][${motorPolicyDocumentIndex}][title]" class="form-control" placeholder="Enter document title" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Document Type <span class="text-danger">*</span></label>
              <select name="motor_insurance[motor_insurance_documents_attributes][${motorPolicyDocumentIndex}][document_type]" class="form-select" required>
                <option value="">Select Document Type</option>
                <option value="rc_book">RC Book</option>
                <option value="driving_license">Driving License</option>
                <option value="vehicle_photos">Vehicle Photos</option>
                <option value="insurance_certificate">Insurance Certificate</option>
                <option value="noc">NOC</option>
                <option value="puc_certificate">PUC Certificate</option>
                <option value="policy_document">Policy Document</option>
                <option value="inspection_report">Inspection Report</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Document File <span class="text-danger">*</span></label>
              <input type="file" name="motor_insurance[motor_insurance_documents_attributes][${motorPolicyDocumentIndex}][file]" class="form-control" accept="application/pdf,image/jpeg,image/jpg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required id="motor_doc_file_${motorPolicyDocumentIndex}">
            </div>
          </div>
          <div class="row mt-2">
            <div class="col-md-12">
              <label class="form-label">Description (Optional)</label>
              <textarea name="motor_insurance[motor_insurance_documents_attributes][${motorPolicyDocumentIndex}][description]" class="form-control" rows="2" placeholder="Optional description"></textarea>
            </div>
          </div>
        </div>
      `;

      motorPolicyDocumentsContainer.insertAdjacentHTML('beforeend', documentHtml);
      motorPolicyDocumentIndex++;
    });

    console.log('✅ Motor Insurance Policy Documents Manager initialized');
  } else {
    console.log('❌ Motor Insurance Policy Documents Manager elements not found');
  }

  // Remove motor document functionality
  window.removeMotorDocument = function(button) {
    if (confirm('Are you sure you want to remove this document?')) {
      button.closest('.document-entry').remove();
    }
  };

  // Main policy document delete functionality
  window.deleteMainPolicyDocument = function() {
    if (!confirm('Are you sure you want to delete the main policy document?')) return;

    fetch(`/admin/insurance/motor/<%= @motor_insurance.id %>/delete_main_policy_document`, {
      method: 'DELETE',
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      }
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        alert('Main policy document deleted successfully');
        window.location.reload();
      } else {
        alert('Failed to delete main policy document: ' + data.error);
      }
    })
    .catch(error => {
      console.error('Delete error:', error);
      alert('Failed to delete main policy document');
    });
  };

  // File size validation for all document file inputs
  document.querySelectorAll('input[type="file"][data-max-size]').forEach(input => {
    input.addEventListener('change', function(e) {
      const file = e.target.files[0];
      const maxSize = parseInt(this.dataset.maxSize);
      if (file && file.size > maxSize) {
        alert('File size must be less than ' + (maxSize / 1024 / 1024) + 'MB');
        e.target.value = '';
      }
    });
  });

</script>

