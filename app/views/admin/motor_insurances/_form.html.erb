            if (optionExists) {
              $(policyHolderSelect).val(existingPolicyHolder).trigger('change');
              console.log('✅ Restored policy holder:', existingPolicyHolder);
              clearInterval(retryInterval);
            } else if (retryCount >= maxRetries) {
              console.log('❌ Policy holder option not found after', maxRetries, 'retries:', existingPolicyHolder);
              console.log('Available options:', options.map(opt => opt.value));
              clearInterval(retryInterval);
            }
          } else if (retryCount >= maxRetries) {
            console.log('❌ Policy holder dropdown not loaded after', maxRetries, 'retries');
            clearInterval(retryInterval);
          }
        } else if (retryCount >= maxRetries) {
          console.log('❌ Policy holder select element not found');
          clearInterval(retryInterval);
        }
      }, 500); // Check every 500ms
    }

    // Listen for dropdown populated event to select existing values
    $('#motor_insurance_agency_code_id').on('dropdown:populated', function() {
      console.log('Agency dropdown populated, selecting existing value...');
      const agencySelect = this;

      // For direct mode, select the agency_code_id
      if (brokerCodeType === 'direct' && existingAgencyCodeId) {
        // Check if the option exists
        const optionExists = Array.from(agencySelect.options).some(opt => opt.value === existingAgencyCodeId);
        if (optionExists) {
          $(agencySelect).val(existingAgencyCodeId).trigger('change');
          console.log('✅ Selected existing agency code:', existingAgencyCodeId);
        } else {
          console.log('❌ Agency code option not found:', existingAgencyCodeId);
        }
      }
      // For broking mode, select the broker (which is stored as broker_X format)
      else if (brokerCodeType === 'broking' && existingBrokerId) {
        const brokerValue = 'broker_' + existingBrokerId;
        // Check if the option exists
        const optionExists = Array.from(agencySelect.options).some(opt => opt.value === brokerValue);
        if (optionExists) {
          $(agencySelect).val(brokerValue).trigger('change');
          console.log('✅ Selected existing broker:', brokerValue);
        } else {
          console.log('❌ Broker option not found:', brokerValue);
        }
      }
    });

    // Trigger broker code type change to load agency codes
    const brokerCodeSelect = document.getElementById('motor_insurance_broker_code_type');
    if (brokerCodeSelect && brokerCodeSelect.value) {
      setTimeout(function() {
        $(brokerCodeSelect).trigger('change');
        console.log('Triggered broker code type change for edit form');
        // The agency code will be selected automatically via the dropdown:populated event
      }, 500); // Small delay to allow customer change to complete first
    }
  <% end %>

  // Initialize date pickers with proper constraints
  function initializeDatePickers() {
    const dateFields = [
      'policy_booking_date',
      'policy_start_date',
      'policy_end_date',
      'autopay_start_date',
      'autopay_end_date'
    ];

    dateFields.forEach(fieldId => {
      const field = document.getElementById(fieldId) || document.querySelector(`[name*="${fieldId}"]`);
      if (field) {
        // Ensure proper min/max attributes are set
        field.setAttribute('min', '1900-01-01');
        field.setAttribute('max', '2099-12-31');

        // Fix any existing invalid values
        if (field.value && (field.value.includes('275760') || field.value.length > 10)) {
          field.value = new Date().toISOString().split('T')[0];
        }

        // Add event listener to prevent manual entry of invalid dates
        field.addEventListener('input', function() {
          const value = this.value;
          if (value && value.length > 10) {
            this.value = value.substring(0, 10);
          }
        });

        console.log(`✅ Initialized date picker for ${fieldId}`);
      }
    });
  }

  // Call date picker initialization
  initializeDatePickers();

  // Nominee Management Functions
  let nomineeIndex = <%= @motor_insurance.motor_insurance_nominees.length %>;

  // Note: Customer change handler is already defined above, which will call loadCustomerNominees

  // Function to load customer nominees via AJAX
  window.loadCustomerNominees = function(customerId) {
    $.ajax({
      url: '<%= load_customer_nominees_admin_motor_insurances_path %>',
      method: 'GET',
      data: { customer_id: customerId },
      success: function(response) {
        if (response.success && response.nominees && response.nominees.length > 0) {
          clearNominees();
          const count = response.nominees.length;
          const equalShare = parseFloat((100 / count).toFixed(2));
          response.nominees.forEach(function(nominee, index) {
            const share = (index === count - 1) ? (100 - equalShare * (count - 1)).toFixed(2) : equalShare;
            addNomineeFromFamilyMember(Object.assign({}, nominee, { share_percentage: share }));
          });
          toggleNoNomineesMessage();
        }
      },
      error: function(xhr, status, error) {
        console.error('Error loading customer nominees:', error);
      }
    });
  }

  // Function to add nominee from family member data
  window.addNomineeFromFamilyMember = function(nominee) {
    const nomineeHtml = `
      <div class="nominee-row border rounded p-3 mb-3" style="background-color: #f8f9fa;">
        <input type="hidden" name="motor_insurance[motor_insurance_nominees_attributes][${nomineeIndex}][id]" id="motor_insurance_motor_insurance_nominees_attributes_${nomineeIndex}_id">
        <div class="row">
          <div class="col-md-4 mb-3">
            <label class="form-label">Nominee Name <span class="text-danger">*</span></label>
            <input class="form-control" placeholder="Enter nominee name" required="required" type="text" value="${nominee.nominee_name || ''}" name="motor_insurance[motor_insurance_nominees_attributes][${nomineeIndex}][nominee_name]" id="motor_insurance_motor_insurance_nominees_attributes_${nomineeIndex}_nominee_name">
          </div>
          <div class="col-md-3 mb-3">
            <label class="form-label">Relationship <span class="text-danger">*</span></label>
            <select class="form-control" required="required" name="motor_insurance[motor_insurance_nominees_attributes][${nomineeIndex}][relationship]" id="motor_insurance_motor_insurance_nominees_attributes_${nomineeIndex}_relationship">
              <option value="">Select Relationship</option>
              <option value="spouse" ${nominee.relationship === 'spouse' ? 'selected' : ''}>Spouse</option>
              <option value="son" ${nominee.relationship === 'son' ? 'selected' : ''}>Son</option>
              <option value="daughter" ${nominee.relationship === 'daughter' ? 'selected' : ''}>Daughter</option>
              <option value="father" ${nominee.relationship === 'father' ? 'selected' : ''}>Father</option>
              <option value="mother" ${nominee.relationship === 'mother' ? 'selected' : ''}>Mother</option>
              <option value="brother" ${nominee.relationship === 'brother' ? 'selected' : ''}>Brother</option>
              <option value="sister" ${nominee.relationship === 'sister' ? 'selected' : ''}>Sister</option>
              <option value="other" ${nominee.relationship === 'other' ? 'selected' : ''}>Other</option>
            </select>
          </div>
          <div class="col-md-2 mb-3">
            <label class="form-label">Age <span class="text-danger">*</span></label>
            <input class="form-control" placeholder="Age" required="required" min="0" max="120" type="number" value="${nominee.age || ''}" name="motor_insurance[motor_insurance_nominees_attributes][${nomineeIndex}][age]" id="motor_insurance_motor_insurance_nominees_attributes_${nomineeIndex}_age">
          </div>
          <div class="col-md-2 mb-3">
            <label class="form-label">Share (%)</label>
            <input class="form-control" placeholder="100" min="0" max="100" step="0.01" type="number" value="${nominee.share_percentage !== undefined ? nominee.share_percentage : 100}" name="motor_insurance[motor_insurance_nominees_attributes][${nomineeIndex}][share_percentage]" id="motor_insurance_motor_insurance_nominees_attributes_${nomineeIndex}_share_percentage">
          </div>
          <div class="col-md-1 mb-3 d-flex align-items-end">
            <button type="button" class="btn btn-danger btn-sm" onclick="removeNominee(this)" title="Remove nominee">
              <i class="bi bi-trash"></i>
            </button>
          </div>
        </div>
        <input value="false" class="destroy-flag" type="hidden" name="motor_insurance[motor_insurance_nominees_attributes][${nomineeIndex}][_destroy]" id="motor_insurance_motor_insurance_nominees_attributes_${nomineeIndex}__destroy">
      </div>
    `;

    $('#nominees-container').append(nomineeHtml);
    nomineeIndex++;
  }

  // Function to clear all nominees
  window.clearNominees = function() {
    $('.nominee-row').remove();
    toggleNoNomineesMessage();
  }

  // Function to toggle no nominees message
  function toggleNoNomineesMessage() {
    const nomineeRows = document.querySelectorAll('.nominee-row');
    const noNomineesMsg = document.getElementById('no_nominees_message');
    if (nomineeRows.length === 0 || Array.from(nomineeRows).every(row => row.style.display === 'none')) {
      noNomineesMsg.style.display = 'block';
    } else {
      noNomineesMsg.style.display = 'none';
    }
  }

  // Initial call to set correct message state
  toggleNoNomineesMessage();
});

// Global nominee management functions (outside jQuery)
function loadNomineesFromCustomer() {
  const customerSelect = document.getElementById('customer_select');
  const customerId = customerSelect ? customerSelect.value : null;

  if (!customerId) {
    alert('Please select a client first');
    return;
  }

  // Show loading state on button
  const btn = document.getElementById('load_customer_nominees_btn');
  const originalText = btn.innerHTML;
  btn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Loading...';
  btn.disabled = true;

  $.ajax({
    url: '<%= load_customer_nominees_admin_motor_insurances_path %>',
    method: 'GET',
    data: { customer_id: customerId },
    success: function(response) {
      if (response.success && response.nominees && response.nominees.length > 0) {
        clearNominees();
        response.nominees.forEach(function(nominee) {
          addNomineeFromFamilyMember(nominee);
        });
        toggleNoNomineesMessage();
        alert(`Successfully loaded ${response.nominees.length} nominee(s) from client's family members.`);
      } else {
        alert('No family members found for this client.');
      }

      // Restore button state
      btn.innerHTML = originalText;
      btn.disabled = false;
    },
    error: function(xhr, status, error) {
      console.error('Error loading customer nominees:', error);
      alert('Error loading nominees. Please try again.');

      // Restore button state
      btn.innerHTML = originalText;
      btn.disabled = false;
    }
  });
}

