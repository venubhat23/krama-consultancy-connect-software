    templateResult: function(option) {
      if (!option.id || option.element.value === '') {
        return option.text;
      }

      // Get agent name and code from data attributes first, then parse from text
      var agentName = option.element ? option.element.getAttribute('data-agent-name') : null;
      var agencyCode = option.element ? option.element.getAttribute('data-agent-code') : null;

      // If data attributes not available, parse from text
      if (!agentName || !agencyCode) {
        var text = option.text;

        // Handle both formats: "Agent Name - Code" and "Agent Name (Code)"
        if (text.includes(' - ')) {
          var parts = text.split(' - ');
          agentName = parts[0];
          agencyCode = parts[1];
        } else if (text.includes('(') && text.includes(')')) {
          var match = text.match(/^(.+?)\s*\((.+?)\)$/);
          if (match) {
            agentName = match[1].trim();
            agencyCode = match[2];
          } else {
            agentName = text;
            agencyCode = '';
          }
        } else {
          agentName = text;
          agencyCode = '';
        }
      }

      var initials = agentName.split(' ').map(function(word) {
        return word.charAt(0).toUpperCase();
      }).join('').substring(0, 2);

      // Custom template with only name on first line and only code on second line
      var $option = $(
        '<div class="agency-option">' +
          '<div class="agency-option-avatar">' + initials + '</div>' +
          '<div class="agency-option-details">' +
            '<div class="agency-option-name" style="font-weight: 500;">' + agentName + '</div>' +
            '<div class="agency-option-code" style="font-size: 12px; color: #6c757d;">' + agencyCode + '</div>' +
          '</div>' +
        '</div>'
      );
      return $option;
    },
    templateSelection: function(option) {
      return option.text || 'Search and select agency code...';
    },
    escapeMarkup: function(markup) {
      return markup;
    }
  });

