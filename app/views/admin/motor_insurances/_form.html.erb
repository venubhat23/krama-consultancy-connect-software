  function callMotorDirectAPI() {
    console.log('🌐 Calling Motor Direct API...');

    fetch('/admin/insurance/motor/agency_codes_for_broker_type?broker_type=direct', {
      method: 'GET',
      headers: {
        'Accept': 'application/json',
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      }
    })
    .then(response => {
      console.log('📡 Motor Direct API Response Status:', response.status);
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      return response.json();
    })
    .then(data => {
      console.log('📊 Motor Direct API Data:', data);

      if (data.success && data.data) {
        populateMotorAgencyDropdown(data.data, 'Select Agent...');

        // Clear company dropdown and show placeholder
        const companySelect = document.getElementById('motor_insurance_insurance_company_name');
        if (companySelect) {
          $(companySelect).select2('destroy');
          companySelect.innerHTML = '<option value="">Select Agent First...</option>';
          $(companySelect).select2({
            theme: 'bootstrap-5',
            placeholder: 'Select Agent First...',
            allowClear: true,
            width: '100%'
          });
        }
      } else {
        console.error('❌ Motor Direct API returned no data');
      }
    })
    .catch(error => {
      console.error('❌ Motor Direct API Error:', error);
    });
  }

  function callMotorBrokingAPI() {
    console.log('🌐 Calling Motor Broking API using broker_codes endpoint (FIXED v2)...');

    // Use the same broker_codes endpoint as life insurance for consistency
    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
    const brokersHeaders = {
      'Accept': 'application/json',
      'X-Requested-With': 'XMLHttpRequest',
      'Content-Type': 'application/json'
    };
    if (csrfToken) {
      brokersHeaders['X-CSRF-Token'] = csrfToken;
    }

    fetch('/admin/broker_codes.json', {
      headers: brokersHeaders,
      credentials: 'same-origin'
    })
    .then(response => {
      console.log('Broker Codes API response status:', response.status);
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      return response.json();
    })
    .then(data => {
      console.log('✅ Motor Broker Codes API Success:', data);
      if (data && data.success && data.broker_codes && data.broker_codes.length > 0) {
        // Transform broker codes to exact same format as life insurance
        const brokersData = data.broker_codes.map(brokerCode => ({
          id: `broker_${brokerCode.id}`,  // Use broker_X format for proper processing
          text: brokerCode.display_name,  // Show "Broker Name (Code)" format like life insurance
          broker_name: brokerCode.broker_name,
          code: brokerCode.broker_code,
          broker_id: brokerCode.broker_id
        }));

        console.log('📦 Transformed broker data for motor:', brokersData);
        populateMotorAgencyDropdown(brokersData, 'Select Broker...');
        console.log('✅ Motor Broking dropdown updated successfully');
      } else {
        console.error('❌ Motor Broker Codes API returned no data');
        populateMotorAgencyDropdown([], 'Select Broker...');
      }
    })
    .catch(error => {
      console.error('❌ Motor Broker Codes API Error:', error);
      populateMotorAgencyDropdown([], 'Select Broker...');
    });

    // Second, get all motor insurance companies
    fetch('/admin/insurance/motor/insurance_companies_for_type', {
      method: 'GET',
      headers: {
        'Accept': 'application/json',
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      }
    })
    .then(response => {
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      return response.json();
    })
    .then(data => {
      console.log('📊 Motor Insurance Companies Data:', data);

      if (data.success && data.data) {
        populateMotorCompanyDropdown(data.data);
      }
    })
    .catch(error => {
      console.error('❌ Motor Company API Error:', error);
    });
  }

  function populateMotorAgencyDropdown(data, placeholder) {
    const agencySelect = document.getElementById('motor_insurance_agency_code_id');
    if (!agencySelect) return;

    console.log(`🔧 Populating motor agency dropdown with ${data.length} items...`);

    // Destroy existing Select2
    $(agencySelect).select2('destroy');

    // Clear and populate options
    agencySelect.innerHTML = `<option value="">${placeholder}</option>`;
    data.forEach((item, index) => {
      const option = document.createElement('option');
      option.value = item.id;

      // Extract name and code from the item
      let name = '';
      let code = '';

      // Simplified handling - prioritize the text field which contains display_name
      if (item.text) {
        // Use the pre-formatted display_name from broker_codes API
        option.textContent = item.text;
        name = item.broker_name || item.agent_name || item.text;
        code = item.code || '';
      } else if (item.broker_name && item.code) {
        // Legacy broker format
        name = item.broker_name;
        code = item.code;
        option.textContent = `${name} - ${code}`;
      } else if (item.agent_name && item.code) {
        // Direct mode agent format
        name = item.agent_name;
        code = item.code;
        option.textContent = `${name} - ${code}`;
      } else {
        // Fallback
        option.textContent = item.text || item.name || 'Unknown';
        name = option.textContent;
        code = '';
      }

      // Set data attributes for the template to use
      if (name) option.setAttribute('data-name', name);
      if (code) option.setAttribute('data-code', code);

      agencySelect.appendChild(option);
    });

    // Reinitialize Select2 with custom templates
    $(agencySelect).select2({
      theme: 'bootstrap-5',
      placeholder: placeholder,
      allowClear: true,
      width: '100%',
      dropdownParent: $('body'),
      minimumResultsForSearch: 0,
      templateResult: function(option) {
        if (!option.id || !option.element) {
          return option.text;
        }

        // Get name and code from data attributes
        const name = option.element.getAttribute('data-name') || '';
        const code = option.element.getAttribute('data-code') || '';

        if (!name && !code) {
          // Try to parse from text if attributes not found
          let parsedName = '';
          let parsedCode = '';

          // Handle both formats: "Name (Code)" and "Name - Code"
          if (option.text.includes(' (') && option.text.includes(')')) {
            // New broker codes format: "Landmark (LM121234001)"
            const match = option.text.match(/^(.+?)\s*\((.+?)\)$/);
            if (match) {
              parsedName = match[1].trim();
              parsedCode = match[2].trim();
            } else {
              parsedName = option.text;
            }
          } else if (option.text.includes(' - ')) {
            // Legacy format: "Name - Code"
            const parts = option.text.split(' - ');
            parsedName = parts[0] || option.text;
            parsedCode = parts[1] || '';
          } else {
            parsedName = option.text;
          }

          if (parsedCode) {
            return $('<div>' +
              '<div style="font-weight: 600;">' + parsedName + '</div>' +
              '<div style="font-size: 12px; color: #6c757d;">' + parsedCode + '</div>' +
            '</div>');
          }
          return parsedName || option.text;
        }

        // Create two-line display
        if (code) {
          return $('<div>' +
            '<div style="font-weight: 600;">' + name + '</div>' +
            '<div style="font-size: 12px; color: #6c757d;">' + code + '</div>' +
          '</div>');
        }

        return name || option.text;
      },
      templateSelection: function(option) {
        return option.text || placeholder;
      }
    });

    // Attach change listener for agency selection
    $(agencySelect).off('change.motorAgency');
    $(agencySelect).on('change.motorAgency', function() {
      const selectedId = $(this).val();
      const brokerType = $('#motor_insurance_broker_code_type').val();

      console.log(`🔥 Motor Agency Selected: ${selectedId}, Broker Type: ${brokerType}`);

      if (brokerType === 'direct' && selectedId) {
        fetchMotorCompanyByAgent(selectedId);
      }
    });

    console.log('✅ Motor agency dropdown populated and events attached');

    // Trigger custom event to indicate dropdown is ready
    $(agencySelect).trigger('dropdown:populated');
  }

