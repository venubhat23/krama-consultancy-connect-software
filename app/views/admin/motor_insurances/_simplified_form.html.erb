<script>
document.addEventListener('DOMContentLoaded', function() {
  // Auto-calculate total premium
  function calculateTotalPremium() {
    const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
    const gstPercentage = parseFloat(document.getElementById('gst_percentage').value) || 0;
    const gstAmount = (netPremium * gstPercentage) / 100;
    const totalPremium = netPremium + gstAmount;
    document.getElementById('total_premium').value = totalPremium.toFixed(2);
  }

  // Auto-calculate total IDV
  function calculateTotalIDV() {
    const vehicleIdv = parseFloat(document.getElementById('vehicle_idv').value) || 0;
    const cngIdv = parseFloat(document.getElementById('cng_idv').value) || 0;
    const totalIdv = vehicleIdv + cngIdv;
    document.getElementById('total_idv').value = totalIdv.toFixed(2);
  }

  // Auto-calculate commission amounts (matching new form)
  function calculateCommission() {
    console.log('🔧 calculateCommission() called');
    const netPremiumField = document.getElementById('net_premium');
    const commissionPercentageField = document.getElementById('commission_percentage');
    const tdsPercentageField = document.getElementById('tds_percentage');
    const commissionAmountField = document.getElementById('commission_amount');
    const tdsAmountField = document.getElementById('tds_amount');
    const afterTdsValueField = document.getElementById('after_tds_value');

    if (!netPremiumField || !commissionPercentageField || !tdsPercentageField) {
      console.error('❌ Missing required fields for commission calculation');
      return;
    }

    const netPremium = parseFloat(netPremiumField.value) || 0;
    const commissionPercentage = parseFloat(commissionPercentageField.value) || 0;
    const tdsPercentage = parseFloat(tdsPercentageField.value) || 0;

    console.log(`📊 Net Premium: Rs. ${netPremium}, Commission %: ${commissionPercentage}%, TDS %: ${tdsPercentage}%`);

    const commissionAmount = netPremium * (commissionPercentage / 100);
    const tdsAmount = commissionAmount * (tdsPercentage / 100);
    const afterTdsValue = commissionAmount - tdsAmount;

    console.log(`💰 Calculated - Commission: Rs. ${commissionAmount.toFixed(2)}, TDS: Rs. ${tdsAmount.toFixed(2)}, After TDS: Rs. ${afterTdsValue.toFixed(2)}`);

    if (commissionAmountField) commissionAmountField.value = commissionAmount.toFixed(2);
    if (tdsAmountField) tdsAmountField.value = tdsAmount.toFixed(2);
    if (afterTdsValueField) afterTdsValueField.value = afterTdsValue.toFixed(2);

    console.log('✅ Main commission calculation completed');
  }

  // Auto-calculate sub-agent commission
  function calculateSubAgentCommission() {
    const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
    const commissionPercentage = parseFloat(document.querySelector('.sub-agent-commission-percentage').value) || 2.0;
    const tdsPercentage = parseFloat(document.querySelector('.sub-agent-tds-percentage').value) || 0;

    const commissionAmount = netPremium * (commissionPercentage / 100);
    const tdsAmount = commissionAmount * (tdsPercentage / 100);
    const afterTdsValue = commissionAmount - tdsAmount;

    document.querySelector('.sub-agent-commission-amount').value = commissionAmount.toFixed(2);
    document.querySelector('.sub-agent-tds-amount').value = tdsAmount.toFixed(2);
    document.querySelector('.sub-agent-after-tds-value').value = afterTdsValue.toFixed(2);
  }

  // Auto-calculate investor commission
  function calculateInvestorCommission() {
    const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
    const commissionPercentage = parseFloat(document.querySelector('.investor-commission-percentage').value) || 2.0;
    const tdsPercentage = parseFloat(document.querySelector('.investor-tds-percentage').value) || 0;

    const commissionAmount = netPremium * (commissionPercentage / 100);
    const tdsAmount = commissionAmount * (tdsPercentage / 100);
    const afterTdsValue = commissionAmount - tdsAmount;

    document.querySelector('.investor-commission-amount').value = commissionAmount.toFixed(2);
  }

  // Auto-calculate ambassador commission
  function calculateAmbassadorCommission() {
    const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
    const commissionPercentage = parseFloat(document.querySelector('.ambassador-commission-percentage').value) || 2.0;
    const tdsPercentage = parseFloat(document.querySelector('.ambassador-tds-percentage').value) || 0;

    const commissionAmount = netPremium * (commissionPercentage / 100);
    const tdsAmount = commissionAmount * (tdsPercentage / 100);
    const afterTdsValue = commissionAmount - tdsAmount;

    document.querySelector('.ambassador-commission-amount').value = commissionAmount.toFixed(2);
    document.querySelector('.ambassador-tds-amount').value = tdsAmount.toFixed(2);
    document.querySelector('.ambassador-after-tds-value').value = afterTdsValue.toFixed(2);
  }

  // Calculate company expenses and profit
  function calculateProfitAndExpenses() {
    const netPremium = parseFloat(document.getElementById('net_premium').value) || 0;
    const mainAgentCommissionPercentage = parseFloat(document.getElementById('commission_percentage').value) || 0;

    // Get commission percentages
    const subAgentPercentage = parseFloat(document.querySelector('.sub-agent-commission-percentage').value) || 2.0;
    const investorPercentage = parseFloat(document.querySelector('.investor-commission-percentage').value) || 2.0;
    const companyExpensesPercentage = parseFloat(document.querySelector('.company-expenses-percentage').value) || 2.0;

    // Calculate total distribution (including ambassador)
    const ambassadorPercentage = parseFloat(document.querySelector('.ambassador-commission-percentage').value) || 2.0;
    const totalDistributionPercentage = subAgentPercentage + investorPercentage + ambassadorPercentage;

    // Calculate profit: Main Agent Commission - Affiliate Commission - Investor Portion - Company Expenses
    const profitPercentage = mainAgentCommissionPercentage - totalDistributionPercentage - companyExpensesPercentage;
    const profitAmount = netPremium * (profitPercentage / 100);

    // Update hidden fields for form submission
    const totalDistributionField = document.querySelector('.total-distribution-percentage');
    const profitPercentageField = document.querySelector('.profit-percentage');
    const profitAmountField = document.querySelector('.profit-amount');

    if (totalDistributionField) {
      totalDistributionField.value = totalDistributionPercentage.toFixed(2);
    }
    if (profitPercentageField) {
      profitPercentageField.value = profitPercentage.toFixed(2);
    }
    if (profitAmountField) {
      profitAmountField.value = profitAmount.toFixed(2);
    }

    // Update summary display
    document.getElementById('main-agent-summary').textContent = mainAgentCommissionPercentage.toFixed(2) + '%';
    document.getElementById('affiliate-summary').textContent = subAgentPercentage.toFixed(2) + '%';
    document.getElementById('ambassador-summary').textContent = ambassadorPercentage.toFixed(2) + '%';
    document.getElementById('investor-summary').textContent = investorPercentage.toFixed(2) + '%';
    document.getElementById('total-distribution-summary').textContent = totalDistributionPercentage.toFixed(2) + '%';
    document.getElementById('company-expenses-summary').textContent = companyExpensesPercentage.toFixed(2) + '%';
    document.getElementById('profit-percentage-summary').textContent = profitPercentage.toFixed(2) + '%';
    document.getElementById('profit-amount-summary').textContent = 'Rs. ' + profitAmount.toFixed(2);

    // Update investor display fields (since they don't have TDS)
    const investorDisplayField = document.querySelector('.investor-commission-amount-display');
    const investorCommissionAmount = netPremium * (investorPercentage / 100);
    if (investorDisplayField) {
      investorDisplayField.value = investorCommissionAmount.toFixed(2);
    }
  }

  // Calculate all commissions when net premium changes
  function calculateAllCommissions() {
    console.log('🚀 calculateAllCommissions() called - Running all commission calculations');
    try {
      calculateCommission();
      calculateSubAgentCommission();
      calculateInvestorCommission();
      calculateAmbassadorCommission();
      calculateProfitAndExpenses();
      console.log('✅ All commission calculations completed successfully');
    } catch (error) {
      console.error('❌ Error in calculateAllCommissions:', error);
    }
  }

  // Event listeners for calculations
  ['net_premium', 'gst_percentage'].forEach(id => {
    document.getElementById(id).addEventListener('input', calculateTotalPremium);
  });

  ['vehicle_idv', 'cng_idv'].forEach(id => {
    document.getElementById(id).addEventListener('input', calculateTotalIDV);
  });

  // Net premium event listeners (triggers all calculations)
  const netPremiumField = document.getElementById('net_premium');
  if (netPremiumField) {
    netPremiumField.addEventListener('input', function() {
      console.log('Net premium changed:', this.value);
      calculateAllCommissions();
    });
    netPremiumField.addEventListener('change', calculateAllCommissions);
  }

  // Commission percentage event listeners (moved from duplicate DOMContentLoaded)
  const commissionPercentageField = document.getElementById('commission_percentage');
  if (commissionPercentageField) {
    commissionPercentageField.addEventListener('input', function() {
      console.log('Commission percentage changed:', this.value);
      calculateCommission();
      calculateProfitAndExpenses();
    });
  }

  const tdsPercentageField = document.getElementById('tds_percentage');
  if (tdsPercentageField) {
    tdsPercentageField.addEventListener('input', calculateCommission);
  }

  // Sub-agent commission fields
  const subAgentFields = document.querySelectorAll('.sub-agent-commission-percentage, .sub-agent-tds-percentage');
  subAgentFields.forEach(field => {
    field.addEventListener('input', calculateAllCommissions);
    field.addEventListener('change', calculateAllCommissions);
  });

  // Investor commission fields
  const investorFields = document.querySelectorAll('.investor-commission-percentage');
  investorFields.forEach(field => {
    field.addEventListener('input', calculateAllCommissions);
    field.addEventListener('change', calculateAllCommissions);
  });

  // Ambassador commission fields
  const ambassadorFields = document.querySelectorAll('.ambassador-commission-percentage, .ambassador-tds-percentage');
  ambassadorFields.forEach(field => {
    field.addEventListener('input', calculateAllCommissions);
    field.addEventListener('change', calculateAllCommissions);
  });

  // Company expenses field
  const companyExpensesField = document.querySelector('.company-expenses-percentage');
  if (companyExpensesField) {
    companyExpensesField.addEventListener('input', calculateProfitAndExpenses);
    companyExpensesField.addEventListener('change', calculateProfitAndExpenses);
  }

  // Nominee management
  let nomineeCount = document.querySelectorAll('.nominee-entry').length;

  document.getElementById('add-nominee').addEventListener('click', function() {
    const container = document.getElementById('nominees-container');
    const nomineeHtml = `
      <div class="nominee-entry border rounded p-3 mb-3" data-index="${nomineeCount}">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h6 class="mb-0">Nominee ${nomineeCount + 1}</h6>
          <button type="button" class="btn btn-sm btn-outline-danger remove-nominee">
            <i class="bi bi-trash"></i> Remove
          </button>
        </div>
        <div class="row">
          <div class="col-md-4 mb-3">
            <label class="form-label">Nominee Name</label>
            <input type="text" name="motor_insurance[motor_insurance_nominees_attributes][${nomineeCount}][nominee_name]"
                   class="form-control" placeholder="Enter nominee name">
          </div>
          <div class="col-md-3 mb-3">
            <label class="form-label">Relationship</label>
            <select name="motor_insurance[motor_insurance_nominees_attributes][${nomineeCount}][relationship]"
                    class="form-control">
              <option value="">Select relationship</option>
              <option value="spouse">Spouse</option>
              <option value="son">Son</option>
              <option value="daughter">Daughter</option>
              <option value="father">Father</option>
              <option value="mother">Mother</option>
              <option value="brother">Brother</option>
              <option value="sister">Sister</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="col-md-2 mb-3">
            <label class="form-label">Age</label>
            <input type="number" name="motor_insurance[motor_insurance_nominees_attributes][${nomineeCount}][age]"
                   class="form-control" placeholder="Age" min="1" max="120">
          </div>
          <div class="col-md-3 mb-3">
            <label class="form-label">Share Percentage</label>
            <input type="number" name="motor_insurance[motor_insurance_nominees_attributes][${nomineeCount}][share_percentage]"
                   class="form-control" placeholder="Share %" min="0" max="100" step="0.01">
          </div>
        </div>
      </div>
    `;
    container.insertAdjacentHTML('beforeend', nomineeHtml);
    nomineeCount++;
  });

  // Remove nominee
  document.addEventListener('click', function(e) {
    if (e.target.closest('.remove-nominee')) {
      e.target.closest('.nominee-entry').remove();
    }
  });

  // Add Document Button Handler
  let motorDocumentIndex = 0;

  document.getElementById('add_motor_document')?.addEventListener('click', function() {
    const container = document.getElementById('motor_documents_container');
    const documentHtml = `
      <div class="document-entry p-3 mb-3 border rounded position-relative" data-index="${motorDocumentIndex}" style="background: #f8f9fa;">
        <button type="button" class="btn btn-sm btn-outline-danger position-absolute" style="top: 10px; right: 10px;" onclick="this.closest('.document-entry').remove()">
          <i class="bi bi-trash"></i>
        </button>
        <div class="row">
          <div class="col-md-4">
            <label class="form-label">Document Title <span class="text-danger">*</span></label>
            <input type="text" name="motor_insurance[motor_insurance_documents_attributes][${motorDocumentIndex}][title]" class="form-control" placeholder="Enter document title" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">Document Type <span class="text-danger">*</span></label>
            <select name="motor_insurance[motor_insurance_documents_attributes][${motorDocumentIndex}][document_type]" class="form-select" required>
              <option value="">Select Document Type</option>
              <option value="policy_document">Policy Document</option>
              <option value="rc_copy">RC Copy</option>
              <option value="driving_license">Driving License</option>
              <option value="puc_certificate">PUC Certificate</option>
              <option value="vehicle_photos">Vehicle Photos</option>
              <option value="claim_form">Claim Form</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label">Document File <span class="text-danger">*</span></label>
            <input type="file" name="motor_insurance[motor_insurance_documents_attributes][${motorDocumentIndex}][file]" class="form-control" accept="application/pdf,image/jpeg,image/jpg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required>
          </div>
        </div>
        <div class="row mt-2">
          <div class="col-md-12">
            <label class="form-label">Description (Optional)</label>
            <textarea name="motor_insurance[motor_insurance_documents_attributes][${motorDocumentIndex}][description]" class="form-control" rows="2" placeholder="Optional description"></textarea>
          </div>
        </div>
        <div class="mt-2">
          <small class="text-muted">
            <i class="bi bi-info-circle me-1"></i>
            Supported formats: PDF, JPG, PNG, Word documents (Max: 10MB per file)
          </small>
        </div>
      </div>
    `;

    container.insertAdjacentHTML('beforeend', documentHtml);
    motorDocumentIndex++;
  });

  // Initial calculations
  calculateTotalPremium();
  calculateTotalIDV();
  calculateAllCommissions();
});
</script>