<%= form_with model: [:admin, @motor_insurance], local: true, class: "needs-validation", novalidate: true do |form| %>

  <!-- Client & Agent Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-person me-2 text-primary"></i>
        Client & Agent Details
      </h5>
    </div>
    <div class="card-body">
      <% if @motor_insurance.errors.any? %>
        <div class="alert alert-danger alert-dismissible fade show">
          <i class="bi bi-exclamation-triangle me-2"></i>
          <strong>Please correct the following errors:</strong>
          <ul class="mb-0 mt-2">
            <% @motor_insurance.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :customer_id, "Client Name*", class: "form-label" %>
          <%= form.select :customer_id,
              options_for_select(@customers.map { |c| [c.display_name, c.id] }, @selected_customer&.id || @motor_insurance.customer_id),
              { prompt: 'Search and select client...' },
              { class: "form-control #{'is-invalid' if @motor_insurance.errors[:customer_id].any?}", required: true, id: "customer_select", data: { placeholder: "Type to search clients..." } } %>
          <% if @motor_insurance.errors[:customer_id].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:customer_id].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :policy_holder, "Policy Holder", class: "form-label" %>
          <%
            policy_holder_options = [['Select Policy Holder', '']]
            selected_policy_holder = @selected_policy_holder || @motor_insurance.policy_holder

            if @customer_family_members&.any?
              @customer_family_members.each do |member|
                option_text = "#{member.name} (#{member.relationship.humanize})"
                option_value = member.name
                policy_holder_options << [option_text, option_value]
              end
            end
          %>
          <%= form.select :policy_holder,
              options_for_select(policy_holder_options, selected_policy_holder),
              {},
              { class: "form-control", id: "policy_holder_select", data: { placeholder: "Select Policy Holder" } } %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :sub_agent_id, "Affiliate", class: "form-label" %>
          <%= form.select :sub_agent_id,
              options_for_select(@sub_agents.map { |sa| [sa.full_name, sa.id] }, @motor_insurance.sub_agent_id),
              { prompt: 'Search and select affiliate...' },
              { class: "form-control", id: "affiliate_select", data: { placeholder: "Type to search affiliates..." } } %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :registration_number, "Vehicle Registration Number*", class: "form-label" %>
          <%= form.text_field :registration_number,
              class: "form-control #{'is-invalid' if @motor_insurance.errors[:registration_number].any?}",
              placeholder: "Enter vehicle registration number", required: true %>
          <% if @motor_insurance.errors[:registration_number].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:registration_number].first %></div>
          <% end %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :vehicle_type, "Vehicle Type*", class: "form-label" %>
          <%= form.select :vehicle_type,
              options_for_select([
                ['New Vehicle', 'New Vehicle'],
                ['Old Vehicle', 'Old Vehicle']
              ], @motor_insurance.vehicle_type),
              { prompt: 'Select Vehicle Type' },
              { class: "form-control #{'is-invalid' if @motor_insurance.errors[:vehicle_type].any?}", required: true } %>
          <% if @motor_insurance.errors[:vehicle_type].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:vehicle_type].first %></div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Policy Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-file-text me-2 text-primary"></i>
        Policy Details
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :broker_code, "Broker Code", class: "form-label" %>
          <%= form.text_field :broker_code, class: "form-control", placeholder: "Enter broker code" %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :agency_code_id, "Agency Code", class: "form-label" %>
          <%= form.select :agency_code_id,
              options_from_collection_for_select(AgencyCode.all, :id, :display_name, @motor_insurance.agency_code_id),
              { prompt: "Select Agency Code" },
              { class: "form-control" } %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :insurance_company_name, "Insurance Company Name*", class: "form-label" %>
          <%= form.text_field :insurance_company_name,
              class: "form-control #{'is-invalid' if @motor_insurance.errors[:insurance_company_name].any?}",
              placeholder: "Enter insurance company name", required: true %>
          <% if @motor_insurance.errors[:insurance_company_name].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:insurance_company_name].first %></div>
          <% end %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :insurance_type, "Insurance Type*", class: "form-label" %>
          <%= form.select :insurance_type,
              options_for_select([
                ['Comprehensive', 'Comprehensive'],
                ['Third Party', 'Third Party']
              ], @motor_insurance.insurance_type),
              { prompt: 'Select Insurance Type' },
              { class: "form-control #{'is-invalid' if @motor_insurance.errors[:insurance_type].any?}", required: true } %>
          <% if @motor_insurance.errors[:insurance_type].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:insurance_type].first %></div>
          <% end %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :class_of_vehicle, "Class of Vehicle*", class: "form-label" %>
          <%= form.text_field :class_of_vehicle,
              class: "form-control #{'is-invalid' if @motor_insurance.errors[:class_of_vehicle].any?}",
              placeholder: "Enter class of vehicle", required: true %>
          <% if @motor_insurance.errors[:class_of_vehicle].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:class_of_vehicle].first %></div>
          <% end %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :policy_type, "Policy Type*", class: "form-label" %>
          <%= form.select :policy_type,
              options_for_select([
                ['New', 'New'],
                ['Renewal', 'Renewal'],
                ['Rollover', 'Rollover']
              ], @motor_insurance.policy_type),
              { prompt: 'Select Policy Type' },
              { class: "form-control #{'is-invalid' if @motor_insurance.errors[:policy_type].any?}", required: true } %>
          <% if @motor_insurance.errors[:policy_type].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:policy_type].first %></div>
          <% end %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :policy_number, "Policy Number*", class: "form-label" %>
          <%= form.text_field :policy_number,
              class: "form-control #{'is-invalid' if @motor_insurance.errors[:policy_number].any?}",
              placeholder: "Enter policy number", required: true %>
          <% if @motor_insurance.errors[:policy_number].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:policy_number].first %></div>
          <% end %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :policy_booking_date, "Policy Booking Date", class: "form-label" %>
          <%= form.date_field :policy_booking_date, class: "form-control" %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :policy_start_date, "Policy Start Date*", class: "form-label" %>
          <%= form.date_field :policy_start_date,
              class: "form-control #{'is-invalid' if @motor_insurance.errors[:policy_start_date].any?}",
              required: true %>
          <% if @motor_insurance.errors[:policy_start_date].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:policy_start_date].first %></div>
          <% end %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :policy_end_date, "Policy End Date*", class: "form-label" %>
          <%= form.date_field :policy_end_date,
              class: "form-control #{'is-invalid' if @motor_insurance.errors[:policy_end_date].any?}",
              required: true %>
          <% if @motor_insurance.errors[:policy_end_date].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:policy_end_date].first %></div>
          <% end %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :payment_mode, "Payment Mode*", class: "form-label" %>
          <%= form.select :payment_mode,
              options_for_select([
                ['Yearly', 'Yearly'],
                ['Half Yearly', 'Half Yearly'],
                ['Quarterly', 'Quarterly'],
                ['Monthly', 'Monthly']
              ], @motor_insurance.payment_mode),
              { prompt: 'Select Payment Mode' },
              { class: "form-control #{'is-invalid' if @motor_insurance.errors[:payment_mode].any?}", required: true } %>
          <% if @motor_insurance.errors[:payment_mode].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:payment_mode].first %></div>
          <% end %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :installment_autopay_start_date, "Installment Autopay Start Date", class: "form-label" %>
          <%= form.date_field :installment_autopay_start_date, class: "form-control" %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :installment_autopay_end_date, "Installment Autopay End Date", class: "form-label" %>
          <%= form.date_field :installment_autopay_end_date, class: "form-control" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Premium Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-currency-rupee me-2 text-primary"></i>
        Premium Details
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :net_premium, "Net Premium*", class: "form-label" %>
          <%= form.number_field :net_premium,
              class: "form-control #{'is-invalid' if @motor_insurance.errors[:net_premium].any?}",
              step: 0.01, placeholder: "Enter net premium", required: true, id: "net_premium" %>
          <% if @motor_insurance.errors[:net_premium].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:net_premium].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :gst_percentage, "GST %*", class: "form-label" %>
          <%= form.number_field :gst_percentage,
              class: "form-control #{'is-invalid' if @motor_insurance.errors[:gst_percentage].any?}",
              step: 0.01, min: 0, placeholder: "Enter GST percentage", required: true, id: "gst_percentage" %>
          <% if @motor_insurance.errors[:gst_percentage].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:gst_percentage].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :total_premium, "Total Premium (Auto-calculated)*", class: "form-label" %>
          <%= form.number_field :total_premium,
              class: "form-control #{'is-invalid' if @motor_insurance.errors[:total_premium].any?}",
              step: 0.01, readonly: true, id: "total_premium" %>
          <% if @motor_insurance.errors[:total_premium].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:total_premium].first %></div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Vehicle Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-car-front me-2 text-primary"></i>
        Vehicle Details
      </h5>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-4 mb-3">
          <%= form.label :vehicle_idv, "Vehicle IDV*", class: "form-label" %>
          <%= form.number_field :vehicle_idv,
              class: "form-control #{'is-invalid' if @motor_insurance.errors[:vehicle_idv].any?}",
              step: 0.01, placeholder: "Enter vehicle IDV", required: true, id: "vehicle_idv" %>
          <% if @motor_insurance.errors[:vehicle_idv].any? %>
            <div class="invalid-feedback"><%= @motor_insurance.errors[:vehicle_idv].first %></div>
          <% end %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :cng_idv, "CNG IDV", class: "form-label" %>
          <%= form.number_field :cng_idv,
              class: "form-control",
              step: 0.01, placeholder: "Enter CNG IDV", value: @motor_insurance.cng_idv || 0, id: "cng_idv" %>
        </div>

        <div class="col-md-4 mb-3">
          <%= form.label :total_idv, "Total IDV (Auto-calculated)", class: "form-label" %>
          <%= form.number_field :total_idv,
              class: "form-control",
              step: 0.01, readonly: true, id: "total_idv" %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :make, "Make", class: "form-label" %>
          <%= form.text_field :make, class: "form-control", placeholder: "Vehicle make" %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :model, "Model", class: "form-label" %>
          <%= form.text_field :model, class: "form-control", placeholder: "Vehicle model" %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :variant, "Variant", class: "form-label" %>
          <%= form.text_field :variant, class: "form-control", placeholder: "Vehicle variant" %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :mfy, "MFY (Year of Manufacture)", class: "form-label" %>
          <%= form.text_field :mfy, class: "form-control", placeholder: "Manufacturing year" %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :engine_number, "Engine Number", class: "form-label" %>
          <%= form.text_field :engine_number, class: "form-control", placeholder: "Engine number" %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :chassis_number, "Chassis Number", class: "form-label" %>
          <%= form.text_field :chassis_number, class: "form-control", placeholder: "Chassis number" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Optional Covers & Additional Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-shield-check me-2 text-primary"></i>
        Optional Covers & Additional Details
      </h5>
    </div>
    <div class="card-body">
      <div class="row mb-3">
        <div class="col-12">
          <label class="form-label">Optional Covers</label>
          <div class="row">
            <div class="col-md-3 mb-2">
              <div class="form-check">
                <%= form.check_box :zero_depreciation, class: "form-check-input" %>
                <%= form.label :zero_depreciation, "Zero Depreciation", class: "form-check-label" %>
              </div>
            </div>
            <div class="col-md-3 mb-2">
              <div class="form-check">
                <%= form.check_box :roadside_assistance, class: "form-check-input" %>
                <%= form.label :roadside_assistance, "Roadside Assistance", class: "form-check-label" %>
              </div>
            </div>
            <div class="col-md-3 mb-2">
              <div class="form-check">
                <%= form.check_box :engine_protector, class: "form-check-input" %>
                <%= form.label :engine_protector, "Engine Protector", class: "form-check-label" %>
              </div>
            </div>
            <div class="col-md-3 mb-2">
              <div class="form-check">
                <%= form.check_box :key_replacement, class: "form-check-input" %>
                <%= form.label :key_replacement, "Key Replacement", class: "form-check-label" %>
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-md-3 mb-2">
              <div class="form-check">
                <%= form.check_box :return_to_invoice, class: "form-check-input" %>
                <%= form.label :return_to_invoice, "Return to Invoice", class: "form-check-label" %>
              </div>
            </div>
            <div class="col-md-3 mb-2">
              <div class="form-check">
                <%= form.check_box :consumable_cover, class: "form-check-input" %>
                <%= form.label :consumable_cover, "Consumable Cover", class: "form-check-label" %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :financier, "Financier / HPA", class: "form-label" %>
          <%= form.text_field :financier, class: "form-control", placeholder: "Enter financier details" %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :reference_by, "Reference By", class: "form-label" %>
          <%= form.text_field :reference_by, class: "form-control", placeholder: "Enter reference name" %>
        </div>
      </div>

      <div class="row">
        <div class="col-12 mb-3">
          <%= form.label :extra_note, "Extra Note", class: "form-label" %>
          <%= form.text_area :extra_note, class: "form-control", rows: 3, placeholder: "Enter additional notes or comments..." %>
        </div>
      </div>
    </div>
  </div>

  <!-- Nominee Details Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-people me-2 text-primary"></i>
        Nominee Details
        <span class="text-danger">*</span>
      </h5>
    </div>
    <div class="card-body">
      <p class="text-muted mb-3">Add nominee details for this motor insurance policy.</p>

      <div id="nominees-container">
        <% if @motor_insurance.motor_insurance_nominees.any? %>
          <% @motor_insurance.motor_insurance_nominees.each_with_index do |nominee, index| %>
            <div class="nominee-entry border rounded p-3 mb-3" data-index="<%= index %>">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0">Nominee <%= index + 1 %></h6>
                <button type="button" class="btn btn-sm btn-outline-danger remove-nominee">
                  <i class="bi bi-trash"></i> Remove
                </button>
              </div>
              <div class="row">
                <div class="col-md-4 mb-3">
                  <label class="form-label">Nominee Name</label>
                  <%= text_field_tag "motor_insurance[motor_insurance_nominees_attributes][#{index}][nominee_name]", nominee.nominee_name,
                      class: "form-control", placeholder: "Enter nominee name" %>
                  <%= hidden_field_tag "motor_insurance[motor_insurance_nominees_attributes][#{index}][id]", nominee.id if nominee.persisted? %>
                </div>
                <div class="col-md-3 mb-3">
                  <label class="form-label">Relationship</label>
                  <%= select_tag "motor_insurance[motor_insurance_nominees_attributes][#{index}][relationship]",
                      options_for_select([
                        ['Spouse', 'spouse'],
                        ['Son', 'son'],
                        ['Daughter', 'daughter'],
                        ['Father', 'father'],
                        ['Mother', 'mother'],
                        ['Brother', 'brother'],
                        ['Sister', 'sister'],
                        ['Other', 'other']
                      ], nominee.relationship),
                      { prompt: 'Select relationship', class: "form-control" } %>
                </div>
                <div class="col-md-2 mb-3">
                  <label class="form-label">Age</label>
                  <%= number_field_tag "motor_insurance[motor_insurance_nominees_attributes][#{index}][age]", nominee.age,
                      class: "form-control", placeholder: "Age", min: 1, max: 120 %>
                </div>
                <div class="col-md-3 mb-3">
                  <label class="form-label">Share Percentage</label>
                  <%= number_field_tag "motor_insurance[motor_insurance_nominees_attributes][#{index}][share_percentage]", nominee.share_percentage,
                      class: "form-control", placeholder: "Share %", min: 0, max: 100, step: 0.01 %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-4">
            <i class="bi bi-people text-muted" style="font-size: 2rem;"></i>
            <p class="text-muted mb-0 mt-2">No nominees added yet. Click "Add Nominee" to add nominee details.</p>
          </div>
        <% end %>
      </div>

      <button type="button" class="btn btn-outline-primary" id="add-nominee">
        <i class="bi bi-plus-circle me-1"></i>Add Nominee
      </button>
    </div>
  </div>

  <% if @motor_insurance.new_record? || @motor_insurance.drwise_policy? %>
  <!-- Commission Calculation Table -->
  <div class="card mb-4 shadow-sm commission-table">
    <div class="card-header" style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0 text-dark fw-bold">
            <i class="bi bi-calculator me-2 text-primary"></i>
            Commission Calculation Table
          </h5>
          <small class="text-muted">Auto-calculated based on Net Premium</small>
        </div>
        <div class="d-flex align-items-center">
          <span class="badge bg-primary me-2">Indian Currency Format</span>
          <i class="bi bi-info-circle text-muted" title="All amounts automatically formatted in Indian currency style"></i>
        </div>
      </div>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0" style="font-size: 0.9rem;">
          <thead style="background: #f1f3f4; border-bottom: 2px solid #dee2e6;">
            <tr>
              <th class="py-3 px-4 fw-bold text-dark" style="min-width: 150px;">Commission To</th>
              <th class="py-3 px-2 text-center fw-bold text-dark" style="width: 120px;">Commission %</th>
              <th class="py-3 px-2 text-center fw-bold text-dark" style="width: 140px;">Commission Amount</th>
              <th class="py-3 px-2 text-center fw-bold text-dark" style="width: 100px;">TDS %</th>
              <th class="py-3 px-2 text-center fw-bold text-dark" style="width: 120px;">TDS Amount</th>
              <th class="py-3 px-2 text-center fw-bold text-dark" style="width: 140px;">After TDS Value</th>
            </tr>
          </thead>
          <tbody>
            <!-- Main Agent -->
            <tr style="border-bottom: 1px solid #e9ecef;">
              <td class="py-3 px-4 fw-bold text-dark bg-light">Main Agent</td>
              <td class="py-2 px-1 text-center">
                <%= form.number_field :main_agent_commission_percentage,
                    class: "form-control border-1 text-center fw-bold shadow-sm",
                    value: @motor_insurance.main_agent_commission_percentage || 10.0,
                    step: 0.01, id: "commission_percentage",
                    style: "background: #fff; border-color: #dee2e6;" %>
