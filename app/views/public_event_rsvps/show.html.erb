<div class="container py-5" style="max-width: 640px;">
  <div class="text-center mb-4">
    <div class="brand-logo" style="color: #667eea; font-size: 1.6rem;"><%= @registration.event.forum.name %></div>
  </div>

  <div class="card section-card border-0 shadow-sm">
    <div class="card-body p-4 p-md-5">
      <div class="text-center mb-4">
        <i class="bi bi-calendar-event display-4" style="color: #667eea;"></i>
        <h3 class="mt-3"><%= @registration.event.title %></h3>
        <p class="text-muted mb-0">
          <%= @registration.event.starts_at.strftime("%B %d, %Y at %I:%M %p") %>
          <% if @registration.event.venue.present? %><br><%= @registration.event.venue %><% end %>
        </p>
      </div>

      <% if @registration.attended? %>
        <div class="text-center">
          <i class="bi bi-check-circle-fill text-success" style="font-size: 1.5rem;"></i>
          <p class="mt-2 mb-0">Thanks for coming, <%= @registration.display_name.to_s.split.first %>!</p>
        </div>
      <% else %>
        <p class="text-center text-muted mb-4">Hi <%= @registration.display_name.to_s.split.first %>, will you be there?</p>

        <div class="d-flex gap-2 mb-3">
          <%= button_to "I'll be there", respond_public_event_rsvp_path(@registration.token), params: { rsvp_status: "going" }, method: :post,
                class: "btn btn-lg w-100 #{@registration.going? ? 'btn-success' : 'btn-outline-success'}" %>
          <%= button_to "Can't make it", respond_public_event_rsvp_path(@registration.token), params: { rsvp_status: "not_going" }, method: :post,
                class: "btn btn-lg w-100 #{@registration.not_going? ? 'btn-secondary' : 'btn-outline-secondary'}" %>
        </div>

        <% if @registration.going? %>
          <p class="text-success text-center small mb-0"><i class="bi bi-check-lg me-1"></i>You're confirmed — see you there!</p>
        <% elsif @registration.not_going? %>
          <p class="text-muted text-center small mb-0">Marked as not attending. Changed your mind? Tap "I'll be there" above.</p>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
