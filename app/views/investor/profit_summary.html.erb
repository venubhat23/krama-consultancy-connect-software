<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Investment Summary - <%= @investor.full_name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">

<div class="container-fluid py-4">
  <!-- Page Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">
        <i class="bi bi-person-circle text-primary me-2"></i>
        My Investment Summary
      </h1>
      <p class="text-muted mb-0">Profit sharing details for <%= @investor.full_name %></p>
    </div>
    <div class="d-flex align-items-center gap-3">
      <small class="text-muted">Generated: <%= Time.current.strftime("%B %d, %Y at %I:%M %p") %></small>
      <%= link_to destroy_user_session_path, method: :delete, class: "btn btn-outline-danger btn-sm",
          data: { confirm: "Are you sure you want to logout?" } do %>
        <i class="bi bi-box-arrow-right me-1"></i>
        Logout
      <% end %>
    </div>
  </div>

  <!-- Key Statistics Row -->
  <div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h6 class="text-muted mb-2">Commission Pool</h6>
              <h4 class="mb-0 text-success"><%= indian_currency(@total_commission_pool.to_i) %></h4>
              <small class="text-muted">Company Total</small>
            </div>
            <div class="bg-success bg-opacity-10 rounded p-3">
              <i class="bi bi-currency-rupee text-success fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h6 class="text-muted mb-2">Total Shares</h6>
              <h4 class="mb-0 text-primary"><%= @total_shares %></h4>
              <small class="text-muted">All Investors</small>
            </div>
            <div class="bg-primary bg-opacity-10 rounded p-3">
              <i class="bi bi-pie-chart text-primary fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h6 class="text-muted mb-2">Profit Per Share</h6>
              <h4 class="mb-0 text-info"><%= indian_currency(@profit_per_share.to_i) %></h4>
              <small class="text-muted">Current Rate</small>
            </div>
            <div class="bg-info bg-opacity-10 rounded p-3">
              <i class="bi bi-graph-up text-info fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h6 class="text-muted mb-2">System Investment</h6>
              <h4 class="mb-0 text-warning"><%= indian_currency(@system_investment_amount.to_i) %></h4>
              <small class="text-muted">Total Investment</small>
            </div>
            <div class="bg-warning bg-opacity-10 rounded p-3">
              <i class="bi bi-piggy-bank text-warning fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- My Profit Sharing Details -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-0">My Profit Sharing Details</h5>
              <small class="text-muted">Your personal investment and profit calculation</small>
            </div>
            <div>
              <small class="text-muted">
                Calculation: <%= indian_currency(@total_commission_pool.to_i) %> ÷ <%= @total_shares %> shares = <%= indian_currency(@profit_per_share.to_i) %> per share
              </small>
            </div>
          </div>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Sl No</th>
                  <th>Investor Name</th>
                  <th>No. of Shares</th>
                  <th>Invested Amount</th>
                  <th>Sharing %</th>
                  <th data-bs-toggle="tooltip" data-bs-placement="top" title="Formula: Shares × Profit Per Share" style="cursor: help;">
                    Profit Amt
                    <i class="bi bi-info-circle text-muted ms-1"></i>
                  </th>
                  <th data-bs-toggle="tooltip" data-bs-placement="top" title="Formula: Profit Amount × Sharing %" style="cursor: help;">
                    Actual Profit Shared
                    <i class="bi bi-calculator text-muted ms-1"></i>
                  </th>
                  <th data-bs-toggle="tooltip" data-bs-placement="top" title="Formula: (Actual Profit Shared ÷ Invested Amount) × 100" style="cursor: help;">
                    Return on Investment
                    <i class="bi bi-graph-up-arrow text-muted ms-1"></i>
                  </th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong><%= @investor_profit_data[:sl_no] %></strong></td>
                  <td>
                    <div>
                      <strong><%= @investor_profit_data[:investor].full_name.upcase %></strong>
                      <br>
                      <small class="text-muted"><%= @investor_profit_data[:investor].email %></small>
                    </div>
                  </td>
                  <td class="text-center">
                    <span class="badge bg-primary fs-6"><%= @investor_profit_data[:shares] %></span>
                  </td>
                  <td>
                    <strong class="text-success"><%= indian_currency(@investor_profit_data[:invested_amount].to_i) %></strong>
                  </td>
                  <td>
                    <span class="text-info"><%= number_with_precision(@investor_profit_data[:sharing_percentage], precision: 2) %>%</span>
                  </td>
                  <td>
                    <strong class="text-primary"><%= indian_currency(@investor_profit_data[:profit_amount].to_i) %></strong>
                  </td>
                  <td>
                    <div>
                      <span class="badge bg-success"><%= @investor_profit_data[:actual_profit_shared_percentage] %>%</span>
                      <br>
                      <strong class="text-success"><%= indian_currency(@investor_profit_data[:actual_profit_shared].to_i) %></strong>
                    </div>
                  </td>
                  <td>
                    <strong class="text-warning"><%= number_with_precision(@investor_profit_data[:roi], precision: 2) %>%</strong>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Investment Summary -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0">
          <h5 class="mb-0">Investment Summary</h5>
          <small class="text-muted">Your investment performance overview</small>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-4">
              <div class="text-center p-3 border rounded">
                <h4 class="text-primary mb-2"><%= indian_currency(@investor_profit_data[:invested_amount].to_i) %></h4>
                <p class="text-muted mb-0">Your Investment</p>
                <small class="text-muted">Initial Amount</small>
              </div>
            </div>
            <div class="col-md-4">
              <div class="text-center p-3 border rounded">
                <h4 class="text-success mb-2"><%= indian_currency(@investor_profit_data[:actual_profit_shared].to_i) %></h4>
                <p class="text-muted mb-0">Your Profit</p>
                <small class="text-success">
                  <%= @investor_profit_data[:actual_profit_shared_percentage] %>% of allocated profit
                </small>
              </div>
            </div>
            <div class="col-md-4">
              <div class="text-center p-3 border rounded">
                <h4 class="text-warning mb-2"><%= number_with_precision(@investor_profit_data[:roi], precision: 2) %>%</h4>
                <p class="text-muted mb-0">Return on Investment</p>
                <small class="text-muted">
                  <%= @investor_profit_data[:roi] > 0 ? 'Profitable' : 'No Profit Yet' %>
                </small>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <div class="text-center text-muted">
    <small>
      Report generated on <%= Date.current.strftime("%B %d, %Y") %> at <%= Time.current.strftime("%I:%M %p") %>
      <br>
      Drwise - Investor Portal
    </small>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Initialize Bootstrap tooltips
  var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
  var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
    return new bootstrap.Tooltip(tooltipTriggerEl);
  });
});
</script>

<style>
.card {
  transition: transform 0.2s ease-in-out;
}

.card:hover {
  transform: translateY(-2px);
}

.table-responsive {
  border-radius: 0.375rem;
}

.badge {
  font-size: 0.75rem;
}

@media print {
  .container-fluid {
    padding: 0;
  }

  .card {
    border: 1px solid #dee2e6 !important;
    box-shadow: none !important;
  }
}
</style>

</body>
</html>