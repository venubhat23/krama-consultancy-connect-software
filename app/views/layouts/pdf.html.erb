<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title><%= @title || "DrWise Insurance Report" %></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      font-size: 11px;
      line-height: 1.3;
      color: #333;
      margin: 0;
      padding: 20px;
    }

    .header {
      text-align: center;
      border-bottom: 2px solid #2c3e50;
      padding-bottom: 15px;
      margin-bottom: 20px;
    }

    .header h1 {
      color: #2c3e50;
      font-size: 20px;
      margin: 0 0 5px 0;
      font-weight: bold;
    }

    .header .subtitle {
      color: #7f8c8d;
      font-size: 12px;
      margin: 0;
    }

    .export-info {
      background: #ecf0f1;
      padding: 10px;
      border-radius: 5px;
      margin-bottom: 20px;
    }

    .export-info p {
      margin: 0;
      font-size: 10px;
      color: #2c3e50;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
      font-size: 9px;
    }

    table th {
      background: #34495e;
      color: white;
      padding: 8px 4px;
      text-align: left;
      font-weight: bold;
      border: 1px solid #2c3e50;
    }

    table td {
      padding: 6px 4px;
      border: 1px solid #bdc3c7;
      vertical-align: top;
    }

    table tr:nth-child(even) {
      background: #f8f9fa;
    }

    table tr:hover {
      background: #e8f4fd;
    }

    .text-right {
      text-align: right;
    }

    .text-center {
      text-align: center;
    }

    .badge {
      padding: 2px 6px;
      border-radius: 3px;
      font-size: 8px;
      font-weight: bold;
      color: white;
    }

    .badge-success { background: #27ae60; }
    .badge-danger { background: #e74c3c; }
    .badge-warning { background: #f39c12; }
    .badge-info { background: #3498db; }
    .badge-secondary { background: #95a5a6; }

    .footer {
      position: fixed;
      bottom: 20px;
      left: 20px;
      right: 20px;
      text-align: center;
      font-size: 9px;
      color: #7f8c8d;
      border-top: 1px solid #bdc3c7;
      padding-top: 10px;
    }

    .page-number:after {
      content: counter(page);
    }

    .currency {
      font-family: monospace;
      font-weight: bold;
      color: #27ae60;
    }

    .policy-number {
      font-family: monospace;
      font-size: 9px;
      background: #ecf0f1;
      padding: 2px 4px;
      border-radius: 3px;
    }

    .no-data {
      text-align: center;
      padding: 40px;
      color: #7f8c8d;
      font-style: italic;
    }

    @media print {
      body { margin: 0; }
      .footer { position: fixed; bottom: 0; }
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>DrWise Insurance</h1>
    <p class="subtitle"><%= @report_title || "Insurance Report" %></p>
  </div>

  <div class="export-info">
    <p><strong>Generated on:</strong> <%= Time.current.strftime('%B %d, %Y at %I:%M %p') %></p>
    <% if @date_range.present? %>
      <p><strong>Date Range:</strong> <%= @date_range %></p>
    <% end %>
    <% if @filters.present? %>
      <p><strong>Filters Applied:</strong> <%= @filters %></p>
    <% end %>
  </div>

  <%= yield %>

  <div class="footer">
    <p>DrWise Insurance Management System | Page <span class="page-number"></span> | Generated by <%= current_user&.name || 'System' %></p>
  </div>
</body>
</html>