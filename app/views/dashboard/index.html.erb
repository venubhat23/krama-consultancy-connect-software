  const startDateField = document.getElementById('start_date_field');
  const endDateField = document.getElementById('end_date_field');
  const currentPeriodDisplay = document.getElementById('current-period-display');

  if (!startDateField || !endDateField || !currentPeriodDisplay) return;

  const startValue = startDateField.value;
  const endValue = endDateField.value;

  if (startValue && endValue) {
    const startDate = new Date(startValue);
    const endDate = new Date(endValue);

    const formatDisplayDate = (date) => {
      const options = { year: 'numeric', month: 'short', day: 'numeric' };
      return date.toLocaleDateString('en-US', options);
    };

    const displayText = `${formatDisplayDate(startDate)} - ${formatDisplayDate(endDate)}`;
    currentPeriodDisplay.textContent = displayText;
  }
}

// Clear all filters function
function clearAllFilters() {
  const periodSelect = document.getElementById('period_select');
  const yearHidden   = document.getElementById('year_hidden');
  const fyHidden     = document.getElementById('fy_hidden');
  const monthSelect  = document.getElementById('month_filter');
  const startDateField = document.getElementById('start_date_field');
  const endDateField = document.getElementById('end_date_field');

  const currentYear = new Date().getFullYear();

  // Reset period dropdown to current calendar year
  if (periodSelect) periodSelect.value = 'cal_' + currentYear;
  if (yearHidden)   yearHidden.value   = currentYear;
  if (fyHidden)     fyHidden.value     = '';
  if (monthSelect)  monthSelect.value  = '';
  if (startDateField) { startDateField.value = currentYear + '-01-01'; }
  if (endDateField)   { endDateField.value   = currentYear + '-12-31'; }

  // Submit the form to reload data with cleared filters
  setTimeout(() => {
    updateCurrentPeriod();
    const form = (periodSelect || monthSelect || startDateField)?.closest('form');
    if (form) {
      form.submit();
      return;
    }

    // Remove highlighting after auto-load
    setTimeout(() => {
      if (startDateField) {
        startDateField.style.backgroundColor = '';
        startDateField.style.border = '';
      }
      if (endDateField) {
        endDateField.style.backgroundColor = '';
        endDateField.style.border = '';
      }
    }, 1500);
  }, 200);

  console.log(`🎯 Filters cleared and reset to default (${currentYear} All Year)`);
}

// Clean up modal backdrops on close
document.addEventListener('DOMContentLoaded', function() {
  // Add event listeners for filter auto-update
  const monthSelect = document.getElementById('month_filter');
  const startDateField = document.getElementById('start_date_field');
  const endDateField = document.getElementById('end_date_field');

  // AUTO-LOAD current year dates on page load
  console.log('🚀 Page loaded - Auto-loading current year dates...');
  if (startDateField && endDateField && !startDateField.value && !endDateField.value) {
    // Only auto-load if fields are empty (first page load)
    const currentYear = new Date().getFullYear();
    const yearStart = `${currentYear}-01-01`;
    const yearEnd = `${currentYear}-12-31`;

    startDateField.value = yearStart;
    endDateField.value = yearEnd;

    // Brief green highlight to show auto-loading
    startDateField.style.backgroundColor = '#d4edda';
    endDateField.style.backgroundColor = '#d4edda';

    setTimeout(() => {
      startDateField.style.backgroundColor = '';
      endDateField.style.backgroundColor = '';
    }, 1000);

    console.log(`✅ Auto-loaded current year dates: ${yearStart} to ${yearEnd}`);
  } else if (startDateField && endDateField) {
    console.log(`ℹ️ Date fields already have values: ${startDateField.value} to ${endDateField.value}`);
  }

  if (monthSelect) {
    monthSelect.addEventListener('change', function() {
      updateCurrentPeriod();
      monthSelect.form.submit();
    });
  }

  if (startDateField) {
    startDateField.addEventListener('change', updateCurrentPeriodFromDates);
  }

  if (endDateField) {
    endDateField.addEventListener('change', updateCurrentPeriodFromDates);
  }

  // Add Clear button event listener
  const clearButton = document.getElementById('clear_filters_btn');
  if (clearButton) {
    console.log('✅ Clear button found, adding click listener');
    clearButton.addEventListener('click', function() {
      console.log('🧹 Clear button clicked!');
      clearAllFilters();
    });
  } else {
    console.log('❌ Clear button not found');
  }

  // Modal cleanup
  ['renewalModal', 'policyModal', 'systemStatusModal', 'policyTypeModal'].forEach(modalId => {
    const modal = document.getElementById(modalId);
    if (modal) {
      modal.addEventListener('hidden.bs.modal', function() {
        setTimeout(() => {
          document.querySelectorAll('.modal-backdrop').forEach(backdrop => backdrop.remove());
          document.body.classList.remove('modal-open');
          document.body.style.paddingRight = '';
          document.body.style.overflow = '';
        }, 100);
      });
    }
  });
});
</script>

