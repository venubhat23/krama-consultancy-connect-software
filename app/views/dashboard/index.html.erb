<div class="modal fade" id="dashboardKpiModal" tabindex="-1" aria-labelledby="dashboardKpiModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header" style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%); color: white;">
        <h5 class="modal-title" id="dashboardKpiModalLabel">Details</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">
        <div id="dashboardKpiLoading" class="text-center py-5">
          <div class="spinner-border text-primary" role="status"></div>
          <p class="mt-2 text-muted">Loading data…</p>
        </div>
        <div id="dashboardKpiContent" style="display:none;">
          <div id="dashboardKpiSummary" class="px-4 pt-3 pb-1"></div>
          <div class="table-responsive px-2 pb-3">
            <table class="table table-hover table-sm align-middle mb-0" id="dashboardKpiTable">
              <thead class="table-dark" id="dashboardKpiHead"></thead>
              <tbody id="dashboardKpiBody"></tbody>
              <tfoot id="dashboardKpiFoot"></tfoot>
            </table>
          </div>
        </div>
        <div id="dashboardKpiError" style="display:none;" class="alert alert-danger m-3"></div>
      </div>
      <div class="modal-footer bg-light py-2 d-flex justify-content-between align-items-center" id="dashboardKpiFooter" style="display:none !important;">
        <div id="dashboardKpiFooterContent" class="d-flex gap-4 fw-bold fs-6"></div>
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
const DASH_CARD_DETAIL_URL = '<%= dashboard_card_detail_path %>';
const DASH_FILTER_START    = '<%= @filter_start_date %>';
const DASH_FILTER_END      = '<%= @filter_end_date %>';

function dashFmtDateDMY(iso) {
  if (!iso) return iso;
  const p = iso.split('-');
  if (p.length !== 3) return iso;
  return p[2] + '-' + p[1] + '-' + p[0];
}

function openDashboardCardModal(card) {
  const metric = card.dataset.cardMetric;
  const label  = card.dataset.cardLabel;
  document.getElementById('dashboardKpiModalLabel').textContent = label + ' — ' + dashFmtDateDMY(DASH_FILTER_START) + ' to ' + dashFmtDateDMY(DASH_FILTER_END);
  document.getElementById('dashboardKpiLoading').style.display = 'block';
  document.getElementById('dashboardKpiContent').style.display = 'none';
  document.getElementById('dashboardKpiError').style.display   = 'none';
  const modal = new bootstrap.Modal(document.getElementById('dashboardKpiModal'));
  modal.show();

  const url = DASH_CARD_DETAIL_URL + '?metric=' + encodeURIComponent(metric) +
              '&start_date=' + encodeURIComponent(DASH_FILTER_START) +
              '&end_date='   + encodeURIComponent(DASH_FILTER_END);

  fetch(url, { headers: { 'Accept': 'application/json',
                           'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content') } })
    .then(r => r.json())
    .then(data => {
      if (data.error) throw new Error(data.error);
      renderDashboardKpiData(metric, label, data);
      document.getElementById('dashboardKpiLoading').style.display = 'none';
      document.getElementById('dashboardKpiContent').style.display = 'block';
    })
    .catch(err => {
      document.getElementById('dashboardKpiLoading').style.display = 'none';
      document.getElementById('dashboardKpiError').style.display = 'block';
      document.getElementById('dashboardKpiError').textContent = 'Error loading data: ' + err.message;
    });
}

function dashFmtINR(v) {
  return 'Rs. ' + Number(v).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function renderDashboardKpiData(metric, label, data) {
  const records = data.records || [];
  const head = document.getElementById('dashboardKpiHead');
  const body = document.getElementById('dashboardKpiBody');
  const foot = document.getElementById('dashboardKpiFoot');
  const summary = document.getElementById('dashboardKpiSummary');

  head.innerHTML = '';
  body.innerHTML = '';
  foot.innerHTML = '';
  summary.innerHTML = '';

  const kpiFooter = document.getElementById('dashboardKpiFooter');
  const kpiFooterContent = document.getElementById('dashboardKpiFooterContent');
  if (kpiFooter) kpiFooter.style.display = 'none';

  if (records.length === 0) {
    body.innerHTML = '<tr><td colspan="10" class="text-center text-muted py-4">No records found for this period.</td></tr>';
    return;
  }

  if (metric === 'policies' || metric === 'premium') {
    head.innerHTML = `<tr>
      <th>#</th><th>Type</th><th>Policy No.</th><th>Customer</th>
      <th>Start Date</th><th>End Date</th><th>Created</th>
      <th class="text-end">Net Premium</th><th class="text-end">Total Premium</th>
      <th class="text-center">Source</th>
    </tr>`;
    let totalNet = 0, totalGross = 0;
    records.forEach((r, i) => {
      totalNet   += r.net_premium   || 0;
      totalGross += r.total_premium || 0;
      const policyCell = r.policy_link
        ? `<a href="${r.policy_link}" target="_blank" class="font-monospace small text-decoration-none">${r.policy_number}</a>`
        : `<span class="font-monospace small">${r.policy_number}</span>`;
      const sourceBadge = r.drwise
        ? `<span class="badge bg-success">DrWise</span>`
        : `<span class="badge bg-warning text-dark">Non-DrWise</span>`;
      body.innerHTML += `<tr>
        <td class="text-muted">${i+1}</td>
        <td><span class="badge bg-secondary">${r.type}</span></td>
        <td>${policyCell}</td>
        <td>${r.customer}</td>
        <td>${r.policy_start_date || '—'}</td>
        <td>${r.policy_end_date   || '—'}</td>
        <td>${r.created_at}</td>
        <td class="text-end">${dashFmtINR(r.net_premium)}</td>
        <td class="text-end fw-bold">${dashFmtINR(r.total_premium)}</td>
        <td class="text-center">${sourceBadge}</td>
      </tr>`;
    });
    foot.innerHTML = `<tr class="table-warning fw-bold">
      <td colspan="7">Total (${records.length} policies)</td>
      <td class="text-end">${dashFmtINR(totalNet)}</td>
      <td class="text-end">${dashFmtINR(totalGross)}</td>
      <td></td>
    </tr>`;
    summary.innerHTML = `<div class="d-flex gap-3 flex-wrap mb-2">
      <span class="badge bg-primary fs-6">${records.length} Policies</span>
      <span class="badge bg-warning text-dark fs-6">Net: ${dashFmtINR(totalNet)}</span>
      <span class="badge bg-success fs-6">Total: ${dashFmtINR(totalGross)}</span>
    </div>`;
    if (kpiFooter && kpiFooterContent) {
      kpiFooterContent.innerHTML = `
        <span>Policies: <strong>${records.length}</strong></span>
        <span class="text-warning">Total Net Premium: <strong>${dashFmtINR(totalNet)}</strong></span>
        <span class="text-success">Total Gross Premium: <strong>${dashFmtINR(totalGross)}</strong></span>`;
      kpiFooter.style.display = 'flex';
    }

  } else if (metric === 'customers') {
    head.innerHTML = `<tr><th>#</th><th>Name</th><th>City</th><th>Mobile</th><th>Joined</th></tr>`;
    records.forEach((r, i) => {
      const nameCell = r.customer_link
        ? `<a href="${r.customer_link}" class="fw-semibold text-decoration-none">${r.name}</a>`
        : r.name;
      body.innerHTML += `<tr>
        <td class="text-muted">${i+1}</td>
        <td>${nameCell}</td><td>${r.city || '—'}</td>
        <td>${r.mobile || '—'}</td><td>${r.created_at}</td>
      </tr>`;
    });
    summary.innerHTML = `<span class="badge bg-primary fs-6 mb-2">${records.length} Customers</span>`;

  } else if (metric === 'leads') {
    head.innerHTML = `<tr><th>#</th><th>Name</th><th>Stage</th><th>Created</th></tr>`;
    records.forEach((r, i) => {
      body.innerHTML += `<tr>
        <td class="text-muted">${i+1}</td>
        <td>${r.name}</td><td>${r.stage}</td><td>${r.created_at}</td>
      </tr>`;
    });
    summary.innerHTML = `<span class="badge bg-info fs-6 mb-2">${records.length} Leads</span>`;

  } else if (metric === 'investors') {
    head.innerHTML = `<tr><th>#</th><th>Name</th><th>Joined</th></tr>`;
    records.forEach((r, i) => {
      body.innerHTML += `<tr>
        <td class="text-muted">${i+1}</td>
        <td>${r.name}</td><td>${r.created_at}</td>
      </tr>`;
    });
    summary.innerHTML = `<span class="badge fs-6 mb-2" style="background:#8b5cf6;">${records.length} Investors</span>`;

  } else if (metric === 'affiliates') {
    head.innerHTML = `<tr><th>#</th><th>Name</th><th>Status</th><th>Joined</th></tr>`;
    records.forEach((r, i) => {
      body.innerHTML += `<tr>
        <td class="text-muted">${i+1}</td>
        <td>${r.name}</td><td>${r.status}</td><td>${r.created_at}</td>
      </tr>`;
    });
    summary.innerHTML = `<span class="badge fs-6 mb-2" style="background:#ec4899;">${records.length} Affiliates</span>`;
  }
}
</script>