function loadCommissionsDueData(content, loading) {
  fetch('/admin/api/system_status/commissions_due_detailed', {
    credentials: 'same-origin',
    headers: {
      'Content-Type': 'application/json',
      'X-Requested-With': 'XMLHttpRequest'
    }
  })
    .then(response => {
      console.log('Commission API response status:', response.status);
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      return response.json();
    })
    .then(data => {
      console.log('Commission API data:', data);
      console.log('Success:', data.success, 'Total Count:', data.total_count, 'Data Array Length:', data.data?.length);

      loading.style.display = 'none';
      content.style.display = 'block';
      if (data.success) { _csvModalData = data; const b = document.getElementById('downloadCsvBtn'); if (b) b.style.display = ''; }

      if (data.success && data.total_count > 0) {
        const fmtAmt = fmtINR; // use global Indian formatter
        const sr = data.summary_by_recipient || {};

        const recipientConfig = [
          { key: 'main_agent',      label: 'Main Agent',      color: '#667eea', bg: 'linear-gradient(135deg,#667eea,#764ba2)' },
          { key: 'affiliate',       label: 'Affiliate',       color: '#27ae60', bg: 'linear-gradient(135deg,#27ae60,#1e8449)' },
          { key: 'ambassador',      label: 'Ambassador',      color: '#e67e22', bg: 'linear-gradient(135deg,#e67e22,#ca6f1e)' },
          { key: 'investor',        label: 'Investor',        color: '#2980b9', bg: 'linear-gradient(135deg,#2980b9,#1a5276)' },
          { key: 'company_expense', label: 'Company Expense', color: '#8e44ad', bg: 'linear-gradient(135deg,#8e44ad,#6c3483)' }
        ];

        const thStyle = 'color:white;font-weight:800;border:none;padding:12px 10px;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;';

        const policyPath = (type, id) => {
          if (!id) return null;
          const map = { health: '/admin/insurance/health', life: '/admin/insurance/life', motor: '/admin/insurance/motor', other: '/admin/insurance/other' };
          return (map[type] || null) ? `${map[type]}/${id}` : null;
        };

        const buildTable = (records, color) => {
          if (!records.length) return '<p class="text-muted py-3 text-center">No pending records.</p>';
          return `
            <div class="table-responsive" style="max-height:420px;overflow-y:auto;border-radius:10px;box-shadow:0 4px 15px rgba(0,0,0,0.08);">
              <table class="table table-hover mb-0" style="background:white;border-radius:10px;overflow:hidden;">
                <thead style="background:${color};position:sticky;top:0;z-index:10;">
                  <tr>
                    <th style="${thStyle}">Lead ID</th>
                    <th style="${thStyle}">Policy</th>
                    <th style="${thStyle}">Customer</th>
                    <th style="${thStyle}">Affiliate</th>
                    <th style="${thStyle}">Type</th>
                    <th style="${thStyle}">Premium</th>
                    <th style="${thStyle}text-align:center;">%</th>
                    <th style="${thStyle}text-align:center;">Commission</th>
                    <th style="${thStyle}">Calculation</th>
                  </tr>
                </thead>
                <tbody>
                  ${records.map((c, i) => {
                    const isOrphaned = c.orphaned === true;
                    const rowBg = isOrphaned ? 'rgba(255,243,205,0.6)' : (i%2===0?'rgba(0,0,0,0.02)':'white');
                    const leadUrl  = c.lead_db_id ? `/admin/leads/${c.lead_db_id}` : null;
                    const polUrl   = policyPath(c.policy_type, c.policy_db_id);
                    const linkStyle = 'color:white;text-decoration:none;cursor:pointer;';
                    const polLinkStyle = 'font-family:monospace;font-weight:700;color:#2c3e50;font-size:0.85rem;background:#ecf0f1;padding:3px 6px;border-radius:5px;text-decoration:none;';
                    const leadCell = leadUrl
                      ? `<a href="${leadUrl}" target="_blank" style="${linkStyle}"><span class="badge" style="background:${isOrphaned?'#adb5bd':color};color:white;font-size:0.7rem;padding:4px 7px;border-radius:6px;">${c.lead_id} <i class="bi bi-box-arrow-up-right" style="font-size:0.6rem;"></i></span></a>`
                      : `<span class="badge" style="background:${isOrphaned?'#adb5bd':color};color:white;font-size:0.7rem;padding:4px 7px;border-radius:6px;">${c.lead_id}</span>`;
                    const policyCell = (polUrl && c.policy_number !== 'N/A')
                      ? `<a href="${polUrl}" target="_blank" style="${polLinkStyle}">${c.policy_number} <i class="bi bi-box-arrow-up-right" style="font-size:0.6rem;color:#667eea;"></i></a>`
                      : `<span style="${polLinkStyle.replace('text-decoration:none;','')}">${c.policy_number}</span>`;
                    return `
                    <tr style="background:${rowBg};border-bottom:1px solid #f0f0f0;${isOrphaned?'opacity:0.85;':''}" title="${isOrphaned?'Policy record not found for this payout':''}">
                      <td style="padding:10px 8px;">${leadCell}</td>
                      <td style="padding:10px 8px;">${policyCell}</td>
                      <td style="padding:10px 8px;font-weight:700;color:#34495e;font-size:0.9rem;">${c.customer_name}${isOrphaned?' <span title="Policy not found" style="color:#e67e22;font-size:0.75rem;">⚠ policy missing</span>':''}</td>
                      <td style="padding:10px 8px;font-size:0.82rem;color:#2c3e7a;">${c.affiliate_name !== 'N/A' ? `<span style="background:#eaf4fb;color:#2980b9;border:1px solid #aed6f1;padding:2px 8px;border-radius:10px;font-weight:600;font-size:0.75rem;">${c.affiliate_name}</span>` : '<span style="color:#adb5bd;font-size:0.75rem;">—</span>'}</td>
                      <td style="padding:10px 8px;"><span class="badge bg-info text-white" style="font-size:0.7rem;">${c.policy_type}</span></td>
                      <td style="padding:10px 8px;font-weight:700;color:${isOrphaned?'#adb5bd':'#667eea'};">${isOrphaned ? '—' : fmtAmt(c.base_premium)}</td>
                      <td style="padding:10px 8px;text-align:center;font-weight:800;color:${isOrphaned?'#adb5bd':'#f39c12'};">${isOrphaned ? '—' : parseFloat(c.percentage||0).toFixed(1)+'%'}</td>
                      <td style="padding:10px 8px;text-align:center;"><span style="font-weight:900;color:#e74c3c;font-size:1rem;background:rgba(231,76,60,0.1);padding:4px 8px;border-radius:7px;">${fmtAmt(c.amount)}</span></td>
                      <td style="padding:10px 8px;font-size:0.8rem;color:${isOrphaned?'#e67e22':'#7f8c8d'};font-style:italic;">${c.calculation}</td>
                    </tr>`;
                  }).join('')}
                </tbody>
              </table>
            </div>`;
        };

        content.innerHTML = `
          <div class="alert mb-3" style="background:linear-gradient(135deg,#667eea,#764ba2);border:none;padding:10px 15px;">
            <span style="color:#fff;font-weight:700;font-size:0.9rem;"><i class="bi bi-calculator me-2"></i>${data.calculation_method}</span>
          </div>

          <!-- Summary KPI cards: one per recipient -->
          <div class="d-flex gap-2 mb-4" style="flex-wrap:nowrap;">
            ${recipientConfig.map(r => `
              <div style="flex:1 1 0;min-width:0;">
                <div style="background:${r.bg};border-radius:12px;padding:12px 10px;color:#fff;text-align:center;height:100%;">
                  <div style="font-size:1.1rem;font-weight:900;">${fmtAmt(sr[r.key] || 0)}</div>
                  <div style="font-size:0.75rem;font-weight:600;opacity:0.9;margin-top:3px;">${r.label} Pending</div>
                </div>
              </div>`).join('')}
          </div>

          <!-- Tabs -->
          <ul class="nav nav-tabs mb-0" id="commTabList" role="tablist" style="border-bottom:2px solid #dee2e6;">
            ${recipientConfig.map((r, i) => {
              const count = data.data.filter(d => d.payout_to === r.key).length;
              return `<li class="nav-item" role="presentation">
                <button class="nav-link${i===0?' active':''}" id="tab-${r.key}" data-bs-toggle="tab" data-bs-target="#pane-${r.key}" type="button" role="tab" style="font-weight:700;font-size:0.85rem;">
                  ${r.label} <span class="badge ms-1" style="background:${r.color};color:#fff;">${count}</span>
                </button>
              </li>`;
            }).join('')}
          </ul>
          <div class="tab-content" style="border:1px solid #dee2e6;border-top:none;border-radius:0 0 10px 10px;padding:15px;background:#fff;">
            ${recipientConfig.map((r, i) => `
              <div class="tab-pane fade${i===0?' show active':''}" id="pane-${r.key}" role="tabpanel">
                <div class="d-flex align-items-center gap-2 mb-3">
                  <span style="width:12px;height:12px;border-radius:50%;background:${r.color};display:inline-block;"></span>
                  <strong style="color:${r.color};">${r.label} Commissions Pending</strong>
                  <span style="margin-left:auto;font-weight:800;color:${r.color};font-size:1.1rem;">${fmtAmt(sr[r.key] || 0)}</span>
                </div>
                ${buildTable(data.data.filter(d => d.payout_to === r.key), r.bg)}
              </div>`).join('')}
          </div>
        `;
      } else {
        console.log('❌ Showing no commissions - API Response:', {
          success: data.success,
          total_count: data.total_count,
          data_length: data.data?.length,
          error: data.error || 'None'
        });

        // Show different message based on the actual issue
        if (!data.success) {
          content.innerHTML = `
            <div class="alert alert-warning" style="background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%); border: none; color: white;">
              <h6 style="color: white; font-weight: bold;"><i class="bi bi-exclamation-triangle me-2"></i>API Error</h6>
              <p class="mb-0" style="color: white; font-weight: 600;">Error: ${data.error || 'Unknown API error'}</p>
            </div>
          `;
        } else {
          content.innerHTML = `
            <div class="text-center py-5">
              <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
              <h3 class="mt-3" style="color: #11998e; font-weight: bold;"><strong>No Pending Commissions!</strong></h3>
              <p style="color: #666; font-weight: 600;">All commission payouts have been processed successfully.</p>
              <div class="mt-3 text-muted">
                <small>Debug: Success=${data.success}, Count=${data.total_count}</small>
              </div>
            </div>
          `;
        }
      }
    })
    .catch(error => {
      console.error('❌ Commission API Error:', error);
      loading.style.display = 'none';
      content.style.display = 'block';
      content.innerHTML = `
        <div class="alert alert-danger" style="background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%); border: none;">
          <h6 style="color: white; font-weight: bold;"><i class="bi bi-exclamation-triangle me-2"></i>Error Loading Data</h6>
          <p class="mb-0" style="color: white; font-weight: 600;">Unable to load commission data: ${error.message}</p>
          <div class="mt-2">
            <small style="color: rgba(255,255,255,0.8);">Please check browser console for details.</small>
          </div>
        </div>
      `;
    });
}

// Load Total Revenue Data
function loadTotalRevenueData(content, loading) {
  // Simulating revenue data - in production, this would come from an API endpoint
  const revenueData = {
    success: true,
    total_revenue: <%= @total_premium_collected || 0 %>,
    revenue_by_type: {
      health: <%= (HealthInsurance.sum(:total_premium) rescue 0) || 0 %>,
      life: <%= (LifeInsurance.sum(:total_premium) rescue 0) || 0 %>,
      motor: <%= (MotorInsurance.sum(:total_premium) rescue 0) || 0 %>,
      other: <%= (OtherInsurance.column_names.include?('total_premium') ? OtherInsurance.sum(:total_premium) : 0) rescue 0 %>
    },
    monthly_revenue: [],
    growth_rate: 0
  };

  // Calculate monthly revenue for the last 6 months
  <% 6.times do |i| %>
    <% month_start = i.months.ago.beginning_of_month %>
    <% month_end = i.months.ago.end_of_month %>
    revenueData.monthly_revenue.push({
      month: '<%= month_start.strftime("%B %Y") %>',
      revenue: <%=
        HealthInsurance.where(created_at: month_start..month_end).sum(:total_premium) +
        LifeInsurance.where(created_at: month_start..month_end).sum(:total_premium) +
        MotorInsurance.where(created_at: month_start..month_end).sum(:total_premium) +
        OtherInsurance.where(created_at: month_start..month_end).sum(:total_premium)
      %>
    });
  <% end %>
  revenueData.monthly_revenue.reverse();

  // Calculate growth rate
  if (revenueData.monthly_revenue.length >= 2) {
    const lastMonth = revenueData.monthly_revenue[revenueData.monthly_revenue.length - 1].revenue;
    const previousMonth = revenueData.monthly_revenue[revenueData.monthly_revenue.length - 2].revenue;
    if (previousMonth > 0) {
      revenueData.growth_rate = ((lastMonth - previousMonth) / previousMonth * 100).toFixed(2);
    }
  }

  loading.style.display = 'none';
  content.style.display = 'block';

  if (revenueData.success) {
    content.innerHTML = `
      <div class="alert" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; border-radius: 16px; padding: 1.5rem;">
        <h6 style="color: #ffffff; font-weight: bold; font-size: 1.1rem;"><i class="bi bi-graph-up-arrow me-2"></i>Revenue Analysis</h6>
        <p class="mb-0" style="color: #ffffff; font-weight: 600;">Total revenue collected from all insurance policies</p>
      </div>

      <div class="row mb-4">
        <div class="col-md-4">
          <div class="card text-white" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); border-radius: 20px; box-shadow: 0 12px 40px rgba(17, 153, 142, 0.4); border: none;">
            <div class="card-body text-center" style="padding: 2rem 1rem;">
              <div style="background: rgba(255, 255, 255, 0.2); border-radius: 15px; padding: 1rem; margin-bottom: 1rem;">
                <i class="bi bi-cash-stack" style="font-size: 2rem; color: white;"></i>
              </div>
              <h2 style="font-weight: 900; font-size: 2.5rem; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); margin: 0; line-height: 1;">${fmtINR(revenueData.total_revenue)}</h2>
              <p style="font-weight: 700; font-size: 1rem; text-transform: uppercase; letter-spacing: 1px; margin-top: 0.5rem; color: rgba(255, 255, 255, 0.9);">Total Revenue</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 20px; box-shadow: 0 12px 40px rgba(102, 126, 234, 0.4); border: none;">
            <div class="card-body text-center" style="padding: 2rem 1rem;">
              <div style="background: rgba(255, 255, 255, 0.2); border-radius: 15px; padding: 1rem; margin-bottom: 1rem;">
                <i class="bi bi-graph-up" style="font-size: 2rem; color: white;"></i>
              </div>
              <h2 style="font-weight: 900; font-size: 2.5rem; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); margin: 0; line-height: 1;">${revenueData.growth_rate}%</h2>
              <p style="font-weight: 700; font-size: 1rem; text-transform: uppercase; letter-spacing: 1px; margin-top: 0.5rem; color: rgba(255, 255, 255, 0.9);">Monthly Growth</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card text-white" style="background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%); border-radius: 20px; box-shadow: 0 12px 40px rgba(243, 156, 18, 0.4); border: none;">
            <div class="card-body text-center" style="padding: 2rem 1rem;">
              <div style="background: rgba(255, 255, 255, 0.2); border-radius: 15px; padding: 1rem; margin-bottom: 1rem;">
                <i class="bi bi-calendar-month" style="font-size: 2rem; color: white;"></i>
              </div>
              <h2 style="font-weight: 900; font-size: 2rem; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); margin: 0; line-height: 1;">${revenueData.monthly_revenue.length > 0 ? fmtINR(revenueData.monthly_revenue[revenueData.monthly_revenue.length - 1].revenue) : 'Rs. 0.00'}</h2>
              <p style="font-weight: 700; font-size: 1rem; text-transform: uppercase; letter-spacing: 1px; margin-top: 0.5rem; color: rgba(255, 255, 255, 0.9);">This Month</p>
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6">
          <h5 style="font-weight: bold; color: #333; margin-bottom: 1rem;">Revenue by Insurance Type</h5>
          <div class="table-responsive">
            <table class="table table-hover" style="background: white; border-radius: 15px; overflow: hidden;">
              <thead style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <tr>
                  <th style="color: white; font-weight: 800; border: none; padding: 15px;">Type</th>
                  <th style="color: white; font-weight: 800; border: none; padding: 15px; text-align: right;">Revenue</th>
                  <th style="color: white; font-weight: 800; border: none; padding: 15px; text-align: right;">Percentage</th>
                </tr>
              </thead>
              <tbody>
                ${Object.entries(revenueData.revenue_by_type).map(([type, amount], index) => {
                  const percentage = revenueData.total_revenue > 0 ? (amount / revenueData.total_revenue * 100).toFixed(1) : 0;
                  const typeColors = {
                    health: '#11998e',
                    life: '#667eea',
                    motor: '#f39c12',
                    other: '#e74c3c'
                  };
                  return `
                    <tr style="background: ${index % 2 === 0 ? 'rgba(102, 126, 234, 0.05)' : 'white'};">
                      <td style="padding: 12px 15px;">
                        <span class="badge" style="background: ${typeColors[type]}; color: white; font-weight: 700; padding: 6px 12px; font-size: 0.9rem;">
                          ${type.charAt(0).toUpperCase() + type.slice(1)} Insurance
                        </span>
                      </td>
                      <td style="padding: 12px 15px; text-align: right; font-weight: bold; font-size: 1.1rem; color: #2c3e50;">
                        ${fmtINR(amount)}
                      </td>
                      <td style="padding: 12px 15px; text-align: right;">
                        <div class="progress" style="height: 25px; background: rgba(0,0,0,0.1); border-radius: 10px;">
                          <div class="progress-bar" role="progressbar"
                               style="width: ${percentage}%; background: linear-gradient(90deg, ${typeColors[type]}, ${typeColors[type]}dd); font-weight: bold;"
                               aria-valuenow="${percentage}" aria-valuemin="0" aria-valuemax="100">
                            ${percentage}%
                          </div>
                        </div>
                      </td>
                    </tr>
                  `;
                }).join('')}
              </tbody>
            </table>
          </div>
        </div>

        <div class="col-md-6">
          <h5 style="font-weight: bold; color: #333; margin-bottom: 1rem;">Monthly Revenue Trend</h5>
          <div class="table-responsive">
            <table class="table table-hover" style="background: white; border-radius: 15px; overflow: hidden;">
              <thead style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
                <tr>
                  <th style="color: white; font-weight: 800; border: none; padding: 15px;">Month</th>
                  <th style="color: white; font-weight: 800; border: none; padding: 15px; text-align: right;">Revenue</th>
                  <th style="color: white; font-weight: 800; border: none; padding: 15px; text-align: center;">Trend</th>
                </tr>
              </thead>
              <tbody>
                ${revenueData.monthly_revenue.map((month, index) => {
                  const prevRevenue = index > 0 ? revenueData.monthly_revenue[index - 1].revenue : month.revenue;
                  const change = ((month.revenue - prevRevenue) / (prevRevenue || 1) * 100).toFixed(1);
                  const trendIcon = change > 0 ? '↑' : change < 0 ? '↓' : '→';
                  const trendColor = change > 0 ? '#11998e' : change < 0 ? '#e74c3c' : '#6c757d';
                  return `
                    <tr style="background: ${index % 2 === 0 ? 'rgba(17, 153, 142, 0.05)' : 'white'};">
                      <td style="padding: 12px 15px; font-weight: 600;">${month.month}</td>
                      <td style="padding: 12px 15px; text-align: right; font-weight: bold; font-size: 1.1rem; color: #2c3e50;">
                        ${fmtINR(month.revenue)}
                      </td>
                      <td style="padding: 12px 15px; text-align: center;">
                        ${index > 0 ? `
                          <span style="color: ${trendColor}; font-weight: bold; font-size: 1.1rem;">
                            ${trendIcon} ${Math.abs(change)}%
                          </span>
                        ` : '<span class="text-muted">-</span>'}
                      </td>
                    </tr>
                  `;
                }).join('')}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    `;
  } else {
    content.innerHTML = '<div class="alert alert-danger">Error loading revenue data. Please try again.</div>';
  }
}

