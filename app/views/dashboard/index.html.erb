<div class="dashboard-container">
  <!-- Filters and Search - Moved to top with no padding -->
  <div class="card shadow-sm mb-4" style="margin-top: 0 !important;">
    <div class="card-body">
      <%= form_with url: dashboard_path, method: :get, local: true, class: "d-flex flex-wrap gap-3 align-items-end" do |form| %>
        <!-- Unified Period Filter -->
        <div>
          <%
            current_year = Date.current.year
            current_fy_end = Date.current.month >= 4 ? current_year + 1 : current_year
            if @filter_financial_year.present?
              selected_period = "fy_#{@filter_financial_year}"
            else
              selected_period = "cal_#{@filter_year || current_year}"
            end
          %>
          <select id="period_select" class="form-select" style="min-width:200px">
            <optgroup label="Calendar Year">
              <% (current_year).downto(current_year - 4) do |y| %>
                <option value="cal_<%= y %>" <%= 'selected' if selected_period == "cal_#{y}" %>>
                  <%= y %><%= " (Current)" if y == current_year %>
                </option>
              <% end %>
            </optgroup>
            <optgroup label="Financial Year">
              <% (current_fy_end).downto(current_fy_end - 4) do |fy| %>
                <option value="fy_<%= fy %>" <%= 'selected' if selected_period == "fy_#{fy}" %>>
                  <%= fy - 1 %>-<%= fy.to_s[-2..] %> Financial Year<%= " (Current)" if fy == current_fy_end %>
                </option>
              <% end %>
            </optgroup>
          </select>
          <%= form.hidden_field :year, id: "year_hidden" %>
          <%= form.hidden_field :financial_year, id: "fy_hidden" %>
        </div>

        <!-- Month Filter -->
        <div>
          <%= form.select :month,
                         options_for_select([
                           ['All Year', ''],
                           ['January', '1'],
                           ['February', '2'],
                           ['March', '3'],
                           ['April', '4'],
                           ['May', '5'],
                           ['June', '6'],
                           ['July', '7'],
                           ['August', '8'],
                           ['September', '9'],
                           ['October', '10'],
                           ['November', '11'],
                           ['December', '12']
                         ], @filter_month.to_s),
                         {},
                         { class: "form-select", id: "month_filter" } %>
        </div>

        <!-- Custom Date Range -->
        <div class="d-flex gap-2">
          <%= form.date_field :start_date,
                             value: @filter_start_date&.strftime('%Y-%m-%d'),
                             class: "form-control",
                             id: "start_date_field",
                             placeholder: "Start Date",
                             min: "1900-01-01",
                             max: "2099-12-31" %>
          <%= form.date_field :end_date,
                             value: @filter_end_date&.strftime('%Y-%m-%d'),
                             class: "form-control",
                             id: "end_date_field",
                             placeholder: "End Date",
                             min: "1900-01-01",
                             max: "2099-12-31" %>
        </div>

        <!-- Actions -->
        <div class="d-flex gap-2">
          <%= form.submit "Apply Filter", class: "btn btn-primary" %>
          <button type="button" id="clear_filters_btn" class="btn btn-outline-secondary">Clear</button>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Core KPI Cards -->
  <div class="row mb-4">
    <!-- Total Customers -->
    <div class="col-xl-3 col-md-6 mb-3">
      <div class="card h-100 border-0 shadow-sm card-hover" style="cursor:pointer;" data-card-metric="customers" data-card-label="Total Customers" onclick="openDashboardCardModal(this)">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h6 class="text-muted mb-2">Total Customers</h6>
              <h3 class="mb-0 text-primary"><%= number_with_delimiter(@total_customers) %></h3>
            </div>
            <div class="bg-primary bg-opacity-10 rounded p-3">
              <i class="bi bi-people text-primary fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Total Policies -->
    <div class="col-xl-3 col-md-6 mb-3">
      <div class="card h-100 border-0 shadow-sm card-hover" style="cursor:pointer;" data-card-metric="policies" data-card-label="Total Policies" onclick="openDashboardCardModal(this)">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h6 class="text-muted mb-2">Total Policies</h6>
              <h3 class="mb-0 text-success"><%= number_with_delimiter(@total_policies) %></h3>
            </div>
            <div class="bg-success bg-opacity-10 rounded p-3">
              <i class="bi bi-file-earmark-text text-success fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Total Premium -->
    <div class="col-xl-3 col-md-6 mb-3">
      <div class="card h-100 border-0 shadow-sm card-hover" style="cursor:pointer;" data-card-metric="premium" data-card-label="Total Premium" onclick="openDashboardCardModal(this)">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h6 class="text-muted mb-2">Total Premium</h6>
              <h3 class="mb-0 text-warning"><%= indian_currency(@total_premium_collected || 0) %></h3>
            </div>
            <div class="bg-warning bg-opacity-10 rounded p-3">
              <i class="bi bi-currency-rupee text-warning fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Active Leads -->
    <div class="col-xl-3 col-md-6 mb-3">
      <div class="card h-100 border-0 shadow-sm card-hover" style="cursor:pointer;" data-card-metric="leads" data-card-label="Active Leads" onclick="openDashboardCardModal(this)">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h6 class="text-muted mb-2">Active Leads</h6>
              <h3 class="mb-0 text-info"><%= number_with_delimiter(@pending_leads) %></h3>
            </div>
            <div class="bg-info bg-opacity-10 rounded p-3">
              <i class="bi bi-funnel text-info fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions Grid -->
  <div class="row mb-4">
    <!-- Renewal Alerts -->
    <div class="col-xl-3 col-lg-6 mb-3">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <h5 class="card-title d-flex align-items-center mb-3">
            <i class="bi bi-arrow-repeat text-primary me-2"></i>
            Renewal Alerts
          </h5>

          <div class="d-flex align-items-center justify-content-between py-2 px-3 rounded-3 mb-2"
               style="background:#fffbeb; cursor:pointer;" onclick="showRenewalModal('expiring')">
            <div>
