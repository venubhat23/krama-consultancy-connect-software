// Render functions
function renderPolicyTable(tableBody, policies, type) {
  if (policies.length === 0) {
    tableBody.innerHTML = '<tr><td colspan="7" class="text-center text-muted">No policies found</td></tr>';
    return;
  }

  let html = '';
  policies.forEach(policy => {
    const daysLeft = policy.days_left || 0;
    let statusBadge = '';

    if (type === 'expired') {
      statusBadge = '<span class="badge status-badge-expired">Expired</span>';
    } else if (type === 'processed') {
      statusBadge = '<span class="badge status-badge-active">Renewed</span>';
    } else if (daysLeft <= 7) {
      statusBadge = '<span class="badge status-badge-expired">Urgent</span>';
    } else if (daysLeft <= 30) {
      statusBadge = '<span class="badge status-badge-warning">Expiring Soon</span>';
    } else {
      statusBadge = '<span class="badge status-badge-active">Active</span>';
    }

    html += `
      <tr>
        <td><span class="text-monospace">${policy.policy_number || 'N/A'}</span></td>
        <td>
          <div>
            <strong>${policy.customer_name || 'Unknown'}</strong>
            ${policy.customer_email ? '<br><small class="text-muted">' + policy.customer_email + '</small>' : ''}
          </div>
        </td>
        <td><span class="badge bg-info text-white">${policy.insurance_type || 'General'}</span></td>
        <td class="fw-bold">${fmtINR(policy.premium)}</td>
        <td>${policy.end_date || 'N/A'}</td>
        <td>${statusBadge}</td>
        <td>
          ${type !== 'processed' ?
            `<a href="/admin/${policy.type_slug}/${policy.id}/renew" class="btn btn-sm btn-success">
              <i class="bi bi-arrow-repeat me-1"></i>Renew
            </a>` :
            '<span class="text-success"><i class="bi bi-check-circle"></i> Completed</span>'
          }
        </td>
      </tr>
    `;
  });

  tableBody.innerHTML = html;
}

function renderHealthPolicyTable(tableBody, policies, type) {
  if (policies.length === 0) {
    tableBody.innerHTML = '<tr><td colspan="8" class="text-center text-muted">No policies found</td></tr>';
    return;
  }

  let html = '';
  policies.forEach(policy => {
    const daysLeft = policy.days_left || 0;
    let daysLeftBadge = '';

    if (daysLeft < 0) {
      daysLeftBadge = `<span class="badge bg-danger">Expired ${Math.abs(daysLeft)} days ago</span>`;
    } else if (daysLeft === 0) {
      daysLeftBadge = '<span class="badge bg-danger">Expires Today</span>';
    } else if (daysLeft <= 7) {
      daysLeftBadge = `<span class="badge bg-warning text-dark">${daysLeft} days</span>`;
    } else {
      daysLeftBadge = `<span class="badge bg-success">${daysLeft} days</span>`;
    }

    const typeSlug = policy.type_slug || 'insurance/health';
    const typeBadgeColor = { Health: 'bg-primary', Life: 'bg-info', Motor: 'bg-warning text-dark', Other: 'bg-secondary' }[policy.insurance_type] || 'bg-primary';
    html += `
      <tr>
        <td><span class="text-monospace">${policy.policy_number || 'N/A'}</span></td>
        <td>
          <div>
            <strong>${policy.customer_name || 'Unknown'}</strong>
            ${policy.customer_email ? '<br><small class="text-muted">' + policy.customer_email + '</small>' : ''}
          </div>
        </td>
        <td><span class="badge ${typeBadgeColor}">${policy.insurance_type || 'Health'}</span></td>
        <td class="fw-bold">${fmtINR(policy.sum_insured)}</td>
        <td>${fmtINR(policy.premium)}</td>
        <td>${policy.end_date || 'N/A'}</td>
        <td>${daysLeftBadge}</td>
        <td>
          <a href="/admin/${typeSlug}/${policy.id}" class="btn btn-sm btn-outline-primary me-1">
