              <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Name</th>
                    <th>Birthday</th>
                    <th>Days Left</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <% @upcoming_birthdays.first(10).each do |customer| %>
                    <% bday = customer.birth_date
                       today = Date.current
                       this_year = Date.new(today.year, bday.month, bday.day) rescue nil
                       next_bday = (this_year && this_year >= today) ? this_year : Date.new(today.year + 1, bday.month, bday.day)
                       days_left = (next_bday - today).to_i %>
                    <tr>
                      <td>
                        <div class="fw-semibold"><%= customer.first_name %> <%= customer.last_name %></div>
                        <small class="text-muted"><%= customer.mobile %></small>
                      </td>
                      <td><span class="badge bg-danger bg-opacity-10 text-danger"><%= bday.strftime("%d %b") %></span></td>
                      <td>
                        <% if days_left == 0 %>
                          <span class="badge bg-success">Today!</span>
                        <% elsif days_left == 1 %>
                          <span class="badge bg-warning text-dark">Tomorrow</span>
                        <% else %>
                          <span class="text-muted"><%= days_left %> days</span>
                        <% end %>
