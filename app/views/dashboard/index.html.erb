<script>
// Unified period dropdown handler
document.addEventListener('DOMContentLoaded', function() {
  const periodSelect = document.getElementById('period_select');
  const yearHidden   = document.getElementById('year_hidden');
  const fyHidden     = document.getElementById('fy_hidden');
  const monthSelect  = document.getElementById('month_filter');
  const startField   = document.getElementById('start_date_field');
  const endField     = document.getElementById('end_date_field');

  function applyPeriod(val) {
    if (!val) return;
    if (val.startsWith('cal_')) {
      const yr = parseInt(val.replace('cal_', ''));
      if (yearHidden) yearHidden.value = yr;
      if (fyHidden)   fyHidden.value   = '';
      if (startField) startField.value = yr + '-01-01';
      if (endField)   endField.value   = yr + '-12-31';
      if (monthSelect) monthSelect.value = '';
    } else if (val.startsWith('fy_')) {
      const fy = parseInt(val.replace('fy_', ''));
      if (fyHidden)   fyHidden.value   = fy;
      if (yearHidden) yearHidden.value = '';
      if (startField) startField.value = (fy - 1) + '-04-01';
      if (endField)   endField.value   = fy       + '-03-31';
      if (monthSelect) monthSelect.value = '';
    }
  }

  if (periodSelect) {
    periodSelect.addEventListener('change', function() {
      applyPeriod(this.value);
      if (this.closest('form')) this.closest('form').submit();
    });
  }

  // Custom date changes clear the period dropdown highlight but keep selection
  [startField, endField].forEach(function(el) {
    if (el) {
      el.addEventListener('change', function() {
        if (fyHidden)   fyHidden.value   = '';
        if (yearHidden) yearHidden.value = '';
      });
    }
  });
});

