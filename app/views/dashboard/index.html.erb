<%
  # Use renewal data from controller (filter-independent)
  renewal_counts = {
    expiring: @renewal_due_count || 0,
    expired: @recently_expired_count || 0,
    processed: (@renewal_status && @renewal_status['Renewed']) || 0
  }
  # Calculate policy alerts using filter-independent data
  health_alerts = {
    expiring_soon: @policies_expiring_soon || 0,
    expired_this_month: @expired_this_month || 0,
    renewal_opportunities: @renewal_opportunities || 0
  }
