    case 'lead_conversion':
      modalTitle.innerHTML = '<i class="bi bi-graph-up-arrow me-2"></i>Lead Conversion Analysis';
      loadLeadConversionData(content, loading);
      break;
    case 'avg_policy_value':
      modalTitle.innerHTML = '<i class="bi bi-cash-stack me-2"></i>Average Policy Value Breakdown';
      loadAvgPolicyValueData(content, loading);
      break;
    case 'commissions_due':
      modalTitle.innerHTML = '<i class="bi bi-wallet2 me-2"></i>Commissions Due - Detailed Calculation';
      loadCommissionsDueData(content, loading);
      break;
    case 'total_revenue':
      modalTitle.innerHTML = '<i class="bi bi-graph-up-arrow me-2"></i>Total Revenue Breakdown';
      loadTotalRevenueData(content, loading);
      break;
    case 'profit':
      modalTitle.innerHTML = '<i class="bi bi-graph-up-arrow me-2 text-success"></i>Net Profit — Policy Commission Breakdown';
      loadProfitSummaryData(content, loading);
      break;
  }

  // Add event listener to restore body overflow when modal is closed
  modalElement.addEventListener('hidden.bs.modal', function () {
    document.body.style.overflow = 'auto';
    document.body.classList.remove('modal-open');
  });

  modal.show();
}

