// Dashboard Filter Auto-Update Functionality
function updateCurrentPeriod() {
  const yearHidden  = document.getElementById('year_hidden');
  const monthSelect = document.getElementById('month_filter');
  const startDateField = document.getElementById('start_date_field');
  const endDateField = document.getElementById('end_date_field');

  if (!monthSelect) return;

  const year = parseInt(yearHidden?.value) || new Date().getFullYear();
  const month = monthSelect.value;

  let startDate, endDate;

  if (month && month !== '') {
    // Specific month selected
    const monthNum = parseInt(month);
    startDate = new Date(year, monthNum - 1, 1);
    endDate = new Date(year, monthNum, 0); // Last day of the month
    console.log(`Month selected: ${monthNum} (${year})`);
  } else {
    // Full year selected
    startDate = new Date(year, 0, 1); // January 1st
    endDate = new Date(year, 11, 31); // December 31st
    console.log(`Full year selected: ${year}`);
  }

  // AUTO-LOAD: Update Custom Date Range fields immediately
  if (startDateField && endDateField) {
    const formatDate = (date) => {
      const yyyy = date.getFullYear();
      const mm = String(date.getMonth() + 1).padStart(2, '0');
      const dd = String(date.getDate()).padStart(2, '0');
      return `${yyyy}-${mm}-${dd}`;
    };

    // Update the date field values
    startDateField.value = formatDate(startDate);
    endDateField.value = formatDate(endDate);

    // Add visual feedback - highlight fields to show they were auto-updated
    startDateField.style.backgroundColor = '#d4edda';
    endDateField.style.backgroundColor = '#d4edda';
    startDateField.style.border = '2px solid #28a745';
    endDateField.style.border = '2px solid #28a745';
    startDateField.style.transition = 'all 0.3s ease';
    endDateField.style.transition = 'all 0.3s ease';

    // Remove the highlight after 2 seconds
    setTimeout(() => {
      startDateField.style.backgroundColor = '';
      endDateField.style.backgroundColor = '';
      startDateField.style.border = '';
      endDateField.style.border = '';
    }, 2000);

    console.log(`🎯 AUTO-LOADED DATES: ${formatDate(startDate)} to ${formatDate(endDate)}`);
    console.log(`📅 Start Date Field Updated: ${startDateField.value}`);
    console.log(`📅 End Date Field Updated: ${endDateField.value}`);
  } else {
    console.log('❌ Date fields not found - cannot auto-update');
  }
}

