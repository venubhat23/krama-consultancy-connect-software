            </a>` : ''
          }
        </td>
      </tr>
    `;
  });

  tableBody.innerHTML = html;
}

// Indian number format helper — reliable across all browsers/locales
function fmtINR(val) {
  const num = parseFloat(val || 0);
  const isNeg = num < 0;
  const [intPart, decPart] = Math.abs(num).toFixed(2).split('.');
  let result = intPart;
  if (intPart.length > 3) {
    const last3 = intPart.slice(-3);
    const rest  = intPart.slice(0, -3);
    result = rest.replace(/\B(?=(\d{2})+(?!\d))/g, ',') + ',' + last3;
  }
  return (isNeg ? '-' : '') + 'Rs. ' + result + '.' + decPart;
}

// System Status Modal Functions
let _csvModalType = null;
let _csvModalData = null;

// ── CSV helpers ────────────────────────────────────────────────────────────
function _esc(v) {
  if (v === null || v === undefined) return '';
  const s = String(v);
  return (s.includes(',') || s.includes('"') || s.includes('\n'))
    ? '"' + s.replace(/"/g, '""') + '"' : s;
}
function _buildCSV(headers, rows) {
  return [headers.map(_esc).join(','), ...rows.map(r => r.map(_esc).join(','))].join('\n');
}
function _triggerDownload(csv, filename) {
  const blob = new Blob(['﻿' + csv], { type: 'text/csv;charset=utf-8;' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
}

function downloadModalCSV() {
  if (!_csvModalData || !_csvModalType) {
    alert('Data not loaded yet. Please wait for the modal to finish loading.');
    return;
  }
  const d = _csvModalData;
  let csv = '', filename = 'export.csv';

  if (_csvModalType === 'active_affiliates') {
    filename = 'active_affiliates.csv';
    csv = _buildCSV(
      ['ID','Name','Email','Phone','Status','Joined Date','Total Policies','Total Premium (Rs.)','Commission Paid (Rs.)','Commission Pending (Rs.)'],
      (d.affiliates || []).map(a => [a.id, a.name, a.email, a.phone, a.status, a.joined_date, a.total_policies, a.total_premium, a.commission_paid, a.commission_pending])
    );
  }
  else if (_csvModalType === 'avg_policy_value') {
    filename = 'avg_policy_value.csv';
    const typeRows = (d.by_type || []).map(p => [p.type, p.count, p.total_premium, p.average, p.min_premium, p.max_premium]);
    const distRows = (d.distribution || []).map(r => [r.range, r.count, r.percentage + '%', '', '', '']);
    csv = _buildCSV(
      ['Insurance Type','Policy Count','Total Premium (Rs.)','Average Premium (Rs.)','Min Premium (Rs.)','Max Premium (Rs.)'],
      [...typeRows, ['--- Distribution ---','','','','',''], ...distRows]
    );
  }
  else if (_csvModalType === 'commissions_due') {
    filename = 'commissions_due.csv';
    csv = _buildCSV(
      ['Policy Number','Customer','Policy Type','Payout To','Commission Amount (Rs.)','Percentage (%)','Base Premium (Rs.)','Created Date','Due Date'],
      (d.data || []).map(r => [r.policy_number, r.customer_name, r.policy_type, r.payout_to, r.amount, r.percentage, r.base_premium, r.created_at, r.due_date])
    );
  }
  else if (_csvModalType === 'lead_conversion') {
    filename = 'lead_conversion.csv';
    const monthRows = (d.monthly_trend || []).map(m => ['Monthly', m.month, m.total_leads, m.converted_leads, m.conversion_rate + '%', '']);
    const srcRows   = (d.source_conversion || []).map(s => ['Source', s.source, s.total, s.converted, s.rate + '%', '']);
    const stageRows = Object.entries(d.stage_breakdown || {}).map(([stage, cnt]) => ['Stage', stage, cnt, '', '', '']);
    csv = _buildCSV(
      ['Section','Name / Month','Total Leads','Converted','Rate (%)',''],
      [...monthRows, ['---','','','','',''], ...srcRows, ['---','','','','',''], ...stageRows]
    );
  }
  else if (_csvModalType === 'profit') {
    filename = 'net_profit.csv';
    const rows = [];
    (d.policies || []).forEach(pol => {
      rows.push([pol.policy_number, pol.policy_type, pol.customer, pol.company, pol.booking_date, 'Net Premium', '', '', '', pol.net_premium]);
      (pol.rows || []).forEach(r => rows.push([pol.policy_number, pol.policy_type, pol.customer, pol.company, pol.booking_date, r.label, r.pct + '%', r.amount, r.tds_pct != null ? r.tds_pct + '%' : '', r.actual]));
    });
    csv = _buildCSV(
      ['Policy Number','Type','Customer','Company','Booking Date','Commission Item','%','Gross Amount (Rs.)','TDS %','Net Amount (Rs.)'],
      rows
    );
  }

  if (csv) _triggerDownload(csv, filename);
}
