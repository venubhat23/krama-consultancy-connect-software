<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Chapters</h2>
    <p class="text-muted mb-0"><%= @current_forum.name %></p>
  </div>
  <% if current_user.forum_admin? %>
    <%= link_to new_forum_portal_chapter_path, class: "btn btn-primary" do %><i class="bi bi-plus-lg me-1"></i> New Chapter<% end %>
  <% end %>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if @chapters.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light">
            <tr><th class="border-0">Chapter</th><th class="border-0">Members</th><th class="border-0">Status</th><th class="border-0">Actions</th></tr>
          </thead>
          <tbody>
            <% @chapters.each do |chapter| %>
              <tr>
                <td><%= link_to chapter.name, forum_portal_chapter_path(chapter), class: "text-decoration-none fw-medium" %></td>
                <td><%= @member_counts[chapter.id] || 0 %></td>
                <td><span class="badge bg-<%= chapter.active? ? 'success' : 'secondary' %>"><%= chapter.status.humanize %></span></td>
                <td>
                  <div class="d-flex gap-1">
                    <%= link_to edit_forum_portal_chapter_path(chapter), class: "btn btn-sm btn-outline-primary" do %><i class="bi bi-pencil"></i><% end %>
                    <% if current_user.forum_admin? %>
                      <%= button_to forum_portal_chapter_path(chapter), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Delete #{chapter.name}?" } } do %><i class="bi bi-trash"></i><% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-transparent border-0">
        <%= render "shared/pagination", records: @chapters %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-diagram-3 fs-1 text-muted d-block mb-3"></i>
        <h5 class="text-muted">No chapters yet</h5>
      </div>
    <% end %>
  </div>
</div>
