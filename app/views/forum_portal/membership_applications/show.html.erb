<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
  <div>
    <h2 class="mb-1"><%= @application.name %></h2>
    <p class="text-muted mb-0">
      <%= @application.email %><% if @application.phone.present? %> · <%= @application.phone %><% end %>
      <% if @application.chapter %> · <%= @application.chapter.name %><% end %>
    </p>
  </div>
  <span class="badge bg-<%= membership_status_color(@application.status) %> fs-6"><%= @application.status.humanize %></span>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <%= render "stepper", steps: @application.timeline_steps %>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-7">
    <% if @application.rejected? %>
      <div class="alert alert-danger">
        <strong>Rejected.</strong> <%= @application.review_note %>
      </div>
    <% end %>

    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0"><h5 class="mb-0">Details</h5></div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6"><small class="text-muted d-block">Company</small><%= @application.company_name.presence || "—" %></div>
          <div class="col-md-6"><small class="text-muted d-block">Source</small><%= @application.event_led? ? "Event: #{@application.event&.title}" : "Direct invite" %></div>
          <div class="col-md-6"><small class="text-muted d-block">Invited by</small><%= @application.invited_by&.full_name || "—" %></div>
          <div class="col-md-6"><small class="text-muted d-block">Invited on</small><%= @application.created_at.strftime("%b %d, %Y") %></div>
        </div>
      </div>
    </div>

    <% if @application.kyc_submitted_at.present? %>
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-transparent border-0"><h5 class="mb-0">KYC Details</h5></div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6"><small class="text-muted d-block">Designation</small><%= @application.designation.presence || "—" %></div>
            <div class="col-md-6"><small class="text-muted d-block">PAN</small><%= @application.pan_number.presence || "—" %></div>
            <div class="col-md-6"><small class="text-muted d-block">GST</small><%= @application.gst_number.presence || "—" %></div>
            <div class="col-md-12"><small class="text-muted d-block">Business Address</small><%= @application.business_address.presence || "—" %></div>
          </div>
          <% if @application.kyc_documents.attached? %>
            <hr>
            <small class="text-muted d-block mb-2">Documents</small>
            <% @application.kyc_documents.each do |doc| %>
              <%= link_to doc.filename.to_s, rails_blob_path(doc, disposition: "attachment"), class: "btn btn-sm btn-outline-secondary me-2 mb-2" %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="col-lg-5">
    <% unless @application.member? || @application.rejected? %>
      <style>
        /* layout_fix.css forces .main-content .card to a white !important background —
           beat it with matching specificity, same pattern as _dark_mode.scss. */
        .main-content .card.ma-whatsapp-card {
          background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
          color: #fff !important;
        }
      </style>
      <div class="card border-0 shadow-sm mb-4 ma-whatsapp-card">
        <div class="card-body">
          <h6 class="mb-2"><i class="bi bi-whatsapp me-1"></i>Send WhatsApp Update</h6>
          <p class="small mb-3" style="opacity: 0.9;"><%= @whatsapp[:text] %></p>
          <%= link_to @whatsapp[:url], target: "_blank", rel: "noopener", class: "btn btn-light btn-sm w-100" do %>
            <i class="bi bi-whatsapp me-1"></i>Open in WhatsApp
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0"><h5 class="mb-0">Actions</h5></div>
      <div class="card-body d-flex flex-column gap-3">

        <% if @application.invited? && @application.event_led? %>
          <%= button_to "Mark Confirmed (RSVP)", confirm_rsvp_forum_portal_membership_application_path(@application), method: :post, class: "btn btn-outline-primary" %>
        <% end %>

        <% if @application.confirmed? %>
          <%= button_to "Mark Attended", mark_attended_forum_portal_membership_application_path(@application), method: :post, class: "btn btn-outline-primary" %>
        <% end %>

        <% if @application.attended? %>
          <%= form_with url: record_feedback_forum_portal_membership_application_path(@application), method: :post, local: true do |f| %>
            <label class="form-label small">Feedback (logged on their behalf, or wait for their own via the link)</label>
            <select name="feedback_rating" class="form-select form-select-sm mb-2">
              <option value="">Rating</option>
              <% (1..5).each { |n| %><option value="<%= n %>"><%= n %> star<%= "s" if n > 1 %></option><% } %>
            </select>
            <textarea name="feedback_comment" class="form-control form-control-sm mb-2" placeholder="Comments" rows="2"></textarea>
            <%= f.submit "Record Feedback", class: "btn btn-outline-primary btn-sm w-100" %>
          <% end %>
        <% end %>

        <% if @application.feedback_collected? && @application.join_invite_sent_at.blank? %>
          <%= button_to "Mark 'Invited to Join' Sent", send_join_invite_forum_portal_membership_application_path(@application), method: :post, class: "btn btn-outline-primary" %>
        <% end %>

        <% if @application.kyc_submitted? %>
          <%= button_to "Start Review", start_review_forum_portal_membership_application_path(@application), method: :post, class: "btn btn-outline-primary" %>
        <% end %>

        <% if @application.kyc_submitted? || @application.under_review? %>
          <%= form_with url: approve_forum_portal_membership_application_path(@application), method: :post, local: true, class: "border-top pt-3" do |f| %>
            <label class="form-label small fw-semibold text-success">Approve</label>
            <textarea name="payment_instructions" class="form-control form-control-sm mb-2" placeholder="Payment instructions to show the applicant (UPI ID / bank details)" rows="2"></textarea>
            <%= f.submit "Approve Application", class: "btn btn-success btn-sm w-100" %>
          <% end %>
          <%= form_with url: reject_forum_portal_membership_application_path(@application), method: :post, local: true do |f| %>
            <label class="form-label small fw-semibold text-danger">Reject</label>
            <textarea name="review_note" class="form-control form-control-sm mb-2" placeholder="Reason (required)" rows="2" required></textarea>
            <%= f.submit "Reject Application", class: "btn btn-outline-danger btn-sm w-100" %>
          <% end %>
        <% end %>

        <% if @application.approved? %>
          <%= button_to "Mark Paid", mark_paid_forum_portal_membership_application_path(@application), method: :post, class: "btn btn-success" %>
        <% end %>

        <% if @application.paid? %>
          <%= button_to "Convert to Member", convert_to_member_forum_portal_membership_application_path(@application), method: :post, class: "btn btn-success" %>
        <% end %>

        <% if @application.member? %>
          <p class="text-success mb-0"><i class="bi bi-check-circle-fill me-1"></i>Member since <%= @application.member_since_at&.strftime("%b %d, %Y") %></p>
          <% if @application.user %><%= link_to "View Member Profile", forum_portal_member_path(@application.user), class: "btn btn-outline-success btn-sm" %><% end %>
        <% end %>

        <% if @application.invited? || @application.confirmed? || @application.attended? || @application.feedback_collected? || @application.interested? %>
          <p class="text-muted small mb-0 border-top pt-3">Waiting on the applicant — they'll move forward when they use their WhatsApp link, or you can prompt them again above.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
