<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-1">Events</h2>
  <%= link_to new_forum_portal_event_path, class: "btn btn-primary" do %><i class="bi bi-plus-lg me-1"></i> New Event<% end %>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if @events.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light"><tr><th class="border-0">Event</th><th class="border-0">Scope</th><th class="border-0">Date</th><th class="border-0">Registrations</th><th class="border-0">Actions</th></tr></thead>
          <tbody>
            <% @events.each do |event| %>
              <tr>
                <td><%= link_to event.title, forum_portal_event_path(event), class: "text-decoration-none fw-medium" %></td>
                <td><%= event.chapter&.name || "Whole Forum" %></td>
                <td><%= event.starts_at.strftime("%b %d, %Y %I:%M %p") %></td>
                <td><%= event.registration_count %></td>
                <td>
                  <div class="d-flex gap-1">
                    <%= link_to edit_forum_portal_event_path(event), class: "btn btn-sm btn-outline-primary" do %><i class="bi bi-pencil"></i><% end %>
                    <%= button_to forum_portal_event_path(event), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Delete #{event.title}?" } } do %><i class="bi bi-trash"></i><% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-transparent border-0">
        <%= render "shared/pagination", records: @events %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-calendar-event fs-1 text-muted d-block mb-3"></i>
        <h5 class="text-muted">No events yet</h5>
      </div>
    <% end %>
  </div>
</div>
