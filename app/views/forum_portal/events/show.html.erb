<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @event.title %></h2>
    <p class="text-muted mb-0"><%= @event.starts_at.strftime("%b %d, %Y %I:%M %p") %> · <%= @event.venue %> · <%= @event.chapter&.name || "Whole Forum" %></p>
  </div>
  <%= link_to edit_forum_portal_event_path(@event), class: "btn btn-outline-primary" do %><i class="bi bi-pencil me-1"></i>Edit<% end %>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">Invite a Guest</h5>
    <small class="text-muted">For people without a Krama account — they'll show up in the attendee list below.</small>
  </div>
  <div class="card-body">
    <%= form_with scope: :registration, url: invite_guest_forum_portal_event_path(@event), method: :post, local: true, class: "row g-2 align-items-end" do |f| %>
      <div class="col-sm-4">
        <%= f.label :guest_name, "Guest name", class: "form-label small" %>
        <%= f.text_field :guest_name, class: "form-control", required: true %>
      </div>
      <div class="col-sm-3">
        <%= f.label :guest_phone, "Phone (for WhatsApp)", class: "form-label small" %>
        <%= f.text_field :guest_phone, class: "form-control", placeholder: "+91XXXXXXXXXX" %>
      </div>
      <div class="col-sm-3">
        <%= f.label :guest_email, "Guest email", class: "form-label small" %>
        <%= f.email_field :guest_email, class: "form-control" %>
      </div>
      <div class="col-sm-2">
        <%= f.submit "Invite", class: "btn btn-primary w-100" %>
      </div>
    <% end %>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
    <h5 class="mb-0">Who's Attending</h5>
    <div class="d-flex gap-2">
      <span class="badge bg-success"><%= @event.registration_count %> going</span>
      <span class="badge bg-warning text-dark"><%= @event.pending_invite_count %> pending</span>
      <span class="badge bg-secondary"><%= @event.not_going_count %> declined</span>
    </div>
  </div>
  <div class="card-body p-0">
    <% if @registrations.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light"><tr><th class="border-0">Attendee</th><th class="border-0">RSVP</th><th class="border-0">Attended</th><th class="border-0">Actions</th></tr></thead>
          <tbody>
            <% @registrations.each do |reg| %>
              <tr>
                <td>
                  <%= reg.display_name %>
                  <% if reg.guest? %><span class="badge bg-info-subtle text-info ms-1">Guest</span><% end %>
                  <% if reg.guest? && reg.guest_email.present? %><br><small class="text-muted"><%= reg.guest_email %></small><% end %>
                </td>
                <td>
                  <% badge = { "going" => "success", "not_going" => "secondary", "invited" => "warning" }[reg.rsvp_status] %>
                  <% label = { "going" => "Going", "not_going" => "Declined", "invited" => "Pending" }[reg.rsvp_status] %>
                  <span class="badge bg-<%= badge %> <%= 'text-dark' if reg.invited? %>"><%= label %></span>
                </td>
                <td>
                  <span class="badge bg-<%= reg.attended? ? 'success' : 'secondary' %>"><%= reg.attended? ? "Present" : "Not marked" %></span>
                </td>
                <td class="d-flex gap-1 flex-wrap">
                  <% if reg.going? %>
                    <%= button_to toggle_attendance_forum_portal_event_path(@event, registration_id: reg.id), method: :patch, class: "btn btn-sm btn-outline-primary" do %>
                      <%= reg.attended? ? "Unmark" : "Mark Present" %>
                    <% end %>
                  <% end %>
                  <% if reg.guest? && reg.guest_phone.present? %>
                    <% wa = EventWhatsappMessage.for(reg) %>
                    <%= link_to wa[:url], target: "_blank", rel: "noopener", class: "btn btn-sm btn-outline-success" do %>
                      <i class="bi bi-whatsapp me-1"></i><%= reg.invited? ? "Send Invite" : "Send Update" %>
                    <% end %>
                  <% end %>
                  <%= link_to "Start Membership App", new_forum_portal_membership_application_path(name: reg.display_name, email: reg.guest_email, event_id: @event.id), class: "btn btn-sm btn-outline-secondary" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-4 text-muted">No responses yet.</div>
    <% end %>
  </div>
</div>
