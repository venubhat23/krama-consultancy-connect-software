<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-1"><%= @member.full_name %></h2>
  <%= link_to edit_forum_portal_member_path(@member), class: "btn btn-outline-primary" do %><i class="bi bi-pencil me-1"></i>Edit<% end %>
</div>
<div class="card border-0 shadow-sm">
  <div class="card-body">
    <p class="mb-1"><strong>Email:</strong> <%= @member.email %></p>
    <p class="mb-1"><strong>Mobile:</strong> <%= @member.mobile %></p>
    <p class="mb-1"><strong>Chapter:</strong> <%= @member.chapter&.name %></p>
    <p class="mb-0"><strong>Role:</strong> <%= @member.user_type.humanize %></p>
  </div>
</div>
