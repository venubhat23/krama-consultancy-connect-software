<div class="container py-5" style="max-width: 640px;">
  <div class="text-center mb-4">
    <h1 class="h3">Bring your forum to Krama Consultancy</h1>
    <p class="text-muted">Tell us about your organization and we'll set you up.</p>
  </div>

  <% if notice %>
    <div class="alert alert-success"><%= notice %></div>
  <% end %>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <%= form_with model: @forum_request, url: forum_requests_path, local: true do |form| %>
        <% if @forum_request.errors.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0"><% @forum_request.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %></ul>
          </div>
        <% end %>

        <div class="mb-3">
          <label class="form-label">Your Name</label>
          <%= form.text_field :name, class: "form-control", required: true %>
        </div>
        <div class="mb-3">
          <label class="form-label">Company / Forum Name</label>
          <%= form.text_field :company_name, class: "form-control", required: true %>
        </div>
        <div class="mb-3">
          <label class="form-label">Email</label>
          <%= form.email_field :email, class: "form-control", required: true %>
        </div>
        <div class="mb-3">
          <label class="form-label">Phone</label>
          <%= form.text_field :phone, class: "form-control" %>
        </div>
        <div class="mb-4">
          <label class="form-label">Tell us more</label>
          <%= form.text_area :message, rows: 4, class: "form-control" %>
        </div>
        <%= form.submit "Submit Request", class: "btn btn-primary w-100" %>
      <% end %>
    </div>
  </div>
</div>
